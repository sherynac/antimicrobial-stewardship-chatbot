<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP009">
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP009</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Obtain urine culture before treatment to ensure the bacteria are susceptible.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP011">
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP011</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor symptoms; if they do not improve within 2-3 days or if they return, contact a healthcare provider for further evaluation</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP012">
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP012</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor for diarrhea or water or bloody stools after antibiotic use, which could indicate C. difficile infection.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP010">
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP010</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patients should take the full dose as instructed and dissolve the powder in water before drinking.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP008">
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP008</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Only a single oral dose is recommended. Repeating daily doses does not improve effectiveness and increases side effects.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:Headache rdf:about="http://example.org/ontology#SE014">
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Occasionally"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Headache</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild to moderate pain.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1-2 days</onto:hasDuration>
</onto:Headache>

<onto:Diarrhea rdf:about="http://example.org/ontology#SE011">
  <onto:whichIs rdf:resource="http://example.org/ontology#Common__early_during_treatment"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diarrhea</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1-3 days</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Loose or watery stools, usually mild and temporary.</onto:hasSideEffectDescription>
</onto:Diarrhea>

<onto:Rash rdf:about="http://example.org/ontology#SE019">
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rash</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Skin redness, irrittation, or small bumps.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1-3 days</onto:hasDuration>
</onto:Rash>

<onto:TasteChanges rdf:about="http://example.org/ontology#SE026">
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare__overdose-related"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Taste Changes</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Few hours</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">General change or decline in taste perception.</onto:hasSideEffectDescription>
</onto:TasteChanges>

<onto:Nausea rdf:about="http://example.org/ontology#SE012">
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Common__may_occur_shortly_after_taking"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nausea</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1-2 days</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Feeling of queasiness or stomach upset.</onto:hasSideEffectDescription>
</onto:Nausea>

<onto:Dizziness rdf:about="http://example.org/ontology#SE015">
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare__may_occur_during_treatment"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dizziness</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Few hours to 1 day</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Feeling lightheaded or unsteady.</onto:hasSideEffectDescription>
</onto:Dizziness>

<onto:Dyspepsia rdf:about="http://example.org/ontology#SE017">
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dyspepsia</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1-2 days</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Upset stomach, indigestion, or discomfort in the upper abdomen.</onto:hasSideEffectDescription>
</onto:Dyspepsia>

<onto:BackPain rdf:about="http://example.org/ontology#SE020">
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Back Pain</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1-2 days</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild discomfort in lower back.</onto:hasSideEffectDescription>
</onto:BackPain>

<onto:ImpairedHearing rdf:about="http://example.org/ontology#SE024">
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare__overdose-related"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Impaired Hearing</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Temporary hearing problems reported in overdose cases.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Variable</onto:hasDuration>
</onto:ImpairedHearing>

<onto:VestibularLoss rdf:about="http://example.org/ontology#SE023">
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare__overdose-related"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vestibular Loss</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Variable</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Loss of balance or issues with inner ear, may occur in overdose situations.</onto:hasSideEffectDescription>
</onto:VestibularLoss>

<onto:MetallicTaste rdf:about="http://example.org/ontology#SE025">
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare__overdose-related"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Metallic Taste</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Few hours</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Altered or metallic taste in the mouth.</onto:hasSideEffectDescription>
</onto:MetallicTaste>

<onto:Asthenia rdf:about="http://example.org/ontology#SE016">
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Asthenia</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Generally feeling of weakness or lack of energy.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1-2 days</onto:hasDuration>
</onto:Asthenia>

<onto:Vaginitis rdf:about="http://example.org/ontology#SE013">
  <onto:whichIs rdf:resource="http://example.org/ontology#Occasionally"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vaginitis</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Several days</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Irritation or infection of the vagina, may cause itching or discharge.</onto:hasSideEffectDescription>
</onto:Vaginitis>

<onto:Dysmenorrhea rdf:about="http://example.org/ontology#SE021">
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dysmenorrhea</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild mentrual cramps in female patients.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1-2 days</onto:hasDuration>
</onto:Dysmenorrhea>

<onto:SideEffect rdf:about="http://example.org/ontology#SE022">
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pharyngitis</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1-3 days</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sore throat or mild irritation in the throat.</onto:hasSideEffectDescription>
</onto:SideEffect>

<onto:AbdominalPain rdf:about="http://example.org/ontology#SE018">
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Abdominal Pain</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1-2 days</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild stomach cramps or discomfort.</onto:hasSideEffectDescription>
</onto:AbdominalPain>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W012">
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W012</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Breastfeeding</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">It is unknown if Fosfomycin Tromethamine passes into breast milk. Talk to your doctor before using while nursing.</onto:hasWarningText>
</onto:PregnancyAndLactation>

<onto:Contraindication rdf:about="http://example.org/ontology#W009">
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W009</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Do not take Fosfomycin Tromethamine if you have a known allergy to it or any ingredient in the medicine.</onto:hasWarningText>
</onto:Contraindication>

<onto:PatientCondition rdf:about="http://example.org/ontology#W010">
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W010</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Clostridium difficile-associated diarrhea (CDAD)</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Clostridium difficile associated diarrhea (CDAD) has been reported with use of nearly all antibacterial agents, including Fosfomycin Tromethamine, and may range in severity from mild diarrhea to fatal colitis. Treatment with antibacterial agents alters the normal flora of the colon leading to overgrowth of C. difficile.</onto:hasWarningText>
</onto:PatientCondition>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W013">
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W013</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The safety and effectiveness of Fosfomycin Tromethamine in children under 12 years have not been established in adequate and well-controlled studies.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pediatric Use</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:PatientCondition rdf:about="http://example.org/ontology#W015">
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W015</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Do not use more than one single dose of Fosfomycin Tromethamine to treat a single episode of acute cystitis. Repeated daily doses of Fosfomycin Tromethamine did not improve the clinical success or microbiological eradication rates compared to single dose therapy, but did increase the incidence of adverse events.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Single-dose Use</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W011">
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W011</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">There are, however, no adequate and well-controlled studies in pregnant women. Because animal reproduction studies are not always predictive of human response, this drug should be used during pregnancy only if clearly needed.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pregnancy</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W014">
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W014</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Geriatric Use</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Older adults may have reduced kidney, liver, or heart function. Use Fosfomycin Tromethamine carefully and follow dosing instructions.</onto:hasWarningText>
</onto:AgeRestriction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN010">
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S009"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN010</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Can be taken with or without food.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A high-fat meal may slow the absorption of Fosfomycin Tromethamine.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lower peak blood level but same total amount excreted in urine.</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN009">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S008"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN009</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None specifically reported.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Consume alcohol moderately; avoid excessie drinking while ill or in antibiotics.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">No known interaction with whiskey; alcohol may affect general health while taking antibiotics.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN006">
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S005"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN006</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">No effect on drug levels or effectiveness.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">No speicla precautions needed.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cimetidine does not affect Fosfomycin Tromethamine absorption or blood levels.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN007">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S006"/>
