<onto:Reference rdf:about="http://example.org/ontology#R240">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">R240</rdfs:label>
  <onto:hasAuthor rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cleveland Clinic</onto:hasAuthor>
  <onto:retrievedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://my.clevelandclinic.org/health/diseases/10349-gastritis</onto:retrievedFrom>
