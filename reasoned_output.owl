<onto:Interaction rdf:about="http://example.org/ontology#ITN254">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S173"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN254</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Your doctor may monitor infection progress. Report any persistent symptoms and continue therapy exactly as prescribed.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Propantheline, an anticholinergic drug, can alter kidney excretion of Furadantin, slightly changing how much antibiotic reaches the urine.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This may reduce the effectiveness of Furadantin in treating urinary infections, though exact clinical impact is uncertain.</onto:hasClinicalEffects>
</onto:Interaction>

