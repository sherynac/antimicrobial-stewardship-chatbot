  <onto:hasReference rdf:resource="http://example.org/ontology#R001"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN275</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rifampicin may decrease trimethoprim concentrations.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN261">
  <onto:hasReference rdf:resource="http://example.org/ontology#R166"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S180"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN261</rdfs:label>
