<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W080">
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W080</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pregnancy</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Comazole is contraindicated during pregnancy. If pregnancy cannot be excluded, possible risks should be balanced against the expected therapeutic effect. Comazole should not be given during pregnancy especially in late pregnancy because of risk of kernicterus.</onto:hasWarningText>
</onto:PregnancyAndLactation>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP028">
