  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The action of sulfonamides may be antagonized by paminobenzoic acid and its derivatives, particularly potassium aminobenzoate and the procaine group of local anesthetics.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN270">
