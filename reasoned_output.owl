<onto:Interaction rdf:about="http://example.org/ontology#ITN089">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S063"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN089</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor serum potassium. Avoid in high-risk patients.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Due to the potassium sparing effects of sulfamethoxazole/trimethoprim, caution should be used when other agents that increase serum potassium, such as angiotensin converting enzyme inhibitors, angiotensin receptor blockers, potassium sparing diuretics and prednisolone, are co-administered. In the literature, two cases of hyperkalaemia in elderly patients have been reported after concomitant intake of sulfamethoxazole/trimethoprim and an angiotensin converting enzyme inhibitor.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hyperkalemia</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN090">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S064"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN090</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Decreased TCA efficacy</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor therapeutic response. Adjust TCA dose if efficacy decreases.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The efficacy of tricyclic antidepressants can decrease when co-administered with sulfamethoxazole/trimethoprim.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN088">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S062"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN088</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant use of trimethoprim with digoxin has been shown to increase plasma digoxin levels in a proportion of elderly patients. Serum digoxin levels should be monitored.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Digoxin toxicity which includes nausea, arrhythmias</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor serum digoxin. Adjust dose to avoid toxicity.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN081">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S055"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN081</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reduced antibacterial effectiveness of TMP‑SMX</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid PABA supplements. They may reduce TMP‑SMX efficacy.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Para-aminobenzoic acid (PABA) or its derivatives may antagonise the antibacterial effects of sulfamethoxazole.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN082">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S056"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN082</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor INR/PT. Adjust dose to avoid over-anticoagulation.</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Prolonged PT/INR, increased bleeding risk</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Anticoagulant activity may be increased by concurrent treatment with sulfamethoxazole/trimethoprim. It has been reported that sulfamethoxazole/trimethoprim may prolong the prothrombin time in patients who are receiving the anticoagulant warfarin (a CYP2C9 substrate). This interaction should be kept in mind when sulfamethoxazole/trimethoprim is given to patients already on anticoagulant therapy, and the coagulation time should be reassessed.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN084">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S058"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN084</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant use may result in potentiation of hypoglycaemia in occasional patients.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypoglycemia</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor blood glucose for potentiated hypoglycemia.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN093">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S067"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN093</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contraindicated with TMP‑SMX. Avoid co-administration</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent administration is contraindicated. Elevated plasma concentrations of dofetilide have been reported following concurrent administration of trimethoprim and dofetilide. Increased plasma concentrations of dofetilide may cause serious ventricular arrhythmias associated with QT interval prolongation, including torsade de pointes.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Elevated dofetilide levels is linear with QT prolongation, torsade de pointes, serious ventricular arrhythmias</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN091">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S065"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN091</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased TMP-SMX blood levels, risk of adverse effects</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May occur in patients who are also receiving urinary acidifiers, oral anticoagulants, phenylbutazone, oxyphenbutazone and indomethacin.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid combination. Monitor for toxicity.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN094">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S068"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN094</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor drug levels. Watch for increased plasma concentrations.</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased plasma levels, risk of toxicity</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">When trimethoprim is administered simultaneously with drugs that form cations at physiological pH, and are also partly excreted by active renal secretion (e.g. procainamide, amantadine), there is the possibility of competitive inhibition of this process which may lead to an increase in plasma concentration of one or both of the drugs.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN083">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S057"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN083</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased effects and side effects of phenytoin (folate deficiencies) could occur when sulfamethoxazole/trimethoprim is given concurrently. Sulfamethoxazole/trimethoprim may inhibit the hepatic metabolism of phenytoin (a CYP2C9 substrate). Oral sulfamethoxazole/trimethoprim, given at a common clinical dosage, increased the phenytoin half-life by 39% and decreased the phenytoin metabolic clearance rate by 27%. When administering these drugs concurrently, one should be alert for possible excessive phenytoin effect.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Phenytoin toxicity. Nystagmus, ataxia, confusion</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor levels and for toxicity. Adjust dose as needed.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN086">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S060"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN086</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Deterioration in renal function in patients with renal transplants. There have been reports of marked but reversible nephrotoxicity with co-
administration of sulfamethoxazole/trimethoprim and ciclosporin in renal transplant recipients.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid combination if possible. Monitor renal function.</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reversible nephrotoxicity</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN085">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S059"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN085</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor for thrombocytopenia. Avoid if high risk.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An increased incidence of thrombocytopenia is reported when this combination is used in the elderly.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Thrombocytopenia, purpura</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN080">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN080</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sulfonamides such as sulfamethoxazole may displace methotrexate from protein binding sites and can compete with the renal transport of methotrexate, thereby increasing free methotrexate levels. Cases of pancytopenia have been reported in patients taking the combination of sulfamethoxazole/trimethoprim and methotrexate.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid combination. Monitor for increased free methotrexate and marrow suppression.</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pancytopenia, marrow suppression, increased toxicity</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN092">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S066"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN092</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor for altered effects. Adjust therapy based on response.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Trimethoprim is an inhibitor of CYP2C8 as well as an OCT2 transporter. Sulfamethoxazole is an inhibitor of CYP2C9. Caution is recommended when DBL Sulfamethoxazole 400 mg and Trimethoprim 80 mg is co-administered with drugs that are substrates of CYP2C8 and 2C9 or OCT2. Sulfamethoxazole/trimethoprim potentiates the effect of oral hypoglycaemics that are metabolised by CYP2C8 (e.g. pioglitazone, repaglinide, and rosiglitazone) or CYP2C9 (e.g. glipizide and glyburide) or eliminated renally via OCT2 (e.g. metformin). Additional monitoring of blood glucose may be warranted.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased drug levels or potentiation, hypoglycemia, toxicity</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN087">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S061"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN087</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid combination. Monitor CBC for anemia.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Occasional reports suggest that patients receiving pyrimethamine as malarial prophylaxis at doses in excess of 25 mg weekly may develop megaloblastic anaemia should sulfamethoxazole/trimethoprim be prescribed concurrently.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Megaloblastic anemia</onto:hasClinicalEffects>
</onto:Interaction>

<onto:JaundiceCholestatic rdf:about="http://example.org/ontology#SE223">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R305"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Jaundice cholestatic</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cholestatic jaundice results from impaired bile flow, accumulating bile components, such as bilirubin, in the bloodstream. This condition can be classified as intrahepatic, caused by issues within the liver, or extrahepatic, resulting from obstructions outside the liver. Common clinical manifestations include jaundice, pruritus, fatigue, malabsorption of fats and fat-soluble vitamins, and the appearance of skin lesions such as xanthomas.</onto:hasSideEffectDescription>
</onto:JaundiceCholestatic>

<onto:Nausea rdf:about="http://example.org/ontology#SE217">
  <onto:hasReference rdf:resource="http://example.org/ontology#R204"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Common"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nausea</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nausea can make it feel like your stomach is ready to do somersaults, sending whatever’s inside right back up and out.</onto:hasSideEffectDescription>
</onto:Nausea>

<onto:Purpura rdf:about="http://example.org/ontology#SE182">
  <onto:hasReference rdf:resource="http://example.org/ontology#R185"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">purpura</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Purpura causes red, purple or brown blood spots on your skin. It happens when small blood vessels leak blood under your skin’s surface.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:Purpura>

<onto:AnaphylacticReaction rdf:about="http://example.org/ontology#SE185">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R283"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">anaphylactic reaction</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Anaphylaxis is when you have a severe allergic reaction. Most commonly, it happens after you eat certain foods or get stung by an insect. Going into anaphylactic shock can be life-threatening.</onto:hasSideEffectDescription>
</onto:AnaphylacticReaction>

<onto:TransaminasesIncreased rdf:about="http://example.org/ontology#SE225">
  <onto:hasReference rdf:resource="http://example.org/ontology#R307"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Transaminases increased</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Transaminitis is one result you might see on a standard blood test. It means you have high levels of certain liver enzymes in your blood. Enzymes called transaminases release from liver cells when something injures those cells. Alcohol, medications, viruses and metabolic diseases are among the possible causes of liver damage and transaminitis.</onto:hasSideEffectDescription>
</onto:TransaminasesIncreased>

<onto:Vomiting rdf:about="http://example.org/ontology#SE219">
  <onto:hasReference rdf:resource="http://example.org/ontology#R210"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vomiting</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vomiting is when muscles in your belly, chest, neck and head work together to push whatever’s in your stomach out. This forceful expulsion of your stomach’s contents can be a symptom of many conditions</onto:hasSideEffectDescription>
</onto:Vomiting>

<onto:Neutropenia rdf:about="http://example.org/ontology#SE174">
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R139"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Neutropenia</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Neutropenia involves having lower-than-normal levels of neutrophils (a type of white blood cell) in your blood.</onto:hasSideEffectDescription>
</onto:Neutropenia>

<onto:Tinnitus rdf:about="http://example.org/ontology#SE212">
  <onto:hasReference rdf:resource="http://example.org/ontology#R135"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">tinnitus</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tinnitus fills your ears with sounds no one else hears. It’s a common issue affecting more than 50 million people in the United States. Tinnitus can be severe, affecting people’s daily lives. Tinnitus isn’t a disease. It’s a symptom of several medical conditions.</onto:hasSideEffectDescription>
</onto:Tinnitus>

<onto:ErythemaMultiforme rdf:about="http://example.org/ontology#SE232">
  <onto:hasReference rdf:resource="http://example.org/ontology#R119"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">erythema multiforme</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Erythema multiforme is your body’s reaction to an illness, infection or medicine. This condition affects your skin and causes a painful, itchy rash that looks like a bulls-eye or a target.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:ErythemaMultiforme>

<onto:Ataxia rdf:about="http://example.org/ontology#SE209">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R299"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ataxia</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ataxia is when you have problems coordinating how your muscles work, leading to awkward, unwieldy or clumsy movements. It’s a possible symptom with a wide range of conditions or circumstances, or it can happen as a stand-alone condition.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:Ataxia>

<onto:ToxicEpidermalNecrolysis rdf:about="http://example.org/ontology#SE234">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R121"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">toxic epidermal necrolysis</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Toxic epidermal necrolysis (TEN) is a life-threatening skin condition. It causes peeling and blistering skin over much of the body, including the mouth, eyes, and genitals. TEN is the most severe form of Stevens-Johnson syndrome.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:ToxicEpidermalNecrolysis>

<onto:Arthralgia rdf:about="http://example.org/ontology#SE238">
  <onto:hasReference rdf:resource="http://example.org/ontology#R314"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Arthralgia</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Arthritis isn't a single condition but a broad term for many conditions affecting the joints. Arthritis typically is associated with pain that affects the ability to move a joint. It causes swelling and tenderness of one or more joints. The main symptoms are joint pain and stiffness, which can impact daily activities and work.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:Arthralgia>

<onto:Diarrhea rdf:about="http://example.org/ontology#SE218">
  <onto:hasReference rdf:resource="http://example.org/ontology#R207"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Common"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diarrhea</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diarrhea means having a loose, watery stool during a bowel movement. It’s common in both children and adults and usually goes away on its own within a few days.</onto:hasSideEffectDescription>
</onto:Diarrhea>

<onto:Stomatitis rdf:about="http://example.org/ontology#SE221">
  <onto:hasReference rdf:resource="http://example.org/ontology#R241"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">stomatitis</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Stomatitis (oral mucositis) is inflammation in the tissue lining your mouth or lips. The most common types are cold sores and canker sores. Causes include infections, injuries, allergic reactions and cancer treatment side effects.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:Stomatitis>

<onto:HaemolyticAnaemia rdf:about="http://example.org/ontology#SE179">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R280"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">haemolytic anaemia</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hemolytic anemia is a blood disorder that typically happens when your red blood cells break down or die faster than your body can replace them with new blood cells. People may develop hemolytic anemia by inheriting genetic conditions that cause anemia, certain infections and certain medications.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:HaemolyticAnaemia>

<onto:Thrombocytopenia rdf:about="http://example.org/ontology#SE175">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R140"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Thrombocytopenia</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Thrombocytopenia occurs when your bone marrow doesn’t make enough platelets. Platelets are blood cells that form blood clots to help stop bleeding. People with this condition may bleed a lot and the bleeding may be hard to stop. Thrombocytopenia affects people with certain medical conditions like autoimmune disease or who take certain medications.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:Thrombocytopenia>

<onto:DrugReactionWithEosinophiliaAndSystemicSymptoms rdf:about="http://example.org/ontology#SE237">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R313"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_known"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Drug reaction with eosinophilia and systemic symptoms</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Drug reaction with eosinophilia and systemic symptoms (DRESS) is a T cell mediated, drug-specific immune response associated with end-organ damage.</onto:hasSideEffectDescription>
</onto:DrugReactionWithEosinophiliaAndSystemicSymptoms>

<onto:Leukopenia rdf:about="http://example.org/ontology#SE173">
  <onto:hasReference rdf:resource="http://example.org/ontology#R276"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Leukopenia</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Leukopenia (low white blood cell count) happens when you have a lower-than-normal number of white blood cells. Specifically, you have fewer neutrophils than normal. Neutrophils are white blood cells that act as your immune system’s first line of defense. Without enough white blood cells, you’re more vulnerable to developing infections.</onto:hasSideEffectDescription>
</onto:Leukopenia>

<onto:SystemicLupusErythematosus rdf:about="http://example.org/ontology#SE189">
  <onto:hasReference rdf:resource="http://example.org/ontology#R187"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">systemic lupus erythematosus</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Systemic lupus erythematosus (SLE) is a systemic autoimmune disease with multisystem involvement and is associated with significant morbidity and mortality. Genetic, immunological, endocrine, and environmental factors influence the loss of immunological tolerance against self-antigens leading to the formation of pathogenic autoantibodies that cause tissue damage through multiple mechanisms.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:SystemicLupusErythematosus>

<onto:SevereHypersensitivityWithPneumocystisJiroveciiPneumonia rdf:about="http://example.org/ontology#SE191">
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R288"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Severe hypersensitivity reactions associated with Pneumocystis jirovecii pneumonia</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pneumocystis carinii pneumonia (PCP), now referred to as Pneumocystis jirovecii pneumonia, is a fungal infection that most commonly affects the immunocompromised and, in some cases, can be severely life-threatening. Typically, patients at risk are those with underlying disease states that alter host immunity, such as cancer, human immunodeficiency virus, transplant recipients, or those taking immunosuppressive therapies and medications. Patients presenting with PCP may show signs of fever, cough, dyspnea, and, in severe cases, respiratory failure.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:SevereHypersensitivityWithPneumocystisJiroveciiPneumonia>

<onto:MetabolicAcidosis rdf:about="http://example.org/ontology#SE201">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R294"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">metabolic acidosis</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Metabolic acidosis is a condition in which acids build up in your body. Causes include untreated diabetes, the loss of bicarbonate in your body and kidney conditions. Symptoms include an accelerated heartbeat, confusion and fatigue.</onto:hasSideEffectDescription>
</onto:MetabolicAcidosis>

<onto:PsychoticDisorder rdf:about="http://example.org/ontology#SE204">
  <onto:hasReference rdf:resource="http://example.org/ontology#R296"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_known"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Psychotic disorder</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Psychosis is the term for a collection of symptoms that happen when a person has trouble telling the difference between what’s real and what’s not. This disconnection from reality can happen for several reasons, including many different mental and physical conditions.</onto:hasSideEffectDescription>
</onto:PsychoticDisorder>

<onto:Agranulocytosis rdf:about="http://example.org/ontology#SE176">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R277"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Agranulocytosis</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Agranulocytosis refers to having severely low neutrophil levels. Neutrophils are a type of white blood cell. They fight germs that make you sick. Untreated agranulocytosis can lead to life-threatening infections.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:Agranulocytosis>

<onto:Hyponatraemia rdf:about="http://example.org/ontology#SE199">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R290"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">hyponatraemia</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hyponatremia is when the amount of sodium in your blood is too low. Common causes include heart, liver, kidney and brain diseases, hormone issues and medications.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:Hyponatraemia>

<onto:RenalTubularAcidosis rdf:about="http://example.org/ontology#SE242">
  <onto:hasReference rdf:resource="http://example.org/ontology#R316"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">renal tubular
acidosis</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Renal tubular acidosis is when you have too much acid in your blood because of a problem with your kidneys. There are three main types of RTA. Causes may include genetic conditions, autoimmune diseases and certain medications.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:RenalTubularAcidosis>

<onto:Methaemoglobinaemia rdf:about="http://example.org/ontology#SE180">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R281"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">methaemoglobinaemia</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Methemoglobinemia (MetHb) is a rare blood disorder that affects how red blood cells deliver oxygen throughout your body. Not everyone has symptoms, but nearly all people with this condition have skin, nails or lips that are a distinctive shade of blue or purple.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:Methaemoglobinaemia>

<onto:Dizziness rdf:about="http://example.org/ontology#SE210">
  <onto:hasReference rdf:resource="http://example.org/ontology#R300"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dizziness</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dizziness is a common issue. If you have dizziness, you may feel woozy and disoriented. You may feel as if you’re about to lose your balance. Many things may make you dizzy, such as anxiety or a reaction to medication. But dizziness may be a symptom of an underlying medical issue.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:Dizziness>

<onto:TubulointerstitialNephritisAndUveitisSyndrome rdf:about="http://example.org/ontology#SE241">
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R315"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">tubulointerstitial nephritis and uveitis syndrome</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tubulointerstitial nephritis and uveitis (TINU) syndrome is defined as the occurrence of tubulointerstitial nephritis (TIN) and uveitis in the absence of other systemic diseases.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:TubulointerstitialNephritisAndUveitisSyndrome>

<onto:Glossitis rdf:about="http://example.org/ontology#SE220">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R245"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Glossitis</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Glossitis is inflammation that makes your tongue swollen, smooth or red. Allergic reactions, infections and dry mouth may cause it.</onto:hasSideEffectDescription>
</onto:Glossitis>

<onto:RenalImpairment rdf:about="http://example.org/ontology#SE240">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R254"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Renal impairment</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidney failure is a condition in which one or both of your kidneys no longer work on their own. Causes include diabetes, high blood pressure and acute kidney injuries. Symptoms include fatigue, nausea and vomiting, swelling, changes in how often you go to the bathroom and brain fog.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:RenalImpairment>

<onto:Eosinophilia rdf:about="http://example.org/ontology#SE181">
  <onto:hasReference rdf:resource="http://example.org/ontology#R068"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">eosinophilia</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Eosinophilia happens when your body produces an unusually high number of eosinophils. Eosinophils are one of several white blood cells that support your immune system.</onto:hasSideEffectDescription>
</onto:Eosinophilia>

<onto:LungInfiltration rdf:about="http://example.org/ontology#SE216">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R304"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">lung infiltration</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lung infiltrates refer to abnormal substances or fluids within the lung tissue that can arise from various causes, including infections, pulmonary hemorrhage, drug toxicity, leukemic infiltration, and pulmonary edema, particularly in patients with hematologic malignancies.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:LungInfiltration>

<onto:Cough rdf:about="http://example.org/ontology#SE214">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R302"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cough</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A cough is a forceful push of air that your body uses to clear irritants, mucus and germs out of your airways. Common causes include allergies, asthma, infections (like colds), chronic lung conditions and acid reflux.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:Cough>

<onto:AllergicMyocarditis rdf:about="http://example.org/ontology#SE186">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R284"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">allergic myocarditis</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Myocarditis is inflammation of the heart muscle, or myocardium. This inflammation weakens your heart muscle, making it harder for your heart to pump. This can be caused by viral infections or inflammatory conditions.</onto:hasSideEffectDescription>
</onto:AllergicMyocarditis>

<onto:AcuteGeneralisedExanthematousPustulosis rdf:about="http://example.org/ontology#SE235">
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R311"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">acute
generalised exanthematous pustulosis</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Acute generalized exanthematous pustulosis (AGEP) comprises a severe cutaneous adverse reaction marked by the abrupt onset of sterile, nonfollicular pinpoint pustules on an erythematous base. Drug exposure, most frequently systemic antibiotics, is the primary cause, although viral infections and environmental triggers have also been implicated. Genetic predisposition, advanced age, and comorbid immune dysregulation are considered risk factors. AGEP is most often attributed to a type IV hypersensitivity mechanism involving drug-specific T cells, neutrophil activation, and cytokine release, although the pathophysiology remains incompletely characterized.</onto:hasSideEffectDescription>
</onto:AcuteGeneralisedExanthematousPustulosis>

<onto:Rash rdf:about="http://example.org/ontology#SE227">
  <onto:whichIs rdf:resource="http://example.org/ontology#Common"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R116"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rash</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Skin rashes can be red, inflamed, bumpy as well as dry, itchy or painful. The main cause is dermatitis, which is when your skin reacts to allergens or irritants. Bacteria, viruses, allergens and conditions including eczema, hives, and psoriasis can be the source of skin rashes.</onto:hasSideEffectDescription>
</onto:Rash>

<onto:StevensJohnsonSyndrome rdf:about="http://example.org/ontology#SE233">
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R120"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Stevens-Johnson syndrome</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Stevens-Johnson syndrome (SJS) is a rare, serious disorder of the skin and mucous membranes. It's usually a reaction to medication that starts with flu-like symptoms, followed by a painful rash that spreads and blisters. Then the top layer of affected skin dies, sheds and begins to heal after several days.</onto:hasSideEffectDescription>
</onto:StevensJohnsonSyndrome>

<onto:DecreasedAppetite rdf:about="http://example.org/ontology#SE200">
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R293"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">decreased appetite</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A loss of appetite is a symptom that can have many causes. This occurs when you don’t feel hungry. The medical term for a loss of appetite is anorexia. This is different from the eating disorder anorexia nervosa.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:DecreasedAppetite>

<onto:Hyperkalaemia rdf:about="http://example.org/ontology#SE197">
  <onto:hasReference rdf:resource="http://example.org/ontology#R289"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_common"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hyperkalaemia</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hyperkalemia is a condition in which you have high potassium levels in your blood. You may not have any symptoms, or they may be easy to dismiss. Severe symptoms may cause muscle weakness or affect your heart.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:Hyperkalaemia>

<onto:Pancreatitis rdf:about="http://example.org/ontology#SE222">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R242"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">pancreatitis</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pancreatitis is inflammation in your pancreas. It’s usually temporary (acute) but can also be a life-long (chronic) condition. The most common symptom is abdominal pain. The most common causes are alcohol use and gallstones.</onto:hasSideEffectDescription>
</onto:Pancreatitis>

<onto:Dyspnoea rdf:about="http://example.org/ontology#SE215">
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R303"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dyspnoea</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dyspnea, or shortness of breath, is the feeling that you can’t get enough air into your lungs. It might feel like your chest is tight, you’re gasping for air or you’re working harder to breathe. Heart and lung conditions are common causes of dyspnea.</onto:hasSideEffectDescription>
</onto:Dyspnoea>

<onto:Angioedema rdf:about="http://example.org/ontology#SE230">
  <onto:hasReference rdf:resource="http://example.org/ontology#R064"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">angioedema</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Angioedema is swelling in the tissue under your skin. It’s most common in your lips, eyelids, tongue, genitals, hands and feet. Causes include allergies, medication side effects, vibrations, inherited gene changes and some health conditions.</onto:hasSideEffectDescription>
</onto:Angioedema>

<onto:FixedDrugEruption rdf:about="http://example.org/ontology#SE231">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R310"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">fixed drug eruption</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The term fixed drug eruption (FDE) describes the development of one or more annular or oval erythematous patches as a result of systemic exposure to a drug. A vesicle or bulla may or may not occur at the center of  patch and these reactions normally resolve with hyperpigmentation and may recur at the same site with reexposure to the drug. Repeated exposure to the offending drug may also cause new lesions to develop in addition to lighting up the older hyperpigmented lesions. Lesions can occur anywhere on the body (ie, face, tongue, hands, feet, torso, extremities, and genitalia) but genitalia and oral muscosa are often favored.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:FixedDrugEruption>

<onto:Headache rdf:about="http://example.org/ontology#SE205">
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R203"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Headache</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Headaches are a very common condition that most people will experience many times during their lives. The main symptom of a headache is pain in your head or face.</onto:hasSideEffectDescription>
</onto:Headache>

<onto:Thrombocytopenia rdf:about="http://example.org/ontology#SE192">
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R140"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">thrombocytopenia</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Thrombocytopenia occurs when your bone marrow doesn’t make enough platelets. Platelets are blood cells that form blood clots to help stop bleeding. People with this condition may bleed a lot and the bleeding may be hard to stop. Thrombocytopenia affects people with certain medical conditions like autoimmune disease or who take certain medications.</onto:hasSideEffectDescription>
</onto:Thrombocytopenia>

<onto:Vertigo rdf:about="http://example.org/ontology#SE211">
  <onto:hasReference rdf:resource="http://example.org/ontology#R231"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vertigo</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vertigo causes dizziness and makes you feel like you’re spinning when you’re not. It most commonly occurs when there’s an issue with your inner ear. But you can also develop it if you have a condition affecting your brain, like a tumor or stroke.</onto:hasSideEffectDescription>
</onto:Vertigo>

<onto:HypersensitivityVasculitisHenochSchonleinPurpura rdf:about="http://example.org/ontology#SE187">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R285"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">hypersensitivity vasculitis resembling Henoch-Schönlein purpura</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Henoch-Schonlein purpura causes the small blood vessels in the skin, joints, intestines and kidneys to become inflamed and bleed. The most noticeable symptom of this form of vasculitis is a rash that often appears on the legs and feet. Henoch-Schonlein purpura also can cause belly pain and aching joints. Rarely, the condition may cause serious kidney damage.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:HypersensitivityVasculitisHenochSchonleinPurpura>

<onto:OvergrowthFungalOrCDifficile rdf:about="http://example.org/ontology#SE172">
  <onto:whichIs rdf:resource="http://example.org/ontology#Common___1_100_to__1_10_"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R072"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Overgrowth fungal / C. difficile</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Clostridioides difficile is a bacterium that causes an infection of the colon, the longest part of the large intestine. Symptoms can range from diarrhea to life-threatening damage to the colon. The bacterium is often called C. difficile or C. diff.</onto:hasSideEffectDescription>
</onto:OvergrowthFungalOrCDifficile>

<onto:HaemophagocyticLymphohistiocytosis rdf:about="http://example.org/ontology#SE190">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R287"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">haemophagocytic lymphohistiocytosis</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hemophagocytic lymphohistiocytosis is a rare and often life-threatening condition if left untreated. HLH causes your immune system to attack your body instead of a foreign invader like a virus. The condition is either acquired or genetic and there’s no way to prevent it.</onto:hasSideEffectDescription>
</onto:HaemophagocyticLymphohistiocytosis>

<onto:AcuteFebrileNeutrophilicDermatosis rdf:about="http://example.org/ontology#SE236">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R312"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_known"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Acute febrile neutrophilic dermatosis</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Acute febrile neutrophilic dermatosis (AFND), also known as Sweet syndrome or Gomm-Button disease, manifests as erythematous plaques and papules, coupled with constitutional symptoms like fever and malaise.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:AcuteFebrileNeutrophilicDermatosis>

<onto:Seizure rdf:about="http://example.org/ontology#SE207">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R144"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">seizure</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A seizure is abnormal electrical activity in your brain. It causes changes in awareness and muscle control. It also causes symptoms that affect your behavior and senses. Seizures can affect anyone at any age and there are a lot of possible causes, from an underlying medical condition to an injury or illness.</onto:hasSideEffectDescription>
</onto:Seizure>

<onto:AplasticAnaemia rdf:about="http://example.org/ontology#SE178">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R279"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Aplastic anaemia</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Aplastic anemia is a rare but serious blood disorder. It happens when something damages your bone marrow so it can’t make enough new blood cells and platelets. Left untreated, aplastic anemia is a life-threatening condition.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:AplasticAnaemia>

<onto:MegaloblasticAnaemia rdf:about="http://example.org/ontology#SE177">
  <onto:hasReference rdf:resource="http://example.org/ontology#R278"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Megaloblastic anaemia</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Megaloblastic anemia is a form of macrocytic anemia, a blood disorder that happens when your bone marrow produces stem cells that make abnormally large red blood cells. Megaloblastic anemia is a type of vitamin deficiency anemia that happens when you don’t get enough vitamin B12 and/or vitamin B9 (folate).</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:MegaloblasticAnaemia>

<onto:IncreasedHepaticEnzymes rdf:about="http://example.org/ontology#SE193">
  <onto:hasReference rdf:resource="http://example.org/ontology#R247"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased Hepatic Enzymes</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">If your blood test showed high (elevated) levels of liver enzymes, you could have a medical condition. Elevated liver enzymes may also be temporary.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:IncreasedHepaticEnzymes>

<onto:SerumSickness rdf:about="http://example.org/ontology#SE184">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R186"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Serum sickness</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Serum sickness is an allergic reaction to certain proteins in medicines. Symptoms may include hives, swelling, fever, rash and joint pain.</onto:hasSideEffectDescription>
</onto:SerumSickness>

<onto:DermatitisExfoliative rdf:about="http://example.org/ontology#SE229">
  <onto:hasReference rdf:resource="http://example.org/ontology#R309"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dermatitis exfoliative</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Exfoliative dermatitis is a serious skin condition that causes extreme shedding of the top layers of your skin. It may cover most of your body and lead to so much skin damage that your body can’t keep warm. Dehydration is also a risk due to your skin losing its ability to hold onto moisture.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:DermatitisExfoliative>

<onto:NeuropathyPeripheral rdf:about="http://example.org/ontology#SE208">
  <onto:hasReference rdf:resource="http://example.org/ontology#R298"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">neuropathy peripheral</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Peripheral neuropathy refers to any condition that affects the nerves outside your brain or spinal cord. This can happen for several reasons, from trauma to infections to inherited conditions.</onto:hasSideEffectDescription>
</onto:NeuropathyPeripheral>

<onto:HepaticNecrosis rdf:about="http://example.org/ontology#SE224">
  <onto:hasReference rdf:resource="http://example.org/ontology#R306"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">hepatic necrosis</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The clinical course of acute hepatic necrosis resembles an acute, toxic injury to the liver with sudden and precipitous onset, marked elevations in serum aminotransferase levels, and early signs of hepatic (or other organ) dysfunction or failure despite minimal or no jaundice. Rapid recovery after withdrawal of the agent is also typical. Other organ failure, such as lung, kidney or bone marrow, may also be present and may overshadow the hepatic injury. Acute hepatic necrosis is typically caused by a direct hepatotoxin and is usually dose dependent and “expected”, rather than idiosyncratic.</onto:hasSideEffectDescription>
</onto:HepaticNecrosis>

<onto:Hyponatraemia rdf:about="http://example.org/ontology#SE195">
  <onto:hasReference rdf:resource="http://example.org/ontology#R290"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">hyponatraemia</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hyponatremia is when the amount of sodium in your blood is too low. Common causes include heart, liver, kidney and brain diseases, hormone issues and medications.</onto:hasSideEffectDescription>
</onto:Hyponatraemia>

<onto:BloodBilirubinIncreased rdf:about="http://example.org/ontology#SE226">
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R308"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">blood bilirubin increased</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Higher than usual levels of bilirubin may mean different types of liver or bile duct problems. Sometimes, higher bilirubin levels may be caused by an increased rate of destruction of red blood cells.</onto:hasSideEffectDescription>
</onto:BloodBilirubinIncreased>

<onto:Myalgia rdf:about="http://example.org/ontology#SE239">
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R252"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">myalgia</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Myalgia is the medical term for muscle pain, which has many causes. Many of them are easy to treat at home. But myalgia can also be a symptom of disease, especially when it’s widespread and long-lasting.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:Myalgia>

<onto:PeriarteritisNodosa rdf:about="http://example.org/ontology#SE188">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R286"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">periarteritis nodosa</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Polyarteritis nodosa or PAN is a rare condition of inflamed blood vessels that hurt your organs. You can have symptoms in many parts of your body at one time.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:PeriarteritisNodosa>

<onto:Hallucinations rdf:about="http://example.org/ontology#SE203">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R126"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hallucinations</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hallucinations are false perceptions of sensory experiences. Some hallucinations are normal, such as those caused by falling asleep or waking up. But others may be a sign of a more serious condition like schizophrenia or dementia.</onto:hasSideEffectDescription>
</onto:Hallucinations>

<onto:PhotosensitivityReaction rdf:about="http://example.org/ontology#SE228">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R063"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Photosensitivity reaction</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Photosensitivity is when your skin reacts negatively to sunlight or UV rays. It causes an itchy, painful rash. Unlike a sunburn, symptoms can appear within minutes.</onto:hasSideEffectDescription>
</onto:PhotosensitivityReaction>

<onto:Rhabdomyolysis rdf:about="http://example.org/ontology#SE196">
  <onto:hasReference rdf:resource="http://example.org/ontology#R291"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">rhabdomyolysis</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rhabdomyolysis is a rare muscle injury where your muscles break down. This is a life-threatening condition that can happen after an injury or excessive exercise without rest.</onto:hasSideEffectDescription>
</onto:Rhabdomyolysis>

<onto:Uveitis rdf:about="http://example.org/ontology#SE213">
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R301"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Uveitis</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Uveitis is a condition where you have inflammation of the uvea, which includes the iris, ciliary body and choroid. It’s common, and vision loss is one of the possible complications (especially when uveitis is severe or goes untreated).</onto:hasSideEffectDescription>
</onto:Uveitis>

<onto:HaemolysisInG6PDDeficiency rdf:about="http://example.org/ontology#SE183">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R282"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">haemolysis in certain susceptible G-6-PD deficient patients</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hemolysis is the medical term used to describe the destruction of red blood cells. Your body is constantly destroying old or damaged red blood cells and replacing them with new ones.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:HaemolysisInG6PDDeficiency>

<onto:Contraindication rdf:about="http://example.org/ontology#W108">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W108</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">It should not be given to patients with known hypersensitivity to trimethoprim or sulfonamides or with documented megaloblastic anaemia secondary to folate deficiency.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity</onto:hasWarningHeadline>
</onto:Contraindication>

<onto:Contraindication rdf:about="http://example.org/ontology#W110">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W110</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Treatment of streptococcal pharyngitis.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Streptococcal Pharyngitis Treatment</onto:hasWarningHeadline>
</onto:Contraindication>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W109">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W109</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Premature &amp; Newborn Infants</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Premature babies and newborn babies during the first eight weeks of life should
not be given sulfamethoxazole/trimethoprim, as sulfamethoxazole may interfere
with the serum albumin binding of bilirubin to produce kernicterus.</onto:hasWarningText>
</onto:AgeRestriction>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W114">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W114</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gastrointestinal, Neurologic, and Hematologic Effects</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Include anorexia, colic, nausea, vomiting, dizziness, headache, drowsiness, and unconsciousness. Pyrexia, haematuria, and crystalluria may be noted. Blood dyscrasias and jaundice are potential late manifestations of overdosage. Signs of acute overdosage with trimethoprim include nausea, vomiting, dizziness, headache, mental depression, confusion, and bone marrow depression.</onto:hasWarningText>
</onto:AgeRestriction>

<onto:Contraindication rdf:about="http://example.org/ontology#W115">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W115</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fatal Reactions</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fatalities associated with the administration of sulphonamides and trimethoprim, either alone or in combination, although rare, have occurred due to severe reactions, including Stevens-Johnson syndrome, toxic epidermal necrolysis, fulminant hepatic necrosis, agranulocytosis, aplastic anaemia, other blood dyscrasias, acute and delayed lung injury, hypersensitivity of the respiratory tract, circulatory shock and other reactions.</onto:hasWarningText>
</onto:Contraindication>

<onto:PatientCondition rdf:about="http://example.org/ontology#W107">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W107</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Severe Hepatic, Hematologic, and Renal Impairment</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sulfamethoxazole/trimethoprim is contraindicated in patients with a history of drug-induced immune thrombocytopenia with use of trimethoprim and/or sulfonamides and in patients showing marked hepatic damage, blood dyscrasias
or with severe renal insufficiency, where repeated measurements of the plasma concentrations cannot be performed.</onto:hasWarningText>
</onto:PatientCondition>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W112">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W112</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pregnancy</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sulfonamides may cause kernicterus in babies during the first month of life by displacing bilirubin from plasma albumin. Sulfonamides should therefore be avoided as far as possible during the last month of pregnancy. Trimethoprim may interfere with folic acid metabolism and animal experiments have shown that administration of very high doses of trimethoprim during organ development may give rise to birth defects typical of folic acid antagonism. If a trimethoprim-sulfonamide combination is given during pregnancy, folic acid supplementation may be required. Because trimethoprim and sulfamethoxazole may interfere with folic acid metabolism, DBL Sulfamethoxazole 400 mg and Trimethoprim 80 mg should be used during pregnancy only if the potential benefit justifies the potential risk to the fetus.</onto:hasWarningText>
</onto:PregnancyAndLactation>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W113">
  <onto:hasReference rdf:resource="http://example.org/ontology#R035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W113</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Although the quantity of sulfamethoxazole/trimethoprim ingested by a breast-fed infant is small, caution should be exercised when DBL Sulfamethoxazole 400 mg and Trimethoprim 80 mg is administered to a nursing woman, especially when breastfeeding jaundiced, ill, stressed, or premature infants because of the potential risk of bilirubin displacement and kernicterus, and it is recommended that the age of the infant be considered and the possible risks be balanced against the expected therapeutic effect.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Breastfeeding</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:Reference rdf:about="http://example.org/ontology#R209">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">R209</rdfs:label>
  <onto:hasReferenceTitle rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Abdominal Pain</onto:hasReferenceTitle>
  <onto:publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</onto:publishedIn>
  <onto:hasAuthor rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cleveland Clinic</onto:hasAuthor>
  <onto:retrievedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://my.clevelandclinic.org/health/symptoms/4167-abdominal-pain</onto:retrievedFrom>
</onto:Reference>

<onto:Restlessness rdf:about="http://example.org/ontology#SE434">
  <onto:hasReference rdf:resource="http://example.org/ontology#R115"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R091"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Restlessness</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">pacing, constant movements of the legs, inability to sit or stand still, rocking from foot to foot, feeling tense or uncomfortable, feeling anxious</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Restlessness>

<onto:Reference rdf:about="http://example.org/ontology#R115">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">R115</rdfs:label>
  <onto:publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2023</onto:publishedIn>
  <onto:retrievedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://www.healthdirect.gov.au/feeling-restless</onto:retrievedFrom>
  <onto:hasAuthor rdf:datatype="http://www.w3.org/2001/XMLSchema#string">HealthDirect</onto:hasAuthor>
  <onto:hasReferenceTitle rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Feeling restless</onto:hasReferenceTitle>
</onto:Reference>

<onto:PatientCondition rdf:about="http://example.org/ontology#W037">
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W037</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Clostridioides difficile-Associated Diarrhea (CDAD)</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This has been reported with nearly all systemic antibacterial agents, including CONTEPO. Evaluate patients if diarrhea occurs.</onto:hasWarningText>
</onto:PatientCondition>

<onto:Agitation rdf:about="http://example.org/ontology#SE472">
  <onto:hasReference rdf:resource="http://example.org/ontology#R125"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Agitation</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">feeling of irritability, mental distress or severe restlessness.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Agitation>

<onto:Reference rdf:about="http://example.org/ontology#R125">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">R125</rdfs:label>
  <onto:hasAuthor rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cleveland Clinic</onto:hasAuthor>
  <onto:publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2024</onto:publishedIn>
  <onto:retrievedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://my.clevelandclinic.org/health/symptoms/agitation</onto:retrievedFrom>
  <onto:hasReferenceTitle rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Agitation</onto:hasReferenceTitle>
</onto:Reference>

<onto:Interaction rdf:about="http://example.org/ontology#ITN055">
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S032"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN055</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid combination or closely monitor CBC for megaloblastic anemia.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Occasionally reports suggest that patients receiving pyrimethamine as malarial prophylaxis in doses exceeding 25 mg weekly may develop megaloblastic anaemia if Co- trimoxazole be prescribed concurrently.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Reference rdf:about="http://example.org/ontology#R031">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">R031</rdfs:label>
  <onto:publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</onto:publishedIn>
  <onto:hasAuthor rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monthly Index of Medical Specialties</onto:hasAuthor>
  <onto:hasReferenceTitle rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Comazole</onto:hasReferenceTitle>
  <onto:retrievedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://www.mims.com/malaysia/drug/info/comazole</onto:retrievedFrom>
</onto:Reference>

<onto:Drug rdf:about="http://example.org/ontology#S032">
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pyrimethamine</rdfs:label>
  <onto:hasSubstanceDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antimalarial antifolate agent.</onto:hasSubstanceDescription>
</onto:Drug>

<onto:Interaction rdf:about="http://example.org/ontology#ITN058">
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S035"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN058</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Comazole also may inhibit the hepatic metabolism of phenytoin. A 39% increase in phenytoin half-life and 27% decrease in the metabolic clearance rate of phenytoin have been observed following administration of Comazole of normal clinical dosages. If these two drugs are given concurrently it is important to remain alert for signs of phenytoin toxicity.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor serum phenytoin levels and signs of toxicity. Dose adjustment may be required.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Drug rdf:about="http://example.org/ontology#S035">
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Phenytoin</rdfs:label>
  <onto:hasSubstanceDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antiepileptic with narrow therapeutic index.</onto:hasSubstanceDescription>
</onto:Drug>

<onto:Reference rdf:about="http://example.org/ontology#R250">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">R250</rdfs:label>
