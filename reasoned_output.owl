  <onto:publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2023</onto:publishedIn>
</onto:Reference>

<onto:PseudomembranousColitis rdf:about="http://example.org/ontology#SE488">
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R142"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pseudomembranous colitis</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An inflammatory process that occurs when your colon lining is being injured. Plaques called “pseudomembranes” develop at the site of the injury.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:PseudomembranousColitis>

<onto:Drug rdf:about="http://example.org/ontology#S030">
  <onto:hasReference rdf:resource="http://example.org/ontology#R014"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ureidopenicillins azlocillin</rdfs:label>
  <onto:hasSubstanceDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Also known as Mezlocillin, may reduce total body clearance of cefotaxime in patients with normal and reduced renal function.</onto:hasSubstanceDescription>
</onto:Drug>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP161">
  <onto:hasReference rdf:resource="http://example.org/ontology#R159"/>
