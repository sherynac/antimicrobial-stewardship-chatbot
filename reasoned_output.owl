</onto:Reference>

<onto:Leukopenia rdf:about="http://example.org/ontology#SE513">
  <onto:hasReference rdf:resource="http://example.org/ontology#R133"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Leukopenia</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">lower-than-normal number of white blood cells</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Leukopenia>

<onto:CDifficileAssociatedDiarrhea rdf:about="http://example.org/ontology#SE411">
  <onto:whichIs rdf:resource="http://example.org/ontology#two_months_after_the_administration_of_antibacterial_agents_"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Clostridium difficile-Associated diarrhea</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diarrhea to fatal colitis</onto:hasSideEffectDescription>
</onto:CDifficileAssociatedDiarrhea>

<onto:Pattern rdf:about="http://example.org/ontology#two_months_after_the_administration_of_antibacterial_agents_">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">two months after the administration of antibacterial agents.</rdfs:label>
</onto:Pattern>

<onto:Reference rdf:about="http://example.org/ontology#R216">
