<onto:AbdominalPain rdf:about="http://example.org/ontology#SE431">
  <onto:hasReference rdf:resource="http://example.org/ontology#R058"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R091"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Abdominal Pain</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pain felt anywhere between the chest and groin.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:AbdominalPain>

<onto:Interaction rdf:about="http://example.org/ontology#ITN258">
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S177"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN258</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid combining these antibiotics unless specifically directed by a physician. Follow medical advice carefully.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Quinolone antibacterials may have antagonistic effects when used together with Nitrofurantoin. This means the medicines may reduce each other's effectiveness.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The combined use may decrease the overall antibacterial action, leading to reduced treatment effectiveness and possible treatment failure.</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Drug rdf:about="http://example.org/ontology#S177">
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Quinolone Antibacterials</rdfs:label>
  <onto:hasSubstanceDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A group of antibiotics used to treat different bacterial infections. They work by stopping bacteria from multiplying and spreading in the body.</onto:hasSubstanceDescription>
</onto:Drug>

