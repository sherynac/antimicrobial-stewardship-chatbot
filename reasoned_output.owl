  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Administered with medication.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN113">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S087"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R018"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN113</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Inhibits clarithromycin metabolism.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor for increased side effects.</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Elevated plasma levels and prolonged half-life.</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN115">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S089"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R018"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN115</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased plasma carbamazepine levels.</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent use.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Consider blood level monitoring.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN117">
