<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP006">
  <onto:hasReference rdf:resource="http://example.org/ontology#R022"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R023"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP006</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pregnant or breastfeeding women should consult their doctor before taking Monurol.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP004">
  <onto:hasReference rdf:resource="http://example.org/ontology#R022"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R023"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP004</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contact your doctor if symptoms do not improve within 2-3 days. Watch for severe diarrhea, allergic reactions, or worsening urinary symptoms.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP003">
  <onto:hasReference rdf:resource="http://example.org/ontology#R023"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R022"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP003</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Take the full single-dose as instructed. Do not repeat the dose unless prescribed by a doctor.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP001">
  <onto:hasReference rdf:resource="http://example.org/ontology#R023"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R022"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP001</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use Monurol only for confirmed uncomplicated urinary tract infections in adult women. Do not use for kidney infections or perinephric abscess.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP002">
  <onto:hasReference rdf:resource="http://example.org/ontology#R022"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R023"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP002</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid unnecessary use to prevent deveopment of antibiotic-resistant bacteria.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

