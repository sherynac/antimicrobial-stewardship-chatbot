<onto:Interaction rdf:about="http://example.org/ontology#ITN256">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S175"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN256</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use with caution and only under medical supervision. Report any unusual side effects or persistent infection symptoms.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sulfinpyrazone also decreases the excretion of Nitrofurantoin by the kidneys. This changes the normal balance of the drug in the body.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased blood levels may raise the chance of side effects, while decreased urinary levels may reduce the drug's effectiveness in treating urinary infections.</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Drug rdf:about="http://example.org/ontology#S175">
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sulfinpyrazone</rdfs:label>
  <onto:hasSubstanceDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A medicine used to treat gout and certain blood clotting conditions. It helps remove uric aced from the body by acting on the kidneys.</onto:hasSubstanceDescription>
