</onto:Nausea>

<onto:Glossitis rdf:about="http://example.org/ontology#SE666">
  <onto:hasReference rdf:resource="http://example.org/ontology#R245"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R008"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
