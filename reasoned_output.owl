  <onto:hasReferenceTitle rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Furadantin</onto:hasReferenceTitle>
</onto:Reference>

<onto:Drug rdf:about="http://example.org/ontology#S170">
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R164"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Magnesium Trisilicate</rdfs:label>
  <onto:hasSubstanceDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Found in some antacids, can reduce Furadantin absorption.</onto:hasSubstanceDescription>
</onto:Drug>

<onto:Thrombophlebitis rdf:about="http://example.org/ontology#SE489">
  <onto:hasReference rdf:resource="http://example.org/ontology#R143"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">thrombophlebitis</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Is a vein inflammation that happens in connection with one or more blood clots. This usually happens in your legs but can affect any vein in your body. While it isn't usually dangerous on its own, it's an important indicator of clotting problems that can lead to life-threatening conditions like pulmonary embolism.</onto:hasSideEffectDescription>
</onto:Thrombophlebitis>

<onto:Reference rdf:about="http://example.org/ontology#R143">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">R143</rdfs:label>
  <onto:publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2022</onto:publishedIn>
  <onto:hasReferenceTitle rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Thrombophlebitis</onto:hasReferenceTitle>
  <onto:hasAuthor rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cleveland Clinic</onto:hasAuthor>
  <onto:retrievedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://my.clevelandclinic.org/health/diseases/23311-thrombophlebitis</onto:retrievedFrom>
</onto:Reference>

<onto:Reference rdf:about="http://example.org/ontology#R075">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">R075</rdfs:label>
  <onto:retrievedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://my.clevelandclinic.org/health/diseases/17704-high-white-blood-cell-count</onto:retrievedFrom>
  <onto:hasReferenceTitle rdf:datatype="http://www.w3.org/2001/XMLSchema#string">High White Blood Cell count</onto:hasReferenceTitle>
  <onto:hasAuthor rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cleveland Clinic</onto:hasAuthor>
  <onto:publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2022</onto:publishedIn>
</onto:Reference>

