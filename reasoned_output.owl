<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W031">
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W031</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Breastfeeding</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">It is not known whether azithromycin is excreted in human milk. Caution should be exercised when azithromycin is administered to a nursing woman.</onto:hasWarningText>
</onto:PregnancyAndLactation>

<onto:PatientCondition rdf:about="http://example.org/ontology#W001">
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W001</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not recommended for people with pneumonia who cannot take medicine by mouth. This includes those who are very sick, need to stay in the hospital, have serious infections, are older or frail, or have serious health problems that weaken the immune system.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pneumonia</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:PatientCondition rdf:about="http://example.org/ontology#W029">
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W029</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cardiac Risk</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Prolonged cardiac repolarization and QT interval, imparting a risk of developing cardiac arrhythmia and torsades de pointes, have been seen in treatment with other macrolides. A similar effect with azithromycin cannot be completely ruled out in patients at increased risk for prolonged cardiac repolarization.</onto:hasWarningText>
</onto:PatientCondition>

<onto:PatientCondition rdf:about="http://example.org/ontology#W027">
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W027</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Impaired hepatic functions</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Due to limited data in subjects with Glomerular Filtration Rate &lt; 10 mL/min, caution should be exercised when taking azithrymycin for these patients</onto:hasWarningText>
</onto:PatientCondition>

<onto:PatientCondition rdf:about="http://example.org/ontology#W002">
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W002</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Azithromycin, at the recommended dose, should not be relied upon to treat syphilis. Antimicrobial agents used in high doses for short periods of time to treat non-gonococcal urethritis may mask or delay the symptoms of incubating syphilis. All patients with sexually-transmitted urethritis or cervicitis should have a serologic test for syphilis and appropriate cultures for gonorrhea performed at the time of diagnosis. Appropriate antimicrobial therapy and follow-up tests for these diseases should be initiated if infection is confirmed.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Syphilis</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W030">
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W030</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pregnancy Category B: In the animal studies, no evidence of harm to the fetus due to azithromycin was found. There are, however, no adequate and well-controlled studies in pregnant women. Because animal reproduction studies are not always predictive of human response, azithromycin should be used during pregnancy only if clearly needed.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pregnancy</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:Contraindication rdf:about="http://example.org/ontology#W017">
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W017</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Azithromycin is contraindicated in patients with known hypersensitivity to azithromycin, erythromycin, any macrolide or ketolide antibiotic.</onto:hasWarningText>
</onto:Contraindication>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W016">
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W016</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Similar effects noted on regular doses. Adverse events experienced in higher than recommended dose were similar effects noted on regular doses. The typical symptoms of an overdose include reversible loss of hearing, severe nausea, vomiting and diarrhea.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Taking higher than recommended dose</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:AcuteBacterialSinusitis rdf:about="http://example.org/ontology#I003">
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#MildToModerate"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R013"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild to Moderate Acute Bacterial Sinusitis</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Colored, thick mucus (from nose or down throat), stuffy, blocked nose, face feels full, pressured, or painful, can't smell things well (or at all), fever</onto:hasSymptoms>
</onto:AcuteBacterialSinusitis>

<onto:AcuteBacterialExacerbationsOfCOPD rdf:about="http://example.org/ontology#I002">
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#MildToModerate"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R040"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild to Moderate Acute Bacterial Exacerbations of COPD</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">increased wheezing, fever without another identified cause, or an increase in heart rate or respiratory rate greater than 20% from baseline.</onto:hasSymptoms>
</onto:AcuteBacterialExacerbationsOfCOPD>

<onto:GenitalUlcerDiseaseForMen rdf:about="http://example.org/ontology#I015">
  <onto:hasReference rdf:resource="http://example.org/ontology#R046"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Genital Ulcer Disease for Men</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Burning sensation, fever, itchy genitals,painful urination or sexual intercourse</onto:hasSymptoms>
</onto:GenitalUlcerDiseaseForMen>

<onto:CommunityAcquiredPneumoniaCAP rdf:about="http://example.org/ontology#I009">
  <onto:hasReference rdf:resource="http://example.org/ontology#R042"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#MildToModerate"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild to Moderate Community-Acquired Pneumonia (CAP)</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cough, greenish/yellowish mucus, mild or high fever, shaking, chills, shortness of breath when you exert yourself</onto:hasSymptoms>
</onto:CommunityAcquiredPneumoniaCAP>

<onto:Vertigo rdf:about="http://example.org/ontology#SE053">
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vertigo</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Minor side effect; false sensation of motion such as spinning or swaying</onto:hasSideEffectDescription>
</onto:Vertigo>

<onto:Angioedema rdf:about="http://example.org/ontology#SE059">
  <onto:whichIs rdf:resource="http://example.org/ontology#Caused_by_allergies"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R064"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Angioedema</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Minor side effect; swelling in the tissue under your skin, commonly seen in the lips, eyelids, tongue, genitals, hands or feet</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Angioedema>

<onto:Nausea rdf:about="http://example.org/ontology#SE037">
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R056"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Common"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nausea</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Effects are usually mild. Sensation of having to vomit or having the urge to vomit.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Nausea>

<onto:Headache rdf:about="http://example.org/ontology#SE041">
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Headache</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Discomfort in the head or face</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Headache>

<onto:Nephritis rdf:about="http://example.org/ontology#SE051">
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R061"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nephritis</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Minor side effect; inflammation of one or both kidneys, which can leak protein into urine and impair the body's ability to absorb water and lead to tissue swelling</onto:hasSideEffectDescription>
</onto:Nephritis>

<onto:Vaginitis rdf:about="http://example.org/ontology#SE050">
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vaginitis</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Minor side effect; inflammation of the vagina</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Vaginitis>

<onto:AbdominalPain rdf:about="http://example.org/ontology#SE040">
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R058"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Common"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Abdominal Pain</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Effects are usually mild; pain felt anywhere between the chest and groin.</onto:hasSideEffectDescription>
</onto:AbdominalPain>

<onto:Melena rdf:about="http://example.org/ontology#SE047">
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R060"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Melena</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Minor side effect; black, tarry stool caused by internal bleeding</onto:hasSideEffectDescription>
</onto:Melena>

<onto:Photosensitivity rdf:about="http://example.org/ontology#SE058">
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R063"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Photosensitivity</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Minor side effect; skin reacts negatively to sunlight or UV rays that causes an itchy, painful rash</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Photosensitivity>

<onto:Flatulence rdf:about="http://example.org/ontology#SE046">
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Flatulence</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Minor side effect; body releases gas in your digestive system through your anus.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Flatulence>

<onto:Rash rdf:about="http://example.org/ontology#SE056">
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rash</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Minor side effect; red, bumpy, often itchy skin</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Rash>

<onto:TransientReductionsInNeutrophilCounts rdf:about="http://example.org/ontology#SE061">
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Transient reductions in neutrophil counts</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reversible side effect; neutrophils, a type of white blood cell, are decreased, but eventually turns back to normal</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
</onto:TransientReductionsInNeutrophilCounts>

<onto:Dyspepsia rdf:about="http://example.org/ontology#SE045">
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dyspepsia</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Minor side effect; pain or discomfort in the upper abdomen</onto:hasSideEffectDescription>
</onto:Dyspepsia>

<onto:Vomiting rdf:about="http://example.org/ontology#SE038">
  <onto:hasReference rdf:resource="http://example.org/ontology#R057"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Common"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vomiting</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Effects are usually mild. Forceful ejection stomach contents through the mouth.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Vomiting>

<onto:CholestaticJaundice rdf:about="http://example.org/ontology#SE048">
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cholestatic jaundice</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Minor side effect; yellowing of skin and whites of the eyes, fatigue</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:CholestaticJaundice>

<onto:Diarrhea rdf:about="http://example.org/ontology#SE039">
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R076"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Common"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diarrhea</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Effects are usually mild. Loose, watery stools during a bowl movement</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Diarrhea>

<onto:Palpitations rdf:about="http://example.org/ontology#SE043">
  <onto:hasReference rdf:resource="http://example.org/ontology#R059"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Palpitations</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Minor side effect; feeling like your heart is missing heartbeats, racing or pounding felt in chest, throat or neck.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Palpitations>

<onto:Fatigue rdf:about="http://example.org/ontology#SE055">
  <onto:hasReference rdf:resource="http://example.org/ontology#R062"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fatigue</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Minor side effect; feeling of weariness, tiredness, or lack of energy</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Fatigue>

<onto:ChestPain rdf:about="http://example.org/ontology#SE044">
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Chest pain</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Minor side effect; Pain felt between neck and belly</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:ChestPain>

<onto:FoodAndTiming rdf:about="http://example.org/ontology#SP036">
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP036</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May be taken with or without meals</onto:hasStewardshipDescription>
</onto:FoodAndTiming>

<onto:FoodAndTiming rdf:about="http://example.org/ontology#SP029">
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP029</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May be taken with meals to reduce gastrointestinal discomfort</onto:hasStewardshipDescription>
</onto:FoodAndTiming>

<onto:Storage rdf:about="http://example.org/ontology#SP046">
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP046</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Protect from light</onto:hasStewardshipDescription>
</onto:Storage>

<onto:Storage rdf:about="http://example.org/ontology#SP013">
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP013</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Store at temperatures not exceeding 30°C</onto:hasStewardshipDescription>
</onto:Storage>

<onto:Interaction rdf:about="http://example.org/ontology#ITN020">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S014"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN020</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor for adverse effects if taken with these medications. Consult doctor or pharmacist.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Azithromycin has little or no effect on hepatic cytochrome P450 enzymes, so may or may not interact with astemizole.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None specifically reported.</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN021">
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN021</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Azithromycin has little or no effect on hepatic cytochrome P450 enzymes, so may or may not interact with cisapride.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None specifically reported.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor for adverse effects if taken with these medications. Consult doctor or pharmacist.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN019">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S003"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN019</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antacids containing aluminum or magnesium salts can reduce the rate, but not the extent, of its absorption</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None specifically reported.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Azithromycin should be given at least 1 before or 2 hours after the antacid</onto:hasManagementAdvice>
</onto:Interaction>

