  <onto:hasReferenceTitle rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gastritis</onto:hasReferenceTitle>
</onto:Reference>

<onto:Reference rdf:about="http://example.org/ontology#R187">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">R187</rdfs:label>
  <onto:publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2023</onto:publishedIn>
  <onto:hasReferenceTitle rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Systemic Lupus Erythematosus</onto:hasReferenceTitle>
  <onto:retrievedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://www.ncbi.nlm.nih.gov/books/NBK535405/</onto:retrievedFrom>
  <onto:hasAuthor rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Goyal, A. et al.</onto:hasAuthor>
</onto:Reference>

<onto:Interaction rdf:about="http://example.org/ontology#ITN095">
  <onto:hasReference rdf:resource="http://example.org/ontology#R016"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S069"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN095</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Inform your doctor if you are taking allopurinol</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased incidence of skin rashes, especially in hyperuricemic patients.</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent use with amoxicillin.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Drug rdf:about="http://example.org/ontology#S069">
  <onto:hasReference rdf:resource="http://example.org/ontology#R016"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Allopurinol</rdfs:label>
  <onto:hasSubstanceDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gout medication</onto:hasSubstanceDescription>
</onto:Drug>

