  <onto:hasStorageRule rdf:resource="http://example.org/ontology#SP118"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">RiteMED Levofloxacin</rdfs:label>
</onto:Brand>

<onto:BloodGlucoseDisturbances rdf:about="http://example.org/ontology#SE413">
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Blood Glucose Disturbances</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">disturbances of blood glucose, including symptomatic hyperglycemia and hypoglycemia</onto:hasSideEffectDescription>
</onto:BloodGlucoseDisturbances>

<onto:Hepatotoxicity rdf:about="http://example.org/ontology#SE409">
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#14_days_of_initiation_of_therapy_and_most_cases_occurred_within_6_days"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hepatotoxicity</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">When you’re exposed to substances that can harm your liver (toxins)</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Hepatotoxicity>

<onto:QTIntervalProlongation rdf:about="http://example.org/ontology#SE412">
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Prolongation of the QT Interval</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sample Description</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:QTIntervalProlongation>

<onto:TendinitisAndTendonRupture rdf:about="http://example.org/ontology#SE403">
  <onto:whichIs rdf:resource="http://example.org/ontology#Within_hours_or_days"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tendinitis and Tendon Rupture</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased risk of tendinitis and tendon rupture involving the achillies rendon, rorator cuffm the hande, the biceps, the thumb, and other tendon sites</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:TendinitisAndTendonRupture>

<onto:PhotosensitivityOrPhototoxicity rdf:about="http://example.org/ontology#SE414">
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Photosensitivity / Phototoxicity</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">exaggerated sunburn reactions (e.g., burning, erythema, exudation, vesicles, blistering, edema)</onto:hasSideEffectDescription>
</onto:PhotosensitivityOrPhototoxicity>

<onto:OtherSeriousAndSometimesFatalReactions rdf:about="http://example.org/ontology#SE407">
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Other Serious and Sometimes Fatal Reactions</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">fever, rash, or severe dermatologic reactions (e.g., toxic epidermal necrolysis, Stevens-Johnson syndrome); vasculitis; arthralgia; myalgia; serum sickness; allergic pneumonitis; interstitial nephritis; acute renal insufficiency or failure; hepatitis; jaundice; acute hepatic necrosis or failure; anemia, including hemolytic and aplastic; thrombocytopenia, including thrombotic thrombocytopenic purpura; leukopenia; agranulocytosis; pancytopenia; and/or other hematologic abnormalities.</onto:hasSideEffectDescription>
</onto:OtherSeriousAndSometimesFatalReactions>

<onto:AorticAneurysmAndDissection rdf:about="http://example.org/ontology#SE410">
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#two_months_after_intake"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Risk of Aortic Aneurysm and Dissection</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">sudden abdominal, chest or back pain,</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:AorticAneurysmAndDissection>

<onto:RenalImpairment rdf:about="http://example.org/ontology#SE417">
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Renal Impairment</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">reduced and plasma elimination</onto:hasSideEffectDescription>
</onto:RenalImpairment>

<onto:PeripheralNeuropathy rdf:about="http://example.org/ontology#SE404">
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Peripheral Neuropathy</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Paresthesias, hypoesthesias, dysesthesias and weakness</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:PeripheralNeuropathy>

<onto:HypersensitivityReactions rdf:about="http://example.org/ontology#SE408">
  <onto:whichIs rdf:resource="http://example.org/ontology#Following_the_first_dose"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity Reactions</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cardiovascular collapse, hypotension/shock, seizure, loss of consciousness, tingling, angioedema (including tongue, laryngeal, throat, or facial edema/swelling), airway obstruction (including bronchospasm, shortness of breath, and acute respiratory distress), dyspnea, urticaria, itching, and other serious skin reactions. Levofloxacin should be discontinued immediately at the first appearance of a skin rash or any other sign of hypersensitivity</onto:hasSideEffectDescription>
</onto:HypersensitivityReactions>

<onto:CentralNervousSystemEffects rdf:about="http://example.org/ontology#SE405">
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#After_the_first_dose"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Central Nervous System Effects</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Toxic psychoses, hallucination, or paranoia; depression, or suicidal thoughts; anxiety, agitation, restlessness, or nervousness; confusion, delirium, disorientation, or disturbances in attention; insomnia or nightmares; memory impairment.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:CentralNervousSystemEffects>

<onto:Interaction rdf:about="http://example.org/ontology#ITN187">
  <onto:hasReference rdf:resource="http://example.org/ontology#R010"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S146"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN187</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lowers renal clearance</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Caution should be exercised when levofloxacin is coadministered with drugs that affect the tubular renal secretion such as probenecid and cimetidine, especially in renally impaired patients.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The renal clearance of levofloxacin is reduced by cimetidine (24%) and probenecid (34%).</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN186">
  <onto:hasReference rdf:resource="http://example.org/ontology#R010"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S145"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN186</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">lower the seizure threshold</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A pronounced lowering of the cerebral seizure threshold</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN188">
  <onto:hasReference rdf:resource="http://example.org/ontology#R010"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S147"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN188</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The half-life of ciclosporin was increased by 33%</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Incerase half-life</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN184">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S143"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R010"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN184</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Levofloxacin absorption is significantly reduced</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">It is recommended that preparations containing iron salts, or magnesium-or aluminum-containing antacids should not be taken 2 hours before or after Levofloxacin tablet administration.</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Decreased absorption</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN185">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S144"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R010"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN185</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">administer sucralfate 2 hours after the Levofloxacin tablet administration.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">bioavailability of levofloxacin tablets is significantly reduced</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Decreased bioavailability</onto:hasClinicalEffects>
</onto:Interaction>

<onto:UncomplicatedUrinaryTractInfectionUTI rdf:about="http://example.org/ontology#I020">
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R264"/>
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#MildToSevere"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild to Severe Uncomplicated Urinary Tract Infection (UTI)</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">urinary frequency, urgency, dysuria, and suprapubic discomfort.</onto:hasSymptoms>
</onto:UncomplicatedUrinaryTractInfectionUTI>

<onto:UrinaryDisease rdf:about="http://example.org/ontology#I047">
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R071"/>
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#MildToSevere"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild to Severe Chronic Bacterial Prostatis</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fever, chills, painful and frequent urination or have trouble urinating,</onto:hasSymptoms>
</onto:UrinaryDisease>

<onto:ComplicatedUrinaryTractInfectionCUTI rdf:about="http://example.org/ontology#I065">
  <onto:hasReference rdf:resource="http://example.org/ontology#R271"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#MildToSevere"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild to Severe Complicated Urinary Tract Infection (cUTI)</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">fever or chills, pain in the lower back or side, and overall malaise</onto:hasSymptoms>
</onto:ComplicatedUrinaryTractInfectionCUTI>

<onto:FoodAndTiming rdf:about="http://example.org/ontology#SP119">
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP119</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May be taken with or without food</onto:hasStewardshipDescription>
</onto:FoodAndTiming>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP120">
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP120</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Take at least 2 hr before or 2 hr after antacids containing Ca/Mg/Al, after sucralfate or metal cations (eg, Fe), multivit prep w/ Zn, or didanosine.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:FoodAndTiming rdf:about="http://example.org/ontology#SP122">
  <onto:hasReference rdf:resource="http://example.org/ontology#R010"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP122</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May be taken with or without food: May be taken during or between meals. Swallow whole, do not chew</onto:hasStewardshipDescription>
</onto:FoodAndTiming>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP123">
  <onto:hasReference rdf:resource="http://example.org/ontology#R010"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP123</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dosage is according to doctor's instructions only</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W199">
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W199</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">No dosage adjustment is necessary for elderly patients with normal renal function. However, since levofloxacin is excreted by the kidneys and some elderly patients experience age-related reduction in renal function, care should be taken in dose selection and renal function monitoring is recommended. Elderly patients are at increased risk of developing severe tendon disorders including tendon rupture, or prolonged QT interval leading to ventricular arrhythmias when being treated with a fluoroquinolone such as levofloxacin</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use in Elderely</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W203">
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W203</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Levofloxacin has not been measured in human milk. However, based on the ofloxacin data, it can be presumed that levofloxacin will be excreted in human milk. Therefore, a decision should be made whether to discontinue breastfeeding or to discontinue the drug, taking into account the importance of the drug to the mother as well as the possible serious adverse effects to the infant.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lactation</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:PatientCondition rdf:about="http://example.org/ontology#W196">
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W196</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Levofloxacin should be avoided in patients with known prolongation of the QT interval, patients with uncorrected electrolyte imbalance (e.g., hypokalemia and
hypomagnesemia) patients with cardiac disease (e.g., heart failure, myocardial infarction and bradycardia), and in patients receiving drugs that are known to prolong the QT interval such as Class IA (quinidine, procainamide), or Class III (amiodarone, sotalol) antiarrhythmic agents, tricyclic antidepressants, macrolides and antipsychotics.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">QT Interval</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W197">
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W197</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">QT Interval</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Elderly patients and women may be more susceptible to drug-associated effects on the QT interval.</onto:hasWarningText>
</onto:AgeRestriction>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W198">
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W198</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Quinolones, including levofloxacin, cause arthropathy and osteochondrosis in juvenile animals of several species. Levofloxacin is indicated in pediatric patients ≥6 months old, for inhalational anthrax (post- exposure) and for the treatment of plague, including pneumonic and septicemic plague due to Yersinia pestis and prophylaxis for plague. The risk-benefit assessment indicates that administration of levofloxacin to pediatric patients is appropriate. Safety and effectiveness in pediatric patients &lt;6 months old have not been established.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use in children</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W200">
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W200</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The drug should not be used in pregnant women unless the potential benefits justify the potential risks to the fetus</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pregnancy</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W201">
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W201</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pregnancy</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The drug should not be used in pregnant women unless the potential benefits justify the potential risks to the fetus</onto:hasWarningText>
</onto:PregnancyAndLactation>

<onto:Storage rdf:about="http://example.org/ontology#SP118">
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP118</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Store at temperatures not exceeding 30°C, Protect from sunlight and moisture.</onto:hasStewardshipDescription>
</onto:Storage>

<onto:Contraindication rdf:about="http://example.org/ontology#W083">
  <onto:hasReference rdf:resource="http://example.org/ontology#R032"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W083</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cefumax should be used with care in patients with hypersensitivity to penicillin.
In the clinical and laboratory tests, cross-allergenicity between penicillin and cephalosporin was ascertained although there were rare cases of patients who have demonstrated allergic reactions to both of these 2 drugs.
Some cases of anaphylactic shock were reported especially following the parenteral administration.
During pregnancy and children &lt;3 months, cefumax should be used in cases of absolute necessity and under direct medical control.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity to Cephalosporins</onto:hasWarningHeadline>
</onto:Contraindication>

<onto:Drug rdf:about="http://example.org/ontology#S086">
  <onto:hasReference rdf:resource="http://example.org/ontology#R018"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Zidovudine</rdfs:label>
  <onto:hasSubstanceDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">HIV medication</onto:hasSubstanceDescription>
</onto:Drug>

