<onto:Interaction rdf:about="http://example.org/ontology#ITN202">
  <onto:hasReference rdf:resource="http://example.org/ontology#R092"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S155"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN202</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent administration of antacids containing magnesium hydroxide or aluminum hydroxide may reduce the bioavailability of ciprofloxacin by as much as 90%.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN199">
  <onto:hasReference rdf:resource="http://example.org/ontology#R092"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S048"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN199</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Overall absorption of Ciprofloxacin is not substantially affected</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">When Ciprofloxacin is given concomitantly with food, there is a delay in the absorption of the drug, resulting in peak concentrations that occur closer to 2 hours after dosing rather than 1 hour.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN201">
  <onto:hasReference rdf:resource="http://example.org/ontology#R092"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S155"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN201</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent administration of antacids containing magnesium hydroxide or aluminum hydroxide may reduce the bioavailability of ciprofloxacin by as much as 90%.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN205">
  <onto:hasReference rdf:resource="http://example.org/ontology#R092"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S025"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN205</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ciprofloxacin decreases caffeine clearance and inhibits the formation of paraxanthine after caffeine administration</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN206">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S025"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R092"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN206</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ciprofloxacin decreases caffeine clearance and inhibits the formation of paraxanthine after caffeine administration</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN203">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S088"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R092"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN203</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Elevated serum theophylline levels and increased risk of a patient developing CNS or other adverse reactions.</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant administration of ciprofloxacin with theophylline decreases the clearance of theophylline</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN204">
