<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP030">
  <onto:hasReference rdf:resource="http://example.org/ontology#R030"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP030</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Only use for prescribed bacterial infections (uncomplicated UTIs). Avoid for viral infections.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP031">
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R030"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP031</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Practice good hygiene to reduce infection spread; drink enough fluids.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP033">
  <onto:hasReference rdf:resource="http://example.org/ontology#R030"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP033</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contact your doctor if severe side effects occur. Kidney function may require monitoring.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP032">
  <onto:hasReference rdf:resource="http://example.org/ontology#R030"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP032</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Take the full single-dose treatment exactly as prescribed, even if symptoms improve quickly.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:Heartburn rdf:about="http://example.org/ontology#SE091">
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R030"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Occasionally_reported"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Heartburn</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild discomfort or burning in chest.</onto:hasSideEffectDescription>
</onto:Heartburn>

<onto:VaginalItching rdf:about="http://example.org/ontology#SE096">
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R030"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vaginal Itching</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild itching; may indicate yeast overgrowth.</onto:hasSideEffectDescription>
</onto:VaginalItching>

<onto:SevereAllergicReaction rdf:about="http://example.org/ontology#SE097">
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R030"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Severe Allergic Reaction</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Immediate</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hives, swelling, difficulty breathing, seek emergency care.</onto:hasSideEffectDescription>
</onto:SevereAllergicReaction>

<onto:Diarrhea rdf:about="http://example.org/ontology#SE088">
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R030"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Can_occur_within_first_days"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diarrhea</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild loose stools; monitor for severe watery or bloody diarrhea.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
</onto:Diarrhea>

<onto:UnexplainedWeakness rdf:about="http://example.org/ontology#SE094">
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R030"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Unexplained Weakness</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Feeling unusually tired or weak.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
</onto:UnexplainedWeakness>

<onto:SymptomsOfBowelInflammation rdf:about="http://example.org/ontology#SE098">
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare_but_serious"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R030"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symptoms of Bowel Inflammation</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Persistent or bloody diarrhea with abdominal pain and/or fever; seek doctor immediately.</onto:hasSideEffectDescription>
</onto:SymptomsOfBowelInflammation>

<onto:RunnyNose rdf:about="http://example.org/ontology#SE093">
  <onto:hasReference rdf:resource="http://example.org/ontology#R030"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Runny Nose</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild nasal discharge.</onto:hasSideEffectDescription>
</onto:RunnyNose>

<onto:Rash rdf:about="http://example.org/ontology#SE095">
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R030"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare_but_serious"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rash</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Skin rash; contact doctor if persistent.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
</onto:Rash>

<onto:BackPain rdf:about="http://example.org/ontology#SE087">
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R030"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Occasionally_reported"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Back Pain</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild back pain.</onto:hasSideEffectDescription>
</onto:BackPain>

<onto:AbdominalPain rdf:about="http://example.org/ontology#SE086">
  <onto:whichIs rdf:resource="http://example.org/ontology#Can_occur_sooner_after_taking"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R030"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Abdominal Pain</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild to moderate stomach discomfort.</onto:hasSideEffectDescription>
</onto:AbdominalPain>

<onto:PatientCondition rdf:about="http://example.org/ontology#W046">
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W046</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fosfomycin may cause dizziness, affecting ability to drive or operate machinery.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dizziness</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:PatientCondition rdf:about="http://example.org/ontology#W051">
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W051</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sucrose Content</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">It contains sucrose. It is not recommended if the patient have hereditary problems of fructose intolerance.</onto:hasWarningText>
</onto:PatientCondition>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W048">
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W048</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pregnancy</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fosfomycin crosses the placenta and may affect a developing baby if it is taken during pregnancy. This medication should not be used during pregnancy unless the benefits outweigh the risks.</onto:hasWarningText>
</onto:PregnancyAndLactation>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W049">
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W049</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May pass into breast milk. If you are breast-feeding and are taking fosfomycin, it may affect your baby.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Breastfeeding</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:Contraindication rdf:about="http://example.org/ontology#W044">
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W044</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Allergy</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Do not take this medication if allergic to fosfomycin or any ingredients of the medication.</onto:hasWarningText>
</onto:Contraindication>

<onto:PatientCondition rdf:about="http://example.org/ontology#W050">
  <onto:hasReference rdf:resource="http://example.org/ontology#R030"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W050</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Overgrowth of Organisms</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Prolonged or repeated use may lead to fungal or resistant bacterial overgrowth.</onto:hasWarningText>
</onto:PatientCondition>

<onto:PatientCondition rdf:about="http://example.org/ontology#W045">
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W045</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antibiotic-Associated Colitis</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May cause persistent or severe blood or watery diarrhea with or without fever and abdominal pain</onto:hasWarningText>
</onto:PatientCondition>

<onto:Interaction rdf:about="http://example.org/ontology#ITN031">
  <onto:hasReference rdf:resource="http://example.org/ontology#R030"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S025"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN031</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Can increase dizziness or mild jitteriness.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor your symptoms and discuss with our doctor if needed.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Consuming caffeine may sometimes interact with fosfomycin and affect its absorption or side effects.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN033">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S027"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R030"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN033</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Can change drug effectiveness.</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Smoking or nicotine use may influence how your body processes fosfomycin.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Consider avoiding nicotine or discuss with your doctor.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN032">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S026"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R030"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN032</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Can increase dizziness or mild jitteriness.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor your symptoms and discuss with our doctor if needed.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Consuming caffeine may sometimes interact with fosfomycin and affect its absorption or side effects.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN030">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S024"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R030"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN030</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Drinking alcohol while taking fosfomycin may increase the risk of side effects.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May cause dizziness or nausea.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Moderate use is generally safe; consult your doctor if unsure.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:VaginalYeastInfection rdf:about="http://example.org/ontology#SE269">
  <onto:whichIs rdf:resource="http://example.org/ontology#During_after_treatment"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R047"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vaginal Yeast Infection</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Itching, irritation, or thick white discharge due to changes in flora.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3–7 days</onto:hasDuration>
</onto:VaginalYeastInfection>

<onto:Neurologic rdf:about="http://example.org/ontology#SE267">
  <onto:whichIs rdf:resource="http://example.org/ontology#During_treatment"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R047"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Neurologic</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1–3 days</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Headache (mild to moderate) or Dizziness (lightheadedness).</onto:hasSideEffectDescription>
</onto:Neurologic>

<onto:Hypersensitivity rdf:about="http://example.org/ontology#SE270">
  <onto:hasReference rdf:resource="http://example.org/ontology#R047"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Frequent"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rashes and urticaria; occasionally more severe dermatitis.</onto:hasSideEffectDescription>
</onto:Hypersensitivity>

<onto:SystemicRare rdf:about="http://example.org/ontology#SE271">
  <onto:hasReference rdf:resource="http://example.org/ontology#R047"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Systemic (Rare)</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hematologic (Anemia) or Hepatic (moderate rise in liver enzymes).</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reversible</onto:hasDuration>
</onto:SystemicRare>

<onto:Gastrointestinal rdf:about="http://example.org/ontology#SE266">
  <onto:whichIs rdf:resource="http://example.org/ontology#During_shortly_after_treatment"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R047"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gastrointestinal</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2–3 days</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diarrhea (usually mild), Nausea, Vomiting, or Stomach pain/cramping.</onto:hasSideEffectDescription>
</onto:Gastrointestinal>

<onto:Interaction rdf:about="http://example.org/ontology#ITN104">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S078"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R047"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN104</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Potential for altered blood levels of the antiepileptic or the antibiotic.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor serum levels of phenytoin and clinical response to therapy.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Interference/enzyme competition.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN109">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S083"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R047"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN109</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor for therapeutic failure; be aware of potential for reduced drug effectiveness.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Effect on gut flora / interference.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reduced efficacy of the antibiotic or other oral medications.</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN103">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S077"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R047"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN103</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Undertake appropriate monitoring (e.g., INR); adjust dose as needed.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent use with amoxicillin or cefuroxime.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased risk of bleeding; rare prolongation of prothrombin time; elevated INR.</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN102">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S076"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R047"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN102</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased risk of kidney damage (AKI); elevated creatinine.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor renal function (BUN, creatinine) and ensure adequate hydration.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent Nephrotoxic use.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN106">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S080"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R047"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN106</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor renal function and electrolyte levels (Potassium/Sodium).</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Potential for fluid/electrolyte imbalance and increased risk of kidney strain.</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent Nephrotoxic use.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN108">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S082"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R047"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN108</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Interference in vitro / potential toxicity.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May interfere with bactericidal effects; potential for bone marrow suppression (rare).</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Clinical significance is not well documented; use under medical supervision.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:AcuteBacterialExacerbationOfChronicBronchitis rdf:about="http://example.org/ontology#I066">
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#MildToModerate"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R270"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R032"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R047"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild to Moderate Acute Bacterial Exacerbation of Chronic Bronchitis</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">persistent cough that lasts one to three weeks, shortness of breath, fever, runny nose, and tiredness</onto:hasSymptoms>
</onto:AcuteBacterialExacerbationOfChronicBronchitis>

<onto:Contraindication rdf:about="http://example.org/ontology#W134">
  <onto:hasReference rdf:resource="http://example.org/ontology#R047"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W134</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Strictly prohibited for patients with a history of hypersensitivity to penicillins or any ingredient in the product.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity</onto:hasWarningHeadline>
</onto:Contraindication>

<onto:PatientCondition rdf:about="http://example.org/ontology#W132">
  <onto:hasReference rdf:resource="http://example.org/ontology#R047"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W132</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Because cefuroxime is eliminated primarily by the kidney, a dosage interval adjustment is required for patients whose creatinine clearance is 30 mL/min</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Renal Impairment</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W133">
  <onto:hasReference rdf:resource="http://example.org/ontology#R047"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W133</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Overdosage of cephalosporins can cause cerebral irritation leading to convulsions or encephalopathy. Serum levels of cefuroxime can be reduced by hemodialysis and peritoneal dialysis.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cerebral Irritation</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:Contraindication rdf:about="http://example.org/ontology#W131">
  <onto:hasReference rdf:resource="http://example.org/ontology#R047"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W131</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cefuroxime (as Axetil) products are contraindicated in patients with known allergy to the cephalosporin group of antibiotics.</onto:hasWarningText>
</onto:Contraindication>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W136">
  <onto:hasReference rdf:resource="http://example.org/ontology#R047"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W136</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dosed at 25-50 mg/kg/day in divided doses every 8 or 12 hours.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Infants &gt; 3 Months &amp; Children &lt; 40 kg</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W135">
  <onto:hasReference rdf:resource="http://example.org/ontology#R047"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W135</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">No evidence of fetal harm; distributed into breast milk.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Safe for Mother; Monitor Baby</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP085">
  <onto:hasReference rdf:resource="http://example.org/ontology#R047"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP085</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Allergic Reactions: Watch for rashes, itching, or swelling (anaphylaxis).</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP084">
  <onto:hasReference rdf:resource="http://example.org/ontology#R047"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP084</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Full Course: Complete the entire prescribed course, even if symptoms improve, to prevent bacterial resistance.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP083">
  <onto:hasReference rdf:resource="http://example.org/ontology#R047"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP083</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Liquid Suspension: Typically administered as $5\text{ mL}$ per dose. Can be taken with meals to improve absorption and reduce GI discomfort.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:Storage rdf:about="http://example.org/ontology#SP086">
  <onto:hasReference rdf:resource="http://example.org/ontology#R047"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP086</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Store at temperatures not exceeding 25°C. Protect from moisture and light</onto:hasStewardshipDescription>
</onto:Storage>

<onto:Interaction rdf:about="http://example.org/ontology#ITN250">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S169"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R161"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN250</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Drugs like probenecid or sulfinpyrazone (used for gout) can block the way your kidneys remove Macrobid from your blood. This can cause higher levels of the drug in your body but lower levels in your urine where it is needed to fight bacteria.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Higher blood levels can increase your risk of side effects like nausea, headache, or nerve problems. Lower urine levels may make Macrobid less effective, leading to persistent urinary infections.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Your doctor may monitor your blood and urine closely if you take these drugs with Macrobid. They may adjust your dose or suggest using a different medication combination to avoid problems.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Drug rdf:about="http://example.org/ontology#S169">
  <onto:hasReference rdf:resource="http://example.org/ontology#R161"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Probenecid</rdfs:label>
  <onto:hasSubstanceDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Heps remove uric acid from body; can affect Macrobid effectiveness and safety.</onto:hasSubstanceDescription>
</onto:Drug>

<onto:Reference rdf:about="http://example.org/ontology#R137">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">R137</rdfs:label>
  <onto:hasReferenceTitle rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lower Respiratory Tract Infection</onto:hasReferenceTitle>
  <onto:hasAuthor rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Medical News Today</onto:hasAuthor>
  <onto:retrievedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://www.medicalnewstoday.com/articles/324413#symptoms</onto:retrievedFrom>
  <onto:publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</onto:publishedIn>
</onto:Reference>

<onto:Drug rdf:about="http://example.org/ontology#S112">
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Zidovudine</rdfs:label>
  <onto:hasSubstanceDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An antiretroviral medication for HIV-infected patients.</onto:hasSubstanceDescription>
</onto:Drug>

<onto:Reference rdf:about="http://example.org/ontology#R182">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">R182</rdfs:label>
  <onto:retrievedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://my.clevelandclinic.org/health/diseases/22632-angioedema</onto:retrievedFrom>
  <onto:publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</onto:publishedIn>
  <onto:hasReferenceTitle rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Angioedema</onto:hasReferenceTitle>
  <onto:hasAuthor rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cleveland Clinic</onto:hasAuthor>
</onto:Reference>

<onto:Storage rdf:about="http://example.org/ontology#SP049">
  <onto:hasReference rdf:resource="http://example.org/ontology#R038"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP049</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Protect from light</onto:hasStewardshipDescription>
</onto:Storage>

<onto:Brand rdf:about="http://example.org/ontology#Macrobid">
  <onto:hasSideEffect rdf:resource="http://example.org/ontology#SE526"/>
  <onto:hasSideEffect rdf:resource="http://example.org/ontology#SE530"/>
  <onto:hasSideEffect rdf:resource="http://example.org/ontology#SE528"/>
  <onto:hasSideEffect rdf:resource="http://example.org/ontology#SE527"/>
  <onto:hasSideEffect rdf:resource="http://example.org/ontology#SE524"/>
  <onto:hasSideEffect rdf:resource="http://example.org/ontology#SE531"/>
  <onto:hasSideEffect rdf:resource="http://example.org/ontology#SE525"/>
  <onto:hasSideEffect rdf:resource="http://example.org/ontology#SE523"/>
  <onto:hasSideEffect rdf:resource="http://example.org/ontology#SE529"/>
  <onto:hasSideEffect rdf:resource="http://example.org/ontology#SE522"/>
  <onto:treats rdf:resource="http://example.org/ontology#I016"/>
  <onto:treats rdf:resource="http://example.org/ontology#I058"/>
  <onto:managedAs rdf:resource="http://example.org/ontology#SP167"/>
  <onto:managedAs rdf:resource="http://example.org/ontology#SP164"/>
  <onto:managedAs rdf:resource="http://example.org/ontology#SP166"/>
  <onto:managedAs rdf:resource="http://example.org/ontology#SP165"/>
  <onto:hasInteraction rdf:resource="http://example.org/ontology#ITN250"/>
  <onto:hasInteraction rdf:resource="http://example.org/ontology#ITN249"/>
  <onto:hasWarning rdf:resource="http://example.org/ontology#W260"/>
  <onto:hasWarning rdf:resource="http://example.org/ontology#W258"/>
  <onto:hasWarning rdf:resource="http://example.org/ontology#W255"/>
  <onto:hasWarning rdf:resource="http://example.org/ontology#W256"/>
  <onto:hasWarning rdf:resource="http://example.org/ontology#W257"/>
  <onto:hasWarning rdf:resource="http://example.org/ontology#W259"/>
