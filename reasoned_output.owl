<onto:AgeRestriction rdf:about="http://example.org/ontology#W212">
  <onto:hasReference rdf:resource="http://example.org/ontology#R092"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W212</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Acute Overdosage</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">In the event of acute overdosage, reversible renal toxicity has been reported in some cases; Make sure to monitor renal (kidney) function and administer magnesium- or calcium-containing antacids which reduce absorption of ciprofloxacin.</onto:hasWarningText>
</onto:AgeRestriction>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W210">
  <onto:hasReference rdf:resource="http://example.org/ontology#R092"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W210</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ciprofloxacin is excreted in human milk; The amount of ciprofloxacin absorbed by the infant is unknown; Due to potential serious adverse reactions to infants nursing from mothers taking ciprofloxacin, a decision should be made whether to discontinue nursing or to discontinue the drug, depending on the importance of the drug to the mother.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nursing Mothers</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W213">
  <onto:hasReference rdf:resource="http://example.org/ontology#R092"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W213</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">In the event of acute overdosage, reversible renal toxicity has been reported in some cases; Make sure to monitor renal (kidney) function and administer magnesium- or calcium-containing antacids which reduce absorption of ciprofloxacin.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Acute Overdosage</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W211">
  <onto:hasReference rdf:resource="http://example.org/ontology#R092"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W211</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ciprofloxacin is excreted in human milk; The amount of ciprofloxacin absorbed by the infant is unknown; Due to potential serious adverse reactions to infants nursing from mothers taking ciprofloxacin, a decision should be made whether to discontinue nursing or to discontinue the drug, depending on the importance of the drug to the mother.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nursing Mothers</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:InhalationAnthrax rdf:about="http://example.org/ontology#I050">
  <onto:hasReference rdf:resource="http://example.org/ontology#R092"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R099"/>
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Inhalation Anthrax</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fever and chills, heavy sweats, chest pain, cough, or shortness of breath, confusion or dizziness, nausea, vomiting, or stomach pains, headache or body aches, and extreme tiredness</onto:hasSymptoms>
</onto:InhalationAnthrax>

<onto:AcuteUncomplicatedUrinaryTractInfectionUTI rdf:about="http://example.org/ontology#I021">
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R092"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Acute Uncomplicated Urinary Tract Infection (UTI)</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Strong and frequent urge to urinate, burning or painful feeling when urinating, urine may look cloudy, dark, or have a strong bad smell; Some people may feel mild lower belly pain or discomfort.</onto:hasSymptoms>
</onto:AcuteUncomplicatedUrinaryTractInfectionUTI>

