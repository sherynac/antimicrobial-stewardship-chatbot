<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP035">
  <onto:hasReference rdf:resource="http://example.org/ontology#R038"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP035</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">For people with advanced HIV infection, to treat a serious illness called Mycobacterium avium complex (MAC) disease, it is taken with another drug called ethambutol (at the recommended dose)</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP034">
  <onto:hasReference rdf:resource="http://example.org/ontology#R038"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP034</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">For people with advanced HIV infection, to prevent a serious illness called Mycobacterium avium complex (MAC) disease, it can be taken by itself or together with another drug called rifabutin (at the recommended dose)</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W065">
  <onto:hasReference rdf:resource="http://example.org/ontology#R038"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W065</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pregnancy</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Should only be used during pregnancy if it is clearly indicated. Caution should be taken when administered to a pregnant woman.</onto:hasWarningText>
</onto:PregnancyAndLactation>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W067">
  <onto:hasReference rdf:resource="http://example.org/ontology#R038"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W067</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Breastfeeding</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Unknown if Azithromycin is excreted in breast milk. Caution should be taken when administered to a nursing woman.</onto:hasWarningText>
</onto:PregnancyAndLactation>

<onto:Contraindication rdf:about="http://example.org/ontology#W058">
  <onto:hasReference rdf:resource="http://example.org/ontology#R038"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W058</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Do not take if you have hypersensitivity to the azithromycin, or any macrolide antibiotics.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity</onto:hasWarningHeadline>
</onto:Contraindication>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W055">
