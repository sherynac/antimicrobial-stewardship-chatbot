  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Central Nervous System Effects</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reversable hyperactivity, agitation, anxiety, insomnia, confusion, behavioral changes, and/or dizziness.</onto:hasSideEffectDescription>
</onto:CentralNervousSystemEffects>

<onto:Storage rdf:about="http://example.org/ontology#SP077">
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP077</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Store powder and reconstituted suspension in a dry place below 30°C; protect from light.</onto:hasStewardshipDescription>
</onto:Storage>

<onto:Storage rdf:about="http://example.org/ontology#SP073">
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP073</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Store in a dry place at temperatures not exceeding 30°C and protect from light.</onto:hasStewardshipDescription>
</onto:Storage>

<onto:Interaction rdf:about="http://example.org/ontology#ITN073">
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S047"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN073</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Consider additional contraceptive measures</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May cause breakthrough bleeding and reduce birth control effectiveness</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant use with penicillins</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN077">
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S051"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN077</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent administration</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increases incidence of skin rashes, especially in hyperuricemic patients</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor for allergic manifestations</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN079">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S053"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN079</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May be taken with meals for better absorption and less Gastrointestinal discomfort</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Taking medication during meals</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Absorption is 90% and is not significantly affected by food</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN078">
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S052"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN078</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patient should be informed of reduced efficacy</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reduces effectiveness and may cause breakthrough bleeding</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant use</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN070">
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S044"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN070</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Carefully monitor patients receiving both concomitantly</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reduced clearance by inhibiting renal tubular secretion</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Penicillins may decrease renal clearance</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN075">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S049"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN075</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Inhibits renal tubular secretion, increasing drug levels</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent use with aminopenicillins</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Carefully monitor clinical status during co-administration</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN071">
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S045"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN071</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Administered shortly before or with amoxicillin</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Management should be overseen by a physician</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Slows renal secretion, producing higher and prolonged serum levels</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN072">
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S046"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN072</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increases the incidence and possibility of skin rashes</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent administration</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor for skin reactions during treatment</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN076">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S050"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN076</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Taken simultaneously or shortly before</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Produces higher and prolonged serum concentrations</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Physician supervision recommended</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN074">
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S048"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN074</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May be taken with meals to reduce Gastrointestinal discomfort and improve absorption</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ingestion alongside the medication</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Has no significant influence on amoxicillin absorption</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Reference rdf:about="http://example.org/ontology#R017">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">R017</rdfs:label>
  <onto:hasReferenceTitle rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pediamox</onto:hasReferenceTitle>
  <onto:publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</onto:publishedIn>
  <onto:retrievedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://www.mims.com/philippines/drug/info/pediamox</onto:retrievedFrom>
  <onto:hasAuthor rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monthly Index of Medical Specialties</onto:hasAuthor>
</onto:Reference>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W116">
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W116</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Safe in Pregnancy; Caution in Nursing</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Administered to pregnant women without evidence of fetal harm; use with caution in breastfeeding mothers because it is distributed into milk and may sensitize infants.</onto:hasWarningText>
</onto:PregnancyAndLactation>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W124">
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W124</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Toxicity Management</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May cause nausea, vomiting, diarrhea, crystalluria, and allergic manifestations. Symptomatic treatment is required for almost all patients. Problems are unlikely if adequate fluid intake and urinary output are maintained; however crystalluria and hemorrhagic cystitis are possible.</onto:hasWarningText>
</onto:AgeRestriction>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W122">
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W122</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dosed at 25-50 mg/kg body weight/day in divided doses every 8 or 12 hours.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Infants &gt; 3 Months &amp; Children &lt; 40 kg</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W119">
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W119</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May cause nausea, vomiting, diarrhea, crystalluria, and allergic manifestations. Symptomatic treatment is required for almost all patients. Problems are unlikely if adequate fluid intake and urinary output are maintained; however crystalluria and hemorrhagic cystitis are possible.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Low Toxicity Symptoms</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:Contraindication rdf:about="http://example.org/ontology#W120">
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W120</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity to penicillins and to any ingredient in the products. Patients with infectious mononucleosis due to possible development of rash during therapy.</onto:hasWarningText>
</onto:Contraindication>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W121">
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W121</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Administered to pregnant women without evidence of fetal harm; use with caution in breastfeeding mothers because it is distributed into milk and may sensitize infants.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Safe for Mother; Monitor Baby</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W117">
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W117</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Neonates and Infants &lt; 3 Months</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Specifically dosed at 20-30 mg/kg body weight/day in divided doses every 12 hours.</onto:hasWarningText>
</onto:AgeRestriction>

<onto:Contraindication rdf:about="http://example.org/ontology#W125">
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W125</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Penicillin Sensitivity</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity to penicillins and to any ingredient in the products. Patients with infectious mononucleosis due to possible development of rash during therapy.</onto:hasWarningText>
</onto:Contraindication>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP076">
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP076</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Usual duration is 5 to 14 days; must complete the course as prescribed.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP071">
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP071</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Administer via dropper. Can be taken with or without food; taking with meals can reduce Gastrointestinal discomfort.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP078">
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP078</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor for superinfections during prolonged use and observe for renal output in overdose cases.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP075">
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP075</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Administer as a liquid suspension (typically 5 mL per dose). Can be taken w/ meals for better absorption &amp; to reduce Gastrointestinal discomfort.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP072">
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP072</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Doses should be given every 8 or 12 hours for neonates/infants &lt; 3 months.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP074">
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP074</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor for allergic manifestations and maintain adequate fluid intake to prevent crystalluria.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:UncomplicatedUrinaryTractInfectionUTI rdf:about="http://example.org/ontology#I018">
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#MildToModerate"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R029"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R158"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R030"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R032"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R164"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild to Moderate Uncomplicated Urinary Tract Infection (UTI)</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Painful or frequent urination, lower abdominal pain, back pain, urgency to urinate, cloudy urine, strong urine smell.</onto:hasSymptoms>
</onto:UncomplicatedUrinaryTractInfectionUTI>

