  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Uncomplicated Gonorrhea</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Often, gonorrhea doesn’t cause symptoms, especially in women.</onto:hasSymptoms>
</onto:UncomplicatedGonorrhea>

