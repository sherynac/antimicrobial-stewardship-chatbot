  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fosfomycin may be less effective at treating infection.</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Metoclopramide may reduce absorption of fosfomycin.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Inform your doctor; avoid taking metoclopramide at the same time as fosfomycin if possible.</onto:hasManagementAdvice>
