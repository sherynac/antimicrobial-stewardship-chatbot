<onto:PatientCondition rdf:about="http://example.org/ontology#W218">
  <onto:hasReference rdf:resource="http://example.org/ontology#R091"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W218</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">In epileptics and in patients who have suffered from previous CNS disorders (e.g. lowered convulsion threshold, previous history of convulsion, reduced cerebral blood flow, altered brain structure or stroke), Ciprofloxacin should only be used where the benefits of treatment exceed the risks, since these patients are endangered because of possible central nervous side effects.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Epileptic, history of Central Nervous System (CNS) disorders</onto:hasWarningHeadline>
</onto:PatientCondition>

