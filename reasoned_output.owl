  <onto:interactsWith rdf:resource="http://example.org/ontology#S022"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN042</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Simultaneous administration of antacids had no effect on overall bioavailability but peak serum concentrations were reduced by approximately 24%.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Do not take azithromycin and antacids simultaneously</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None specifically reported.</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN193">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S123"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN193</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Due to the theoretical possibility of ergotism, the concurrent use of azithromycin with ergot derivatives is not recommended</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN197">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S153"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN197</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant use of several medical products from the same group of substances is not recommended</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Possible co-resistance between macrolide antibiotic and azithromycin (e.g. erythromycin) as well as lincomycin and clindamycin is to look at</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN191">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S062"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN191</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">If azithromycin and P-gp substrates are administered concomitantly, the possibility of eleventaed serum concentrations of the subtrate should be considered</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant administration with macrolide antibiotics, including azithromycin result in increased serum levels of the P-glycoprotein substrate</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN192">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S092"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN192</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">If azithromycin and P-gp substrates are administered concomitantly, the possibility of eleventaed serum concentrations of the subtrate should be considered</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant administration with macrolide antibiotics, including azithromycin result in increased serum levels of the P-glycoprotein substrate</onto:hasInteractionDescription>
</onto:Interaction>

<onto:FoodAndTiming rdf:about="http://example.org/ontology#SP038">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP038</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May be taken with or without food</onto:hasStewardshipDescription>
</onto:FoodAndTiming>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP037">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP037</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Should be swallowed whole with liquid as a single daily dose. Do not chew or crush when taking.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP051">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP051</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Observation for sign of superinfection with non-susceptible organisms, including fungi.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP052">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP052</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Azithromycin is not intended to treat suitable severe infections where fast high blood concentrations of antibiotic have to be achieved,</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP104">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP104</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use for treating tonsillitis, pharyngitis and acute otitis media (ear infection) for patients with hypersensitivity to beta-lactam antibiotics or when such treatment is not suitable for other reasons.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:Dysgeusia rdf:about="http://example.org/ontology#SE124">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R070"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dysgeusia</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">all foods taste metallic, sweet, sour or bitter</onto:hasSideEffectDescription>
</onto:Dysgeusia>

<onto:IncreasedEosinophilCountBasophilsMonocytesAndNeutrophils rdf:about="http://example.org/ontology#SE134">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R075"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Common"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased Eosinophil count, basophils, monocytes and neutrophils</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This can lead to leukocytosis, which means the patient has a high white blood cell count than normal; Neutrophilia leukocytosis is caused by a high number of neutrophils (the most plentiful type of white blood cell, which helps resolve infections and heal damaged tissues).; Monocytosis is caused by a high number of monocytes (white blood cells that boost your immune responses).; Eosinophilia refers to high levels of eosinophils (white blood cells that play a role in fighting infections and inflammation). Eosinophilia is common and is often related to allergies, parasitic infections or autoimmune disorders; Basophilia, the rarest form of leukocytosis, is characterized by an increased number of basophils (white blood cells that play a role in fighting parasitic infections, preventing blood clotting and responding to allergic reactions).</onto:hasSideEffectDescription>
</onto:IncreasedEosinophilCountBasophilsMonocytesAndNeutrophils>

<onto:Somnolence rdf:about="http://example.org/ontology#SE123">
  <onto:whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Somnolence</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">feeling tired and wanting to fall asleep</onto:hasSideEffectDescription>
</onto:Somnolence>

<onto:Leukopenia rdf:about="http://example.org/ontology#SE112">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Leukopenia</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">lower-than-normal number of white blood cells</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Leukopenia>

<onto:DecreasedLymphocyteCountAndBloodBicarbonate rdf:about="http://example.org/ontology#SE133">
  <onto:whichIs rdf:resource="http://example.org/ontology#Common"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R073"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R074"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Decreased lymphocyte count and blood bicarbonate</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Low lymphocyte count can increase chances of getting sick; Low level of blood bicarbonate can cause metabolic acidosis or too much acid in the body.</onto:hasSideEffectDescription>
</onto:DecreasedLymphocyteCountAndBloodBicarbonate>

<onto:Diarrhea rdf:about="http://example.org/ontology#SE129">
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_Common"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diarrhea</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Loose, watery stools.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Diarrhea>

<onto:SideEffect rdf:about="http://example.org/ontology#SE107">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R055"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pharyngitis</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">scratchy or burning feeling in the back of your throat; it may hurt to swallow or talk</onto:hasSideEffectDescription>
</onto:SideEffect>

<onto:Insomnia rdf:about="http://example.org/ontology#SE119">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Insomnia</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">difficulty falling asleep or staying asleep</onto:hasSideEffectDescription>
</onto:Insomnia>

<onto:Palpitations rdf:about="http://example.org/ontology#SE127">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R059"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Palpitations</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">feeling like your heart is missing heartbeats, racing or pounding felt in chest, throat or neck.</onto:hasSideEffectDescription>
</onto:Palpitations>

<onto:SideEffect rdf:about="http://example.org/ontology#SE104">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pneumonia</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">difficulty breathing that can cause fever and cough with yellow, green or blood mucus</onto:hasSideEffectDescription>
</onto:SideEffect>

<onto:Headache rdf:about="http://example.org/ontology#SE121">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Common"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Headache</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Discomfort in the head or face</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Headache>

<onto:HotFlush rdf:about="http://example.org/ontology#SE128">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hot flush</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">sudden feeling of warmth in the upper body mostly affecting the face, neck and chest</onto:hasSideEffectDescription>
</onto:HotFlush>

<onto:AbdominalPain rdf:about="http://example.org/ontology#SE131">
  <onto:hasReference rdf:resource="http://example.org/ontology#R058"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Common"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Abdominal Pain</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">pain felt anywhere between the chest and groin.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:AbdominalPain>

<onto:OralCandidiasis rdf:about="http://example.org/ontology#SE111">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R065"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Oral candidiasis</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Infection that affections your mouth, throat, tongue or esophagus; Causes raised, white sores to develop, along with mouth pain, irritation and redness</onto:hasSideEffectDescription>
</onto:OralCandidiasis>

<onto:Angioedema rdf:about="http://example.org/ontology#SE115">
  <onto:whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R064"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Angioedema</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">swelling in the tissue under your skin, commonly seen in the lips, eyelids, tongue, genitals, hands or feet</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Angioedema>

<onto:FungalInfections rdf:about="http://example.org/ontology#SE105">
  <onto:hasReference rdf:resource="http://example.org/ontology#R066"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fungal Infections</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">condition caused by fungus; usually affect skin, hair nails or mucous membranes</onto:hasSideEffectDescription>
</onto:FungalInfections>

<onto:Agitation rdf:about="http://example.org/ontology#SE120">
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Agitation</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">state of severe restlessness or inner tension</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Agitation>

<onto:Vomiting rdf:about="http://example.org/ontology#SE130">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R057"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Common"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vomiting</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Effects are usually mild. Forceful ejection stomach contents through the mouth.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Vomiting>

<onto:Candidiasis rdf:about="http://example.org/ontology#SE102">
  <onto:whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R065"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Candidiasis</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Yeast infection caused by Candida albicans that commonly affects mouth, skin and vagina</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Candidiasis>

<onto:Gastroenteritis rdf:about="http://example.org/ontology#SE108">
  <onto:whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R067"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gastroenteritis</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">inflammation of the lining of the stomach and intestines; vomiting and diarrhea</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Gastroenteritis>

<onto:Eosinophilia rdf:about="http://example.org/ontology#SE114">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R068"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Eosinophilia</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">unusually high number of eosinophils (type of white blood cell) in blood; High number of eosinophils crowd at specific areas of the body, causing medical conditions linked to inflammation that can affecti multiple areas of the body.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Eosinophilia>

<onto:PatientCondition rdf:about="http://example.org/ontology#W101">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W101</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Exacerbations of the symptoms of myasthenia gravis and new onset of myasthenia syndrome have been reported in patients receiving azithromycin therapy</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Myasthenia gravis</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:Contraindication rdf:about="http://example.org/ontology#W056">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W056</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity to the active substance, erythromycin, any macrolide or ketolide antibiotic, or to any of the excipients.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity</onto:hasWarningHeadline>
</onto:Contraindication>

<onto:PatientCondition rdf:about="http://example.org/ontology#W169">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W169</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cross Resistance</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not recommended for infections caused by erythromycin-resistant Gram-positive bacteria or MRSA (Methicillin-resistant Staphylococcus aureus). Consider local resistance patterns before use.</onto:hasWarningText>
</onto:PatientCondition>

<onto:PatientCondition rdf:about="http://example.org/ontology#W069">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W069</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hepatotoxicity</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use with caution for patients with significant hepatic (liver) disease as cases of fulminant hepatitis leading to life-threatening liver failure have been reported with azithromycin. In case of signs and symptoms of liver dysfunction, such as rapid developing asthenia associated with jaundice, dark urine, bleeding tendency or hepatic encephalopathy. Azithromycin administration should be stopped if liver dysfunction has emerged.</onto:hasWarningText>
</onto:PatientCondition>

<onto:PatientCondition rdf:about="http://example.org/ontology#W063">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W063</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fertility</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Animal studies have shown reduced pregnancy rate upon the administration of azithromycin. The clinical relevance for humans is unknown.</onto:hasWarningText>
</onto:PatientCondition>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W053">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W053</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Adverse effects experienced at doses higher than recommended are similar to those seen at normal doses. Symptoms of a macrolide antibiotic overdose typically include reversible hearing loss, severe nausea, vomiting, and diarrhea. In case of an overdose, administration of medicinal charcoal is recommended, along with general symptomatic treatment and supportive measures as needed.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Taking higher than recommended dose</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:PatientCondition rdf:about="http://example.org/ontology#W099">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W099</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Renal Impairment</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">33% increase in systemic exposure in severe renal impairment (GFR &lt;10 mL/min)</onto:hasWarningText>
</onto:PatientCondition>

<onto:Contraindication rdf:about="http://example.org/ontology#W072">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W072</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Co-administration</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Due to theoretical possibility of ergotism, azithromycin and ergot derivatives should not be co-administered.</onto:hasWarningText>
</onto:Contraindication>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W061">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W061</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The safety of azithromycin has not been confirmed with regard to the use of the active substance during pregnancy. Therefore, azithromycin should only be used during pregnancy if the benefit outweighs the risk.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pregnancy</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W102">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W102</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Infantile hypertrophic pyloric stenosis (IHPS)</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Following the use of azithromycin in neonates (treatment up to 42 days of life), infantile hypertrophic pyloric stenosis (IHPS) has been reported. Parents and caregiviers should contact physician if vomiting/irritability occurs.</onto:hasWarningText>
</onto:AgeRestriction>

<onto:PatientCondition rdf:about="http://example.org/ontology#W100">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W100</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use with caution in patients with ongoing proarrthymic conditions (especially women and elderly patients) such as: congenital or documented QT prolongation; patients currently receiving treatment with other substances that prolong QT interval, such as antiarrythmics of classes IA (quinidine and procainamide) and class III (dofelitide, amiodarone, and sotalol), cisparide and terfenadine; antipsychotic agents such as pimozide; antidepressants such as citalopram; fluoroquinolones such as moxiflaxin and levoflaxin; patients with electrolyte disturbance, particularly in cases of hypokalaemia and hypomagnesaemia; patients with bradycardia, cardiac arrhythmia or severe cardiac insufficiency.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cardiovascular events</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W062">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W062</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Azithromycin is secreted into human breast milk. A risk to the newborn/infant cannot be excluded. A decision must be made whether to discontinue breastfeeding or discontinue the drug, taking into account the benefit of breastfeeding to the child and the benefit of therapy to the mother.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Breastfeeding</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:PatientCondition rdf:about="http://example.org/ontology#W075">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W075</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Neurological and pyschiatric disorders</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Azithromycin should be used with caution in patients with neurological and psychiartric disorders.</onto:hasWarningText>
</onto:PatientCondition>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W073">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W073</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pediatric Use</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Safety and efficacy for the prevention or treatment of Mycobacterium avium complex in children have not been established.</onto:hasWarningText>
</onto:AgeRestriction>

