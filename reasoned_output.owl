<onto:Interaction rdf:about="http://example.org/ontology#ITN063">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S043"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN063</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rare cases of increased INR have been reported in the literature for patients on these medications</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Potential for altered blood clotting (increased INR)</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Prothrombin time or INR should be carefully monitored when starting or stopping Amoxil</onto:hasManagementAdvice>
</onto:Interaction>

