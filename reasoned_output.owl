  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">inflammation that makes your tongue swollen, smooth or red</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Glossitis>

<onto:AcuteRenalFailure rdf:about="http://example.org/ontology#SE676">
  <onto:hasReference rdf:resource="http://example.org/ontology#R255"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R008"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
