<onto:Interaction rdf:about="http://example.org/ontology#ITN114">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S088"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R018"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN114</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increase in serum theophylline concentrations.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor serum concentrations of theophylline.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent use.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN112">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S086"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R018"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN112</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Separate doses by 1 to 2 hours.</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Decreased concentrations of zidovudine.</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant use.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN111">
  <onto:hasReference rdf:resource="http://example.org/ontology#R018"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S085"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN111</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reported case of delirium.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use with caution.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent use.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN119">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S093"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R018"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN119</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent use.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor ECG and serum drug levels.</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Risk of Torsades de Pointes and QTc prolongation.</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN120">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S094"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R018"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN120</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent use.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor for muscle pain.</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased statin levels; rare reports of rhabdomyolysis.</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN118">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S092"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R018"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN118</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid combination if possible.</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reported colchicine toxicity, especially in the elderly.</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent use.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN116">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S090"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R018"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN116</rdfs:label>
