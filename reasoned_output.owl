<onto:ToxicEpidermalNecrolysis rdf:about="http://example.org/ontology#SE136">
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_specified"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R033"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Toxic epidermal necrolysis</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Toxic epidermal necrolysis (TEN) is potentially life-threatening acute mucocutaneous Syndrome. It usually occurs because of inappropriate immune reactions to certain drugs.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:ToxicEpidermalNecrolysis>

<onto:StevensJohnsonSyndrome rdf:about="http://example.org/ontology#SE137">
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_specified"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R034"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Stevens-Johnson Syndrome</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Stevens-Johnson syndrome (SJS) is a rare, serious disorder of the skin and mucous membranes. It's usually a reaction to medication that starts with flu-like symptoms, followed by a painful rash that spreads and blisters. Then the top layer of affected skin dies, sheds and begins to heal after several days.</onto:hasSideEffectDescription>
</onto:StevensJohnsonSyndrome>

<onto:ToxicEpidermalNecrolysis rdf:about="http://example.org/ontology#SE138">
  <onto:hasReference rdf:resource="http://example.org/ontology#R033"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Toxic epidermal necrolysis</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Toxic epidermal necrolysis (TEN) is potentially life-threatening acute mucocutaneous Syndrome. It usually occurs because of inappropriate immune reactions to certain drugs.</onto:hasSideEffectDescription>
</onto:ToxicEpidermalNecrolysis>

<onto:StevensJohnsonSyndrome rdf:about="http://example.org/ontology#SE135">
  <onto:hasReference rdf:resource="http://example.org/ontology#R034"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Stevens-Johnson Syndrome</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Stevens-Johnson syndrome (SJS) is a rare, serious disorder of the skin and mucous membranes. It's usually a reaction to medication that starts with flu-like symptoms, followed by a painful rash that spreads and blisters. Then the top layer of affected skin dies, sheds and begins to heal after several days.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:StevensJohnsonSyndrome>

<onto:Interaction rdf:about="http://example.org/ontology#ITN045">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S033"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN045</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor for enhanced drug effects and adjust doses as needed.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cotrimoxazole has been shown to potentiate activity of strongly serum protein-bound drugs like oral hypoglycaemic or anticoagulant.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN043">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S031"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN043</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use TMP-SMX with caution in elderly patients receiving thiazide diuretics</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">In elderly patients concurrently receiving diuretics, mainly thiazide, there appears to be an increased risk of thrombocytopenia with purpura.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN046">
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S034"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN046</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor INR closely and reduce warfarin dose if necessary.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">It has been reported that comazole may displace the anticoagulant warfarin. Careful control of the anticoagulant therapy during treatment with Comazole is advisable.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN048">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S036"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN048</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent use of rifampicin and Comazole results in shortening of plasma half life of trimethoprim.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor clinical response as trimethoprim levels may be reduced. Consider alternative therapy.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN047">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S035"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN047</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Comazole also may inhibit the hepatic metabolism of phenytoin. A 39% increase in phenytoin half-life and 27% decrease in the metabolic clearance rate of phenytoin have been observed following administration of Comazole of normal clinical dosages. If these two drugs are given concurrently it is important to remain alert for signs of phenytoin toxicity.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor serum phenytoin levels and signs of toxicity. Dose adjustment may be required.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN044">
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S032"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN044</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Occasionally reports suggest that patients receiving pyrimethamine as malarial prophylaxis in doses exceeding 25 mg weekly may develop megaloblastic anaemia if Co- trimoxazole be prescribed concurrently.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid combination or closely monitor CBC for megaloblastic anemia.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN059">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S036"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN059</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor clinical response as trimethoprim levels may be reduced. Consider alternative therapy.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent use of rifampicin and Comazole results in shortening of plasma half life of trimethoprim.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN057">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S034"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN057</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor INR closely and reduce warfarin dose if necessary.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">It has been reported that comazole may displace the anticoagulant warfarin. Careful control of the anticoagulant therapy during treatment with Comazole is advisable.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN054">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S031"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN054</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use TMP-SMX with caution in elderly patients receiving thiazide diuretics</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">In elderly patients concurrently receiving diuretics, mainly thiazide, there appears to be an increased risk of thrombocytopenia with purpura.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN056">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S033"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN056</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor for enhanced drug effects and adjust doses as needed.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cotrimoxazole has been shown to potentiate activity of strongly serum protein-bound drugs like oral hypoglycaemic or anticoagulant.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Contraindication rdf:about="http://example.org/ontology#W082">
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W082</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Comazole is contraindicated in patients with marked liver parenchymal damage. It is also contraindicated in patients with severe renal insufficiency when repeated determinations of the plasma concentration cannot be made. Except in rare circumstances Comazole should not be given to patient with serious haematological disorders. The combination has occasionally been administered to patients receiving cytotoxic agents for the treatment of leukemias, without evidence of any adverse effect on the bone marrow or peripheral blood. Comazole should not be administered to patients with a history of hypersensitivity to sulphonamides or trimethoprim. Comazole is contraindicated in G6PD (Glucose-6-phosphate dehydrogenase
deficiency). Treatment must be immediately discontinued on the appearance of a skin rash or any element of blood count reduced.</onto:hasWarningText>
</onto:Contraindication>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W103">
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W103</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nausea, vomiting, dizziness and confusion are likely symptoms of overdosage.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gastronintestinal Effects</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W077">
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W077</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pregnancy</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Comazole is contraindicated during pregnancy. If pregnancy cannot be excluded, possible risks should be balanced against the expected therapeutic effect. Comazole should not be given during pregnancy especially in late pregnancy because of risk of kernicterus.</onto:hasWarningText>
</onto:PregnancyAndLactation>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W078">
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W078</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lactation</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Despite the excretion of trimethoprim and sulphamethoxazole into breast milk, the administration of comazole to lactating women represents a negligible risk to the suckling infants. It also should be used with caution in nursing
mothers because it can pass the placenta and is excreted in breast milk and may cause kernicterus.</onto:hasWarningText>
</onto:PregnancyAndLactation>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W076">
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W076</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pediatric Use</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Comazole should not be given to premature and newborn infants during the first week of life.</onto:hasWarningText>
</onto:AgeRestriction>

<onto:Contraindication rdf:about="http://example.org/ontology#W074">
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W074</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Comazole is contraindicated in patients with marked liver parenchymal damage. It is also contraindicated in patients with severe renal insufficiency when repeated determinations of the plasma concentration cannot be made. Except in rare circumstances Comazole should not be given to patient with serious haematological disorders. The combination has occasionally been administered to patients receiving cytotoxic agents for the treatment of leukemias, without evidence of any adverse effect on the bone marrow or peripheral blood. Comazole should not be administered to patients with a history of hypersensitivity to sulphonamides or trimethoprim. Comazole is contraindicated in G6PD (Glucose-6-phosphate dehydrogenase
deficiency). Treatment must be immediately discontinued on the appearance of a skin rash or any element of blood count reduced.</onto:hasWarningText>
</onto:Contraindication>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W079">
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W079</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Comazole should not be given to premature and newborn infants during the first week of life.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pediatric Use</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W081">
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W081</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Despite the excretion of trimethoprim and sulphamethoxazole into breast milk, the administration of comazole to lactating women represents a negligible risk to the suckling infants. It also should be used with caution in nursing
mothers because it can pass the placenta and is excreted in breast milk and may cause kernicterus.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Breastfeeding</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:Storage rdf:about="http://example.org/ontology#SP057">
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP057</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Store at temperatures below 30C, in a tight, light resistant container, protect from light.</onto:hasStewardshipDescription>
</onto:Storage>

<onto:Storage rdf:about="http://example.org/ontology#SP058">
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
