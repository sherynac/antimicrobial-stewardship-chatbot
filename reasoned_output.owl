  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent use.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor prothrombin time carefully.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN110">
