  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">passing fewer than three stools a week or having a difficult time passing stool</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
