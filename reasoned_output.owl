<onto:AgeRestriction rdf:about="http://example.org/ontology#W204">
  <onto:hasReference rdf:resource="http://example.org/ontology#R010"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W204</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">QT Interval</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Elderly patients may be more susceptible to drug-associated effects on the QT interval. Therefore, precaution should be taken when using levofloxacin with concomitant drugs that can result in prolongation of the QT interval (e.g. class IA or class III antiarrhythmic) or in patients with risk factors for Torsades de pointes (e.g. known QT prolongation, uncorrected hypokalemia).</onto:hasWarningText>
</onto:AgeRestriction>

