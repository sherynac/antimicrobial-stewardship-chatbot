  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Store at temperatures below 30C, in a tight, light resistant container, protect from light.</onto:hasStewardshipDescription>
</onto:Storage>

<onto:UpperUrinaryTractInfection rdf:about="http://example.org/ontology#I032">
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Upper Urinary Tract Infection</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">pain in the lower back or side, fever or chills, nausea or vomiting, brain fog or overall restlessness and bloody urine</onto:hasSymptoms>
</onto:UpperUrinaryTractInfection>

<onto:LowerUrinaryTractInfection rdf:about="http://example.org/ontology#I033">
  <onto:hasReference rdf:resource="http://example.org/ontology#R266"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lower Urinary Tract Infection</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">more frequent urination, pain, burning, or other discomfort during urination, a sudden urge to urinate (even if you just went), feeling unable to empty the bladder fully, urine that’s cloudy or slightly colored with blood, urine that smells more pungent than usual, and abdominal or pelvic pain</onto:hasSymptoms>
</onto:LowerUrinaryTractInfection>

<onto:Contraindication rdf:about="http://example.org/ontology#W130">
  <onto:hasReference rdf:resource="http://example.org/ontology#R016"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W130</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity and Mononucleosis</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Prohibited for patients with a known hypersensitivity to penicillins or cephalosporins. Forbidden for patients with infectious mononucleosis due to the high risk of a maculopapular rash</onto:hasWarningText>
</onto:Contraindication>

