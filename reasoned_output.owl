<onto:Interaction rdf:about="http://example.org/ontology#ITN179">
  <onto:hasReference rdf:resource="http://example.org/ontology#R013"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S103"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN179</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">render oral contraceptives less effective</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid taking together</onto:hasManagementAdvice>
