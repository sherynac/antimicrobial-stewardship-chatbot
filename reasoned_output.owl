<owl:Class rdf:about="http://example.org/ontology#Indication">
  <owl:disjointWith rdf:resource="http://example.org/ontology#SideEffect"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#Severity"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="http://example.org/ontology#hasSymptoms"/>
      <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</owl:minCardinality>
