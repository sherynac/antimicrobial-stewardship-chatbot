  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W055</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Do not exceed the recommended doses. In case of overdosage consult your physician immediately.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Taking higher than recommended dose</onto:hasWarningHeadline>
