  <onto:hasAuthor rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mayo Clinic</onto:hasAuthor>
  <onto:hasReferenceTitle rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Thrombocytopenia (low platelet count)</onto:hasReferenceTitle>
  <onto:publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</onto:publishedIn>
</onto:Reference>

<onto:Interaction rdf:about="http://example.org/ontology#ITN247">
  <onto:hasReference rdf:resource="http://example.org/ontology#R157"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S166"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN247</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Do not take nitrofurantoin at the same time as magnesium-containing antacids. Take the antibiotic at least 2 hours before or after antacids to ensure proper absorption.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antacids that contain magnesium can bind with nitrofurantoin in the stomach or intestines and reduce how much of the drugs is absorbed into the blood.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reduced absorption can make the antibiotic less effective at treating urinary tract infections, potentially allowing the bacteria to persist or worsen.</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Reference rdf:about="http://example.org/ontology#R169">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">R169</rdfs:label>
