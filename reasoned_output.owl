<onto:InjectionSiteReaction rdf:about="http://example.org/ontology#SE031">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#At_or_shortly_after_IV_administration"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Injection Site Reaction</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pain, redness, or swelling at the injection site.</onto:hasSideEffectDescription>
</onto:InjectionSiteReaction>

<onto:Nausea rdf:about="http://example.org/ontology#SE027">
  <onto:whichIs rdf:resource="http://example.org/ontology#May_occur_during_or_shortly_after_infusion"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nausea</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Feeling sick to the stomach. Usually mild to temporary.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term; during treatment</onto:hasDuration>
</onto:Nausea>

<onto:Hypokalemia rdf:about="http://example.org/ontology#SE034">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#More_common_in_long-term_therapy"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypokalemia</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">During prolonged or high-dose use</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Low potassium levels which may cause weakness, muscle cramps, or irregular heartbeat.</onto:hasSideEffectDescription>
</onto:Hypokalemia>

<onto:ElevatedLiverEnzymes rdf:about="http://example.org/ontology#SE035">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Usually_detected_in_lab_tests"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Elevated Liver Enzymes</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild increase in liver enzymes seen in blood tests. Often reversible.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">During treatment</onto:hasDuration>
</onto:ElevatedLiverEnzymes>

<onto:SodiumOverload rdf:about="http://example.org/ontology#SE036">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#More_likely_in_high_doses"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sodium Overload</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">High sodium levels that may worsen heart failure or high blood pressure.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">During treatment</onto:hasDuration>
</onto:SodiumOverload>

<onto:HypersensitivityReactions rdf:about="http://example.org/ontology#SE033">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare_but_serious"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity Reactions</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Severe allergic reaction such as swelling, breathing difficulty, or hives. Needs urgent care.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Immediate or shortly after dose</onto:hasDuration>
</onto:HypersensitivityReactions>

<onto:Headache rdf:about="http://example.org/ontology#SE030">
  <onto:whichIs rdf:resource="http://example.org/ontology#May_appear_during_therapy"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Headache</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild to moderate head pain.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Temporary</onto:hasDuration>
</onto:Headache>

<onto:Rash rdf:about="http://example.org/ontology#SE032">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Can_occur_during_treatment"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rash</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Temporary</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Skin redness or itching due to allergic reaction.</onto:hasSideEffectDescription>
</onto:Rash>

<onto:Diarrhea rdf:about="http://example.org/ontology#SE029">
  <onto:whichIs rdf:resource="http://example.org/ontology#Can_occur_anytome_while_using_or_after_stopping_the_drug"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diarrhea</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Loose or water stools. Severe cases may indicate C. difficile infection.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">During treatment or even weeks after</onto:hasDuration>
</onto:Diarrhea>

<onto:Interaction rdf:about="http://example.org/ontology#ITN013">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S011"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN013</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased creatinine or kidney impairment.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use with caution and monitor renal function.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Combining fosfomycin with vancomycin may increase the risk of kidney problems.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN011">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S004"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN011</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid combined use with Fosfomycin if possible. Monitor treatment response.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Metoclopramide may lower fosfomycin levels in the body by affecting how it is distributed.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reduced antibiotic effectiveness.</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN016">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S006"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN016</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased discomfort or nausea.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Limit or avoid alcohol during therapy.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alcohol does not directly interact, but it may worsen side effects like dizziness or stomach upset.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN012">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S010"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN012</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Higher risk of kidney damage.</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Using fosfomycin with gentamicin may increase stress on the kidneys.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor kidney function closely.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN018">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S008"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN018</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alcohol does not directly interact, but it may worsen side effects like dizziness or stomach upset.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased discomfort or nausea.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Limit or avoid alcohol during therapy.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN015">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S013"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN015</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fluid retention, high blood pressure, worsening heart failure.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor sodium levels and fluid status.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fosfomycin contains sodium, and additional sodium from IV fluids may increase total sodium load.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN017">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S007"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN017</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Limit or avoid alcohol during therapy.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alcohol does not directly interact, but it may worsen side effects like dizziness or stomach upset.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased discomfort or nausea.</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN014">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S012"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN014</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor potassium levels regularly.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fosfomycin may lower potassium levels, and furosemide can also reduce potassium.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased risk of hypokalemia (weakness, irregular heartbeat).</onto:hasClinicalEffects>
</onto:Interaction>

<onto:PatientCondition rdf:about="http://example.org/ontology#W020">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W020</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sodium Content</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Before receiving IVOZFO, notify the doctor if the patient have any of the following health conditions: heart problems, high blood pressure, hyperaldosteronism which is a condition where you have too much of a hormone called aldosterone, cirrhosis (scar tissue) of the liver, kidney problems, high levels of sodium in the blood, or fluid in your lungs. IVOZFO contains sodium that could make these conditions worse.</onto:hasWarningText>
</onto:PatientCondition>

<onto:PatientCondition rdf:about="http://example.org/ontology#W022">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W022</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidney Impairment</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dose adjustment may be needed in patients with reduced kidney function. Monitor kidney status during therapy.</onto:hasWarningText>
</onto:PatientCondition>

<onto:Contraindication rdf:about="http://example.org/ontology#W018">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W018</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Do not use if the patient has a known allergy to fosfomycin. Serious allergic reactions like difficulty breathing, difficulty swallowing, fever, hives, itchy skin, rash, swelling of your tongue, throat or face</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity</onto:hasWarningHeadline>
</onto:Contraindication>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W025">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W025</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Safety and effectiveness in children should be confirmed before use. Follow proper dosing guidelines.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pediatric Use</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W024">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W024</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">It is not fully known if the drug passes into breast milk. Consult a healthcare provider before use.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Breastfeeding</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W026">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W026</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">In patients with impaired renal function, the elimination half-life is increased proportionally to the degree of renal insufficiency. Patients with creatinine clearance values of 40 mL/min or less require dose adjustments</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Geriatric Use</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:PatientCondition rdf:about="http://example.org/ontology#W021">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W021</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Decrease in Potassium Level</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A high sodium load associated with the use of IVOZFO™ may result in decreased levels of potassium in serum or plasma. A low-sodium diet is recommended during treatment. The substitution of potassium may be necessary in some cases. Serum electrolyte levels and water balance must be monitored regularly during therapy</onto:hasWarningText>
</onto:PatientCondition>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W023">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W023</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use during pregnancy only if clearly needed and prescribed by a doctor.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pregnancy</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP018">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP018</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Check electrolyte levels (especially potassium) during prolonged therapy.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP020">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP020</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Watch for severe diarrhea that may indicate C. difficile infection.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP022">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP022</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Complete the full prescribed duration even if symptoms improve early.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP014">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP014</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use IV fosfomycin only for confirmed or strongly suspected bacterial infections. It should not be used for viral infections.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP023">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP023</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use proper infection control practices in hospital settings to prevent the spread of resistant bacteria.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP015">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP015</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reserve IV fosfomycin for serious infections or resistant bacteriawhen other antibiotics are not effective.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP016">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP016</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Adjust dose based on kidney function to avoid toxicity.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP019">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP019</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor sodium levels in patients with heart failure, hypertension, or fluid retention.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP024">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP024</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid unnecessary combination with other nephrotoxic drugs unless clearly needed.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP017">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP017</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor kidney function during treatment, especially in patients with renal impairment.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:Reference rdf:about="http://example.org/ontology#R021">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">R021</rdfs:label>
  <onto:hasAuthor rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DrugBank</onto:hasAuthor>
  <onto:hasReferenceTitle rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fosfomycin</onto:hasReferenceTitle>
  <onto:retrievedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://go.drugbank.com/drugs/DB00828</onto:retrievedFrom>
  <onto:publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</onto:publishedIn>
</onto:Reference>

<onto:AcutePyelonephritis rdf:about="http://example.org/ontology#I023">
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R027"/>
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#Severe"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Severe Acute Pyelonephritis</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">High fever, flank or back pain, chills, nausea, vomiting, painful urination</onto:hasSymptoms>
</onto:AcutePyelonephritis>

<onto:HospitalAcquiredPneumoniaHAP rdf:about="http://example.org/ontology#I024">
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#Severe"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Severe Hospital-Acquired Pneumonia (HAP)</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cough, fever, shortness of breath, chest pain, thick mucus</onto:hasSymptoms>
</onto:HospitalAcquiredPneumoniaHAP>

<onto:VentilatorAssociatedPneumoniaVAP rdf:about="http://example.org/ontology#I025">
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#Severe"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Severe Ventilator-Associated Pneumonia (VAP)</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fever, worsening breathing, increased secretions, low oxygen levels</onto:hasSymptoms>
</onto:VentilatorAssociatedPneumoniaVAP>

<onto:ComplicatedUrinaryTractInfectionCUTI rdf:about="http://example.org/ontology#I017">
  <onto:hasReference rdf:resource="http://example.org/ontology#R026"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R027"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#ModerateToSevere"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Moderate to Severe Complicated Urinary Tract Infection (cUTI)</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Painful urination, frequent urination, fever, lower abdominal pain, cloudy or foul-smelling urine.</onto:hasSymptoms>
</onto:ComplicatedUrinaryTractInfectionCUTI>

<onto:Somnolence rdf:about="http://example.org/ontology#SE054">
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R037"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Somnolence</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Minor side effect; feeling tired and wanting to fall asleep</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Somnolence>

<onto:Reference rdf:about="http://example.org/ontology#R037">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">R037</rdfs:label>
  <onto:hasReferenceTitle rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Azcotil</onto:hasReferenceTitle>
  <onto:hasAuthor rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monthly Index of Medical Specialties</onto:hasAuthor>
  <onto:publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</onto:publishedIn>
  <onto:retrievedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://www.mims.com/philippines/drug/info/azcotil/presentation-and-price</onto:retrievedFrom>
</onto:Reference>

<onto:PatientCondition rdf:about="http://example.org/ontology#W068">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W068</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Taking can cause rare serious allergic reactions (including angioneurotic oedema, anaphylaxis, which have been rarely fatal) and dermatologic reactions, such as acute generalised exanthematous pustulosis (AGEP), Stevens-Johnson syndrome, toxic epidermal necrolysis (rarely fatal), and drug reaction with eosinophilia and systemic symptoms (DRESS), have been reported. Some reactions have required prolonged observation and treatment. If any of these hypersensitivity reactions occur, discontinue azithromycin immediately and institute appropriate emergency therapy.</onto:hasWarningText>
</onto:PatientCondition>

<onto:Reference rdf:about="http://example.org/ontology#R048">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">R048</rdfs:label>
  <onto:retrievedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://my.clevelandclinic.org/health/drugs/18631-bismuth-subsalicylate-tablets</onto:retrievedFrom>
  <onto:hasReferenceTitle rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bismuth Subsalicylate Tablets</onto:hasReferenceTitle>
  <onto:hasAuthor rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cleveland Clinic</onto:hasAuthor>
  <onto:publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</onto:publishedIn>
</onto:Reference>

