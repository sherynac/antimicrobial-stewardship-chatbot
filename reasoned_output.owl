  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patients must not take when they have hypersensitivity to ciprofloxacin and other quinolone antibiotics</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity</onto:hasWarningHeadline>
</onto:Contraindication>

<onto:Contraindication rdf:about="http://example.org/ontology#W209">
