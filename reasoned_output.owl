  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">is involved in</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://example.org/ontology#sideEffectOf">
  <rdfs:domain rdf:resource="http://example.org/ontology#SideEffect"/>
  <rdfs:range rdf:resource="http://example.org/ontology#Brand"/>
  <owl:inverseOf rdf:resource="http://example.org/ontology#hasSideEffect"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">side effect of</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://example.org/ontology#warningOf">
  <owl:inverseOf rdf:resource="http://example.org/ontology#hasWarning"/>
  <rdfs:domain rdf:resource="http://example.org/ontology#Warning"/>
  <rdfs:range rdf:resource="http://example.org/ontology#Brand"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://example.org/ontology#hasAdministrationAndAdherenceRule">
  <rdfs:domain rdf:resource="http://example.org/ontology#Brand"/>
  <rdfs:range rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">has administration &amp; adherence rule</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://example.org/ontology#isPresentationOf">
  <owl:inverseOf rdf:resource="http://example.org/ontology#hasPresentation"/>
  <rdfs:domain rdf:resource="http://example.org/ontology#PresentationOrPacking"/>
  <rdfs:range rdf:resource="http://example.org/ontology#Brand"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://example.org/ontology#hasTherapeuticUseAndMonitoringRule">
  <rdfs:domain rdf:resource="http://example.org/ontology#Brand"/>
  <rdfs:range rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
