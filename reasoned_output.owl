  <onto:retrievedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://my.clevelandclinic.org/health/symptoms/24932-paresthesia</onto:retrievedFrom>
  <onto:publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2023</onto:publishedIn>
  <onto:hasAuthor rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cleveland Clinic</onto:hasAuthor>
</onto:Reference>

<onto:Contraindication rdf:about="http://example.org/ontology#W269">
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W269</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Anuria or Oliguria</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This medicine should not be used in patients who are not producing urine (anuria) or producing very little urine (oliguria). Because the drug is removed through the urine, it will not work properly and may build up in the body, increasing the risk of side effects.</onto:hasWarningText>
</onto:Contraindication>

