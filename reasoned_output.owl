<onto:Interaction rdf:about="http://example.org/ontology#ITN141">
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S115"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN141</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant use with Clarithromycin.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Potentiates anticoagulant effects; risk of serious hemorrhage and significant elevations in INR and prothrombin time.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Frequently monitor prothrombin time and International Normalized Ratio (INR).</onto:hasManagementAdvice>
</onto:Interaction>

