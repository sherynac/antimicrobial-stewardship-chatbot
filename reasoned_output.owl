<onto:Interaction rdf:about="http://example.org/ontology#ITN246">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S165"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R158"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN246</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This drug reduces the kidney's ability to remove nitrofurantoin from the body, which can make the antibiotic stay longer in the bloodstream.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Higher levels of nitrofurantoin in the body can increase the risk of side effects such as nausea, liver problems, nerve issues, and general toxicity.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid taking probenecid and nitrofurantoin together. If combination is necessary, monitor closely for side effects and adjust dosage under medical supervision.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Reference rdf:about="http://example.org/ontology#R230">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">R230</rdfs:label>
