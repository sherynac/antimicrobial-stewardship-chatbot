<onto:PatientCondition rdf:about="http://example.org/ontology#W276">
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W276</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Risk of Peripheral Neuropathy</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Withdraw if signs of peripheral neuropathy occur.</onto:hasWarningText>
</onto:PatientCondition>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W272">
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W272</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nitrofurantoin passes into breastmilk in very small amounts. Caution should be used when giving this medicine to breastfeeding mothers, and the infant should be observed for any unusual symptoms.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lactation</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:Contraindication rdf:about="http://example.org/ontology#W268">
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W268</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Do not use Nitrofurantoin  if the patient has a known allergy to this medicine. Taking it again may cause serious allergic reactions such as skin rash, swelling, breathing difficulty, or other harmful effects.</onto:hasWarningText>
</onto:Contraindication>

<onto:PatientCondition rdf:about="http://example.org/ontology#W275">
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W275</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patients who already have lung, liver, nerve, or allergic conditions should use this medicine with caution. These existing problems may increase the risk of serious side effects.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pre-Existing Pulmonary, Hepatic, Neurological, or Allergic Disorders</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:Contraindication rdf:about="http://example.org/ontology#W270">
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W270</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patients with hepatitis should not use this medicine.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hepatitis</onto:hasWarningHeadline>
</onto:Contraindication>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W271">
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W271</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nitrofurantoin should not be used during pregnancy (labor and delivery).</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pregnancy at Term</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:PatientCondition rdf:about="http://example.org/ontology#W274">
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W274</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Elderly patients using this medicine for a long time should have their liver and lung function checked regularly. Older adults may be more sensitive to possible side effects affecting the lungs of liver.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Elderly</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W273">
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W273</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This medicine should not be given to infants younger than 1 month old.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Infants Under 1 Month</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:Anorexia rdf:about="http://example.org/ontology#SE549">
  <onto:whichIs rdf:resource="http://example.org/ontology#Can_develop_gradually_while_taking_the_medicine"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Anorexia</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reduced desire to eat or feeling full quickly. The patient may eat less than usual because of stomach discomfort.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May last during the period of treatment</onto:hasDuration>
</onto:Anorexia>

<onto:PulmonaryHypersensitivityReaction rdf:about="http://example.org/ontology#SE552">
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#May_appear_during_therapy__especially_with_prolonged_use"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pulmonary Hypersensitivity Reaction</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An allergic-type reaction affecting the lungs. Symptoms may include cough, chest pain, fever, or difficulty breathing. Immediate medical attention is needed.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Can occur suddenly and may become serious if not treated</onto:hasDuration>
</onto:PulmonaryHypersensitivityReaction>

<onto:ErythemaMultiforme rdf:about="http://example.org/ontology#SE555">
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare_skin_reaction_during_use"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Erythema Multiforme</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A skin condition causing red patches, spots, or blister-like lesions on the skin. It may be mild or severe.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Duration varies; may resolve after stopping the drug</onto:hasDuration>
</onto:ErythemaMultiforme>

<onto:LupusLikeSyndrome rdf:about="http://example.org/ontology#SE556">
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare_and_usually_associated_with_long-term_use"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lupus-like Syndrome</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nat develop during prolonged therapy; improves after stopping medicine</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A reaction that causes symptoms similar to lupus, such as joint pain, muscle pain, fever, and skin rash. Symptoms usually improve when the medicine is discontinued.</onto:hasSideEffectDescription>
</onto:LupusLikeSyndrome>

<onto:AbdominalPain rdf:about="http://example.org/ontology#SE550">
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Can_appear_during_early_treatment"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Abdominal Pain</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Usually temporary; may last several hours to days</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pain or discomfort in the stomach or lower belly area. It may feel like cramping, pressure, or aching.</onto:hasSideEffectDescription>
</onto:AbdominalPain>

<onto:ExfoliativeDermatitis rdf:about="http://example.org/ontology#SE554">
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare_but_serious_reaction_during_treatment"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Exfoliative Dermatitis</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Duration varies; may last until medicine is stopped</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Severe skin reaction where the skin becomes red, irritated, and may peel off. Medical attention is required immediately.</onto:hasSideEffectDescription>
</onto:ExfoliativeDermatitis>

<onto:PeripheralNeuropathy rdf:about="http://example.org/ontology#SE553">
  <onto:whichIs rdf:resource="http://example.org/ontology#More_likely_with_prolonged_use_or_in_high-risk_patients"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Peripheral Neuropathy</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nerve damage that causes numbness, tingling, burning sensation, or weakness in the hands and feet. Treatment should be stopped if symptoms appear.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May develop gradually and can be long-lasting or permanent if not stopped early</onto:hasDuration>
</onto:PeripheralNeuropathy>

<onto:Nausea rdf:about="http://example.org/ontology#SE547">
  <onto:whichIs rdf:resource="http://example.org/ontology#Commonly_appears_early_in_treatment__especially_if_taken_without_food"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nausea</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term; may last a few hours to a few days</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A feeling of sickness in the stomach that may make the patient feel like vomiting. It may improve when the medicine is taken with meals.</onto:hasSideEffectDescription>
</onto:Nausea>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP176">
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP176</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">During prolonged therapy, especially in elderly patients, liver and lung function should be checked regularly. Patients with existing lung, liver, nerve, or kidney problems should be monitored closely. If symptoms such as breathing difficulty, numbness, tingling, or weakness occur, the medicine should be stopped and medical advice sought immediately.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP177">
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP177</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">To reduce the risk of side effects, avoid use in patients with contraindications such as anuria, oliguria, hepatitis, late pregnancy, or infants under 1 month old. Careful patient selection helps prevent serious complications.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP174">
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP174</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nitrofurantoin should only be used to treat urinary tract infections caused by bacteria that are sensitive to the medicine. It should not be used for viral infections or infections outside the urinary tract. Using the medicine only when needed helps prevent bacteria from becoming resistant and keeps the drug effective in the future.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:BladderInfection rdf:about="http://example.org/ontology#I059">
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#MildToModerate"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild to Moderate Bladder Infection</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pain or pressure in the lower abdomen and a burning feeling during urination. The person may need to urinate very often. Urine may appear cloudy and sometimes may have small amounts of blood.</onto:hasSymptoms>
</onto:BladderInfection>

<onto:RecurrentUrinaryTractInfection rdf:about="http://example.org/ontology#I060">
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild to Moderate (can worsen if untreated) Recurrent Urinary Tract Infection</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Repeated episodes of urinary burning, urgency, and discomfort that happen several times over a period of months. Symptoms are similar to previous bladder infections.</onto:hasSymptoms>
</onto:RecurrentUrinaryTractInfection>

<onto:Interaction rdf:about="http://example.org/ontology#ITN260">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S179"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN260</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The medicine may not work as effectively, and the infection may persist or return.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid unnecessary use of urinary alkalinisers while taking Nitrofurantoin. Inform your doctor about all medications being used.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Urinary alkalinisers increase urine pH (make urine more alkaline), which can decrease the activity of Nitrofurantoin.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN259">
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S178"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN259</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use cautiously. The doctor may monitor treatment response and adjust therapy if needed.</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reduced antibacterial activity may occur, leading to incomplete treatment of urinary tract infections.</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Carbonic anhydrase inhibitors reduce the effectiveness of Nitrofurantoin by making the urine less acidic. Nitrofurantoin works better in acidic urine.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN255">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S174"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN255</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid using together unless prescribed by a doctor. The healthcare provider may monitor closely for side effects or adjust the treatment if necessary.</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Higher levels of Nitrofurantoin may build up in the blood, increasing the risk of side effects. At the same time, lower levels in the urine may reduce its ability to effectively kill bacteria in urinary tract infections.</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Probenecid reduces the kidney's ability to remove Nitrofurantoin from the body through urine. This causes the drug to stay longer in the bloodstream instead of being properly excreted into the urine where it is needed to treat infection.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN257">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S176"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN257</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid taking magnesium-containing antacids at the same time. If necessary, separate doses by several hours. Consult a healthcare provider before combining.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Magnesium Trisilicate reduces the absorption of Nitrofurantoin from the stomach and intestines. This means less of the antibiotic enters the bloodstream.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lower absorption can reduce the amount of medicine reaching the urine. making treatment less effective. The infection may not fully clear.</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Storage rdf:about="http://example.org/ontology#SP178">
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP178</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Store Nitrofurantoin at temperatures not exceeding 30°C. Keep it in a dry place away from direct heat and moisture. Proper storage ensures that the medicine remains stable and effective until its expiration date.</onto:hasStewardshipDescription>
</onto:Storage>

<onto:Reference rdf:about="http://example.org/ontology#R124">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">R124</rdfs:label>
  <onto:hasAuthor rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cleveland Clinic</onto:hasAuthor>
  <onto:publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</onto:publishedIn>
