  <onto:hasAuthor rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cleveland Clinic</onto:hasAuthor>
  <onto:retrievedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://my.clevelandclinic.org/health/diseases/17413-rashes-red-skin</onto:retrievedFrom>
</onto:Reference>

<onto:Interaction rdf:about="http://example.org/ontology#ITN249">
  <onto:hasReference rdf:resource="http://example.org/ontology#R161"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S168"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN249</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Because less Macrobid reaches your bloodstream and urine, the infection may not get treated properly. You may have ongoing symptoms of urinary tract infection like pain, burning, or frequent urination.</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antacids that contain magnesium trisilicate can stick to Macrobid in your stomach and gut, which lowers the amount of the antibiotic that your body can absorb. This makes Macrobid less able to fight the bacteria causing your infection.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid taking these antacids while on Macrobid. If you must take an antacid, separate the doses by at least 2-3 hours. Always tell your doctor or pharmacist about any antacids you are using.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Reference rdf:about="http://example.org/ontology#R161">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">R161</rdfs:label>
