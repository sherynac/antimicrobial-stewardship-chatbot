</onto:Reference>

<onto:Pattern rdf:about="http://example.org/ontology#Can_appear_after_taking_first_doses">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Can appear after taking first doses</rdfs:label>
</onto:Pattern>

<onto:PatientCondition rdf:about="http://example.org/ontology#W249">
  <onto:hasReference rdf:resource="http://example.org/ontology#R157"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W249</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Should not be used if kidneys are not workingas well as they should be. If there is a concern about the health of the kidneys, the healthcare provider may do tests to determine if the kidneys are working well enough to take this medicine.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidney Disease Warning</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:Pattern rdf:about="http://example.org/ontology#Frequent">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Frequent</rdfs:label>
</onto:Pattern>

