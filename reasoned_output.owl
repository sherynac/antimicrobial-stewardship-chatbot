  <onto:publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</onto:publishedIn>
  <onto:hasAuthor rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monthly Index of Medical Specialties</onto:hasAuthor>
</onto:Reference>

<onto:Reference rdf:about="http://example.org/ontology#R163">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">R163</rdfs:label>
  <onto:hasAuthor rdf:datatype="http://www.w3.org/2001/XMLSchema#string">John P. Cunha, DO, FACOEP (RxList)</onto:hasAuthor>
  <onto:retrievedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://www.rxlist.com/furadantin-drug.htm#description</onto:retrievedFrom>
