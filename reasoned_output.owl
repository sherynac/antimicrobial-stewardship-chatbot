  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Consume alcohol moderately; avoid excessie drinking while ill or in antibiotics.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">No known interaction with beer; alcohol may affect general health while taking antibiotics.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None specifically reported for Fosfomycin Tromethamine.</onto:hasClinicalEffects>
