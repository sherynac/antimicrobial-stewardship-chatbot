<onto:AllergicReaction rdf:about="http://example.org/ontology#SE642">
  <onto:hasReference rdf:resource="http://example.org/ontology#R008"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R221"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">allergic reaction</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">immune system overreacts to something that’s usually not harmful — like pollen, pet dander and certain foods</onto:hasSideEffectDescription>
</onto:AllergicReaction>

<onto:Anxiety rdf:about="http://example.org/ontology#SE587">
  <onto:whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R008"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R225"/>
