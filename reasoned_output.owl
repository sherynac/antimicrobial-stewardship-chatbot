<onto:Interaction rdf:about="http://example.org/ontology#ITN069">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S039"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R032"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN069</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cefuroxime may enhance anticoagulant effect</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor INR closely, adjust anticoagulant dose as needed</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased risk of bleeding, elevated INR</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN068">
  <onto:hasReference rdf:resource="http://example.org/ontology#R032"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S038"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN068</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased risk of kidney damage (AKI), elevated creatinine</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Possible additive nephrotoxicity when given concurrently</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor renal function (BUN, creatinine), ensure hydration, adjust dose if needed</onto:hasManagementAdvice>
</onto:Interaction>

