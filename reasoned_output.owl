<onto:Interaction rdf:about="http://example.org/ontology#ITN005">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S004"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R024"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN005</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lower blood and urine levels of fosfomycin.</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Metoclopramide may lower the absorption of Fosfomycin Tromethamine by speeding up digestion.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid using together with Fosfomycin if possible. If needed, monitor for treatment effectiveness.</onto:hasManagementAdvice>
</onto:Interaction>

