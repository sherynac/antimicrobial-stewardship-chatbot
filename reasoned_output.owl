<onto:Interaction rdf:about="http://example.org/ontology#ITN172">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S095"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R013"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN172</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reduction of dose may be necessary</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant therapy of tetracycline with anticoagulants may result to prolongation of prothrombin time. Reduction of dose may be necessary.</onto:hasInteractionDescription>
