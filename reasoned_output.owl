<onto:Interaction rdf:about="http://example.org/ontology#ITN066">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S042"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN066</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased likelihood of allergic skin reactions</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Inform your doctor if you are taking allopurinol</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Administered concurrently during treatment with amoxicillin</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN061">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S041"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN061</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Be aware of potential reduced effectiveness of birth control while taking this antibiotic</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Amoxil may affect gut flora, leading to lower estrogen reabsorption</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reduced efficacy of oral contraceptives</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN064">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S040"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN064</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Probenecid decreases the renal tubular secretion of amoxicillin</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant use should be managed by a healthcare provider</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased and prolonged blood levels of amoxicillin</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN060">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S040"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN060</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Probenecid decreases the renal tubular secretion of amoxicillin</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant use should be managed by a healthcare provider</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased and prolonged blood levels of amoxicillin</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN062">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S042"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN062</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased likelihood of allergic skin reactions</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Inform your doctor if you are taking allopurinol</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Administered concurrently during treatment with amoxicillin</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN065">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S041"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN065</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Amoxil may affect gut flora, leading to lower estrogen reabsorption</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reduced efficacy of oral contraceptives</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Be aware of potential reduced effectiveness of birth control while taking this antibiotic</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN067">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S043"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN067</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rare cases of increased INR have been reported in the literature for patients on these medications</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Potential for altered blood clotting (increased INR)</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Prothrombin time or INR should be carefully monitored when starting or stopping Amoxil</onto:hasManagementAdvice>
</onto:Interaction>

<onto:PatientCondition rdf:about="http://example.org/ontology#W086">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W086</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Should be avoided if infectious mononucleosis is suspected due to risk of morbilliform rash.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Infectious Mononucleosis</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:PatientCondition rdf:about="http://example.org/ontology#W088">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W088</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dosage adjustment required in patients with renal impairment.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Renal Impairment</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W094">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W094</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hemodialysis</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Can be removed from circulation by hemodialysis.</onto:hasWarningText>
</onto:AgeRestriction>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W090">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W090</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pregnancy</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The safety of use in human pregnancy has not been established by well-controlled studies in pregnant women. May be used in pregnancy when the potential benefits outweigh the potential risks associated with treatment.</onto:hasWarningText>
</onto:PregnancyAndLactation>

<onto:PatientCondition rdf:about="http://example.org/ontology#W097">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W097</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Newborn Jaundice Risk</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contains sodium benzoate which is a mild irritant to the skin, eyes and mucus membrane. It may increase risk of jaundice in newborn babies</onto:hasWarningText>
</onto:PatientCondition>

<onto:Contraindication rdf:about="http://example.org/ontology#W085">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W085</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Should not be given to patients with a history of hypersensitivity to β-lactam antibiotics (e.g., penicillins, cephalosporins).</onto:hasWarningText>
</onto:Contraindication>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W092">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W092</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May cause nausea, vomiting, diarrhea, and electrolyte imbalance. Treat symptomatically.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gastrointestinal Effects</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:PatientCondition rdf:about="http://example.org/ontology#W095">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W095</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Phenylketonuria</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contains aspartame (source of phenylalanine). Use with caution in patients with phenylketonuria.</onto:hasWarningText>
</onto:PatientCondition>

<onto:PatientCondition rdf:about="http://example.org/ontology#W096">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W096</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May contain sorbitol. Caution in patients with sugar intolerance.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sugar Intolerance</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:PatientCondition rdf:about="http://example.org/ontology#W089">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W089</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May prolong prothrombin time (INR). Monitor INR and adjust anticoagulant dose if prescribed concurrently.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent Anticoagulant Use</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W098">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W098</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Newborns &amp; Infants</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use with caution in newborns due to risk of jaundice from sodium benzoate.</onto:hasWarningText>
</onto:AgeRestriction>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W093">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W093</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">High doses may cause crystalluria, potentially leading to renal failure. Maintain adequate fluid intake.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Crystalluria &amp; Renal Risk</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:PatientCondition rdf:about="http://example.org/ontology#W087">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W087</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antibiotic use may cause mild to life-threatening pseudomembranous colitis. Discontinue if prolonged or significant diarrhea or abdominal cramps occur.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pseudomembranous Colitis</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP067">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP067</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor for superficial tooth discoloration, a side effect specific to the liquid forms; this can often be prevented by maintaining good oral hygiene</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP064">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP064</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The bottle must be shaken well before taking each dose to ensure the medication is evenly distributed</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP059">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP059</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Administered orally as a solid dosage form. General medical practice for antibiotics involves taking the medication for the full prescribed duration even if symptoms improve.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP062">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP062</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ensure doses are taken at regular intervals as prescribed to maintain effective blood levels.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP061">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP061</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor for common side effects such as skin rash, nausea, and diarrhea. If taking anticoagulants, prothrombin time or INR should be carefully monitored when starting or stopping treatment.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP068">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP068</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Complete the full 7-day potency period as prescribed; any remaining reconstituted liquid should be discarded after 7 days</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP063">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP063</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reconstitution is required before use: 1. Loosen powder by shaking. 2. Add water up to 2/3 of the mark on the label. 3. Shake well for 1 minute, then let stand for 1 minute. 4. Add water exactly to the mark and shake well for 30 seconds</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:Bronchopneumonia rdf:about="http://example.org/ontology#I038">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R083"/>
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#MildToSevere"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild to severe Bronchopneumonia</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">fever, cough, shortness of breath, chest pain, rapid breathing, sweating, chills, headaches, muscle aches, pleurisy, fatigue, confusion or delirium</onto:hasSymptoms>
</onto:Bronchopneumonia>

<onto:Storage rdf:about="http://example.org/ontology#SP066">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP066</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Once water is added (reconstituted), the drops must be stored at refrigerated temperatures (between 2-8°C). The medicine will retain its potency for 7 days under these conditions</onto:hasStewardshipDescription>
</onto:Storage>

<onto:Storage rdf:about="http://example.org/ontology#SP060">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP060</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Store the capsules in a dry place at temperatures not exceeding 25°C</onto:hasStewardshipDescription>
</onto:Storage>

<onto:Storage rdf:about="http://example.org/ontology#SP065">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP065</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Before the water is added, the powder should be stored in a dry place at temperatures not exceeding 25°C</onto:hasStewardshipDescription>
</onto:Storage>

<onto:Interaction rdf:about="http://example.org/ontology#ITN194">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S151"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN194</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Neutropenia was observed in subjects receiving concomitant treatment of azithromycin and ribafutin. Although neutropenia has been associated with the use of ribafutin, a causal relationship to combination with azithromycin has not been established.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Co-administration did not affect the serum concentrations of either products</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Drug rdf:about="http://example.org/ontology#S151">
  <onto:hasReference rdf:resource="http://example.org/ontology#R108"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ribafutin</rdfs:label>
  <onto:hasSubstanceDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An antibiotic used to treat infections caused by bacteria called mycobacteria which cannot be destroyed by usual antibiotics</onto:hasSubstanceDescription>
</onto:Drug>

