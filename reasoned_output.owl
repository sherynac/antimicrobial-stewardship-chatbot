  <onto:hasReference rdf:resource="http://example.org/ontology#R161"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Magnesium Trisilicate</rdfs:label>
  <onto:hasSubstanceDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Medicine used to reduce stomach acid; can reduce Macrobid absorption.</onto:hasSubstanceDescription>
</onto:Drug>

