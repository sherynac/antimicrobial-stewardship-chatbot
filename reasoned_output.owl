  <onto:publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2024</onto:publishedIn>
  <onto:hasAuthor rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sanjai Sinha</onto:hasAuthor>
  <onto:hasReferenceTitle rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Macrobid</onto:hasReferenceTitle>
</onto:Reference>

