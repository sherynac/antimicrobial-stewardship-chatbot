  <onto:hasSubstanceDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">pills preventing pregnancy</onto:hasSubstanceDescription>
</onto:Drug>

<onto:Drug rdf:about="http://example.org/ontology#S156">
  <onto:hasReference rdf:resource="http://example.org/ontology#R112"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R111"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Naproxen and chloroquine</rdfs:label>
  <onto:hasSubstanceDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Naproxen helps relieve inflammation and pain associated with muscle, joint or tendon disorders.; Chloroquine is used to prevent and treat malaria. It is also used to treat liver infection caused by protozoa (extraintestinal amebiasis).</onto:hasSubstanceDescription>
</onto:Drug>

