  <onto:whichIs rdf:resource="http://example.org/ontology#Rare__can_happen_anytime"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Allergic Reactions</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rash, swelling, anaphylaxis.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Minutes to Hours</onto:hasDuration>
</onto:AllergicReactions>

<onto:LiverProblems rdf:about="http://example.org/ontology#SE545">
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Liver Problems</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Jaundice, liver inflammation.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Days to Weeks</onto:hasDuration>
</onto:LiverProblems>

<onto:Dizziness rdf:about="http://example.org/ontology#SE538">
  <onto:hasReference rdf:resource="http://example.org/ontology#R164"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#May_appear_after_dose"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DIzziness</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Feeling lightheaded or unsteady.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Few hours</onto:hasDuration>
</onto:Dizziness>

<onto:Vomiting rdf:about="http://example.org/ontology#SE533">
  <onto:hasReference rdf:resource="http://example.org/ontology#R164"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Often_appears_when_starting_the_drug"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vomiting</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Throwing up.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Few hours to 1 day</onto:hasDuration>
</onto:Vomiting>

<onto:SeriousPulmonaryReaction rdf:about="http://example.org/ontology#SE542">
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare__usually_with_long-term_use__6__months_"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Serious Pulmonary Reaction</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cough, fever, chest pain, shortness of breath.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Weeks to Months</onto:hasDuration>
</onto:SeriousPulmonaryReaction>

<onto:HemolyticAnemia rdf:about="http://example.org/ontology#SE544">
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R164"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare__in_infants__1_month_or_G6PD_deficiency"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hemolytic Anemia</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Days</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Blood cells break down, causing tiredness, pale skin.</onto:hasSideEffectDescription>
</onto:HemolyticAnemia>

<onto:VaginalItchingOrDischarge rdf:about="http://example.org/ontology#SE541">
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R164"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#May_appear_during_or_after_treatment"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vaginal Itching or Discharge</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Itchy or unusual vaginal discharge.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Few days</onto:hasDuration>
</onto:VaginalItchingOrDischarge>

<onto:Drowsiness rdf:about="http://example.org/ontology#SE539">
  <onto:whichIs rdf:resource="http://example.org/ontology#May_appear_after_dose"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R164"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Drowsiness</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Few hours</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Feeling sleepy.</onto:hasSideEffectDescription>
</onto:Drowsiness>

<onto:Diarrhea rdf:about="http://example.org/ontology#SE536">
  <onto:whichIs rdf:resource="http://example.org/ontology#May_appear_anytime__can_be_mild_or_severe"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R164"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diarrhea</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Loose stools.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Few days</onto:hasDuration>
</onto:Diarrhea>

<onto:RustColoredUrine rdf:about="http://example.org/ontology#SE540">
  <onto:hasReference rdf:resource="http://example.org/ontology#R164"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Appears_when_on_drug"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rust-colored Urine</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Urine changes color, harmless.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">While taking drug</onto:hasDuration>
</onto:RustColoredUrine>

<onto:UpsetStomach rdf:about="http://example.org/ontology#SE535">
  <onto:whichIs rdf:resource="http://example.org/ontology#Usually_appears_at_start"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R164"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Upset Stomach</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Stomach discomfort or mild pain.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Few hours to 1 day</onto:hasDuration>
</onto:UpsetStomach>

<onto:PeripheralNeuropathy rdf:about="http://example.org/ontology#SE543">
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare__usually_with_long-term_use_or_kidney_problems"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Peripheral Neuropathy</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Weeks to Months</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Numbness, tingling, or weakness in hands/feet.</onto:hasSideEffectDescription>
</onto:PeripheralNeuropathy>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W263">
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W263</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pediatric Restriction</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Children under 1 month should not take this drug.</onto:hasWarningText>
</onto:AgeRestriction>

<onto:PatientCondition rdf:about="http://example.org/ontology#W261">
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R164"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W261</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">G6PD Deficiency</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">People with G6PD deficiency are at risk for hemolytic anemia from furadantin exposure</onto:hasWarningText>
</onto:PatientCondition>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W266">
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W266</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Incidents of acute overdosage of FURADANTIN have resulted in symptoms such as vomiting. Induction of emesis is recommended. There is no specific antidote, but a high fluid intake should be maintained to promote urinary excretion of the drug. Nitrofurantoin is dialyzable.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Acute Overdose</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W262">
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W262</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">pregnant patients at term (38 weeks to 42 weeks gestation), during labor and delivery, or when the onset of labor is imminent and in pediatric patients younger than 1 month of age because of the possibility of hemolytic anemia due to immature erythrocyte enzyme systems (glutathione instability)</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Do not use near term or in infants under 1 month</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:Contraindication rdf:about="http://example.org/ontology#W267">
  <onto:hasReference rdf:resource="http://example.org/ontology#R164"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W267</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Allergic to Furadantin (nitrofurantoin oral suspension); any part of Furadantin (nitrofurantoin oral suspension); or any other drugs, foods, or substances.</onto:hasWarningText>
</onto:Contraindication>

<onto:PatientCondition rdf:about="http://example.org/ontology#W264">
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W264</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">patients who have anuria, oliguria, or significant impairment of renal function (creatinine clearance under 60 mL per minute or clinically significant elevated serum creatinine) due to an increased risk of toxicity resulting from impaired excretion of the drug</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Renal Impairment</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:PatientCondition rdf:about="http://example.org/ontology#W265">
  <onto:hasReference rdf:resource="http://example.org/ontology#R164"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W265</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Notify healthcare provider if patient developed liver problems before due to furadantin (nitrofurantoin oral suspension) intake</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">History of Liver Problems</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP172">
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP172</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Watch for side effects like lung problems, liver issues, or nerve problems, especially with long-term use.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP170">
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R164"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP170</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Complete full course even if you feel better, to prevent bacteria from coming back.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP171">
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R164"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP171</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Take doses with food and at the same time each day; measure liquid carefully.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP169">
  <onto:hasReference rdf:resource="http://example.org/ontology#R164"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP169</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Take Furadantin only for urinary tract infections, do not use for colds or other viral infections.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:Interaction rdf:about="http://example.org/ontology#ITN252">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S171"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN252</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Probenecid, a uricosuric drug, can reduce kidney excretion of Furadantin, increasing drug levels in the blood.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor for side effects. Your doctor may adjust doses of Furadantin or the uricosuric drug. Report any persistent urinary symptoms.</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Higher blood levels may increase risk of side effects such as nausea, dizziness, or neuropathy, while lower drug concentration in urine can reduce effectiveness against urinary infections.</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN253">
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S172"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN253</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Blood levels of Furadantin may rise, increasing side effect risks, while effectiveness in treating urinary tract infections may decrease.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor for side effects and infection signs. Your doctor may need to adjust treatment. Avoid combining without supervision.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sulfinpyrazone, another uricosuric agent, can similarly interfere with kidney excretion of Furadantin.</onto:hasInteractionDescription>
</onto:Interaction>

