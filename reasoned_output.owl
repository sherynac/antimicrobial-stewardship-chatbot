<owl:Ontology rdf:about="file:///Users/krishiannemaealcaparras/Documents/4th Year/2nd Sem/Midterms/Thesis 2/Ontology/antimicrobial-stewardship-chatbot/ontology/output.owl"/>

<owl:ObjectProperty rdf:about="http://example.org/ontology#hasPresentation">
  <rdfs:domain rdf:resource="http://example.org/ontology#Brand"/>
  <rdfs:range rdf:resource="http://example.org/ontology#PresentationOrPacking"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">has presentation</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://example.org/ontology#hasSeverityType">
  <rdfs:domain rdf:resource="http://example.org/ontology#Indication"/>
  <rdfs:range rdf:resource="http://example.org/ontology#Severity"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">has severity type</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://example.org/ontology#hasReference">
  <rdfs:domain>
    <rdf:Description>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="http://example.org/ontology#Antibiotic"/>
        <rdf:Description rdf:about="http://example.org/ontology#Brand"/>
        <rdf:Description rdf:about="http://example.org/ontology#Indication"/>
        <rdf:Description rdf:about="http://example.org/ontology#Warning"/>
        <rdf:Description rdf:about="http://example.org/ontology#SideEffect"/>
        <rdf:Description rdf:about="http://example.org/ontology#Interaction"/>
        <rdf:Description rdf:about="http://example.org/ontology#StewardshipPrinciple"/>
        <rdf:Description rdf:about="http://example.org/ontology#Pattern"/>
        <rdf:Description rdf:about="http://example.org/ontology#Substance"/>
      </owl:unionOf>
    </rdf:Description>
  </rdfs:domain>
  <rdfs:range rdf:resource="http://example.org/ontology#Reference"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">has reference</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://example.org/ontology#treats">
  <rdfs:domain rdf:resource="http://example.org/ontology#Brand"/>
  <rdfs:range rdf:resource="http://example.org/ontology#Indication"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">treats</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://example.org/ontology#hasSideEffect">
  <rdfs:domain rdf:resource="http://example.org/ontology#Brand"/>
  <rdfs:range rdf:resource="http://example.org/ontology#SideEffect"/>
  <rdfs:inverseOf rdf:resource="http://example.org/ontology#sideEffectOf"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">has side effect</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://example.org/ontology#hasWarning">
  <rdfs:domain rdf:resource="http://example.org/ontology#Brand"/>
  <rdfs:range rdf:resource="http://example.org/ontology#Warning"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">has warning</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://example.org/ontology#hasInteraction">
  <rdfs:domain rdf:resource="http://example.org/ontology#Brand"/>
  <rdfs:range rdf:resource="http://example.org/ontology#Interaction"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">has interaction</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://example.org/ontology#hasStorageRule">
  <rdfs:domain rdf:resource="http://example.org/ontology#Brand"/>
  <rdfs:range rdf:resource="http://example.org/ontology#Storage"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">has storage rule</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://example.org/ontology#interactsWith">
  <rdfs:domain rdf:resource="http://example.org/ontology#Interaction"/>
  <rdfs:range rdf:resource="http://example.org/ontology#Substance"/>
  <owl:inverseOf rdf:resource="http://example.org/ontology#isInvolvedIn"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">interacts with</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://example.org/ontology#managedAs">
  <rdfs:domain rdf:resource="http://example.org/ontology#Brand"/>
  <rdfs:range rdf:resource="http://example.org/ontology#StewardshipPrinciple"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">managed as</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://example.org/ontology#hasBrandName">
  <rdfs:domain rdf:resource="http://example.org/ontology#Antibiotic"/>
  <rdfs:range rdf:resource="http://example.org/ontology#Brand"/>
  <owl:inverseOf rdf:resource="http://example.org/ontology#isBrandOf"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">has brand name</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://example.org/ontology#isBrandOf">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="http://example.org/ontology#Brand"/>
  <rdfs:range rdf:resource="http://example.org/ontology#Antibiotic"/>
  <owl:inverseOf rdf:resource="http://example.org/ontology#hasBrandName"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">is brand of</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://example.org/ontology#isInvolvedIn">
  <rdfs:domain rdf:resource="http://example.org/ontology#Substance"/>
  <rdfs:range rdf:resource="http://example.org/ontology#Interaction"/>
