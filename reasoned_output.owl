  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">a condition characterized by damage to the liver caused by exposure to harmful substances</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Hepatotoxicity>

