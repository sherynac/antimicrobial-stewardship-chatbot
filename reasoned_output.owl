  <onto:hasReference rdf:resource="http://example.org/ontology#R013"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R077"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">inflammatory lesions (with monilial overgrowth)</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An overgrowth of the fungus Candida causes a vaginal yeast infection. A vaginal yeast infection causes the skin around vagina to burn and itch, and it may change the consistency of vaginal discharge</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:InflammatoryLesionsWithMonilialOvergrowth>

<onto:Neutropenia rdf:about="http://example.org/ontology#SE391">
  <onto:hasReference rdf:resource="http://example.org/ontology#R190"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R077"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R013"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">neutropenia</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">having low levels of neutrophils (a type of white blood cell) in blood</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Neutropenia>

<onto:Contraindication rdf:about="http://example.org/ontology#W176">
  <onto:hasReference rdf:resource="http://example.org/ontology#R013"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W176</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The drug is contraindicated in patients who have shown hypersensitivity to any of the tetracyclines.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity</onto:hasWarningHeadline>
</onto:Contraindication>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W177">
  <onto:hasReference rdf:resource="http://example.org/ontology#R013"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W177</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The use of drugs of the tetracycline class during tooth development (last half of pregnancy, infancy and childhood to the age of 8 years) may cause permanent discoloration of the teeth (yellow-gray-brown). This adverse reaction is more common during long term use of the drugs but has been observed following repeated short-term courses. Enamel hypoplasia has also been reported. Tetracycline drugs, therefore, should not be used in this age group unless other drugs are not likely to be effective or as contraindicated.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pediatric Use</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W175">
  <onto:hasReference rdf:resource="http://example.org/ontology#R013"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W175</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">In case of overdosage, discontinue medication. Treat symptomatically and institute supportive measures. Dialysis does not alter serum half-life and thus would not be of benefit in treating cases of overdosage.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Overdose Treatment Guidance</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN173">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S096"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R013"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN173</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">bacteriostatic drugs interfere with the bactericidal action of penicillin</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Since bacteriostatic drugs interfere with the bactericidal action of penicillin, it is advisable to avoid giving tetracyclines in conjuction with penicillin</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">avoid giving tetracyclines in conjuction with penicillin</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN175">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S098"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R013"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN175</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid taking together</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Absorption of tetracyclines is impaired by Bismuth Subsalicylate</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Decreased absorption</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN176">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S099"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R013"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN176</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Decreased absorption</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid taking together</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Barbiturates decrease the half-life of doxycycline</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN174">
  <onto:hasReference rdf:resource="http://example.org/ontology#R013"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S097"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN174</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid taking together</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Decreased absorption</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Absorption of tetracyclines is impaired by antacids containing aluminum, calcium, or magnesium and iron-containing preparations</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN177">
