<onto:Leukopenia rdf:about="http://example.org/ontology#SE558">
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R276"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Leukopenia</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Leukopenia (low white blood cell count) happens when you have a lower-than-normal number of white blood cells. Specifically, you have fewer neutrophils than normal. Neutrophils are white blood cells that act as your immune system’s first line of defense. Without enough white blood cells, you’re more vulnerable to developing infections.</onto:hasSideEffectDescription>
</onto:Leukopenia>

