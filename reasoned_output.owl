  <onto:hasReference rdf:resource="http://example.org/ontology#R077"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R193"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">intracranial hypertension</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">increased pressure in skull</onto:hasSideEffectDescription>
</onto:IntracranialHypertension>

<onto:Vomiting rdf:about="http://example.org/ontology#SE341">
  <onto:hasReference rdf:resource="http://example.org/ontology#R077"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R169"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#common"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">vomiting</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">forceful ejection of some or all of the contents of the stomach through the mouth</onto:hasSideEffectDescription>
</onto:Vomiting>

<onto:Nausea rdf:about="http://example.org/ontology#SE340">
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R168"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R077"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#common"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">nausea</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">a feeling of sickness or discomfort in the stomach</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Nausea>

<onto:BulgingFontanels rdf:about="http://example.org/ontology#SE369">
  <onto:hasReference rdf:resource="http://example.org/ontology#R077"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R192"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">bulging fontanels</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">During treatment</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">outward curving of an infant's soft spot (fontanelle)</onto:hasSideEffectDescription>
</onto:BulgingFontanels>

<onto:Anaphylaxis rdf:about="http://example.org/ontology#SE358">
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R183"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R077"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#frequency_not_reported"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">anaphylaxis</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">severe, potentially life-threatening allergic reaction</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Anaphylaxis>

<onto:JarischHerxheimerReaction rdf:about="http://example.org/ontology#SE364">
  <onto:hasReference rdf:resource="http://example.org/ontology#R201"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R077"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Jarisch-Herxheimer reaction</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">new or worsening symptoms within a few hours of starting treatment for syphilis or certain other bacterial infections</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:JarischHerxheimerReaction>

<onto:Diarrhea rdf:about="http://example.org/ontology#SE338">
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R077"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#infrequent"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">diarrhea</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2 months or more</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May occur after a patient stop taking doxycycline</onto:hasSideEffectDescription>
</onto:Diarrhea>

<onto:ExfoliativeDermatitis rdf:about="http://example.org/ontology#SE354">
  <onto:hasReference rdf:resource="http://example.org/ontology#R176"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R077"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#uncommon"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">exfoliative dermatitis</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">redness and scaling of the skin</onto:hasSideEffectDescription>
</onto:ExfoliativeDermatitis>

<onto:Urticaria rdf:about="http://example.org/ontology#SE356">
  <onto:whichIs rdf:resource="http://example.org/ontology#frequency_not_reported"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R181"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R077"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">urticaria</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hives (also called urticaria) refers to raised and splotchy areas of skin that can be caused by an allergic reaction to something</onto:hasSideEffectDescription>
</onto:Urticaria>

<onto:Interaction rdf:about="http://example.org/ontology#ITN166">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S098"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN166</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Absorption of tetracyclines is impaired by Bismuth Subsalicylate</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Decreased absorption</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid taking together</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN167">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S099"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN167</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Barbiturates decrease the half-life of doxycycline</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Decreased absorption</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid taking together</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN164">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S096"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN164</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">bacteriostatic drugs interfere with the bactericidal action of penicillin</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Since bacteriostatic drugs interfere with the bactericidal action of penicillin, it is advisable to avoid giving tetracyclines in conjuction with penicillin</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">avoid giving tetracyclines in conjuction with penicillin</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN170">
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S102"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN170</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">fatal renal toxicity</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">concurrent use of tetracycline and methoxyflurane has been reported to result in fatal renal toxicity.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid taking together</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN165">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S097"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN165</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Decreased absorption</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Absorption of tetracyclines is impaired by antacids containing aluminum, calcium, or magnesium and iron-containing preparations</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid taking together</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN168">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S100"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN168</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Decreased absorption</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Carbamazepine decrease the half-life of doxycycline</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid taking together</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN171">
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S103"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN171</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">render oral contraceptives less effective</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid taking together</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent use of tetracycline may render oral contraceptives less effective</onto:hasInteractionDescription>
</onto:Interaction>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W174">
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W174</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">In case of overdosage, discontinue medication, treat symptomatically and institute supportive measures. Dialysis does not alter serum half-life and thus would not be of benefit in treating cases of overdosage.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Overdose Treatment Guidance</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:PatientCondition rdf:about="http://example.org/ontology#W173">
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W173</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Photosensitivity manifested by an exaggerated sunburn has been observed in some individuals taking tetracyclines. Patients apt to be exposed to direct sunlight or ultraviolet light should be advised that this reaction can occur with tetracycline drugs, and treatment should be discontinued at the first evidence of skin erythema.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Photosensitivity</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W172">
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W172</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">If any tetracycline is used during pregnancy or if the patient becomes pregnant while taking this drug, the patient should be apprised of the potential hazard to the fetus.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tetracycline Use in Pregnancy</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:PatientCondition rdf:about="http://example.org/ontology#W151">
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W151</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Skin Reactions</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Severe skin reactions, such as exfoliative dermatitis, erythema multiforme, Steven-Johnson syndrome, toxic epidermal necrolysis, and drug reaction with eosinophilia and systemic symptoms (DRESS) have been reported in patients receiving doxycycline.</onto:hasWarningText>
</onto:PatientCondition>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W148">
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W148</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pediatric Use</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The use of drugs of the tetracycline class during tooth development (last half of pregnancy, infancy and childhood to the age of 8 years) may cause permanent discoloration of the teeth (yellow-gray-brown).</onto:hasWarningText>
</onto:AgeRestriction>

<onto:PatientCondition rdf:about="http://example.org/ontology#W171">
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W171</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Intracranial Hypertension (Pseudotumor Cerebri)</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Intracranial hypertension (IH, pseudotumor cerebri) has been assciated with the use of tetracyclines including Doxycycline. Clinical manifestations of IH include headache, blurred vision, diplopia, and vision loss; papilledema can be found on fundoscopy. Women of childbearing age who are overweight or have history of IH are at greater risk for developing tetracycline associated IH.</onto:hasWarningText>
</onto:PatientCondition>

<onto:Contraindication rdf:about="http://example.org/ontology#W147">
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W147</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This drug is contraindicated in persons who have shown hypersensitivity to any of the tetracyclines.</onto:hasWarningText>
</onto:Contraindication>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W149">
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W149</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pediatric Use</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use doxycycline in pediatric patients 8 years of age or less only when the potential benefits are expected to outweigh the risks in severe or life-threatening conditions (e.g., anthrax, Rocky Mountain spotted fever), particularly when there are no alternative therapies.</onto:hasWarningText>
</onto:AgeRestriction>

<onto:PatientCondition rdf:about="http://example.org/ontology#W150">
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W150</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Risk of Severe Diarrhea (C. difficile Infection)</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Clostridium difficile associated diarrhea (CDAD) has been reported with use of nearly all antibacterial agents, including Doxycycline, and may range in severity from mild diarrhea to fatal colitis.</onto:hasWarningText>
</onto:PatientCondition>

<onto:LobarPneumonia rdf:about="http://example.org/ontology#I037">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R011"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R082"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#Severe"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Severe Lobar pneumonia</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">persistent cough, high-grade fever with chills, confusion or delirium, pleuritic chest pain, shortness of breath, vomiting, abdominal pain, tiredness or fatigue</onto:hasSymptoms>
</onto:LobarPneumonia>

<onto:Tracheobronchitis rdf:about="http://example.org/ontology#I043">
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#Severe"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R012"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R089"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R320"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Severe Tracheobronchitis</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">coughing, mild headaches, soreness in the chest, a sore throat, tiredness, mild body aches</onto:hasSymptoms>
</onto:Tracheobronchitis>

