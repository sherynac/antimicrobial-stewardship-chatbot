<onto:Photosensitivity rdf:about="http://example.org/ontology#SE462">
  <onto:hasReference rdf:resource="http://example.org/ontology#R063"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Photosensitivity</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Skin reacts negatively to sunlight or UV rays that causes an itchy, painful rash</onto:hasSideEffectDescription>
</onto:Photosensitivity>

<onto:Vasculitis rdf:about="http://example.org/ontology#SE463">
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R118"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vasculitis</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fever, headache, tiredness, weight loss, aches and pains.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Vasculitis>

<onto:ErythemaMultiforme rdf:about="http://example.org/ontology#SE464">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R119"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Erythema multiforme</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A red to purple rash that causes your skin to puff up (swell) and be painful to the touch.; Pimple-like blisters on your skin or inside of your mouth.; Round mark on your skin that looks like a bulls-eye on a target, with a dark center and a pale ring around it.; Itchy skin.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:ErythemaMultiforme>

<onto:Flatulence rdf:about="http://example.org/ontology#SE456">
  <onto:whichIs rdf:resource="http://example.org/ontology#Common"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Flatulence</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Body releases gas in your digestive system through your anus.</onto:hasSideEffectDescription>
</onto:Flatulence>

<onto:Tremor rdf:about="http://example.org/ontology#SE469">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R123"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tremor</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">type of body movement that’s out of your control. It looks like shakiness and can affect many different body parts.</onto:hasSideEffectDescription>
</onto:Tremor>

<onto:Vomiting rdf:about="http://example.org/ontology#SE450">
  <onto:whichIs rdf:resource="http://example.org/ontology#Common"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R057"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vomiting</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Forceful ejection stomach contents through the mouth.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Vomiting>

<onto:Pruritus rdf:about="http://example.org/ontology#SE461">
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R117"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pruritus</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Itchy skin that can affect small areas, such as the scalp, an arm or a leg or cover the whole body. Itchy come with inflamed skin, scratch marks, bumps, spots or blisters, dry, cracked skin, leathery or scaly patches</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Pruritus>

<onto:Hallucinations rdf:about="http://example.org/ontology#SE474">
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R126"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hallucinations</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false perception of objects or events involving your senses: sight, sound, smell, touch and taste.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Hallucinations>

<onto:Restlessness rdf:about="http://example.org/ontology#SE459">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R115"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Common"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Restlessness</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">pacing, constant movements of the legs, inability to sit or stand still, rocking from foot to foot, feeling tense or uncomfortable, feeling anxious</onto:hasSideEffectDescription>
</onto:Restlessness>

<onto:Drowsiness rdf:about="http://example.org/ontology#SE470">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Drowsiness</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">feeling tired and wanting to fall asleep</onto:hasSideEffectDescription>
</onto:Drowsiness>

<onto:Diarrhea rdf:about="http://example.org/ontology#SE451">
  <onto:hasReference rdf:resource="http://example.org/ontology#R076"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Common"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diarrhea</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Loose, watery stool during a bowl movement</onto:hasSideEffectDescription>
</onto:Diarrhea>

<onto:Headache rdf:about="http://example.org/ontology#SE454">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Common"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Headache</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Discomfort in the head or face</onto:hasSideEffectDescription>
</onto:Headache>

<onto:Dizziness rdf:about="http://example.org/ontology#SE458">
  <onto:whichIs rdf:resource="http://example.org/ontology#Common"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dizziness</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Feeling lightheaded or unsteady.</onto:hasSideEffectDescription>
</onto:Dizziness>

<onto:PeripheralNeuropathy rdf:about="http://example.org/ontology#SE479">
  <onto:hasReference rdf:resource="http://example.org/ontology#R131"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Peripheral neuropathy</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Peripheral neuropathy refers to any condition that affects the nerves outside your brain or spinal cord.</onto:hasSideEffectDescription>
</onto:PeripheralNeuropathy>

<onto:Dysesthesia rdf:about="http://example.org/ontology#SE480">
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R132"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dysesthesia</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dysesthesia is a set of symptoms that revolve around unusual touch-based sensations. It can refer to sensations that are unexpected or feel unpleasant, painful or just strange.</onto:hasSideEffectDescription>
</onto:Dysesthesia>

<onto:Tinnitus rdf:about="http://example.org/ontology#SE483">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R135"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tinnitus</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ringing in the ears</onto:hasSideEffectDescription>
</onto:Tinnitus>

<onto:Anaphylaxis rdf:about="http://example.org/ontology#SE468">
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R122"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">anaphylaxis</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">skin reactions, including hives and itching and flushed or pale skin; low blood pressure (hypotension); constriction of the airways and a swollen tongue or throat, which can cause wheezing and trouble breathing; a weak and rapid pulse; nausea, vomiting or diarrhea; dizziness or fainting</onto:hasSideEffectDescription>
</onto:Anaphylaxis>

<onto:StevensJohnsonSyndrome rdf:about="http://example.org/ontology#SE465">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R120"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Stevens-Johnson Syndrome</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fever, sore mouth and throat, fatigue, burning eyes, unexplained widespread skin pain, red or purple rash that spreads, blisters on your skin and the mucous membranes of the mouth, nose, eyes and genitals, shedding of skin within days after blisters form</onto:hasSideEffectDescription>
</onto:StevensJohnsonSyndrome>

<onto:ToxicEpidermalNecrolysis rdf:about="http://example.org/ontology#SE466">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R121"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Toxic epidermal necrolysis</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">It causes peeling and blistering skin over much of the body, including the mouth, eyes, and genitals.</onto:hasSideEffectDescription>
</onto:ToxicEpidermalNecrolysis>

<onto:Catatonia rdf:about="http://example.org/ontology#SE481">
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R134"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Catatonia</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Catatonia is a disorder that disrupts a person’s awareness of the world around them. People with this condition sometimes react very little or not at all to their surroundings, or might behave in ways that are unusual, unexpected or unsafe to themselves or others.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Catatonia>

<onto:Convulsions rdf:about="http://example.org/ontology#SE476">
  <onto:hasReference rdf:resource="http://example.org/ontology#R114"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Convulsions</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Surge of abnormal electrical activity in the brain. Temporary loss of consciousness and uncontrollable movements.</onto:hasSideEffectDescription>
</onto:Convulsions>

<onto:Nausea rdf:about="http://example.org/ontology#SE449">
  <onto:hasReference rdf:resource="http://example.org/ontology#R056"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Common"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nausea</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sensation of having to vomit or having the urge to vomit.</onto:hasSideEffectDescription>
</onto:Nausea>

<onto:AbdominalPain rdf:about="http://example.org/ontology#SE452">
  <onto:hasReference rdf:resource="http://example.org/ontology#R058"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Common"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Abdominal Pain</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pain felt anywhere between the chest and groin.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:AbdominalPain>

<onto:Dyspepsia rdf:about="http://example.org/ontology#SE453">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Common"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dyspepsia</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pain or discomfort in the upper abdomen</onto:hasSideEffectDescription>
</onto:Dyspepsia>

<onto:Insomnia rdf:about="http://example.org/ontology#SE471">
  <onto:hasReference rdf:resource="http://example.org/ontology#R124"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Insomnia</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Trouble falling asleep; waking up in the middle of the night but falling back asleep; waking up too early without being able to fall back asleep; feeling tired, unwell or sleepy; delayed responses, such as reacting too slowly when you’re driving; Memory issues; Slowed thinking, confusion or trouble concentrating; Mood changes, like anxiety, depression and irritability</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Insomnia>

<onto:Rash rdf:about="http://example.org/ontology#SE460">
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R116"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rash</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">red, inflamed, bumpy as well as dry, itchy or painful</onto:hasSideEffectDescription>
</onto:Rash>

<onto:Storage rdf:about="http://example.org/ontology#SP142">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP142</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Protect from direct light including sunlamps</onto:hasStewardshipDescription>
</onto:Storage>

<onto:Storage rdf:about="http://example.org/ontology#SP141">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP141</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Store at temperatures not exceeding 25°C</onto:hasStewardshipDescription>
</onto:Storage>

<onto:FoodAndTiming rdf:about="http://example.org/ontology#SP140">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP140</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Do not take with antacids, iron or dairy products</onto:hasStewardshipDescription>
</onto:FoodAndTiming>

<onto:FoodAndTiming rdf:about="http://example.org/ontology#SP139">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP139</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May be taken with meals to minimize gastrointestinal discomfort</onto:hasStewardshipDescription>
</onto:FoodAndTiming>

<onto:FoodAndTiming rdf:about="http://example.org/ontology#SP138">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP138</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May be taken with or without food</onto:hasStewardshipDescription>
</onto:FoodAndTiming>

<onto:PatientCondition rdf:about="http://example.org/ontology#W219">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W219</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patients with alkaline urine</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The risk of crystalluria is high in patients with alkaline urine</onto:hasWarningText>
</onto:PatientCondition>

<onto:PatientCondition rdf:about="http://example.org/ontology#W220">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W220</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Renal Impairment</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ciprofloxacin should be used with caution in patients with impaired renal function</onto:hasWarningText>
</onto:PatientCondition>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W216">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W216</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use it with caution if you are pregnant or a lactating mother.; Ciprofloxacin is excreted in breast milk; Ciprofloxacin was reported to cause arthralgia and degenerative changes in joints that bear weight in young animals.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pregnant and Nursing Mothers</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W222">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W222</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Elderly</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dose of ciprofloxacin should be reduced in the elderly as increased bioavailability and reduced renal clearance were seen probably due to absorption or first pass elimination</onto:hasWarningText>
</onto:AgeRestriction>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W215">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W215</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Do not take ciprofloxacin if you are a child or an adolescent. Ciprofloxacin was reported to cause arthralgia and degenerative changes in joints that bear weight in young animals.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Children and Adolescents</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:PatientCondition rdf:about="http://example.org/ontology#W214">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W214</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">If tendon pain, inflammation or rupture occurs, treatment with ciprofloxacin should be discontinued</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tendon pain, inflammation, rupture</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:PatientCondition rdf:about="http://example.org/ontology#W221">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W221</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ciprofloxacin should be used with caution in patients with severe hepatic impairment where peak plasma concentration and serum half life may be increased.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hepatic Impairment</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:PatientCondition rdf:about="http://example.org/ontology#W217">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W217</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Epileptic, history of Central Nervous System (CNS) disorders, myastenia gravis and glucose-6-phosphate dehydrogenase deficiency</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Caution should be taken when giving ciprofloxacin to epileptic patients and to those with history of Central Nervous System (CNS) disorders, myasthenia gravis and glucose-6-phosphate dehydrogenase deficiency.; Ciprofloxacin may exacerbate or unmask symptoms of myasthenia gravis.</onto:hasWarningText>
</onto:PatientCondition>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W223">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W223</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">In elderly patients treated with ciprofloxacin or urinary tract infeactions, a false postiive reaction for urinary glucose (pseudoglycosuria) has been reported.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Elderly Laboratory Results</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:Tuberculosis rdf:about="http://example.org/ontology#I053">
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R103"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tuberculosis</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A bad cough that lasts 3 weeks or longer, pain in the chest, coughing up blood or sputum (phlegm) from deep inside the lungs</onto:hasSymptoms>
</onto:Tuberculosis>

<onto:QFever rdf:about="http://example.org/ontology#I052">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R102"/>
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#MildToSevere"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild to Severe Q Fever</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">fever, fatigue, headache, malaise, myalgia, chills or sweats, cough, nausea, vomiting, diarrhea</onto:hasSymptoms>
</onto:QFever>

<onto:LegionnairesDisease rdf:about="http://example.org/ontology#I051">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R101"/>
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legionnaire's disease</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">symptoms similar to pneumonia, cough, fever, headaches, muscle aches, shortness of breath</onto:hasSymptoms>
</onto:LegionnairesDisease>

<onto:Interaction rdf:about="http://example.org/ontology#ITN207">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S088"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN207</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">In one study, seizures had developed after concomitant use of ciprofloxacin with theophylline</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ciprofloxacin may interfere with the clearance of drugs metabolized by the liver such as theophylline on account of the ability of ciprofloxacin to inhibit hepatic metabolism</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN198">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S154"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN198</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May affect ability to drive and use machines</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patients who drive and operate machines must not take ciprofloxacin with alcohol.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN212">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S157"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN212</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">In surgical infection prophylaxis, concomitant administration of ciprofloxacin with opioid analgesics is not recommended</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Peak serum concentration of ciprofloxacin is reduced significantly.</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN210">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S021"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN210</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The possibility of interfering with the absorption of fluoroquinolones may be present in dairy products with high calcium content</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN211">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S156"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN211</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Naproxen and chloroquine were found to cause adverse neurological effect with the addition of ciprofloxacin.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Effect was reduced when the antirheumatic drugs were discontinued.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN214">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S040"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN214</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Probenecid was found to reduce the urinary excretion of ciprofloxacin without increasing plasma concentration of the latter.</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN209">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S144"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN209</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May reduce absorption of ciprofloxacin and other quinolones</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sucralfate releases aluminum ions in the stomach</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN208">
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S098"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN208</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reduces absorption of ciprofloxacin as well as other fluoroquinolones.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ciprofloxacin is not recommended to be administered orally within 4 hours of taking magnesium, aluminum or iron and zinc salts-containing antacids</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Rhinitis rdf:about="http://example.org/ontology#SE110">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rhinitis</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">nasal congestion, runny nose, sneezing, itching</onto:hasSideEffectDescription>
</onto:Rhinitis>

