  <onto:treats rdf:resource="http://example.org/ontology#I030"/>
  <onto:treats rdf:resource="http://example.org/ontology#I046"/>
  <onto:treats rdf:resource="http://example.org/ontology#I039"/>
  <onto:treats rdf:resource="http://example.org/ontology#I045"/>
  <onto:treats rdf:resource="http://example.org/ontology#I004"/>
  <onto:hasInteraction rdf:resource="http://example.org/ontology#ITN150"/>
  <onto:hasInteraction rdf:resource="http://example.org/ontology#ITN149"/>
  <onto:hasInteraction rdf:resource="http://example.org/ontology#ITN147"/>
  <onto:hasInteraction rdf:resource="http://example.org/ontology#ITN148"/>
  <onto:hasInteraction rdf:resource="http://example.org/ontology#ITN151"/>
  <onto:hasWarning rdf:resource="http://example.org/ontology#W157"/>
  <onto:hasWarning rdf:resource="http://example.org/ontology#W158"/>
  <onto:hasWarning rdf:resource="http://example.org/ontology#W155"/>
  <onto:hasWarning rdf:resource="http://example.org/ontology#W154"/>
  <onto:hasWarning rdf:resource="http://example.org/ontology#W156"/>
