<onto:VaginalItchingOrDischarge rdf:about="http://example.org/ontology#SE526">
  <onto:hasReference rdf:resource="http://example.org/ontology#R161"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#May_appear_while_taking_medicine"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vaginal Itching or Discharge</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild irritation or unusual discharge in females.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Days to weeks</onto:hasDuration>
</onto:VaginalItchingOrDischarge>

<onto:AllergicReactions rdf:about="http://example.org/ontology#SE528">
  <onto:whichIs rdf:resource="http://example.org/ontology#Can_appear_anytime"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R160"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Allergic Reactions</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rash, swelling, trouble breathing; serious, seek help immediately.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Until treatment stopped</onto:hasDuration>
</onto:AllergicReactions>

<onto:Dizziness rdf:about="http://example.org/ontology#SE527">
  <onto:whichIs rdf:resource="http://example.org/ontology#Can_appear_after_taking_first_doses"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R160"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DIzziness</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Feeling lightheaded or unsteady.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hours to days</onto:hasDuration>
</onto:Dizziness>

<onto:PulmonaryProblems rdf:about="http://example.org/ontology#SE531">
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare__more_likely_with_long-term_use"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R162"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pulmonary Problems</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Weeks to Months</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Trouble breathing, cough, chest pain; can be serious.</onto:hasSideEffectDescription>
</onto:PulmonaryProblems>

<onto:RustColoredUrine rdf:about="http://example.org/ontology#SE525">
  <onto:whichIs rdf:resource="http://example.org/ontology#Appears_soon_after_starting"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R161"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rust-colored Urine</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">While taking medicine</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Urine may look brownish, harmless but normal.</onto:hasSideEffectDescription>
</onto:RustColoredUrine>

<onto:Headache rdf:about="http://example.org/ontology#SE523">
  <onto:whichIs rdf:resource="http://example.org/ontology#Can_appear_during_early_days_of_use"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R160"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Headache</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild to moderate pain in the head.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hours to a day</onto:hasDuration>
</onto:Headache>

<onto:PeripheralNeuropathy rdf:about="http://example.org/ontology#SE529">
  <onto:hasReference rdf:resource="http://example.org/ontology#R162"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare__can_appear_with_long-term_use"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Peripheral Neuropathy</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Numbness, tingling, or pain in hands or feet; may becoe permanent if untreated.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Weeks to Months</onto:hasDuration>
</onto:PeripheralNeuropathy>

<onto:Nausea rdf:about="http://example.org/ontology#SE522">
  <onto:whichIs rdf:resource="http://example.org/ontology#Usually_appears_at_the_start_of_treatment__may_lessen_with_food"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R160"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nausea</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Few hours to days</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Feeling sick to your stomach or throwing up.</onto:hasSideEffectDescription>
</onto:Nausea>

<onto:RecurrentUrinaryTractInfection rdf:about="http://example.org/ontology#I058">
  <onto:hasReference rdf:resource="http://example.org/ontology#R161"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R162"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R159"/>
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#Mild"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild Recurrent Urinary Tract Infection</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Repeated bladder infections, urgency to urinate, discomfort in lower abdomen.</onto:hasSymptoms>
</onto:RecurrentUrinaryTractInfection>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP167">
  <onto:hasReference rdf:resource="http://example.org/ontology#R162"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP167</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Watch for side effects such as breathing problems, numbness, or yellow skin; report to doctor promptly.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP164">
  <onto:hasReference rdf:resource="http://example.org/ontology#R160"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP164</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Take Macrobid only for urinary infections proven or strongly suspected; do not use for colds or other viruses.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP166">
  <onto:hasReference rdf:resource="http://example.org/ontology#R160"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP166</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Take the medicine exactly as prescribed, at the correct times, with food; skipping doses reduces effectiveness.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP165">
  <onto:hasReference rdf:resource="http://example.org/ontology#R160"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP165</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Complete the full course of medicine even if symptoms improve, to prevent infection from coming back and bacteria from becoming resistant.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:PatientCondition rdf:about="http://example.org/ontology#W260">
  <onto:hasReference rdf:resource="http://example.org/ontology#R160"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W260</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Current and Past Health Conditions</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Notify healthcare provider if a patient have current and past health conditions in any of the following: kidnet or liver problems, history of anemia, history of diabetes, electrolyte imbalance, history of low levels of vitamin B, or Glucose-6-phosphate dehydrogenase (G6PD) deficiency</onto:hasWarningText>
</onto:PatientCondition>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W258">
  <onto:hasReference rdf:resource="http://example.org/ontology#R161"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W258</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Macrobid should not be used in babies under 1 month old.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Newborn Use</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:Contraindication rdf:about="http://example.org/ontology#W255">
  <onto:hasReference rdf:resource="http://example.org/ontology#R160"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W255</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May cause allergic reactions, which can be serious. Stop using nitrofurantoin and get help right away if any of the following symptoms of a serious allergic reaction: Breathing problems or wheezing, racing heart, fever or general ill feeling, swollen lymph nodes, swelling of the face, lips, mouth, tongue, or throat, trouble swallowing or throat tightness, itching, skin rash, or pale red bumps on the skin called hives, nausea or vomiting, or dizziness, feeling lightheaded , or fainting</onto:hasWarningText>
</onto:Contraindication>

<onto:PatientCondition rdf:about="http://example.org/ontology#W256">
  <onto:hasReference rdf:resource="http://example.org/ontology#R160"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W256</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid Macrobid if your kidneys are not working well; poor kidney function can make the medicine less effective and increase side effects.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidney Problems</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W257">
  <onto:hasReference rdf:resource="http://example.org/ontology#R161"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W257</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Do not take Macrobid in the last 2-4 weeks of pregnancy.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Late Pregnancy Use</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W259">
  <onto:hasReference rdf:resource="http://example.org/ontology#R160"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W259</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Taking too much can cause severe nausea, vomiting, stomach pain, or other serious health problems; seek medical help immediately.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Over Use</onto:hasWarningHeadline>
</onto:AgeRestriction>

