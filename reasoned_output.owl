<onto:Interaction rdf:about="http://example.org/ontology#ITN096">
  <onto:hasReference rdf:resource="http://example.org/ontology#R016"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S070"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN096</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rare prolongation of prothrombin time.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Undertake appropriate monitoring (e.g., INR).</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent use with amoxicillin.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN097">
  <onto:hasReference rdf:resource="http://example.org/ontology#R016"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S071"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN097</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May interfere with the bactericidal effects of amoxicillin.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Clinical significance is not well documented.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Interference in vitro.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN101">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S075"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R016"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN101</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased and prolonged blood levels of amoxicillin.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use only under medical supervision.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Competes for renal secretion.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN099">
  <onto:hasReference rdf:resource="http://example.org/ontology#R016"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S073"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN099</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Inhibits renal tubular secretion of MTX.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Decreased renal clearance; potential for GI or hematologic toxicity.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Careful monitoring is recommended.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN098">
  <onto:hasReference rdf:resource="http://example.org/ontology#R016"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S072"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN098</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor digoxin levels.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent administration.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May result in increased absorption of digoxin.</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN100">
  <onto:hasReference rdf:resource="http://example.org/ontology#R016"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S074"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN100</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Be aware of potential for reduced birth control effectiveness</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Effect on gut flora.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reduced efficacy of combined oral contraceptives.</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Renal rdf:about="http://example.org/ontology#SE680">
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Renal</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">acute interstitial nephritis and crystalluria.</onto:hasSideEffectDescription>
</onto:Renal>

<onto:Hypersensitivity rdf:about="http://example.org/ontology#SE265">
  <onto:hasReference rdf:resource="http://example.org/ontology#R016"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Anaphylaxis, exanthema, bullous dermatitis, Stevens-Johnson syndrome (SJS), and pruritus</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:Hypersensitivity>

<onto:Hepatic rdf:about="http://example.org/ontology#SE679">
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R016"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hepatic</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">moderate rise in aspartate aminotransferase, and/or alanine aminotransferase; transient increases in serum alkaline phosphatase and lactate dehydrogenase levels; hepatic dysfunction including cholestatic jaundice, hepatic cholestasis and acute cytolytic hepatitis.</onto:hasSideEffectDescription>
</onto:Hepatic>

<onto:HemicAndLymphatic rdf:about="http://example.org/ontology#SE264">
  <onto:hasReference rdf:resource="http://example.org/ontology#R016"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hemic and Lymphatic</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Anemia (including hemolytic), leukopenia, neutropenia, and thrombocytopenia.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:HemicAndLymphatic>

<onto:ToothDiscoloration rdf:about="http://example.org/ontology#SE261">
  <onto:whichIs rdf:resource="http://example.org/ontology#Mostly_in_pediatric_patients"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R016"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tooth Discoloration</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reversible (via brushing)</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Brown, yellow, or gray staining; can be reduced or eliminated with dental cleaning.</onto:hasSideEffectDescription>
</onto:ToothDiscoloration>

<onto:NervousSystemEffects rdf:about="http://example.org/ontology#SE263">
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare___at_extremely_high_doses"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R016"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nervous System Effects</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reversible</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Agitation, anxiety, behavioral changes, confusion, convulsions, hyperactivity, and dizziness.</onto:hasSideEffectDescription>
</onto:NervousSystemEffects>

<onto:GastrointestinalEffects rdf:about="http://example.org/ontology#SE262">
  <onto:hasReference rdf:resource="http://example.org/ontology#R016"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#During_or_following_discontinuance_of_amoxicillin"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gastrointestinal Effects</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nausea, vomiting, diarrhea, black hairy tongue, Clostridioides difficile-associated disease and colitis; hemorrhagic colitis; acute, transient enterocolitis with severe abdominal pain and bloody diarrhea, and colitis; glossitis, stomatitis, epigastric distress, gastritis, flatulence, soft stools, loss of appetite, sore mouth or tongue, dry mouth, taste disturbances.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:GastrointestinalEffects>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W129">
  <onto:hasReference rdf:resource="http://example.org/ontology#R016"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W129</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symptoms include allergic reactions, nausea, vomiting, and diarrhea. High doses may cause crystalluria, potentially leading to renal failure, which is generally reversible upon cessation</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Toxicity and Renal Risk</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W127">
  <onto:hasReference rdf:resource="http://example.org/ontology#R016"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W127</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Neonates, Infants, and Elderly</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Neonates and young infants have incompletely developed renal function, delaying drug elimination. Elderly patients should have doses selected with care due to likely decreased renal function</onto:hasWarningText>
</onto:AgeRestriction>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W126">
  <onto:hasReference rdf:resource="http://example.org/ontology#R016"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W126</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pregnancy Category B</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Safety not definitely established, but used for UTIs without evidence of fetal harm. Distributed into human milk and may lead to sensitization of the infant; use with caution when breastfeeding</onto:hasWarningText>
</onto:PregnancyAndLactation>

<onto:PatientCondition rdf:about="http://example.org/ontology#W128">
  <onto:hasReference rdf:resource="http://example.org/ontology#R016"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W128</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Renal and Hypersensitivity Precautions</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dose adjustment required based on the degree of renal impairment. Long-term use may result in the overgrowth of non-susceptible organisms, including fungi</onto:hasWarningText>
</onto:PatientCondition>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP080">
  <onto:hasReference rdf:resource="http://example.org/ontology#R016"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP080</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Usual duration is 5 to 14 days. Continue treatment for at least 48 to 72 hours after becoming asymptomatic. Take for at least 10 days for β-hemolytic streptococcal infections to prevent rheumatic fever.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP079">
  <onto:hasReference rdf:resource="http://example.org/ontology#R016"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP079</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Administered orally. May be taken with or without food. Prescribe only for proven or strongly suspected bacterial infections to prevent the development of drug-resistant bacteria.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP082">
  <onto:hasReference rdf:resource="http://example.org/ontology#R016"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP082</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Maintain adequate fluid intake and urinary output to reduce the possibility of crystalluria. Periodic assessment of renal, hepatic, and hematopoietic functions is recommended during prolonged therapy.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:Storage rdf:about="http://example.org/ontology#SP081">
  <onto:hasReference rdf:resource="http://example.org/ontology#R016"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP081</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Store in a dry place at temperatures not exceeding 30°C. Protect from light to ensure optimal shelf-life.</onto:hasStewardshipDescription>
</onto:Storage>

<onto:Drug rdf:about="http://example.org/ontology#S046">
  <onto:hasReference rdf:resource="http://example.org/ontology#R017"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Allopurinol</rdfs:label>
  <onto:hasSubstanceDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Uric acid medication</onto:hasSubstanceDescription>
</onto:Drug>

<onto:Reference rdf:about="http://example.org/ontology#R096">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">R096</rdfs:label>
  <onto:hasAuthor rdf:datatype="http://www.w3.org/2001/XMLSchema#string">National Health Service (NHS)</onto:hasAuthor>
  <onto:publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2024</onto:publishedIn>
  <onto:hasReferenceTitle rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Respiratory tract infections (RTIs)</onto:hasReferenceTitle>
  <onto:retrievedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://www.nhs.uk/conditions/respiratory-tract-infection/</onto:retrievedFrom>
</onto:Reference>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W202">
  <onto:hasReference rdf:resource="http://example.org/ontology#R009"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W202</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lactation</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Levofloxacin has not been measured in human milk. However, based on the ofloxacin data, it can be presumed that levofloxacin will be excreted in human milk. Therefore, a decision should be made whether to discontinue breastfeeding or to discontinue the drug, taking into account the importance of the drug to the mother as well as the possible serious adverse effects to the infant.</onto:hasWarningText>
</onto:PregnancyAndLactation>

<onto:Diarrhea rdf:about="http://example.org/ontology#SE524">
  <onto:whichIs rdf:resource="http://example.org/ontology#May_appear_during_or_shortly_after_use"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R161"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diarrhea</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Loose or watery stool; may be mild or severe.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Few days</onto:hasDuration>
</onto:Diarrhea>

<onto:Pattern rdf:about="http://example.org/ontology#May_appear_during_or_shortly_after_use">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May appear during or shortly after use</rdfs:label>
</onto:Pattern>

<onto:Drug rdf:about="http://example.org/ontology#S163">
  <onto:hasReference rdf:resource="http://example.org/ontology#R153"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nifedipine</rdfs:label>
  <onto:hasSubstanceDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A medication used to manage high blood pressure and to relieve chest pain.</onto:hasSubstanceDescription>
</onto:Drug>

<onto:Interaction rdf:about="http://example.org/ontology#ITN107">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S081"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R047"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN107</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Inform your doctor if you are taking allopurinol; monitor for skin changes.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent use with amoxicillin.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased incidence of skin rashes, especially in hyperuricemic patients.</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Drug rdf:about="http://example.org/ontology#S081">
  <onto:hasReference rdf:resource="http://example.org/ontology#R047"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Allopurinol</rdfs:label>
  <onto:hasSubstanceDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Used to lower uric acid (Gout); may increase incidence of skin rashes.</onto:hasSubstanceDescription>
</onto:Drug>

<onto:IncreasedHepaticEnzymes rdf:about="http://example.org/ontology#SE436">
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R091"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">increased hepatic enzymes</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hepatic enzyme levels may be increased especially in the case of pre-existing hepatic malfunction</onto:hasSideEffectDescription>
</onto:IncreasedHepaticEnzymes>

