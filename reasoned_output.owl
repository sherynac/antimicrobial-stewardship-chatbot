  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN029</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May reduce effectiveness or increase side effects.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Adjust dosing or monitor for interactions; consult doctor.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Taking other antibiotics or medications at the same time may affect how fosfomycin works.</onto:hasInteractionDescription>
</onto:Interaction>

