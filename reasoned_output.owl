<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP175">
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP175</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The medicine should be taken exactly as prescribed by the doctor. Adults should take 50–100 mg every 6 hours with meals, and children should take the prescribed dose based on body weight. Taking it with food helps improve absorption and reduces stomach upset. Do not skip doses and complete the full course even if symptoms improve early.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

