  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kracid</rdfs:label>
</onto:Brand>

<onto:CardiacArrhythmias rdf:about="http://example.org/ontology#SE288">
  <onto:whichIs rdf:resource="http://example.org/ontology#Associated_with_drug_interactions"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R020"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cardiac Arrhythmias</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">QT prolongation, ventricular tachycardia, ventricular fibrillation, and torsades de pointes.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:CardiacArrhythmias>

<onto:SkinAndSystemicReactions rdf:about="http://example.org/ontology#SE287">
  <onto:whichIs rdf:resource="http://example.org/ontology#Common___1_100_to__1_10_"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R020"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Skin &amp; Systemic Reactions</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rash, hyperhidrosis, and abnormal liver function tests (LFT).</onto:hasSideEffectDescription>
</onto:SkinAndSystemicReactions>

<onto:Rhabdomyolysis rdf:about="http://example.org/ontology#SE289">
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare_Concomitant_use_reports"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R020"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rhabdomyolysis</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Muscle tissue breakdown (rhabdomyolysis) has been reported when taken with statins, fibrates, colchicine, or allopurinol</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:Rhabdomyolysis>

<onto:GastrointestinalEffects rdf:about="http://example.org/ontology#SE285">
  <onto:hasReference rdf:resource="http://example.org/ontology#R020"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Common___1_100_to__1_10_"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gastrointestinal Effects</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Insomnia, headache, dysgeusia (taste perversion), diarrhea, vomiting, dyspepsia, nausea, and abdominal pain.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:GastrointestinalEffects>

<onto:CentralNervousSystemEffects rdf:about="http://example.org/ontology#SE286">
  <onto:whichIs rdf:resource="http://example.org/ontology#Common___1_100_to__1_10_"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R020"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Central Nervous System Effects</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Insomnia, headache, dysgeusia (taste perversion), diarrhea, vomiting, dyspepsia, nausea, and abdominal pain.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:CentralNervousSystemEffects>

