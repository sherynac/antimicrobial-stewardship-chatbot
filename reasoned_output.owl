<onto:Interaction rdf:about="http://example.org/ontology#ITN162">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S136"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN162</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contraindicated.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant use with clarithromycin</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Elevated drug levels and serious cardiac arrhythmias</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN158">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S132"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN158</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant use with CYP-450 metabolized drugs</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Risk of QT prolongation and fatal cardiac arrhythmias</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contraindicated.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN160">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S134"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN160</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Risk of hypotension and acute kidney injury</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant use with drugs metabolized by CYP3A4</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use with caution, especially in elderly patients.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN161">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S135"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN161</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Food does not affect the extent of bioavailability</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May be taken with or without food.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Effect of food on drug levels</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN155">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S129"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN155</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Potential for increased bleeding or altered clotting time</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor Prothrombin Time (PT) or INR closely.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent use with oral anticoagulants</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN157">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S131"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN157</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased quetiapine levels; risk of malignant neuroleptic syndrome</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid combination; requires close monitoring or dose reduction.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Inhibition of the CYP3A enzyme</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN163">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S137"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN163</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May result in ergot toxicity</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contraindicated.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant administration</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN152">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S126"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN152</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Potential for altered antiretroviral concentration</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor clinically for efficacy or toxicity.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant use with macrolides</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN159">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S133"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN159</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Can result in significant hypoglycemia (low blood sugar)</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Careful monitoring of blood glucose levels is recommended.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant use with clarithromycin</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN154">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S128"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN154</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Effect of food on bioavailability</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dietary intake consumed near dose administration</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May be taken with or without food as it does not affect absorption.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN156">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S130"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN156</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Risk of rhabdomyolysis and myopathy</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant use with macrolides</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contraindicated.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN153">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S127"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN153</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased risk of ototoxicity (hearing/balance damage)</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant use with drugs that cause hearing damage</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use with extreme caution; monitor hearing and balance.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Contraindication rdf:about="http://example.org/ontology#W163">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W163</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contraindicated for patients with known hypersensitivity to macrolides or history of drug-induced hepatic dysfunction. Also contraindicated with drugs like cisapride, simvastatin, or lovastatin.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Allergic Reactions and Dangerous Combinations</onto:hasWarningHeadline>
</onto:Contraindication>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W164">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W164</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use is not advised without carefully weighing benefits against risk, as adverse embryo-fetal development effects cannot be excluded. Clarithromycin is excreted into human breast milk.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Safety Not Established</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:PatientCondition rdf:about="http://example.org/ontology#W161">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W161</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Do not use in children aged 8 years and below because of the effect of tetracyclines in teeth (permanent discoloration and possibly enamel hypoplasia) and bone.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pediatric Use</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W165">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W165</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not for Children &lt;12</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Indicated for adults and children 12 years and older. It is not recommended for children younger than 12 years; they should use the paediatric suspension instead.</onto:hasWarningText>
</onto:AgeRestriction>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W160">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W160</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lactation</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tetracyclines are excreted in breast milk. A dosage of 2g/day for 3 days has achieved a milk plasma ratio of 0.6 to 0.8.</onto:hasWarningText>
</onto:AgeRestriction>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W167">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W167</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Large amounts produce GI symptoms. A patient ingesting 8 grams showed altered mental status, paranoid behaviour, hypokalemia, and hypoxemia.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gastrointestinal and Mental Effects</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:PatientCondition rdf:about="http://example.org/ontology#W166">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W166</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Renal and Hepatic Impairment</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Caution is advised in patients with severe renal insufficiency or impaired hepatic function. Fatal hepatic failure has been reported in some cases.</onto:hasWarningText>
</onto:PatientCondition>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W159">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W159</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Embryotoxicity has also been noted in animals treated early in pregnancy.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pregnancy</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:Contraindication rdf:about="http://example.org/ontology#W168">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W168</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contraindicated for patients with hypersensitivity to macrolides, a history of QT prolongation, or those taking drugs like cisapride, pimozide, ergot alkaloids, ticagrelor, or ranolazine.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dangerous Combinations</onto:hasWarningHeadline>
</onto:Contraindication>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W162">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W162</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symptoms include abdominal pain, nausea, vomiting, and diarrhea. High doses (8g) may cause altered mental status and paranoid behavior.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gastrointestinal and Mental Effects</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:VisualImpairment rdf:about="http://example.org/ontology#SE293">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Visual Impairment</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rare</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Temporary changes in vision reported in isolated cases.</onto:hasSideEffectDescription>
</onto:VisualImpairment>

<onto:Dizziness rdf:about="http://example.org/ontology#SE298">
  <onto:whichIs rdf:resource="http://example.org/ontology#Occasionally_reported"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dizziness</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May cause lightheadedness that affects daily activities.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
</onto:Dizziness>

<onto:Rash rdf:about="http://example.org/ontology#SE304">
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare_but_serious"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rash</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Skin rash; contact a doctor if it persists or worsens.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
</onto:Rash>

<onto:RunnyNose rdf:about="http://example.org/ontology#SE302">
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Runny Nose</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild nasal discharge.</onto:hasSideEffectDescription>
</onto:RunnyNose>

<onto:Headache rdf:about="http://example.org/ontology#SE299">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Occasionally_reported"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Headache</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild headache.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
</onto:Headache>

<onto:UnexplainedWeakness rdf:about="http://example.org/ontology#SE303">
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Unexplained Weakness</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Feeling unusually tired or weak.</onto:hasSideEffectDescription>
</onto:UnexplainedWeakness>

<onto:VaginalItching rdf:about="http://example.org/ontology#SE305">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#mild"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vaginal Itching</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild itching; may indicate a yeast overgrowth.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
</onto:VaginalItching>

<onto:TorsadeDePointes rdf:about="http://example.org/ontology#SE290">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Torsade de pointes</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">During treatment</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A life-threatening, polymorphic ventricular tachycardia that must be monitored in high-risk patients.</onto:hasSideEffectDescription>
</onto:TorsadeDePointes>

<onto:SevereAllergicReaction rdf:about="http://example.org/ontology#SE294">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Severe Allergic Reaction</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Immediate</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Includes hives, swelling, and difficulty breathing; seek emergency care immediately.</onto:hasSideEffectDescription>
</onto:SevereAllergicReaction>

<onto:AbdominalPain rdf:about="http://example.org/ontology#SE295">
  <onto:whichIs rdf:resource="http://example.org/ontology#Can_occur_sooner_after_taking"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Abdominal Pain</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A side effect is an unwanted response to a medication when it is taken in normal doses. Side effects can be mild or severe, temporary or permanent.</onto:hasSideEffectDescription>
</onto:AbdominalPain>

<onto:BackPain rdf:about="http://example.org/ontology#SE296">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Occasionally_reported"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Back Pain</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild back pain.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
</onto:BackPain>

<onto:CDifficileAssociatedDiarrhea rdf:about="http://example.org/ontology#SE291">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Severe_and_potentially_life-threatening"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C. difficile-associated diarrhea</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">During or weeks after therapy</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Remember that while diarrhea is a recognized side effect of cefuroxime, it is generally mild and transient in most cases.</onto:hasSideEffectDescription>
</onto:CDifficileAssociatedDiarrhea>

<onto:Vertigo rdf:about="http://example.org/ontology#SE292">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vertigo</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">During treatment</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A temporary feeling of spinning or dizziness.</onto:hasSideEffectDescription>
</onto:Vertigo>

<onto:Heartburn rdf:about="http://example.org/ontology#SE300">
  <onto:whichIs rdf:resource="http://example.org/ontology#Occasionally_reported"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Heartburn</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild discomfort or burning sensation in the chest.</onto:hasSideEffectDescription>
</onto:Heartburn>

<onto:Nausea rdf:about="http://example.org/ontology#SE301">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Occasionally_reported"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nausea</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Feeling of sickness or queasiness.</onto:hasSideEffectDescription>
</onto:Nausea>

<onto:Diarrhea rdf:about="http://example.org/ontology#SE297">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Can_occur_within_first_days"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diarrhea</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">may cause diarrhea, and in some cases it can be severe. Diarrhea medicines may make the diarrhea worse or make it last longer.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
</onto:Diarrhea>

<onto:AcuteBacterialSinusitis rdf:about="http://example.org/ontology#I005">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R261"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R092"/>
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Acute Bacterial Sinusitis</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">an infection in your sinuses that typically lasts seven to 10 days</onto:hasSymptoms>
</onto:AcuteBacterialSinusitis>

<onto:Gonorrhea rdf:about="http://example.org/ontology#I057">
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R092"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R091"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R133"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gonorrhea</rdfs:label>
</onto:Gonorrhea>

<onto:UrinaryTractInfections rdf:about="http://example.org/ontology#I049">
  <onto:hasReference rdf:resource="http://example.org/ontology#R091"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R127"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R010"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R092"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R098"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R166"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R129"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R093"/>
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Urinary Tract Infections</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pain in your flank, abdomen, pelvic area or lower back, pressure in the lower part of your pelvis, cloudy, foul-smelling pee, urinary incontinence, frequent urination, urge incontinence, pain when you pee (dysuria), and blood in your pee (hematuria).</onto:hasSymptoms>
</onto:UrinaryTractInfections>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP108">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP108</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patient Safety: Monitor for signs of hepatic failure, especially in those with pre-existing liver disease. Also, monitor for the development of drug-resistant organisms during H. pylori therapy.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP105">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP105</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Oral administration: The usual dose is 250 mg twice daily, though this may be increased to 500 mg twice daily for severe infections.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP109">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP109</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use for treating tonsillitis, pharyngitis and acute otitis media (ear infection) for patients with hypersensitivity to beta-lactam antibiotics or when such treatment is not suitable for other reasons.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP106">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP106</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dosage &amp; Duration: Treatment usually lasts 6 to 14 days. For patients with renal impairment ($CrCl &lt; 30$ mL/min), the dose should be halved and not continue beyond 14 days.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP110">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP110</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor for symptoms such as tender abdomen and discontinue treatment immediately if they occur.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:Storage rdf:about="http://example.org/ontology#SP107">
  <onto:hasReference rdf:resource="http://example.org/ontology#R054"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP107</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Store at temperatures not exceeding 30°C.</onto:hasStewardshipDescription>
</onto:Storage>

