  <onto:hasSideEffect rdf:resource="http://example.org/ontology#SE075"/>
  <onto:hasSideEffect rdf:resource="http://example.org/ontology#SE077"/>
  <onto:hasSideEffect rdf:resource="http://example.org/ontology#SE062"/>
  <onto:hasSideEffect rdf:resource="http://example.org/ontology#SE071"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R021"/>
  <onto:treats rdf:resource="http://example.org/ontology#I017"/>
  <onto:treats rdf:resource="http://example.org/ontology#I023"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contepo</rdfs:label>
</onto:Brand>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W041">
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W041</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Breastfeeding</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Breastfeeding not recommended during treatment and for 24 hours after last dose.</onto:hasWarningText>
</onto:PregnancyAndLactation>

<onto:PatientCondition rdf:about="http://example.org/ontology#W033">
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W033</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Serum Electrolyte Abnormalities</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The high sodium load associated with the use of CONTEPO may result in changes in serum electrolytes, such as increased levels of sodium and decreased levels of potassium, calcium and phosphorus. A low-sodium diet is recommended during CONTEPO treatment. Monitor serum electrolyte levels and fluid status during CONTEPO treatment</onto:hasWarningText>
</onto:PatientCondition>

<onto:PatientCondition rdf:about="http://example.org/ontology#W036">
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W036</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Neutropenia including Agranulocytosis</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Neutropenia, including agranulocytosis, has occurred in patients receiving IV fosfomycin treatment. Monitor complete blood count during CONTEPO therapy. If such reactions occur, discontinue CONTEPO and institute appropriate treatment</onto:hasWarningText>
</onto:PatientCondition>

<onto:PatientCondition rdf:about="http://example.org/ontology#W035">
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W035</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased Transaminase Levels</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increase in alanine aminotransferase (ALT) and aspartate aminotransferase (AST) were reported in the clinical trial. Monitor hepatic enzymes during CONTEPO treatment.</onto:hasWarningText>
</onto:PatientCondition>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W040">
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W040</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Available data from observational studies and pharmacovigilance reports with fosfomycin use in pregnant women are insufficient to identify a drug-associated risk of major birth defects, miscarriage, or adverse maternal or fetal outcomes. Fosfomycin crosses the placental barrier. There are no animal data that meet current standards for nonclinical developmental toxicity studies. However, some reproductive toxicity data are available from published literature. Intravenous or intraperitoneal fosfomycin-sodium did not cause malformations in rabbits or rats, respectively, but showed evidence of fetotoxicity (see Data). The clinical relevance of these animal data is uncertain.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pregnancy Use</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W043">
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W043</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Geriatric Use</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Elderly patients are more likely to have decreased cardiac and renal function, care should be taken in dose selection, and electrolytes, fluid status, and renal function should be monitored. Dosage adjustment in elderly patients should take into account renal function</onto:hasWarningText>
</onto:AgeRestriction>

<onto:Contraindication rdf:about="http://example.org/ontology#W032">
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W032</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactions such as rash, urticaria and anaphylaxis were reported with the use of CONTEPO. Before initiating therapy with CONTEPO, it is important to inquire about previous hypersensitivity reactions to oral or parenteral fosfomycin. If an allergic reaction occurs, discontinue CONTEPO immediately.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity</onto:hasWarningHeadline>
</onto:Contraindication>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W042">
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W042</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Safety and effectiveness of CONTEPO in patients less than 18 years of age has not been established.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pediatric Use</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:PatientCondition rdf:about="http://example.org/ontology#W034">
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W034</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">QT Prolongation</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The risk of QT prolongation may increase in patients with electrolyte abnormalities (such as hypokalemia and hypocalcemia), patients with conditions that have potential to cause electrolyte imbalance (such as renal impairment), or patients taking other drugs affecting electrolyte balance or QT prolongation. Avoid CONTEPO in patients with known QT prolongation or ventricular arrhythmias, including a history of torsade de pointes.</onto:hasWarningText>
</onto:PatientCondition>

<onto:PatientCondition rdf:about="http://example.org/ontology#W038">
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W038</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Development of Drug-Resistant Bacteria</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Prescribing CONTEPO in the absence of a proven or strongly suspected bacterial infection indication is unlikely to provide benefit to the patient and increases the risk of the development of drug resistant bacteria</onto:hasWarningText>
</onto:PatientCondition>

<onto:PatientCondition rdf:about="http://example.org/ontology#W039">
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W039</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cardiac/Fluid Overload</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor signs and symptoms of edema, particularly in patients with cardiac insufficiency, renal impairment, cirrhosis, hypertension, hyperaldosteronism, hypernatremia or pulmonary edema.</onto:hasWarningText>
</onto:PatientCondition>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP025">
  <onto:hasReference rdf:resource="http://example.org/ontology#R027"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP025</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Only use Contepo when prescribed by a healthcare professional for a confirmed infection. Avoid using for viral infections like colds or flu.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP027">
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R027"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP027</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Complete the full course of Contepo even if you feel better to prevent bacterial resistance. Do not skip doses.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP026">
  <onto:hasReference rdf:resource="http://example.org/ontology#R027"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP026</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Take infection control measures such as hand hygiene and avoiding contact with sick individuals to prevent the spread of infection.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:Interaction rdf:about="http://example.org/ontology#ITN025">
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R027"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S019"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN025</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor kidney funcation; avoid combination if possible.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Using with other nephrotoxic antibiotics increases risk of kidney damage.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidney injury or electrolyte imbalance.</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN024">
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R027"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S018"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN024</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor INR/blood clotting; adjust warfarin dose if necessary.</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Prolonged bleeding or easy bruising.</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May increase risk of bleeding when used together.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN023">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S017"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R027"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN023</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased stomach upset, dizziness, or liver strain.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid alcohol while taking Contepo.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alcohol may increase risk of side effects like nausea, vomiting, or liver problems.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN027">
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S021"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN027</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Take the drug 2 hours before of after consuming dairy.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dairy products can interfere with absorption.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reduced drug effectiveness.</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN028">
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S022"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN028</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antacids may reduce absorption of the drug.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reduced antibiotic effectiveness.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Take antacids 2 hours before or after the dose.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Thrombocytopenia rdf:about="http://example.org/ontology#SE073">
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare__hardly_happens"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Thrombocytopenia</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Low platelet count; may cause easy bruising or bleeding.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rare</onto:hasDuration>
</onto:Thrombocytopenia>

<onto:Vomiting rdf:about="http://example.org/ontology#SE063">
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R027"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Common__may_happen_during_infusion"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vomiting</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Few hours</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Forceful expulsion of stomach contents; usually mild and stops after the dose.</onto:hasSideEffectDescription>
</onto:Vomiting>

<onto:Anemia rdf:about="http://example.org/ontology#SE072">
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare__hardly_happens"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Anemia</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rare</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Low red blood cells; may cause fatigue, weakness, or shortness of breath.</onto:hasSideEffectDescription>
</onto:Anemia>

<onto:HearingLoss rdf:about="http://example.org/ontology#SE079">
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare__may_happen"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hearing Loss</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">During treatment</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Temporary or mild hearing changes reported rarely.</onto:hasSideEffectDescription>
</onto:HearingLoss>

<onto:PeripheralEdema rdf:about="http://example.org/ontology#SE076">
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare__may_happen"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Peripheral Edema</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">During treatment</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Swelling in hands, feet, or ankles; usually mild.</onto:hasSideEffectDescription>
</onto:PeripheralEdema>

<onto:Headache rdf:about="http://example.org/ontology#SE065">
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R027"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Common__may_happen_during_treatment"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Headache</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Few hours to a day</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild to moderate head pain; usually temporary.</onto:hasSideEffectDescription>
</onto:Headache>

<onto:Hypernatremia rdf:about="http://example.org/ontology#SE067">
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R027"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Common__can_happen_while_on_drug"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypernatremia</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">High sodium in blood; may cause thirst, swelling, or confusion if severe.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">During treatment</onto:hasDuration>
</onto:Hypernatremia>

<onto:Hypokalemia rdf:about="http://example.org/ontology#SE066">
  <onto:whichIs rdf:resource="http://example.org/ontology#Common__can_happen_while_on_drug"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R027"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypokalemia</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Low potassium; may cause muscle weakness, cramps, or irregular heartbeat; often corrected with supplements</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">During treatment</onto:hasDuration>
</onto:Hypokalemia>

<onto:Hypophosphatemia rdf:about="http://example.org/ontology#SE069">
  <onto:whichIs rdf:resource="http://example.org/ontology#Common__can_happen_while_on_drug"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R027"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypophosphatemia</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">During treatment</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Low phosphate; may cause weakness or bone/muscle pain; usually mild.</onto:hasSideEffectDescription>
</onto:Hypophosphatemia>

<onto:Dyspnea rdf:about="http://example.org/ontology#SE080">
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare__may_happen"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dyspnea</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Shortness of breath; can happen in allergic reactions or fluid overload.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">During treatment</onto:hasDuration>
</onto:Dyspnea>

<onto:TorsadeDePointes rdf:about="http://example.org/ontology#SE082">
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Torsade de pointes</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rare heart rthythm proble; can be life-threatening; monitored in high-risk patients.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">During treatment</onto:hasDuration>
</onto:TorsadeDePointes>

<onto:Anaphylaxis rdf:about="http://example.org/ontology#SE081">
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare__emergency"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Anaphylaxis</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Severe allergic reaction with difficulty breathing, swelling, low blood pressure; needs emergency care.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Immediate</onto:hasDuration>
</onto:Anaphylaxis>

<onto:Constipation rdf:about="http://example.org/ontology#SE078">
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare__may_happen"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Constipation</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Difficulty passing stools; usually mild and temporary.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">During treatment</onto:hasDuration>
</onto:Constipation>

<onto:Hypocalcemia rdf:about="http://example.org/ontology#SE068">
  <onto:hasReference rdf:resource="http://example.org/ontology#R027"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Common__can_happen_while_on_drug"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypocalcemia</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">During treatment</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Low calcium; may cause muscle cramps, tingling, or numbness; usually mild and temporary.</onto:hasSideEffectDescription>
</onto:Hypocalcemia>

<onto:Vertigo rdf:about="http://example.org/ontology#SE084">
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vertigo</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">During treatment</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Feeling of spinning or dizziness; usually temporary.</onto:hasSideEffectDescription>
</onto:Vertigo>

<onto:Diarrhea rdf:about="http://example.org/ontology#SE064">
  <onto:hasReference rdf:resource="http://example.org/ontology#R027"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Common__may_occue_while_taking_the_drug"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diarrhea</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Few days</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Loose or watery stools; usually mild, stops after treatment.</onto:hasSideEffectDescription>
</onto:Diarrhea>

<onto:TransaminaseElevations rdf:about="http://example.org/ontology#SE070">
  <onto:whichIs rdf:resource="http://example.org/ontology#Common__usually_mild"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R027"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R028"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Transaminase elevations</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Liver enzymes increase; usually no symptoms and reversible after stopping drug.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">During treatment</onto:hasDuration>
</onto:TransaminaseElevations>

<onto:Rash rdf:about="http://example.org/ontology#SE074">
