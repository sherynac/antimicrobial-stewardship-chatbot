<onto:NonGonococcalUrethritis rdf:about="http://example.org/ontology#I013">
  <onto:hasReference rdf:resource="http://example.org/ontology#R038"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R045"/>
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Non-gonococcal urethritis</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Men: Discharge from penis, pain while peeing (dysuria), pain while ejaculating (dysorgasmia or orgasmalgia), itching, irritation and/or tenderness, abdominal pain. Women: Vaginal discharge, pain while peeing, pain during sexual intercourse (dyspareunia), spotting or cramping throughout the month (irregular periods).</onto:hasSymptoms>
</onto:NonGonococcalUrethritis>

