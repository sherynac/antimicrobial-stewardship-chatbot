<onto:AgeRestriction rdf:about="http://example.org/ontology#W152">
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W152</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gastrointestinal and Mental Effects</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symptoms include abdominal pain, nausea, vomiting, and diarrhea. High doses (8g) may cause altered mental status and paranoid behavior.</onto:hasWarningText>
</onto:AgeRestriction>

<onto:Contraindication rdf:about="http://example.org/ontology#W153">
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W153</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contraindicated for patients with known hypersensitivity to macrolides or history of cholestatic jaundice/hepatic dysfunction.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Allergic Reactions and Dangerous Combinations</onto:hasWarningHeadline>
</onto:Contraindication>

<onto:GastrointestinalEffects rdf:about="http://example.org/ontology#SE278">
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gastrointestinal Effects</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diarrhea, nausea, abnormal taste, dyspepsia, and abdominal pain.</onto:hasSideEffectDescription>
</onto:GastrointestinalEffects>

<onto:CardiacEffects rdf:about="http://example.org/ontology#SE284">
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Infrequent"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cardiac Effects</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">QT interval prolongation and ventricular arrhythmias, including Torsades de pointes.</onto:hasSideEffectDescription>
</onto:CardiacEffects>

<onto:AllergicReactions rdf:about="http://example.org/ontology#SE281">
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Allergic Reactions</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity reactions including rash</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:AllergicReactions>

<onto:GastrointestinalEffects rdf:about="http://example.org/ontology#SE282">
  <onto:whichIs rdf:resource="http://example.org/ontology#Common"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gastrointestinal Effects</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diarrhea, nausea, vomiting, dyspepsia, and abdominal pain or discomfort.</onto:hasSideEffectDescription>
</onto:GastrointestinalEffects>

<onto:NervousSystemEffects rdf:about="http://example.org/ontology#SE283">
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Common"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nervous System Effects</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Headache and abnormal taste (dysgeusia).</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
</onto:NervousSystemEffects>

<onto:CentralNervousSystemEffects rdf:about="http://example.org/ontology#SE279">
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_specified"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Central Nervous System Effects</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diarrhea, nausea, abnormal taste, dyspepsia, and abdominal pain.</onto:hasSideEffectDescription>
</onto:CentralNervousSystemEffects>

<onto:Storage rdf:about="http://example.org/ontology#SP098">
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP098</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Store at temperatures not exceeding 30°C and protect from light.</onto:hasStewardshipDescription>
</onto:Storage>

<onto:Storage rdf:about="http://example.org/ontology#SP094">
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP094</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Store reconstituted suspension at 15°C to 25°C and use within 14 days. Do not refrigerate. Protect from moisture and keep tightly closed.</onto:hasStewardshipDescription>
</onto:Storage>

<onto:UpperRespiratoryTractInfection rdf:about="http://example.org/ontology#I031">
  <onto:hasReference rdf:resource="http://example.org/ontology#R015"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R020"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R016"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R265"/>
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Upper Respiratory Tract Infection</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">a runny or stuffy nose, sore throat or headache</onto:hasSymptoms>
</onto:UpperRespiratoryTractInfection>

<onto:AcuteMaxillarySinusitis rdf:about="http://example.org/ontology#I008">
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#MildToModerate"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R010"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R047"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R262"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild to Moderate Acute Maxillary Sinusitis</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">an infection in your sinuses that typically lasts seven to 10 days</onto:hasSymptoms>
</onto:AcuteMaxillarySinusitis>

<onto:Interaction rdf:about="http://example.org/ontology#ITN135">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S109"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN135</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitoring of serum theophylline concentrations should be considered, especially for high doses.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant use in patients receiving theophylline.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Associated with an increase of serum theophylline concentrations.</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN142">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S116"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN142</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant use with macrolides like Clarithromycin.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased statin concentrations; rare reports of rhabdomyolysis and myopathy.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contraindicated. Use the lowest dose of other statins or a statin not dependent on CYP3A (e.g., fluvastatin).</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN144">
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S118"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN144</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May result in death due to cardiac arrhythmias (QT prolongation, ventricular tachycardia, and Torsades de pointes).</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contraindicated.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent use with Clarithromycin.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN145">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S119"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN145</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Can result in significant hypoglycemia.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Careful monitoring of blood glucose levels is recommended.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant use with Clarithromycin.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN134">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S108"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN134</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Adults: Decreased mean plasma concentration. Children: Increased peak concentration (Cmax​) and extent of absorption (AUC).</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May be administered with or without food and can be taken with milk.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Absorption under fed vs. fasting conditions.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN136">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S110"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN136</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant administration of single doses.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Results in increased plasma concentrations of Carbamazepine and potential toxicity.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Blood level monitoring of Carbamazepine may be considered.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN143">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S117"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN143</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Inhibition of the CYP3A enzyme by Clarithromycin.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid combination unless clinically necessary; requires close monitoring and potential dose reductions.</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Results in increased quetiapine concentrations; risk of malignant neuroleptic syndrome.</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN146">
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S120"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN146</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Risk of hypotension and acute kidney injury, particularly in elderly patients.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use with caution</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant administration of drugs metabolized by CYP3A4.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN138">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S112"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN138</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">(No specific advice provided in source, but monitor for efficacy).</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Results in decreased steady-state Zidovudine concentrations.</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Simultaneous oral administration with Clarithromycin.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN139">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S113"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN139</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use of Clarithromycin alongside other ototoxic agents.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor vestibular and auditory function during and after treatment.</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Potential for cumulative damage to auditory or vestibular functions.</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN137">
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S111"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN137</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dosage adjustment should be considered, especially in patients with renal impairment.</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">77% increase in Clarithromycin AUC and 100% decrease in 14-OH Clarithromycin AUC.</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant administration with Clarithromycin.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN140">
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S114"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN140</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May be taken with or without food.</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The overall extent of absorption remains unaffected.</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Delays the onset of absorption and increases the peak time (tmax​) from 2 to 2.5 hours.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP096">
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP096</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tablets should be swallowed whole and can be taken with or without food. Take every 12 hours as prescribed.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP097">
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP097</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">For respiratory infections, the usual duration is 7-14 days. Dosage for renal impairment (CrCl &lt;30 mL/min) should be reduced by half.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP095">
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP095</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">If used with other ototoxic drugs (like aminoglycosides), monitor vestibular and auditory function</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP093">
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP093</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dosage: The usual recommended daily dosage for children is 15 mg/kg/day divided every 12 hours for 10 days.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP092">
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP092</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Preparation: Add half the water and shake vigorously; then add the remaining water and shake again. Shake well before each use. Can be taken with milk.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP099">
  <onto:hasReference rdf:resource="http://example.org/ontology#R019"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP099</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor for signs of hepatitis (jaundice, dark urine, tender abdomen) and discontinue immediately if they occur</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:Brand rdf:about="http://example.org/ontology#Kracid">
