<owl:Class rdf:about="http://example.org/ontology#Brand">
  <owl:disjointWith rdf:resource="http://example.org/ontology#Antibiotic"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#Interaction"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#Warning"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#SideEffect"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#Pattern"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#Indication"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#Severity"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="http://example.org/ontology#hasPresentation"/>
      <owl:onClass rdf:resource="http://example.org/ontology#PresentationOrPacking"/>
      <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</owl:minQualifiedCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="http://example.org/ontology#treats"/>
      <owl:onClass rdf:resource="http://example.org/ontology#Indication"/>
      <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</owl:minQualifiedCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="http://example.org/ontology#PresentationOrPacking">
  <owl:disjointWith rdf:resource="http://example.org/ontology#Brand"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#Antibiotic"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#Interaction"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#Warning"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#SideEffect"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#Pattern"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#Indication"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#Severity"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:oneOf rdf:parseType="Collection">
        <rdf:Description rdf:about="http://example.org/ontology#Capsule"/>
        <rdf:Description rdf:about="http://example.org/ontology#Tablet"/>
        <rdf:Description rdf:about="http://example.org/ontology#IVInjection"/>
        <rdf:Description rdf:about="http://example.org/ontology#Syrup"/>
        <rdf:Description rdf:about="http://example.org/ontology#Suspension"/>
        <rdf:Description rdf:about="http://example.org/ontology#Ointment"/>
      </owl:oneOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="http://example.org/ontology#Pattern">
  <owl:disjointWith rdf:resource="http://example.org/ontology#Indication"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#Severity"/>
</owl:Class>

<owl:Class rdf:about="http://example.org/ontology#DisseminatedMycobacteriumAviumComplexMACDisease">
  <rdfs:subClassOf rdf:resource="http://example.org/ontology#RespiratoryDisease"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Disseminated Mycobacterium Avium Complex (MAC) Disease</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://example.org/ontology#NotSpecified">
  <rdf:type rdf:resource="http://example.org/ontology#Severity"/>
  <rdfs:subClassOf rdf:resource="http://example.org/ontology#Severity"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#MildToModerate"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#Mild"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#MildToSevere"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#ModerateToSevere"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#Severe"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#InitialTherapy"/>
  <owl:differentFrom rdf:resource="http://example.org/ontology#MildToModerate"/>
  <owl:differentFrom rdf:resource="http://example.org/ontology#Mild"/>
  <owl:differentFrom rdf:resource="http://example.org/ontology#MildToSevere"/>
  <owl:differentFrom rdf:resource="http://example.org/ontology#ModerateToSevere"/>
  <owl:differentFrom rdf:resource="http://example.org/ontology#Severe"/>
  <owl:differentFrom rdf:resource="http://example.org/ontology#InitialTherapy"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not specified</rdfs:label>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NotSpecified</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://example.org/ontology#TherapeuticUseAndMonitoring">
  <rdfs:subClassOf rdf:resource="http://example.org/ontology#StewardshipPrinciple"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#FoodAndTiming"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#Storage"/>
  <owl:differentFrom rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
  <owl:differentFrom rdf:resource="http://example.org/ontology#FoodAndTiming"/>
  <owl:differentFrom rdf:resource="http://example.org/ontology#Storage"/>
</owl:Class>

<owl:Class rdf:about="http://example.org/ontology#Interaction">
  <owl:disjointWith rdf:resource="http://example.org/ontology#Warning"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#SideEffect"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#Pattern"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#Indication"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#Severity"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="http://example.org/ontology#interactsWith"/>
      <owl:onClass rdf:resource="http://example.org/ontology#Substance"/>
      <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</owl:minQualifiedCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="http://example.org/ontology#hasClinicalEffects"/>
      <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</owl:minCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="http://example.org/ontology#Warning">
  <owl:disjointWith rdf:resource="http://example.org/ontology#SideEffect"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#Pattern"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#Indication"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#Severity"/>
  <rdfs:subClassOf>
