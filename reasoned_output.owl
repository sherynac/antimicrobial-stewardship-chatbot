<onto:Interaction rdf:about="http://example.org/ontology#ITN050">
  <onto:hasReference rdf:resource="http://example.org/ontology#R038"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S037"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN050</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Co-administration with a single oral dose of azithromycin resulted in increased azithromycin serum concetration.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dose adjustment of azithromycin is not recommended when administered in combination with nelfinavir.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Close monitoring for known adverse effects of azithromycin, such as liver enzyme abnormalities and hearing impairment.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN049">
  <onto:hasReference rdf:resource="http://example.org/ontology#R038"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S018"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN049</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None specifically reported in the dedicated drug interaction study.</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concurrent use of warfarin and azithromycin may potentiate the effects of oral anticoagulants.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Prothrombin time should be carefully monitored while patients are receiving azithromycin and oral anticoagulants concurrently</onto:hasManagementAdvice>
</onto:Interaction>

