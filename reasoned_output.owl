<onto:Interaction rdf:about="http://example.org/ontology#ITN150">
  <onto:hasReference rdf:resource="http://example.org/ontology#R020"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S124"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN150</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contraindicated.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant administration.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not explicitly detailed but implies increased toxicity.</onto:hasClinicalEffects>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN149">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S123"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R020"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN149</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant administration.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May result in ergot toxicity.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contraindicated.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN147">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S121"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R020"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN147</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Food does not affect the extent of bioavailability.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May be taken with or without food.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Effect of food on bioavailability.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN148">
  <onto:hasReference rdf:resource="http://example.org/ontology#R020"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S122"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN148</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Elevated drug levels, QT prolongation, and serious cardiac arrhythmias.</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant use with clarithromycin.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contraindicated.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN151">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S125"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R020"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN151</rdfs:label>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant administration.</onto:hasInteractionDescription>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not explicitly detailed but implies increased sedative effects.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contraindicated.</onto:hasManagementAdvice>
</onto:Interaction>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W157">
  <onto:hasReference rdf:resource="http://example.org/ontology#R020"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W157</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Large amounts produce GI symptoms. A patient ingesting 8 grams showed altered mental status, paranoid behaviour, hypokalemia, and hypoxemia.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gastrointestinal and Mental Effects</onto:hasWarningHeadline>
</onto:AgeRestriction>

<onto:Contraindication rdf:about="http://example.org/ontology#W158">
  <onto:hasReference rdf:resource="http://example.org/ontology#R020"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W158</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contraindicated for patients with hypersensitivity to macrolides, a history of QT prolongation, ventricular cardiac arrhythmia, or those taking drugs like oral midazolam, astemizole, cisapride, pimozide, terfenadine, ergot alkaloids, ticagrelor, or ranolazine.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dangerous Combinations</onto:hasWarningHeadline>
</onto:Contraindication>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W155">
  <onto:hasReference rdf:resource="http://example.org/ontology#R020"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W155</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not for Children &lt;12</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Indicated for adults and children 12 years and older. It is not recommended for children younger than 12 years; they should use the paediatric suspension instead.</onto:hasWarningText>
</onto:AgeRestriction>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W154">
  <onto:hasReference rdf:resource="http://example.org/ontology#R020"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W154</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Safety Not Established</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use is not advised without carefully weighing benefits against risk, as adverse embryo-fetal development effects cannot be excluded. The safety of Clarithromycin for using breast-feeding of infants has not been established. Clarithromycin is excreted into human breast milk.</onto:hasWarningText>
</onto:PregnancyAndLactation>

<onto:PatientCondition rdf:about="http://example.org/ontology#W156">
  <onto:hasReference rdf:resource="http://example.org/ontology#R020"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W156</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Renal and Hepatic Impairment</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Caution is advised in patients with severe renal insufficiency or impaired hepatic function. Fatal hepatic failure has been reported in some cases.</onto:hasWarningText>
</onto:PatientCondition>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP100">
  <onto:hasReference rdf:resource="http://example.org/ontology#R020"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP100</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The usual dose is 250 mg twice daily, though this may be increased to 500 mg twice daily for severe infections.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP101">
  <onto:hasReference rdf:resource="http://example.org/ontology#R020"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP101</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Treatment usually lasts 6 to 14 days. For patients with renal impairment (CrCl &lt;30 mL/min), the dose should be halved and not continue beyond 14 days.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP103">
  <onto:hasReference rdf:resource="http://example.org/ontology#R020"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP103</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor for signs of hepatic failure, especially in those with pre-existing liver disease. Also, monitor for the development of drug-resistant organisms during H. pylori therapy.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:Storage rdf:about="http://example.org/ontology#SP102">
  <onto:hasReference rdf:resource="http://example.org/ontology#R020"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP102</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Store at temperatures not exceeding 30°C. The shelf life is 36 months.</onto:hasStewardshipDescription>
</onto:Storage>

