<onto:Interaction rdf:about="http://example.org/ontology#ITN195">
  <onto:hasReference rdf:resource="http://example.org/ontology#R039"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S147"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN195</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Caution should be exercised before considering concurrent administration of these medicinal products. If co-administration is necessary, ciclosporin levels should be monitored</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ciclosporin Cmax and AUC0-5 were found to be significantly elevated</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Drug rdf:about="http://example.org/ontology#S147">
  <onto:hasReference rdf:resource="http://example.org/ontology#R010"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ciclosporin</rdfs:label>
</onto:Drug>

<onto:Interaction rdf:about="http://example.org/ontology#ITN238">
  <onto:interactsWith rdf:resource="http://example.org/ontology#S162"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R129"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN238</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">In vitro and in vivo antagonism have been noted between cephalosporins and chloramphenicol against a variety of Gram-positive and Gram-negative bacteria</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">it is recommended that combined therapy with chloramphenicol and a cephalosporin be avoided, particularly when bactericidal activity is considered important.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">In vitro and in vivo antagonism have been noted between cephalosporins and chloramphenicol against a variety of Gram-positive and Gram-negative bacteria</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Drug rdf:about="http://example.org/ontology#S162">
  <onto:hasReference rdf:resource="http://example.org/ontology#R152"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Chloramphenicol</rdfs:label>
  <onto:hasSubstanceDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An antibiotic medication used to treat a variety of serious infections caused by bacteria but carries a high risk of causing serious bone marrow problems and is not frequently used.</onto:hasSubstanceDescription>
</onto:Drug>

<onto:Drug rdf:about="http://example.org/ontology#S028">
