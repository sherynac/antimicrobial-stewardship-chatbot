<onto:FallInProthrombinActivity rdf:about="http://example.org/ontology#SE505">
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R149"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fall in prothrombin activity</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">a disorder caused by the lack of a protein in the blood called prothrombin.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:FallInProthrombinActivity>

<onto:Seizures rdf:about="http://example.org/ontology#SE506">
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R147"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Seizures</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">abnormal electrical activity in your brain. It causes changes in awareness and muscle control.</onto:hasSideEffectDescription>
</onto:Seizures>

<onto:CDifficileAssociatedDiarrhea rdf:about="http://example.org/ontology#SE504">
  <onto:hasReference rdf:resource="http://example.org/ontology#R146"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Clostridium difficile-associated diarrhea</rdfs:label>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">is a bacterium that causes an infection of the colon, the longest part of the large intestine.</onto:hasSideEffectDescription>
</onto:CDifficileAssociatedDiarrhea>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W243">
  <onto:hasReference rdf:resource="http://example.org/ontology#R129"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W243</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reproduction studies performed in mice and rats up to 400 times the human dose have not revealed evidence of harm to the fetus. There are no adequate and well-controlled studies in pregnant women, and the drug should be used during pregnancy only when clearly needed.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pregnancy</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:PatientCondition rdf:about="http://example.org/ontology#W239">
  <onto:hasReference rdf:resource="http://example.org/ontology#R128"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W239</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Colitis</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">As with other broad-spectrum antibiotics, cefixime should be given with caution in individuals with a history of colitis</onto:hasWarningText>
</onto:PatientCondition>

<onto:PatientCondition rdf:about="http://example.org/ontology#W241">
  <onto:hasReference rdf:resource="http://example.org/ontology#R129"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W241</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antibotic Resistance</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Prescribing cefixime in the absence of a proven or strongly suspected bacterial infection or a prophylactic indication is unlikely to provide benefit to the patient and increases the risk of antibiotic resistance.</onto:hasWarningText>
</onto:PatientCondition>

<onto:PatientCondition rdf:about="http://example.org/ontology#W242">
  <onto:hasReference rdf:resource="http://example.org/ontology#R129"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W242</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">As with other antibacterial drugs, long term or repeated use may result in overgrowth of non- susceptible organisms, including fungi.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Overgrowth of non-susceptible</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:PatientCondition rdf:about="http://example.org/ontology#W240">
  <onto:hasReference rdf:resource="http://example.org/ontology#R129"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W240</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The safety and efficacy of cefixime have not been established in patients with gastrointestinal malabsorption.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gastrointestinal Malabsorption</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W244">
  <onto:hasReference rdf:resource="http://example.org/ontology#R129"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W244</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">It is not known whether cefixime is excreted in human milk. Consideration should be given to discontinuing breastfeeding temporarily during treatment with cefixime.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lactation</onto:hasWarningHeadline>
</onto:PregnancyAndLactation>

<onto:Contraindication rdf:about="http://example.org/ontology#W238">
  <onto:hasReference rdf:resource="http://example.org/ontology#R128"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W238</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity to other cephalosporins or penicillins.</onto:hasWarningText>
</onto:Contraindication>

<onto:FoodAndTiming rdf:about="http://example.org/ontology#SP157">
  <onto:hasReference rdf:resource="http://example.org/ontology#R129"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP157</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May be taken with or without food.</onto:hasStewardshipDescription>
</onto:FoodAndTiming>

<onto:Interaction rdf:about="http://example.org/ontology#ITN240">
  <onto:hasReference rdf:resource="http://example.org/ontology#R129"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S146"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN240</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant administration of probenecid reportedly increases Cmax and AUC of cefixime and decreases renal clearance and volume of distribution of the drug.</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Concomitant administration of probenecid reportedly increases Cmax and AUC of cefixime and decreases renal clearance and volume of distribution of the drug.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN237">
  <onto:hasReference rdf:resource="http://example.org/ontology#R129"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S161"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN237</rdfs:label>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Drug monitoring when these drugs are given together is advised.</onto:hasManagementAdvice>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Elevated carbamazepine levels have been reported when administered concomitantly with cefixime.</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Elevated carbamazepine levels</onto:hasInteractionDescription>
</onto:Interaction>

<onto:Interaction rdf:about="http://example.org/ontology#ITN241">
  <onto:hasReference rdf:resource="http://example.org/ontology#R129"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S164"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN241</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased prothrombin time, with or without clinical bleeding, has been reported when cefixime is given concomitantly.</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased prothrombin time, with or without clinical bleeding, has been reported when cefixime is given concomitantly.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasManagementAdvice>
</onto:Interaction>

