  <onto:retrievedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://my.clevelandclinic.org/health/diseases/22632-angioedema</onto:retrievedFrom>
</onto:Reference>

<onto:Drug rdf:about="http://example.org/ontology#S158">
  <onto:hasReference rdf:resource="http://example.org/ontology#R145"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ethacrinic Acid</rdfs:label>
  <onto:hasSubstanceDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ETHACRYNIC ACID reduces swelling related to heart, kidney, liver, or lung disease. It may also be used to reduce swelling caused by cancer. It helps your kidneys remove more fluid and salt from your blood through the urine. It belongs to a group of medications called diuretics.</onto:hasSubstanceDescription>
</onto:Drug>

<onto:Reference rdf:about="http://example.org/ontology#R062">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">R062</rdfs:label>
  <onto:retrievedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://medlineplus.gov/ency/article/003088.htm</onto:retrievedFrom>
  <onto:hasReferenceTitle rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fatigue</onto:hasReferenceTitle>
  <onto:publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</onto:publishedIn>
  <onto:hasAuthor rdf:datatype="http://www.w3.org/2001/XMLSchema#string">National Library of Medicine</onto:hasAuthor>
</onto:Reference>

<onto:Drug rdf:about="http://example.org/ontology#S051">
