  <onto:hasReference rdf:resource="http://example.org/ontology#R031"/>
  <onto:hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Respiratory Tract Infection</rdfs:label>
  <onto:hasSymptoms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">a cough that may bring up mucus (phlegm), sneezing a stuffy or runny nose, a sore throat, headaches, muscle aches, breathlessness, tight chest or wheezing, a high temperature, and feeling generally unwell</onto:hasSymptoms>
</onto:RespiratoryTractInfection>

<onto:FoodAndTiming rdf:about="http://example.org/ontology#SP087">
  <onto:hasReference rdf:resource="http://example.org/ontology#R018"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP087</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reconstitution: For 250mg/5mL 35mL, add 25mL water; for 70mL, add 51mL water. Shake well before each use. May be taken with or without food.</onto:hasStewardshipDescription>
</onto:FoodAndTiming>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP091">
  <onto:hasReference rdf:resource="http://example.org/ontology#R018"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP091</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Only prescribe Klaryth for proven or strongly suspected bacterial infections to reduce the risk of drug-resistant bacteria developing.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:TherapeuticUseAndMonitoring rdf:about="http://example.org/ontology#SP090">
  <onto:hasReference rdf:resource="http://example.org/ontology#R018"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP090</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Monitor for the development of diarrhea, which may indicate pseudomembranous colitis. Regularly check blood levels for theophylline, digoxin, or carbamazepine if used concurrently.</onto:hasStewardshipDescription>
</onto:TherapeuticUseAndMonitoring>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP088">
  <onto:hasReference rdf:resource="http://example.org/ontology#R018"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP088</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Usual duration of treatment is 5 to 10 days depending on severity. Ensure zidovudine and Klaryth doses are separated as advised to maintain efficacy.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:PatientCondition rdf:about="http://example.org/ontology#W140">
  <onto:hasReference rdf:resource="http://example.org/ontology#R018"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W140</rdfs:label>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use with caution and consider dose reductions in severe renal or hepatic impairment. Consider a diagnosis of pseudomembranous colitis in patients who develop diarrhea.</onto:hasWarningText>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Renal/Hepatic Impairment &amp; Colitis</onto:hasWarningHeadline>
</onto:PatientCondition>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W141">
  <onto:hasReference rdf:resource="http://example.org/ontology#R018"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W141</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gastrointestinal Symptoms &amp; Supportive Care</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Overdose causes abdominal pain, vomiting, nausea, and diarrhea. Treat with prompt elimination of unabsorbed drug and supportive measures.</onto:hasWarningText>
</onto:AgeRestriction>

<onto:Contraindication rdf:about="http://example.org/ontology#W142">
  <onto:hasReference rdf:resource="http://example.org/ontology#R018"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W142</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity &amp; Drug Blocks</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Prohibited for patients with known hypersensitivity to macrolides. Concurrent use with astemizole, cisapride, or terfenadine is strictly forbidden.</onto:hasWarningText>
</onto:Contraindication>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W138">
  <onto:hasReference rdf:resource="http://example.org/ontology#R018"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W138</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Embryotoxicity &amp; Milk Distribution</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Should not be used in pregnant women unless no alternative is appropriate; high doses are associated with embryotoxicity in animals. Detected in breast milk; exercise caution when nursing.</onto:hasWarningText>
</onto:PregnancyAndLactation>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W139">
  <onto:hasReference rdf:resource="http://example.org/ontology#R018"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W139</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Elderly Risk</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Elderly patients are at higher risk for colchicine toxicity.</onto:hasWarningText>
</onto:AgeRestriction>

<onto:Storage rdf:about="http://example.org/ontology#SP089">
  <onto:hasReference rdf:resource="http://example.org/ontology#R018"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP089</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Store powder and reconstituted suspension at temperatures not exceeding 30°C. Reconstituted suspension is stable for 14 days. Do not refrigerate.</onto:hasStewardshipDescription>
</onto:Storage>

<onto:Storage rdf:about="http://example.org/ontology#SP173">
  <onto:hasReference rdf:resource="http://example.org/ontology#R163"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP173</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Store at room temperature (20-25 degrees celcius), protect from light and freezing, use within 30 days after opening.</onto:hasStewardshipDescription>
</onto:Storage>

<onto:Headache rdf:about="http://example.org/ontology#SE433">
  <onto:hasReference rdf:resource="http://example.org/ontology#R091"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Headache</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Discomfort in the head or face</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Headache>

<onto:Reference rdf:about="http://example.org/ontology#R091">
