  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">avoid giving tetracyclines in conjuction with penicillin</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Since bacteriostatic drugs interfere with the bactericidal action of penicillin, it is advisable to avoid giving tetracyclines in conjuction with penicillin</onto:hasInteractionDescription>
</onto:Interaction>

