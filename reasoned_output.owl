<owl:Class rdf:about="http://example.org/ontology#SideEffect">
  <owl:disjointWith rdf:resource="http://example.org/ontology#Indication"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#Pattern"/>
  <owl:disjointWith rdf:resource="http://example.org/ontology#Severity"/>
