  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">intense, excessive and persistent worry and fear about everyday situations</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasDuration>
</onto:Anxiety>

<onto:Constipation rdf:about="http://example.org/ontology#SE570">
  <onto:hasReference rdf:resource="http://example.org/ontology#R008"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R208"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Common"/>
