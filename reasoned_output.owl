<onto:Interaction rdf:about="http://example.org/ontology#ITN200">
  <onto:hasReference rdf:resource="http://example.org/ontology#R092"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S048"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN200</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Overall absorption of Ciprofloxacin is not substantially affected</onto:hasClinicalEffects>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">When Ciprofloxacin is given concomitantly with food, there is a delay in the absorption of the drug, resulting in peak concentrations that occur closer to 2 hours after dosing rather than 1 hour.</onto:hasInteractionDescription>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not Specified</onto:hasManagementAdvice>
</onto:Interaction>

