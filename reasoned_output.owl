<onto:Drug rdf:about="http://example.org/ontology#S166">
  <onto:hasReference rdf:resource="http://example.org/ontology#R157"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Magnesium Antacids</rdfs:label>
  <onto:hasSubstanceDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antacids that contain magnesium, such as Gaviscon, are used to reduce stomach acidity and relieve heartburn or indigestion. When taken with Macrodantin, these antacids may reduce how much of the antibiotic is absorbed into the body, making it less effective in treating infections.</onto:hasSubstanceDescription>
</onto:Drug>

