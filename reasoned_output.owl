<onto:Drug rdf:about="http://example.org/ontology#S165">
  <onto:hasReference rdf:resource="http://example.org/ontology#R158"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Probenecid</rdfs:label>
  <onto:hasSubstanceDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Probenecid is a medicine commonly used to treat gout by reducing uric acid in the body. It can affect how the kidneys remove other medicines, including Macrodantin. Taking them together may reduce the amount of nitrofurantoin that is cleared from the body, which can increase the drug levels and potentially casuse side effects.</onto:hasSubstanceDescription>
</onto:Drug>

