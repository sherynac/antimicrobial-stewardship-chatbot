<onto:Interaction rdf:about="http://example.org/ontology#ITN248">
  <onto:hasReference rdf:resource="http://example.org/ontology#R159"/>
  <onto:interactsWith rdf:resource="http://example.org/ontology#S167"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITN248</rdfs:label>
  <onto:hasClinicalEffects rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reduced antibacterial effectiveness can lead to slower infections recovery, persistent infection, or increased risk of bacterial resistance.</onto:hasClinicalEffects>
  <onto:hasManagementAdvice rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avoid combining nitrofurantoin with fluoroquinolone antibiotics unless directed by a doctor. If both are needed, careful monitoring and alternative dosing strategies may be required.</onto:hasManagementAdvice>
  <onto:hasInteractionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">When taken together, fluoroquinolone antibiotics may have an antagonistic effect on nitrofurantoin, meaning the two drugs can interfere with each other's ability to kill bacteria.</onto:hasInteractionDescription>
</onto:Interaction>

<onto:PeripheralNeuropathy rdf:about="http://example.org/ontology#SE521">
  <onto:hasReference rdf:resource="http://example.org/ontology#R158"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare__higher_risk_in_kidney_disease"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Peripheral Neuropathy</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Damage to nerves that may cause numbness, tingling, burning, or weakness in the hands and feet. Risk is higher in patients with kidney problems or long-term use.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May last if not treated early</onto:hasDuration>
</onto:PeripheralNeuropathy>

<onto:Vomiting rdf:about="http://example.org/ontology#SE516">
  <onto:whichIs rdf:resource="http://example.org/ontology#Early_in_treatment"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R157"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vomiting</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Forceful emptying of stomach contents. It may happen if the medicine irritates the stomach. Taking the capsule with meals may reduce this effect.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
</onto:Vomiting>

<onto:LossOfAppetite rdf:about="http://example.org/ontology#SE517">
  <onto:hasReference rdf:resource="http://example.org/ontology#R158"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#During_therapy"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Loss of Appetite</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Decreased desire to eat. The patient may feel full quickly or uninterested in food while taking the medicine.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
</onto:LossOfAppetite>

<onto:Nausea rdf:about="http://example.org/ontology#SE515">
  <onto:whichIs rdf:resource="http://example.org/ontology#Early_in_treatment"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R157"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nausea</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A sick feeling in the stomach that may make the patient feel like vomiting. It usually improves when the medicine is taken with food.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
</onto:Nausea>

<onto:Headache rdf:about="http://example.org/ontology#SE518">
  <onto:whichIs rdf:resource="http://example.org/ontology#Occasional_during_use"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R158"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Headache</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild to moderate head pain that may feel like pressure or throbbing. Usually resolves after the body adjust to the medicine.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short-term</onto:hasDuration>
</onto:Headache>

<onto:UrineColorChange rdf:about="http://example.org/ontology#SE519">
  <onto:hasReference rdf:resource="http://example.org/ontology#R157"/>
  <onto:whichIs rdf:resource="http://example.org/ontology#Very_common"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Urine Color</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The urine may turn dark yellow or brown in color. This is harmless and happens because the drug is being removed through the urine. It is not sign of kidney damage.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">While taking the drug</onto:hasDuration>
</onto:UrineColorChange>

<onto:LungReaction rdf:about="http://example.org/ontology#SE520">
  <onto:whichIs rdf:resource="http://example.org/ontology#Rare_but_serious"/>
  <onto:hasReference rdf:resource="http://example.org/ontology#R159"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lung Reaction</rdfs:label>
  <onto:hasSideEffectDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May cause cough, chest pain, fever, and difficulty breathing. Acute reactions can happen suddenly within days, while chronic reactions may develop after long-term use. Medical attention is needed immediately.</onto:hasSideEffectDescription>
  <onto:hasDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Can be sudden or develop with long-term use</onto:hasDuration>
</onto:LungReaction>

<onto:AdministrationAndAdherence rdf:about="http://example.org/ontology#SP159">
  <onto:hasReference rdf:resource="http://example.org/ontology#R157"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SP159</rdfs:label>
  <onto:hasStewardshipDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Only take nitrofurantoin if a healthcare provider confirms or strongly suspects a urinary tract infection. Avoid using it for viral infections or other conditions where it won't help, to prevent antibiotic resistance and side effects.</onto:hasStewardshipDescription>
</onto:AdministrationAndAdherence>

<onto:Contraindication rdf:about="http://example.org/ontology#W254">
  <onto:hasReference rdf:resource="http://example.org/ontology#R157"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W254</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Do not use if you are allergic to nitrofurantoin or any of its ingredients. May cause serious allergic reactions like swelling, rash, itching, trouble breathing, or dizziness. Seek medical help immediately if these occur.</onto:hasWarningText>
</onto:Contraindication>

<onto:Contraindication rdf:about="http://example.org/ontology#W252">
  <onto:hasReference rdf:resource="http://example.org/ontology#R158"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W252</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Renal Impairement</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Should not be taken if the patient has renal impairment (including anuria, oliguria, eGFR &lt;45 mL/min or CrCl &lt;60 mL, or clinically significant elevated serum creatinine); history of cholestatic jaundice or hepatic dysfunction associated with previous nitrofurantoin use.</onto:hasWarningText>
</onto:Contraindication>

<onto:Drug rdf:about="http://example.org/ontology#S178">
  <onto:hasReference rdf:resource="http://example.org/ontology#R165"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Carbonic Anhydrase</rdfs:label>
  <onto:hasSubstanceDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A group of medicines that reduce aced production in the body and may change urine acidity. They are used for conditions like glaucoma, seizures, or fluid retention.</onto:hasSubstanceDescription>
</onto:Drug>

