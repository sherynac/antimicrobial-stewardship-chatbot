<onto:Contraindication rdf:about="http://example.org/ontology#W205">
  <onto:hasReference rdf:resource="http://example.org/ontology#R091"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W205</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypersensitivity</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ciprofloxacin must not be used in cases of hypersensitivity to Ciproflaxin or other quinolone chemotherapeutics</onto:hasWarningText>
</onto:Contraindication>

<onto:AgeRestriction rdf:about="http://example.org/ontology#W206">
  <onto:hasReference rdf:resource="http://example.org/ontology#R091"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W206</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Children and Adolescents</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ciprofloxacin must not be administered to children and adolescents, since there is no experience on the drug's safety in these patient groups; On the basis of animal studies, it is not entirely improbable that the drug could cause damage to articular cartilage in the immature organism.</onto:hasWarningText>
</onto:AgeRestriction>

<onto:PregnancyAndLactation rdf:about="http://example.org/ontology#W207">
  <onto:hasReference rdf:resource="http://example.org/ontology#R091"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">W207</rdfs:label>
  <onto:hasWarningHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pregnant Women and Nursing Mothers</onto:hasWarningHeadline>
  <onto:hasWarningText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ciprofloxacin must not be administered to pregnant women or nursing mothers, since there is no experience on the drug's safety in these patient groups; On the basis of animal studies, it is not entirely improbable that the drug could cause damage to articular cartilage in the immature organism; Animal studies have also not yet yielded any evidence of teratogenic effects (malformations)</onto:hasWarningText>
</onto:PregnancyAndLactation>

