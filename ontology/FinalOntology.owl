  <rdf:Description rdf:about="http://example.org/ontology#W243">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W243</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R129"/>
    <hasWarningHeadline>Pregnancy</hasWarningHeadline>
    <hasWarningText>Reproduction studies performed in mice and rats up to 400 times the human dose have not revealed evidence of harm to the fetus. There are no adequate and well-controlled studies in pregnant women, and the drug should be used during pregnancy only when clearly needed.</hasWarningText>
  </rdf:Description>
