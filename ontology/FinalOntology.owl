    <hasDurationOf>Can occur suddenly and may become serious if not treated</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#May_appear_during_therapy__especially_with_prolonged_use"/>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasSideEffectDescription>An allergic-type reaction affecting the lungs. Symptoms may include cough, chest pain, fever, or difficulty breathing. Immediate medical attention is needed.</hasSideEffectDescription>
  </rdf:Description>
