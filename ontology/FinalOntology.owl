    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP018</rdfs:label>
    <hasStewardshipDescription>Check electrolyte levels (especially potassium) during prolonged therapy.</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SkeletalPain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Skeletal Pain</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W098">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W098</rdfs:label>
    <hasWarningHeadline>Newborns &amp; Infants</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasWarningText>Use with caution in newborns due to risk of jaundice from sodium benzoate.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W205">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W205</rdfs:label>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R091"/>
    <hasWarningText>Ciprofloxacin must not be used in cases of hypersensitivity to Ciproflaxin or other quinolone chemotherapeutics</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R239">
