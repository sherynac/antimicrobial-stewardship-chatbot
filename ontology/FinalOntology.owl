    <rdfs:label>ITN102</rdfs:label>
    <hasClinicalEffects>Increased risk of kidney damage (AKI); elevated creatinine.</hasClinicalEffects>
    <hasInteractionDescription>Concurrent Nephrotoxic use.</hasInteractionDescription>
    <hasManagementAdvice>Monitor renal function (BUN, creatinine) and ensure adequate hydration.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <interactsWith rdf:resource="http://example.org/ontology#S076"/>
  </rdf:Description>
