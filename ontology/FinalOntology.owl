    <hasReference rdf:resource="http://example.org/ontology#R010"/>
    <hasClinicalEffects>Lowers renal clearance</hasClinicalEffects>
    <hasManagementAdvice>Caution should be exercised when levofloxacin is coadministered with drugs that affect the tubular renal secretion such as probenecid and cimetidine, especially in renally impaired patients.</hasManagementAdvice>
    <interactsWith rdf:resource="http://example.org/ontology#S146"/>
    <hasInteractionDescription>The renal clearance of levofloxacin is reduced by cimetidine (24%) and probenecid (34%).</hasInteractionDescription>
