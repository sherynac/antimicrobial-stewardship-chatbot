  <rdf:Description rdf:about="http://example.org/ontology#W161">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W161</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasWarningHeadline>Pediatric Use</hasWarningHeadline>
    <hasWarningText>Do not use in children aged 8 years and below because of the effect of tetracyclines in teeth (permanent discoloration and possibly enamel hypoplasia) and bone.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE547">
    <rdf:type rdf:resource="http://example.org/ontology#Nausea"/>
    <rdfs:label>Nausea</rdfs:label>
    <hasDurationOf>Short-term; may last a few hours to a few days</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Commonly_appears_early_in_treatment__especially_if_taken_without_food"/>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasSideEffectDescription>A feeling of sickness in the stomach that may make the patient feel like vomiting. It may improve when the medicine is taken with meals.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE039">
    <rdf:type rdf:resource="http://example.org/ontology#Diarrhea"/>
