  <rdf:Description rdf:about="http://example.org/ontology#ITN252">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN252</rdfs:label>
    <hasClinicalEffects>Higher blood levels may increase risk of side effects such as nausea, dizziness, or neuropathy, while lower drug concentration in urine can reduce effectiveness against urinary infections.</hasClinicalEffects>
    <hasInteractionDescription>Probenecid, a uricosuric drug, can reduce kidney excretion of Furadantin, increasing drug levels in the blood.</hasInteractionDescription>
    <hasManagementAdvice>Monitor for side effects. Your doctor may adjust doses of Furadantin or the uricosuric drug. Report any persistent urinary symptoms.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R163"/>
    <interactsWith rdf:resource="http://example.org/ontology#S171"/>
  </rdf:Description>
