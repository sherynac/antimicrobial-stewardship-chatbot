    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W159</rdfs:label>
    <hasWarningText>Embryotoxicity has also been noted in animals treated early in pregnancy.</hasWarningText>
    <hasWarningHeadline>Pregnancy</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SymptomaticHyperAndHypoglycemia">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Symptomatic Hyper and Hypoglycemia</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S151">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Ribafutin</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R108"/>
    <hasSubstanceDescription>An antibiotic used to treat infections caused by bacteria called mycobacteria which cannot be destroyed by usual antibiotics</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W165">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W165</rdfs:label>
    <hasWarningHeadline>Not for Children &lt;12</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasWarningText>Indicated for adults and children 12 years and older. It is not recommended for children younger than 12 years; they should use the paediatric suspension instead.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP132">
    <rdf:type rdf:resource="http://example.org/ontology#FoodAndTiming"/>
    <rdfs:label>SP132</rdfs:label>
    <hasStewardshipDescription>May be taken with or without food</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP020">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP020</rdfs:label>
    <hasStewardshipDescription>Watch for severe diarrhea that may indicate C. difficile infection.</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R252">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
