    <hasReference rdf:resource="http://example.org/ontology#R029"/>
    <hasWarningHeadline>Antibiotic-Associated Colitis</hasWarningHeadline>
    <hasWarningText>May cause persistent or severe blood or watery diarrhea with or without fever and abdominal pain</hasWarningText>
  </rdf:Description>
