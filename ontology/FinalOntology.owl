    <rdfs:label>SP117</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasStewardshipDescription>Take at least 2 hr before or 2 hr after antacids containing Mg/Al, sucralfate, metal cations (eg, Fe), &amp; multivit prep w/ Zn.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W175">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W175</rdfs:label>
    <hasWarningText>In case of overdosage, discontinue medication. Treat symptomatically and institute supportive measures. Dialysis does not alter serum half-life and thus would not be of benefit in treating cases of overdosage.</hasWarningText>
    <hasWarningHeadline>Overdose Treatment Guidance</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R013"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I002">
