    <rdf:type rdf:resource="http://example.org/ontology#FoodAndTiming"/>
    <rdfs:label>SP038</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasStewardshipDescription>May be taken with or without food</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R033">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R033</rdfs:label>
    <hasAuthor>National Library of Medicine</hasAuthor>
    <hasReferenceTitle>Toxic Epidermal Necrolysis</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2023</publishedIn>
    <retrievedFrom>https://www.ncbi.nlm.nih.gov/books/NBK574530/</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W058">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W058</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasWarningText>Do not take if you have hypersensitivity to the azithromycin, or any macrolide antibiotics.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W080">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W080</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R031"/>
    <hasWarningHeadline>Pregnancy</hasWarningHeadline>
    <hasWarningText>Comazole is contraindicated during pregnancy. If pregnancy cannot be excluded, possible risks should be balanced against the expected therapeutic effect. Comazole should not be given during pregnancy especially in late pregnancy because of risk of kernicterus.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE149">
    <rdf:type rdf:resource="http://example.org/ontology#Melena"/>
    <rdfs:label>Melena</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <hasReference rdf:resource="http://example.org/ontology#R060"/>
    <hasSideEffectDescription>Black, tarry stool caused by internal bleeding</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#UpperRespiratoryTractInfection">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Upper Respiratory Tract Infection</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#RespiratoryDisease"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Usually_detected_in_lab_tests">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Usually detected in lab tests</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W095">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W095</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasWarningHeadline>Phenylketonuria</hasWarningHeadline>
    <hasWarningText>Contains aspartame (source of phenylalanine). Use with caution in patients with phenylketonuria.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Rare__more_likely_with_long-term_use">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Rare; more likely with long-term use</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN021">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN021</rdfs:label>
    <hasClinicalEffects>None specifically reported.</hasClinicalEffects>
    <hasInteractionDescription>Azithromycin has little or no effect on hepatic cytochrome P450 enzymes, so may or may not interact with cisapride.</hasInteractionDescription>
    <hasManagementAdvice>Monitor for adverse effects if taken with these medications. Consult doctor or pharmacist.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <interactsWith rdf:resource="http://example.org/ontology#S015"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#AllergicReaction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Allergic Reaction</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#LobarPneumonia">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Lobar Pneumonia</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#RespiratoryDisease"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#BladderInfection">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Bladder Infection</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#UrinaryDisease"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE471">
    <rdf:type rdf:resource="http://example.org/ontology#Insomnia"/>
    <rdfs:label>Insomnia</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasReference rdf:resource="http://example.org/ontology#R124"/>
    <hasSideEffectDescription>Trouble falling asleep; waking up in the middle of the night but falling back asleep; waking up too early without being able to fall back asleep; feeling tired, unwell or sleepy; delayed responses, such as reacting too slowly when you’re driving; Memory issues; Slowed thinking, confusion or trouble concentrating; Mood changes, like anxiety, depression and irritability</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#During_or_after_treatment">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>During or after treatment</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP086">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP086</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <hasStewardshipDescription>Store at temperatures not exceeding 25°C. Protect from moisture and light</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W187">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W187</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasWarningHeadline>Prevention of photosensitisation</hasWarningHeadline>
    <hasWarningText>Although photosensitisation is very rare with levofloxacin,
it is recommended that patients should not expose themselves unnecessarily to strong sunlight or to artificial UV rays (e.g., sunray lamp, solarium), in order to prevent
photosensitisation.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W045">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
