    <hasReference rdf:resource="http://example.org/ontology#R030"/>
    <hasSubstanceDescription>Drinking alcohol may increase risks of side effects like dizziness or nausea.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN038">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN038</rdfs:label>
    <hasClinicalEffects>None specifically reported.</hasClinicalEffects>
    <hasInteractionDescription>The total body clearance of cefotaxime has been reduced in patients with normal and reduced renal function by mezlocillin.</hasInteractionDescription>
    <hasManagementAdvice>Monitor for adverse effects if taken with these medications. Consult doctor or pharmacist.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R014"/>
    <interactsWith rdf:resource="http://example.org/ontology#S029"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE439">
    <rdf:type rdf:resource="http://example.org/ontology#AbdominalPain"/>
    <rdfs:label>Abdominal Pain</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R058"/>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasSideEffectDescription>Pain felt anywhere between the chest and groin.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W020">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W020</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <hasWarningHeadline>Sodium Content</hasWarningHeadline>
    <hasWarningText>Before receiving IVOZFO, notify the doctor if the patient have any of the following health conditions: heart problems, high blood pressure, hyperaldosteronism which is a condition where you have too much of a hormone called aldosterone, cirrhosis (scar tissue) of the liver, kidney problems, high levels of sodium in the blood, or fluid in your lungs. IVOZFO contains sodium that could make these conditions worse.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE124">
    <rdf:type rdf:resource="http://example.org/ontology#Dysgeusia"/>
    <rdfs:label>Dysgeusia</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasReference rdf:resource="http://example.org/ontology#R070"/>
    <hasSideEffectDescription>all foods taste metallic, sweet, sour or bitter</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#interactsWith">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>interacts with</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Substance"/>
    <owl:inverseOf rdf:resource="http://example.org/ontology#isInvolvedIn"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP026">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP026</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R027"/>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasStewardshipDescription>Take infection control measures such as hand hygiene and avoiding contact with sick individuals to prevent the spread of infection.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Flatulence">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Flatulence</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#A054">
    <rdf:type rdf:resource="http://example.org/ontology#OralSuspension"/>
    <rdfs:label>Oral Suspension</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE523">
    <rdf:type rdf:resource="http://example.org/ontology#Headache"/>
    <rdfs:label>Headache</rdfs:label>
    <hasDurationOf>Hours to a day</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Can_appear_during_early_days_of_use"/>
    <hasReference rdf:resource="http://example.org/ontology#R160"/>
    <hasSideEffectDescription>Mild to moderate pain in the head.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W214">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W214</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasWarningHeadline>Tendon pain, inflammation, rupture</hasWarningHeadline>
    <hasWarningText>If tendon pain, inflammation or rupture occurs, treatment with ciprofloxacin should be discontinued</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Pancreatitis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Pancreatitis</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE015">
    <rdf:type rdf:resource="http://example.org/ontology#Dizziness"/>
    <rdfs:label>Dizziness</rdfs:label>
    <hasDurationOf>Few hours to 1 day</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Rare__may_occur_during_treatment"/>
    <hasReference rdf:resource="http://example.org/ontology#R024"/>
    <hasSideEffectDescription>Feeling lightheaded or unsteady.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R093">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R093</rdfs:label>
    <hasAuthor>Monthly Index of Medical Specialties</hasAuthor>
    <hasReferenceTitle>Ziprocap</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</publishedIn>
    <retrievedFrom>https://www.mims.com/philippines/drug/info/ziprocap</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#LungInfiltration">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Lung Infiltration</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE056">
    <rdf:type rdf:resource="http://example.org/ontology#Rash"/>
    <rdfs:label>Rash</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <hasSideEffectDescription>Minor side effect; red, bumpy, often itchy skin</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE464">
    <rdf:type rdf:resource="http://example.org/ontology#ErythemaMultiforme"/>
    <rdfs:label>Erythema multiforme</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasReference rdf:resource="http://example.org/ontology#R119"/>
    <hasSideEffectDescription>A red to purple rash that causes your skin to puff up (swell) and be painful to the touch.; Pimple-like blisters on your skin or inside of your mouth.; Round mark on your skin that looks like a bulls-eye on a target, with a dark center and a pale ring around it.; Itchy skin.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W133">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W133</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <hasWarningHeadline>Cerebral Irritation</hasWarningHeadline>
    <hasWarningText>Overdosage of cephalosporins can cause cerebral irritation leading to convulsions or encephalopathy. Serum levels of cefuroxime can be reduced by hemodialysis and peritoneal dialysis.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R103">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R103</rdfs:label>
    <hasAuthor>US Centers for Disease Control and Prevention</hasAuthor>
    <hasReferenceTitle>Signs and Symptoms of Tuberculosis</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</publishedIn>
    <retrievedFrom>https://www.cdc.gov/tb/signs-symptoms/index.html</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W210">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W210</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasWarningHeadline>Nursing Mothers</hasWarningHeadline>
    <hasWarningText>Ciprofloxacin is excreted in human milk; The amount of ciprofloxacin absorbed by the infant is unknown; Due to potential serious adverse reactions to infants nursing from mothers taking ciprofloxacin, a decision should be made whether to discontinue nursing or to discontinue the drug, depending on the importance of the drug to the mother.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W136">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W136</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <hasWarningHeadline>Infants &gt; 3 Months &amp; Children &lt; 40 kg</hasWarningHeadline>
    <hasWarningText>Dosed at 25-50 mg/kg/day in divided doses every 8 or 12 hours.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP025">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP025</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R027"/>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasStewardshipDescription>Only use Contepo when prescribed by a healthcare professional for a confirmed infection. Avoid using for viral infections like colds or flu.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#retrievedFrom">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>retrieved from</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
