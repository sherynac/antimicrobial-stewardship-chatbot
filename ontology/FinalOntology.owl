    <rdfs:label>ITN214</rdfs:label>
    <hasClinicalEffects>Probenecid was found to reduce the urinary excretion of ciprofloxacin without increasing plasma concentration of the latter.</hasClinicalEffects>
    <hasInteractionDescription>Not Specified</hasInteractionDescription>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <interactsWith rdf:resource="http://example.org/ontology#S040"/>
  </rdf:Description>
