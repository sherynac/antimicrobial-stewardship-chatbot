  <rdf:Description rdf:about="http://example.org/ontology#ITN020">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN020</rdfs:label>
    <hasClinicalEffects>None specifically reported.</hasClinicalEffects>
    <hasInteractionDescription>Azithromycin has little or no effect on hepatic cytochrome P450 enzymes, so may or may not interact with astemizole.</hasInteractionDescription>
