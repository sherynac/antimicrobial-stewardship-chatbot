  <rdf:Description rdf:about="http://example.org/ontology#ITN004">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN004</rdfs:label>
    <interactsWith rdf:resource="http://example.org/ontology#S004"/>
    <hasClinicalEffects>Fosfomycin may be less effective at treating infection.</hasClinicalEffects>
    <hasInteractionDescription>Metoclopramide may reduce absorption of fosfomycin.</hasInteractionDescription>
    <hasManagementAdvice>Inform your doctor; avoid taking metoclopramide at the same time as fosfomycin if possible.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R022"/>
    <hasReference rdf:resource="http://example.org/ontology#R023"/>
  </rdf:Description>
