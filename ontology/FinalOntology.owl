  <rdf:Description rdf:about="http://example.org/ontology#SE207">
    <rdf:type rdf:resource="http://example.org/ontology#Seizure"/>
    <rdfs:label>seizure</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R144"/>
    <hasDuration>Not specified</hasDuration>
    <hasSideEffectDescription>A seizure is abnormal electrical activity in your brain. It causes changes in awareness and muscle control. It also causes symptoms that affect your behavior and senses. Seizures can affect anyone at any age and there are a lot of possible causes, from an underlying medical condition to an injury or illness.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  </rdf:Description>
