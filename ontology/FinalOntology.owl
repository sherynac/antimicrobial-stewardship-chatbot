    <rdf:type rdf:resource="http://example.org/ontology#Vomiting"/>
    <rdfs:label>Vomiting</rdfs:label>
    <hasDurationOf>Few hours</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Common__may_happen_during_infusion"/>
    <hasReference rdf:resource="http://example.org/ontology#R027"/>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasSideEffectDescription>Forceful expulsion of stomach contents; usually mild and stops after the dose.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE527">
    <rdf:type rdf:resource="http://example.org/ontology#Dizziness"/>
    <rdfs:label>DIzziness</rdfs:label>
    <hasDurationOf>Hours to days</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Can_appear_after_taking_first_doses"/>
    <hasReference rdf:resource="http://example.org/ontology#R160"/>
    <hasSideEffectDescription>Feeling lightheaded or unsteady.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R095">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R095</rdfs:label>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <hasReferenceTitle>Ear Infection (Otitis Media)</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2023</publishedIn>
    <retrievedFrom>https://my.clevelandclinic.org/health/diseases/8613-ear-infection-otitis-media</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Rare__may_happen">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Rare, may happen</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE518">
    <rdf:type rdf:resource="http://example.org/ontology#Headache"/>
    <rdfs:label>Headache</rdfs:label>
    <hasDurationOf>Short-term</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Occasional_during_use"/>
    <hasReference rdf:resource="http://example.org/ontology#R158"/>
    <hasSideEffectDescription>Mild to moderate head pain that may feel like pressure or throbbing. Usually resolves after the body adjust to the medicine.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE558">
    <rdf:type rdf:resource="http://example.org/ontology#Leukopenia"/>
    <rdfs:label>Leukopenia</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R276"/>
    <hasSideEffectDescription>Leukopenia (low white blood cell count) happens when you have a lower-than-normal number of white blood cells. Specifically, you have fewer neutrophils than normal. Neutrophils are white blood cells that act as your immune system’s first line of defense. Without enough white blood cells, you’re more vulnerable to developing infections.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W238">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W238</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R128"/>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasWarningText>Hypersensitivity to other cephalosporins or penicillins.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE157">
    <rdf:type rdf:resource="http://example.org/ontology#Rash"/>
    <rdfs:label>Rash</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <hasSideEffectDescription>red, bumpy, often itchy skin</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE190">
    <rdf:type rdf:resource="http://example.org/ontology#HaemophagocyticLymphohistiocytosis"/>
    <rdfs:label>haemophagocytic lymphohistiocytosis</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R287"/>
    <hasSideEffectDescription>Hemophagocytic lymphohistiocytosis is a rare and often life-threatening condition if left untreated. HLH causes your immune system to attack your body instead of a foreign invader like a virus. The condition is either acquired or genetic and there’s no way to prevent it.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE503">
    <rdf:type rdf:resource="http://example.org/ontology#Seizures"/>
    <rdfs:label>Seizures</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R147"/>
    <hasSideEffectDescription>abnormal electrical activity in your brain. It causes changes in awareness and muscle control.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W110">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W110</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasWarningHeadline>Streptococcal Pharyngitis Treatment</hasWarningHeadline>
    <hasWarningText>Treatment of streptococcal pharyngitis.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Contepo">
    <rdf:type rdf:resource="http://example.org/ontology#Brand"/>
    <rdfs:label>Contepo</rdfs:label>
    <hasPresentation rdf:resource="http://example.org/ontology#A028"/>
    <hasReference rdf:resource="http://example.org/ontology#R021"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE192">
    <rdf:type rdf:resource="http://example.org/ontology#Thrombocytopenia"/>
    <rdfs:label>thrombocytopenia</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R140"/>
    <hasSideEffectDescription>Thrombocytopenia occurs when your bone marrow doesn’t make enough platelets. Platelets are blood cells that form blood clots to help stop bleeding. People with this condition may bleed a lot and the bleeding may be hard to stop. Thrombocytopenia affects people with certain medical conditions like autoimmune disease or who take certain medications.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE418">
    <rdf:type rdf:resource="http://example.org/ontology#TendonEffects"/>
    <rdfs:label>Tendon Effects</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R010"/>
    <hasSideEffectDescription>Ruptures of the shoulder, hand, or Achilles tendon, or other tendons</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN042">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN042</rdfs:label>
    <hasClinicalEffects>None specifically reported.</hasClinicalEffects>
    <hasInteractionDescription>Simultaneous administration of antacids had no effect on overall bioavailability but peak serum concentrations were reduced by approximately 24%.</hasInteractionDescription>
    <hasManagementAdvice>Do not take azithromycin and antacids simultaneously</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <interactsWith rdf:resource="http://example.org/ontology#S022"/>
  </rdf:Description>
