    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R024"/>
    <hasWarningText>Do not take Fosfomycin Tromethamine if you have a known allergy to it or any ingredient in the medicine.</hasWarningText>
  </rdf:Description>
