    <rdfs:label>R108</rdfs:label>
    <hasReferenceTitle>Rifabutin</hasReferenceTitle>
    <hasAuthor>Monthly Index of Medical Specialties</hasAuthor>
    <retrievedFrom>https://www.mims.com/philippines/drug/info/rifabutin/patientmedicine/rifabutin-oral</retrievedFrom>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</publishedIn>
