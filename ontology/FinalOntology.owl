    <rdfs:label>W139</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <hasWarningHeadline>Elderly Risk</hasWarningHeadline>
    <hasWarningText>Elderly patients are at higher risk for colchicine toxicity.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#At_or_shortly_after_IV_administration">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
