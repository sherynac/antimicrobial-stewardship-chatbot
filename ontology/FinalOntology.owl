    <rdf:type rdf:resource="http://example.org/ontology#BloodBilirubinIncreased"/>
    <rdfs:label>blood bilirubin increased</rdfs:label>
    <hasDuration>Not specified</hasDuration>
    <hasSideEffectDescription>Higher than usual levels of bilirubin may mean different types of liver or bile duct problems. Sometimes, higher bilirubin levels may be caused by an increased rate of destruction of red blood cells.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R308"/>
