    <rdfs:label>Anorexia</rdfs:label>
    <hasDurationOf>May last during the period of treatment</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Can_develop_gradually_while_taking_the_medicine"/>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasSideEffectDescription>Reduced desire to eat or feeling full quickly. The patient may eat less than usual because of stomach discomfort.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE638">
    <rdf:type rdf:resource="http://example.org/ontology#GenitalMoniliasis"/>
