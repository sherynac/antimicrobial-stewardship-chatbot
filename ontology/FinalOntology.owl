    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R318"/>
    <hasSideEffectDescription>SAIDs (systemic autoinflammatory diseases) are a group of disorders that cause recurring fevers. They most commonly affect children. Formerly known as “periodic fever syndromes,” most of these conditions are hereditary and result from a genetic variant.</hasSideEffectDescription>
  </rdf:Description>
