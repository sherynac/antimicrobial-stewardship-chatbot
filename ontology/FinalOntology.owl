    <hasReference rdf:resource="http://example.org/ontology#R231"/>
    <hasSideEffectDescription>dizziness and makes you feel like you’re spinning when you’re not</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S105">
