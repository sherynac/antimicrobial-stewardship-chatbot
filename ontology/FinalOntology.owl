    <rdfs:label>W131</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasWarningText>Cefuroxime (as Axetil) products are contraindicated in patients with known allergy to the cephalosporin group of antibiotics.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Amoxicillin">
    <rdf:type rdf:resource="http://example.org/ontology#Antibiotic"/>
    <rdfs:label>Amoxicillin</rdfs:label>
    <hasBrandName rdf:resource="http://example.org/ontology#Amoxil"/>
    <hasBrandName rdf:resource="http://example.org/ontology#Pediamox"/>
    <hasBrandName rdf:resource="http://example.org/ontology#RiteMED_Amoxicillin"/>
    <hasDrugClass>Penicillins</hasDrugClass>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Usually_appears_at_the_start_of_treatment__may_lessen_with_food">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Usually appears at the start of treatment; may lessen with food</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R144">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R144</rdfs:label>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <hasReferenceTitle>Diarrhea</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2023</publishedIn>
    <retrievedFrom>https://my.clevelandclinic.org/health/diseases/4108-diarrhea</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP108">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP108</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasStewardshipDescription>Patient Safety: Monitor for signs of hepatic failure, especially in those with pre-existing liver disease. Also, monitor for the development of drug-resistant organisms during H. pylori therapy.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#A048">
    <rdf:type rdf:resource="http://example.org/ontology#PowderForInjection"/>
    <rdfs:label>Powder for Injection</rdfs:label>
    <hasInteraction rdf:resource="http://example.org/ontology#ITN242"/>
    <hasInteraction rdf:resource="http://example.org/ontology#ITN244"/>
    <hasSideEffect rdf:resource="http://example.org/ontology#SE507"/>
    <hasSideEffect rdf:resource="http://example.org/ontology#SE509"/>
    <hasSideEffect rdf:resource="http://example.org/ontology#SE513"/>
    <treats rdf:resource="http://example.org/ontology#I057"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R133">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R133</rdfs:label>
    <hasAuthor>Monthly Index of Medical Specialties</hasAuthor>
    <hasReferenceTitle>MIMS Drug Reference Concise Prescribing Information 2024</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2024</publishedIn>
    <retrievedFrom>ISSN 0218-4206</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE031">
    <rdf:type rdf:resource="http://example.org/ontology#InjectionSiteReaction"/>
    <rdfs:label>Injection Site Reaction</rdfs:label>
    <hasDurationOf>Short-term</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#At_or_shortly_after_IV_administration"/>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <hasSideEffectDescription>Pain, redness, or swelling at the injection site.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE199">
    <rdf:type rdf:resource="http://example.org/ontology#Hyponatraemia"/>
    <rdfs:label>hyponatraemia</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R290"/>
    <hasSideEffectDescription>Hyponatremia is when the amount of sodium in your blood is too low. Common causes include heart, liver, kidney and brain diseases, hormone issues and medications.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE287">
    <rdf:type rdf:resource="http://example.org/ontology#SkinAndSystemicReactions"/>
    <rdfs:label>Skin &amp; Systemic Reactions</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Common___1_100_to__1_10_"/>
    <hasReference rdf:resource="http://example.org/ontology#R020"/>
    <hasSideEffectDescription>Rash, hyperhidrosis, and abnormal liver function tests (LFT).</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN269">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN269</rdfs:label>
    <hasClinicalEffects>Not Specified</hasClinicalEffects>
    <hasInteractionDescription>Trimethoprim may increase serum concentrations of some drugs, including phenytoin, digoxin, procainamide, rosiglitazone, and repaglinidine, potentiating their effect. This may be due to competitive inhibition of renal excretion, decreased metabolism, or both.</hasInteractionDescription>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R166"/>
    <interactsWith rdf:resource="http://example.org/ontology#S188"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN091">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN091</rdfs:label>
    <hasClinicalEffects>Increased TMP-SMX blood levels, risk of adverse effects</hasClinicalEffects>
    <hasInteractionDescription>May occur in patients who are also receiving urinary acidifiers, oral anticoagulants, phenylbutazone, oxyphenbutazone and indomethacin.</hasInteractionDescription>
    <hasManagementAdvice>Avoid combination. Monitor for toxicity.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <interactsWith rdf:resource="http://example.org/ontology#S065"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S039">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Metoclopramide</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R032"/>
    <hasSubstanceDescription>Used for nausea or to speed up stomach emptying. When taken with oral antibiotics, it may decrease their absorption and overall effectiveness.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#UpperUrinaryTractInfection">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Upper Urinary Tract Infection</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#UrinaryDisease"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R111">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R111</rdfs:label>
    <hasAuthor>Monthly Index of Medical Specialties</hasAuthor>
    <hasReferenceTitle>Naproxen</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</publishedIn>
    <retrievedFrom>https://www.mims.com/philippines/drug/info/naproxen?mtype=generic</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP012">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP012</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R024"/>
    <hasStewardshipDescription>Monitor for diarrhea or water or bloody stools after antibiotic use, which could indicate C. difficile infection.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Appears_soon_after_starting">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Appears soon after starting</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Palpitation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Palpitation</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#PsychoticDisorder">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Psychotic Disorder</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ncc9caf714a1e4eda918fdaa09880ac90b65">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</owl:minQualifiedCardinality>
    <owl:onClass rdf:resource="http://example.org/ontology#Indication"/>
    <owl:onProperty rdf:resource="http://example.org/ontology#treats"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN201">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN201</rdfs:label>
    <hasClinicalEffects>Not Specified</hasClinicalEffects>
    <hasInteractionDescription>Concurrent administration of antacids containing magnesium hydroxide or aluminum hydroxide may reduce the bioavailability of ciprofloxacin by as much as 90%.</hasInteractionDescription>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <interactsWith rdf:resource="http://example.org/ontology#S155"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Renal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Renal</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W042">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W042</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasWarningHeadline>Pediatric Use</hasWarningHeadline>
    <hasWarningText>Safety and effectiveness of CONTEPO in patients less than 18 years of age has not been established.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S187">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Rosiglitazone</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R166"/>
    <hasSubstanceDescription>Oral antidiabetic (CYP2C8 substrate).</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP155">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP155</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R128"/>
    <hasStewardshipDescription>Store at temperatures not exceeding 30°C</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE368">
    <rdf:type rdf:resource="http://example.org/ontology#Eosinophilia"/>
    <rdfs:label>eosinophilia</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R191"/>
    <hasSideEffectDescription>increase of circulating eosinophils &gt;500 /mm^3</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE512">
    <rdf:type rdf:resource="http://example.org/ontology#Eosinophilia"/>
    <rdfs:label>Eosinophilia</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R133"/>
    <hasReference rdf:resource="http://example.org/ontology#R155"/>
    <hasSideEffectDescription>Eosinophilia happens when the body produces an unusually high number of eosinophils - one of the white blood cells that support your immune system.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W008">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W008</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R023"/>
    <hasWarningHeadline>Geriatric Use</hasWarningHeadline>
    <hasWarningText>Dose selection for an elderly patient should be cautious, usually starting at the low end of the dosing range, reflecting the greater frequency of decreased hepatic, renal, or cardiac function, and of concomitant disease or other drug therapy.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE262">
    <rdf:type rdf:resource="http://example.org/ontology#GastrointestinalEffects"/>
    <rdfs:label>Gastrointestinal Effects</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#During_or_following_discontinuance_of_amoxicillin"/>
    <hasReference rdf:resource="http://example.org/ontology#R016"/>
    <hasSideEffectDescription>Nausea, vomiting, diarrhea, black hairy tongue, Clostridioides difficile-associated disease and colitis; hemorrhagic colitis; acute, transient enterocolitis with severe abdominal pain and bloody diarrhea, and colitis; glossitis, stomatitis, epigastric distress, gastritis, flatulence, soft stools, loss of appetite, sore mouth or tongue, dry mouth, taste disturbances.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I065">
    <rdf:type rdf:resource="http://example.org/ontology#ComplicatedUrinaryTractInfectionCUTI"/>
    <rdfs:label>Mild to Severe Complicated Urinary Tract Infection (cUTI)</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasReference rdf:resource="http://example.org/ontology#R271"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#MildToSevere"/>
    <hasSymptoms>fever or chills, pain in the lower back or side, and overall malaise</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R240">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R240</rdfs:label>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <hasReferenceTitle>Gastritis</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2023</publishedIn>
    <retrievedFrom>https://my.clevelandclinic.org/health/diseases/10349-gastritis</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S007">
    <rdf:type rdf:resource="http://example.org/ontology#Beverage"/>
    <rdfs:label>Wine</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R024"/>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <hasSubstanceDescription>An alcoholic beverage. No known interaction with Fosfomycin, but general caution with antibiotics is advised.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Fairly_Frequent">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Fairly Frequent</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Can_appear_during_early_days_of_use">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Can appear during early days of use</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Melena">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Melena</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Vaginitis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Vaginitis</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S038">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Gentamicin / Amikacin</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R032"/>
    <hasSubstanceDescription>Aminoglycoside antibiotics. Increased risk of nephrotoxicity (kidney damage) and ototoxicity (hearing loss) when taken with Cephalosporins.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE371">
    <rdf:type rdf:resource="http://example.org/ontology#Diarrhea"/>
    <rdfs:label>diarrhea</rdfs:label>
    <hasDurationOf>2 months or more</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#infrequent"/>
    <hasReference rdf:resource="http://example.org/ontology#R013"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasSideEffectDescription>May occur after a patient stop taking doxycycline</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP159">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP159</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R157"/>
    <hasStewardshipDescription>Only take nitrofurantoin if a healthcare provider confirms or strongly suspects a urinary tract infection. Avoid using it for viral infections or other conditions where it won't help, to prevent antibiotic resistance and side effects.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP066">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP066</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasStewardshipDescription>Once water is added (reconstituted), the drops must be stored at refrigerated temperatures (between 2-8°C). The medicine will retain its potency for 7 days under these conditions</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN035">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN035</rdfs:label>
    <hasClinicalEffects>None specifically reported.</hasClinicalEffects>
    <hasInteractionDescription>The total body clearance of cefotaxime has been reduced in patients with normal and reduced renal function by mezlocillin.</hasInteractionDescription>
    <hasManagementAdvice>Monitor for adverse effects if taken with these medications. Consult doctor or pharmacist.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R014"/>
    <interactsWith rdf:resource="http://example.org/ontology#S029"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#TransientReductionsInNeutrophilCounts">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Transient Reductions in Neutrophil Counts</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE040">
    <rdf:type rdf:resource="http://example.org/ontology#AbdominalPain"/>
    <rdfs:label>Abdominal Pain</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Common"/>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <hasReference rdf:resource="http://example.org/ontology#R058"/>
    <hasSideEffectDescription>Effects are usually mild; pain felt anywhere between the chest and groin.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R047">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R047</rdfs:label>
    <hasAuthor>Glenmark</hasAuthor>
    <hasReferenceTitle>Altacef</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2020</publishedIn>
    <retrievedFrom>https://www.mims.com/philippines/drug/info/altacef?type=full</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S165">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Probenecid</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R158"/>
    <hasSubstanceDescription>Probenecid is a medicine commonly used to treat gout by reducing uric acid in the body. It can affect how the kidneys remove other medicines, including Macrodantin. Taking them together may reduce the amount of nitrofurantoin that is cleared from the body, which can increase the drug levels and potentially casuse side effects.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S113">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Ototoxic Drugs (e.g., Aminoglycosides)</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasSubstanceDescription>Drugs that can cause hearing or balance damage.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE067">
    <rdf:type rdf:resource="http://example.org/ontology#Hypernatremia"/>
    <rdfs:label>Hypernatremia</rdfs:label>
    <hasDurationOf>During treatment</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Common__can_happen_while_on_drug"/>
    <hasReference rdf:resource="http://example.org/ontology#R027"/>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasSideEffectDescription>High sodium in blood; may cause thirst, swelling, or confusion if severe.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R077">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R077</rdfs:label>
    <hasAuthor>Drugs.com</hasAuthor>
    <hasReferenceTitle>Doxycycline Side Effects</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2024</publishedIn>
    <retrievedFrom>https://www.drugs.com/sfx/doxycycline-side-effects.html</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W216">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W216</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasWarningHeadline>Pregnant and Nursing Mothers</hasWarningHeadline>
    <hasWarningText>Use it with caution if you are pregnant or a lactating mother.; Ciprofloxacin is excreted in breast milk; Ciprofloxacin was reported to cause arthralgia and degenerative changes in joints that bear weight in young animals.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#BulgingFontanels">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Bulging Fontanels</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S102">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Methoxyflurane</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R052"/>
    <hasSubstanceDescription>Inhalation anesthetic</hasSubstanceDescription>
