  <rdf:Description rdf:about="http://example.org/ontology#SP178">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP178</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasStewardshipDescription>Store Nitrofurantoin at temperatures not exceeding 30°C. Keep it in a dry place away from direct heat and moisture. Proper storage ensures that the medicine remains stable and effective until its expiration date.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W053">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W053</rdfs:label>
    <hasWarningText>Adverse effects experienced at doses higher than recommended are similar to those seen at normal doses. Symptoms of a macrolide antibiotic overdose typically include reversible hearing loss, severe nausea, vomiting, and diarrhea. In case of an overdose, administration of medicinal charcoal is recommended, along with general symptomatic treatment and supportive measures as needed.</hasWarningText>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasWarningHeadline>Taking higher than recommended dose</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN178">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN178</rdfs:label>
    <hasInteractionDescription>phenytoin decrease the half-life of doxycycline</hasInteractionDescription>
    <hasClinicalEffects>Decreased absorption</hasClinicalEffects>
    <interactsWith rdf:resource="http://example.org/ontology#S101"/>
    <hasManagementAdvice>Avoid taking together</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R013"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S048">
    <rdf:type rdf:resource="http://example.org/ontology#Food"/>
    <rdfs:label>Food</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasSubstanceDescription>Meals/Diet</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W198">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W198</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasWarningText>Quinolones, including levofloxacin, cause arthropathy and osteochondrosis in juvenile animals of several species. Levofloxacin is indicated in pediatric patients ≥6 months old, for inhalational anthrax (post- exposure) and for the treatment of plague, including pneumonic and septicemic plague due to Yersinia pestis and prophylaxis for plague. The risk-benefit assessment indicates that administration of levofloxacin to pediatric patients is appropriate. Safety and effectiveness in pediatric patients &lt;6 months old have not been established.</hasWarningText>
    <hasWarningHeadline>Use in children</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SideEffect">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:disjointWith rdf:resource="http://example.org/ontology#Indication"/>
    <owl:disjointWith rdf:resource="http://example.org/ontology#Pattern"/>
    <owl:disjointWith rdf:resource="http://example.org/ontology#Severity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W140">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W140</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <hasWarningText>Use with caution and consider dose reductions in severe renal or hepatic impairment. Consider a diagnosis of pseudomembranous colitis in patients who develop diarrhea.</hasWarningText>
    <hasWarningHeadline>Renal/Hepatic Impairment &amp; Colitis</hasWarningHeadline>
  </rdf:Description>
