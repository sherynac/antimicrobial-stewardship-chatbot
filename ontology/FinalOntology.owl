    <hasReference rdf:resource="http://example.org/ontology#R245"/>
    <hasSideEffectDescription>Glossitis is inflammation that makes your tongue swollen, smooth or red. Allergic reactions, infections and dry mouth may cause it.</hasSideEffectDescription>
  </rdf:Description>
