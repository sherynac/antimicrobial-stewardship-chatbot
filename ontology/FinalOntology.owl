    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Early in treatment</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R298">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R298</rdfs:label>
    <hasReferenceTitle>Peripheral Neuropathy</hasReferenceTitle>
    <retrievedFrom>https://my.clevelandclinic.org/health/diseases/14737-peripheral-neuropathy</retrievedFrom>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2022</publishedIn>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W138">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W138</rdfs:label>
    <hasWarningHeadline>Embryotoxicity &amp; Milk Distribution</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <hasWarningText>Should not be used in pregnant women unless no alternative is appropriate; high doses are associated with embryotoxicity in animals. Detected in breast milk; exercise caution when nursing.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R101">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R101</rdfs:label>
    <hasAuthor>US Centers for Disease Control and Prevention</hasAuthor>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</publishedIn>
    <retrievedFrom>https://www.cdc.gov/legionella/about/index.html</retrievedFrom>
    <hasReferenceTitle>About Legionnaires' Disease</hasReferenceTitle>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#DrugReactionWithEosinophiliaAndSystemicSymptoms">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Drug Reaction with Eosinophilia and Systemic Symptoms</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE542">
    <rdf:type rdf:resource="http://example.org/ontology#SeriousPulmonaryReaction"/>
    <rdfs:label>Serious Pulmonary Reaction</rdfs:label>
    <hasSideEffectDescription>Cough, fever, chest pain, shortness of breath.</hasSideEffectDescription>
    <hasDuration>Weeks to Months</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Rare__usually_with_long-term_use__6__months_"/>
    <hasReference rdf:resource="http://example.org/ontology#R163"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE105">
    <rdf:type rdf:resource="http://example.org/ontology#FungalInfections"/>
    <rdfs:label>Fungal Infections</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R066"/>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasSideEffectDescription>condition caused by fungus; usually affect skin, hair nails or mucous membranes</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W113">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W113</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasWarningText>Although the quantity of sulfamethoxazole/trimethoprim ingested by a breast-fed infant is small, caution should be exercised when DBL Sulfamethoxazole 400 mg and Trimethoprim 80 mg is administered to a nursing woman, especially when breastfeeding jaundiced, ill, stressed, or premature infants because of the potential risk of bilirubin displacement and kernicterus, and it is recommended that the age of the infant be considered and the possible risks be balanced against the expected therapeutic effect.</hasWarningText>
    <hasWarningHeadline>Breastfeeding</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S092">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Colchicine</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <hasSubstanceDescription>Gout medication</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN072">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN072</rdfs:label>
    <hasClinicalEffects>Increases the incidence and possibility of skin rashes</hasClinicalEffects>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <interactsWith rdf:resource="http://example.org/ontology#S046"/>
    <hasInteractionDescription>Concurrent administration</hasInteractionDescription>
    <hasManagementAdvice>Monitor for skin reactions during treatment</hasManagementAdvice>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN140">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN140</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasManagementAdvice>May be taken with or without food.</hasManagementAdvice>
    <interactsWith rdf:resource="http://example.org/ontology#S114"/>
    <hasClinicalEffects>The overall extent of absorption remains unaffected.</hasClinicalEffects>
    <hasInteractionDescription>Delays the onset of absorption and increases the peak time (tmax​) from 2 to 2.5 hours.</hasInteractionDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R241">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R241</rdfs:label>
    <retrievedFrom>https://my.clevelandclinic.org/health/diseases/stomatitis-oral-mucositis</retrievedFrom>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2024</publishedIn>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <hasReferenceTitle>Stomatitis</hasReferenceTitle>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP042">
    <rdf:type rdf:resource="http://example.org/ontology#FoodAndTiming"/>
    <rdfs:label>SP042</rdfs:label>
    <hasStewardshipDescription>May be taken with or without food</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP013">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP013</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <hasStewardshipDescription>Store at temperatures not exceeding 30°C</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE588">
    <rdf:type rdf:resource="http://example.org/ontology#Agitation"/>
    <rdfs:label>agitation</rdfs:label>
    <hasSideEffectDescription>state of severe restlessness or inner tension</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R226"/>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN132">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
