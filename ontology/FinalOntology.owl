  <rdf:Description rdf:about="http://example.org/ontology#ITN157">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN157</rdfs:label>
    <hasClinicalEffects>Increased quetiapine levels; risk of malignant neuroleptic syndrome</hasClinicalEffects>
    <hasInteractionDescription>Inhibition of the CYP3A enzyme</hasInteractionDescription>
    <hasManagementAdvice>Avoid combination; requires close monitoring or dose reduction.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <interactsWith rdf:resource="http://example.org/ontology#S131"/>
  </rdf:Description>
