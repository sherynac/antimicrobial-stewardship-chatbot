    <rdfs:label>W267</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R164"/>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasWarningText>Allergic to Furadantin (nitrofurantoin oral suspension); any part of Furadantin (nitrofurantoin oral suspension); or any other drugs, foods, or substances.</hasWarningText>
  </rdf:Description>
