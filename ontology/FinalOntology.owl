    <rdfs:label>SP110</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasStewardshipDescription>Monitor for symptoms such as tender abdomen and discontinue treatment immediately if they occur.</hasStewardshipDescription>
  </rdf:Description>
