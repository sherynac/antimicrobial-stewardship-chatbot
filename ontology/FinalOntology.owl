    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Can appear during early days of use</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE525">
    <rdf:type rdf:resource="http://example.org/ontology#RustColoredUrine"/>
