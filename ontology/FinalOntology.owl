  <rdf:Description rdf:about="http://example.org/ontology#W178">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W178</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasWarningHeadline>Maintained Hydration</hasWarningHeadline>
    <hasWarningText>Although levofloxacin is more soluble than other quinolones, adequate hydration of patients receiving levofloxacin should be maintained to prevent the formation of highly concentrated urine.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP063">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP063</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasStewardshipDescription>Reconstitution is required before use: 1. Loosen powder by shaking. 2. Add water up to 2/3 of the mark on the label. 3. Shake well for 1 minute, then let stand for 1 minute. 4. Add water exactly to the mark and shake well for 30 seconds</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP106">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP106</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasStewardshipDescription>Dosage &amp; Duration: Treatment usually lasts 6 to 14 days. For patients with renal impairment ($CrCl &lt; 30$ mL/min), the dose should be halved and not continue beyond 14 days.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE044">
    <rdf:type rdf:resource="http://example.org/ontology#ChestPain"/>
    <rdfs:label>Chest pain</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <hasSideEffectDescription>Minor side effect; Pain felt between neck and belly</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I037">
    <rdf:type rdf:resource="http://example.org/ontology#LobarPneumonia"/>
    <rdfs:label>Severe Lobar pneumonia</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R011"/>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasReference rdf:resource="http://example.org/ontology#R082"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#Severe"/>
    <hasSymptoms>persistent cough, high-grade fever with chills, confusion or delirium, pleuritic chest pain, shortness of breath, vomiting, abdominal pain, tiredness or fatigue</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W204">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W204</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R010"/>
    <hasWarningHeadline>QT Interval</hasWarningHeadline>
    <hasWarningText>Elderly patients may be more susceptible to drug-associated effects on the QT interval. Therefore, precaution should be taken when using levofloxacin with concomitant drugs that can result in prolongation of the QT interval (e.g. class IA or class III antiarrhythmic) or in patients with risk factors for Torsades de pointes (e.g. known QT prolongation, uncorrected hypokalemia).</hasWarningText>
  </rdf:Description>
