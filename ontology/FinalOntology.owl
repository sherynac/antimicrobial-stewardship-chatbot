    <hasReference rdf:resource="http://example.org/ontology#R027"/>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasSymptoms>Painful urination, frequent urination, fever, lower abdominal pain, cloudy or foul-smelling urine.</hasSymptoms>
    <hasSeverityType rdf:resource="http://example.org/ontology#ModerateToSevere"/>
  </rdf:Description>
