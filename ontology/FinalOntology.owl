  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#MegaloblasticAnaemia">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Megaloblastic Anaemia</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP106">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP106</rdfs:label>
    <hasStewardshipDescription>Dosage &amp; Duration: Treatment usually lasts 6 to 14 days. For patients with renal impairment ($CrCl &lt; 30$ mL/min), the dose should be halved and not continue beyond 14 days.</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S090">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Oral Anticoagulants</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <hasSubstanceDescription>Blood thinners</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE408">
    <rdf:type rdf:resource="http://example.org/ontology#HypersensitivityReactions"/>
    <rdfs:label>Hypersensitivity Reactions</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Following_the_first_dose"/>
    <hasSideEffectDescription>Cardiovascular collapse, hypotension/shock, seizure, loss of consciousness, tingling, angioedema (including tongue, laryngeal, throat, or facial edema/swelling), airway obstruction (including bronchospasm, shortness of breath, and acute respiratory distress), dyspnea, urticaria, itching, and other serious skin reactions. Levofloxacin should be discontinued immediately at the first appearance of a skin rash or any other sign of hypersensitivity</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I063">
    <rdf:type rdf:resource="http://example.org/ontology#ComplicatedUrinaryTractInfectionCUTI"/>
    <rdfs:label>Complicated Urinary Tract Infection (cUTI)</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R271"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
    <hasSymptoms>fever or chills, pain in the lower back or side, and overall malaise</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W045">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W045</rdfs:label>
    <hasWarningHeadline>Antibiotic-Associated Colitis</hasWarningHeadline>
    <hasWarningText>May cause persistent or severe blood or watery diarrhea with or without fever and abdominal pain</hasWarningText>
    <hasReference rdf:resource="http://example.org/ontology#R029"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN051">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN051</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S095">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>anticoagulant</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R011"/>
    <hasSubstanceDescription>Anticoagulant therapy</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE361">
    <rdf:type rdf:resource="http://example.org/ontology#Pericarditis"/>
    <rdfs:label>pericarditis</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R199"/>
    <whichIs rdf:resource="http://example.org/ontology#frequency_not_reported"/>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>swelling and irritation of the thin, saclike tissue surrounding the heart</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE407">
    <rdf:type rdf:resource="http://example.org/ontology#OtherSeriousAndSometimesFatalReactions"/>
    <rdfs:label>Other Serious and Sometimes Fatal Reactions</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <whichIs rdf:resource="http://example.org/ontology#Rare"/>
    <hasSideEffectDescription>fever, rash, or severe dermatologic reactions (e.g., toxic epidermal necrolysis, Stevens-Johnson syndrome); vasculitis; arthralgia; myalgia; serum sickness; allergic pneumonitis; interstitial nephritis; acute renal insufficiency or failure; hepatitis; jaundice; acute hepatic necrosis or failure; anemia, including hemolytic and aplastic; thrombocytopenia, including thrombotic thrombocytopenic purpura; leukopenia; agranulocytosis; pancytopenia; and/or other hematologic abnormalities.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE497">
    <rdf:type rdf:resource="http://example.org/ontology#Convulsions"/>
    <rdfs:label>Convulsions</rdfs:label>
    <hasSideEffectDescription>Surge of abnormal electrical activity in the brain. Temporary loss of consciousness and uncontrollable movements.</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R133"/>
    <hasReference rdf:resource="http://example.org/ontology#R114"/>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE439">
    <rdf:type rdf:resource="http://example.org/ontology#AbdominalPain"/>
    <rdfs:label>Abdominal Pain</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasSideEffectDescription>Pain felt anywhere between the chest and groin.</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R058"/>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
