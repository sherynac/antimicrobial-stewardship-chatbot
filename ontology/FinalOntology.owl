  <rdf:Description rdf:about="http://example.org/ontology#W218">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W218</rdfs:label>
    <hasWarningText>In epileptics and in patients who have suffered from previous CNS disorders (e.g. lowered convulsion threshold, previous history of convulsion, reduced cerebral blood flow, altered brain structure or stroke), Ciprofloxacin should only be used where the benefits of treatment exceed the risks, since these patients are endangered because of possible central nervous side effects.</hasWarningText>
    <hasWarningHeadline>Epileptic, history of Central Nervous System (CNS) disorders</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R091"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN179">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN179</rdfs:label>
    <hasClinicalEffects>render oral contraceptives less effective</hasClinicalEffects>
    <hasManagementAdvice>Avoid taking together</hasManagementAdvice>
    <hasInteractionDescription>Concurrent use of tetracycline may render oral contraceptives less effective</hasInteractionDescription>
    <hasReference rdf:resource="http://example.org/ontology#R013"/>
    <interactsWith rdf:resource="http://example.org/ontology#S103"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#May_occur_after_taking_a_dose__especially_if_stomach_upset_happens">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>May occur after taking a dose, especially if stomach upset happens</rdfs:label>
  </rdf:Description>
