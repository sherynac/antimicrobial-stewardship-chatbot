    <rdfs:label>ITN008</rdfs:label>
    <hasClinicalEffects>None specifically reported.</hasClinicalEffects>
    <hasInteractionDescription>No known interaction with wine; alcohol may affect general health while taking antibiotics.</hasInteractionDescription>
