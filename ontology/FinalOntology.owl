  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W196">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W196</rdfs:label>
    <hasWarningText>Levofloxacin should be avoided in patients with known prolongation of the QT interval, patients with uncorrected electrolyte imbalance (e.g., hypokalemia and
hypomagnesemia) patients with cardiac disease (e.g., heart failure, myocardial infarction and bradycardia), and in patients receiving drugs that are known to prolong the QT interval such as Class IA (quinidine, procainamide), or Class III (amiodarone, sotalol) antiarrhythmic agents, tricyclic antidepressants, macrolides and antipsychotics.</hasWarningText>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasWarningHeadline>QT Interval</hasWarningHeadline>
  </rdf:Description>
