  <rdf:Description rdf:about="http://example.org/ontology#SP159">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP159</rdfs:label>
    <hasStewardshipDescription>Only take nitrofurantoin if a healthcare provider confirms or strongly suspects a urinary tract infection. Avoid using it for viral infections or other conditions where it won't help, to prevent antibiotic resistance and side effects.</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R157"/>
  </rdf:Description>
