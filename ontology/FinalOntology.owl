    <hasSideEffectDescription>Mild discomfort or burning sensation in the chest.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN164">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN164</rdfs:label>
    <hasClinicalEffects>bacteriostatic drugs interfere with the bactericidal action of penicillin</hasClinicalEffects>
    <interactsWith rdf:resource="http://example.org/ontology#S096"/>
    <hasInteractionDescription>Since bacteriostatic drugs interfere with the bactericidal action of penicillin, it is advisable to avoid giving tetracyclines in conjuction with penicillin</hasInteractionDescription>
    <hasManagementAdvice>avoid giving tetracyclines in conjuction with penicillin</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN253">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN253</rdfs:label>
    <hasClinicalEffects>Blood levels of Furadantin may rise, increasing side effect risks, while effectiveness in treating urinary tract infections may decrease.</hasClinicalEffects>
    <hasReference rdf:resource="http://example.org/ontology#R163"/>
    <interactsWith rdf:resource="http://example.org/ontology#S172"/>
    <hasManagementAdvice>Monitor for side effects and infection signs. Your doctor may need to adjust treatment. Avoid combining without supervision.</hasManagementAdvice>
    <hasInteractionDescription>Sulfinpyrazone, another uricosuric agent, can similarly interfere with kidney excretion of Furadantin.</hasInteractionDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE088">
    <rdf:type rdf:resource="http://example.org/ontology#Diarrhea"/>
    <rdfs:label>Diarrhea</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R029"/>
    <hasReference rdf:resource="http://example.org/ontology#R030"/>
    <whichIs rdf:resource="http://example.org/ontology#Can_occur_within_first_days"/>
    <hasSideEffectDescription>Mild loose stools; monitor for severe watery or bloody diarrhea.</hasSideEffectDescription>
    <hasDuration>Short-term</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN080">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN080</rdfs:label>
    <hasInteractionDescription>Sulfonamides such as sulfamethoxazole may displace methotrexate from protein binding sites and can compete with the renal transport of methotrexate, thereby increasing free methotrexate levels. Cases of pancytopenia have been reported in patients taking the combination of sulfamethoxazole/trimethoprim and methotrexate.</hasInteractionDescription>
    <hasManagementAdvice>Avoid combination. Monitor for increased free methotrexate and marrow suppression.</hasManagementAdvice>
    <hasClinicalEffects>Pancytopenia, marrow suppression, increased toxicity</hasClinicalEffects>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <interactsWith rdf:resource="http://example.org/ontology#S054"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE289">
    <rdf:type rdf:resource="http://example.org/ontology#Rhabdomyolysis"/>
    <rdfs:label>Rhabdomyolysis</rdfs:label>
    <hasSideEffectDescription>Muscle tissue breakdown (rhabdomyolysis) has been reported when taken with statins, fibrates, colchicine, or allopurinol</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Rare_Concomitant_use_reports"/>
    <hasDuration>Not specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R020"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP069">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP069</rdfs:label>
    <hasStewardshipDescription>Must be reconstituted correctly and administered by a healthcare professional via IV or IM to ensure correct dosage and effectiveness.</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R032"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I024">
