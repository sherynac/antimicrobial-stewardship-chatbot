  <rdf:Description rdf:about="http://example.org/ontology#SE520">
    <rdf:type rdf:resource="http://example.org/ontology#LungReaction"/>
    <rdfs:label>Lung Reaction</rdfs:label>
    <hasDurationOf>Can be sudden or develop with long-term use</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Rare_but_serious"/>
    <hasReference rdf:resource="http://example.org/ontology#R159"/>
    <hasSideEffectDescription>May cause cough, chest pain, fever, and difficulty breathing. Acute reactions can happen suddenly within days, while chronic reactions may develop after long-term use. Medical attention is needed immediately.</hasSideEffectDescription>
  </rdf:Description>
