    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasStewardshipDescription>Preparation: Add half the water and shake vigorously; then add the remaining water and shake again. Shake well before each use. Can be taken with milk.</hasStewardshipDescription>
  </rdf:Description>
