  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I038">
    <rdf:type rdf:resource="http://example.org/ontology#Bronchopneumonia"/>
    <rdfs:label>Mild to severe Bronchopneumonia</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasReference rdf:resource="http://example.org/ontology#R083"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#MildToSevere"/>
    <hasSymptoms>fever, cough, shortness of breath, chest pain, rapid breathing, sweating, chills, headaches, muscle aches, pleurisy, fatigue, confusion or delirium</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE557">
    <rdf:type rdf:resource="http://example.org/ontology#Megaloblastosis"/>
    <rdfs:label>Megaloblastosis</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R317"/>
    <hasSideEffectDescription>Megaloblastosis is a cytomorphological diagnostic sign for megaloblastic anaemia, which is a morphological and functional erythropoiesis abnormality. At all stages of maturity, megaloblasts have various cytomorphological traits that distinguish them from normal erythroid precursor cells (i.e., normoblasts).</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#HemicAndLymphatic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Hemic and Lymphatic</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN194">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN194</rdfs:label>
    <hasClinicalEffects>Neutropenia was observed in subjects receiving concomitant treatment of azithromycin and ribafutin. Although neutropenia has been associated with the use of ribafutin, a causal relationship to combination with azithromycin has not been established.</hasClinicalEffects>
    <hasInteractionDescription>Co-administration did not affect the serum concentrations of either products</hasInteractionDescription>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <interactsWith rdf:resource="http://example.org/ontology#S151"/>
  </rdf:Description>
