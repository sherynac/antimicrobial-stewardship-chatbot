  <rdf:Description rdf:about="http://example.org/ontology#Cefotaxime">
    <rdf:type rdf:resource="http://example.org/ontology#Antibiotic"/>
    <rdfs:label>Cefotaxime</rdfs:label>
    <hasBrandName rdf:resource="http://example.org/ontology#Ximvex"/>
