  <rdf:Description rdf:about="http://example.org/ontology#ITN191">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN191</rdfs:label>
    <hasClinicalEffects>If azithromycin and P-gp substrates are administered concomitantly, the possibility of eleventaed serum concentrations of the subtrate should be considered</hasClinicalEffects>
    <hasInteractionDescription>Concomitant administration with macrolide antibiotics, including azithromycin result in increased serum levels of the P-glycoprotein substrate</hasInteractionDescription>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <interactsWith rdf:resource="http://example.org/ontology#S062"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN121">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN121</rdfs:label>
    <hasClinicalEffects>tetracyclines depress plasma prothrombin activity</hasClinicalEffects>
    <hasInteractionDescription>Because tetracyclines depress plasma prothrombin activity, patients who are on anticoagulant therapy may require reduction of their anticoagulant dosage.</hasInteractionDescription>
    <hasManagementAdvice>reduction of anticoagulant dosage</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R011"/>
    <interactsWith rdf:resource="http://example.org/ontology#S095"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN034">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN034</rdfs:label>
    <hasClinicalEffects>None specifically reported.</hasClinicalEffects>
    <hasInteractionDescription>Probenecid reduces the renal clearance of cefatoxime, resulting in higher and prolonged plasma concentrations of cefotaxime and its desacetyl metabolite.</hasInteractionDescription>
    <hasManagementAdvice>Monitor for adverse effects if taken with these medications. Consult doctor or pharmacist.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R014"/>
    <interactsWith rdf:resource="http://example.org/ontology#S028"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN238">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN238</rdfs:label>
    <hasClinicalEffects>In vitro and in vivo antagonism have been noted between cephalosporins and chloramphenicol against a variety of Gram-positive and Gram-negative bacteria</hasClinicalEffects>
    <hasInteractionDescription>In vitro and in vivo antagonism have been noted between cephalosporins and chloramphenicol against a variety of Gram-positive and Gram-negative bacteria</hasInteractionDescription>
    <hasManagementAdvice>it is recommended that combined therapy with chloramphenicol and a cephalosporin be avoided, particularly when bactericidal activity is considered important.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R129"/>
    <interactsWith rdf:resource="http://example.org/ontology#S162"/>
  </rdf:Description>
