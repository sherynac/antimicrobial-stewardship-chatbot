  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W225">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W225</rdfs:label>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R133"/>
    <hasWarningText>Should not be used if patient has a history of allergy or hypersensitivity to cephalosporins</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP016">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP016</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
