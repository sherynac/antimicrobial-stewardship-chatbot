    <hasDuration>1-2 days</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W018">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W018</rdfs:label>
    <hasWarningText>Do not use if the patient has a known allergy to fosfomycin. Serious allergic reactions like difficulty breathing, difficulty swallowing, fever, hives, itchy skin, rash, swelling of your tongue, throat or face</hasWarningText>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP084">
