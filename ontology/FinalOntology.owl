  <rdf:Description rdf:about="http://example.org/ontology#I049">
    <rdf:type rdf:resource="http://example.org/ontology#UrinaryTractInfections"/>
    <rdfs:label>Urinary Tract Infections</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R010"/>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasReference rdf:resource="http://example.org/ontology#R091"/>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
