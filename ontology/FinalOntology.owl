  <rdf:Description rdf:about="http://example.org/ontology#I009">
    <rdf:type rdf:resource="http://example.org/ontology#CommunityAcquiredPneumoniaCAP"/>
    <rdfs:label>Mild to Moderate Community-Acquired Pneumonia (CAP)</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R042"/>
