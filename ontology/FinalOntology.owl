  <rdf:Description rdf:about="http://example.org/ontology#ITN093">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN093</rdfs:label>
    <hasClinicalEffects>Elevated dofetilide levels is linear with QT prolongation, torsade de pointes, serious ventricular arrhythmias</hasClinicalEffects>
    <hasInteractionDescription>Concurrent administration is contraindicated. Elevated plasma concentrations of dofetilide have been reported following concurrent administration of trimethoprim and dofetilide. Increased plasma concentrations of dofetilide may cause serious ventricular arrhythmias associated with QT interval prolongation, including torsade de pointes.</hasInteractionDescription>
    <hasManagementAdvice>Contraindicated with TMP‑SMX. Avoid co-administration</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <interactsWith rdf:resource="http://example.org/ontology#S067"/>
  </rdf:Description>
