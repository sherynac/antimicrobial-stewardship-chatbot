    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasWarningText>Azithromycin is contraindicated in patients with known hypersensitivity to azithromycin, erythromycin, any macrolide or ketolide antibiotic.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN033">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN033</rdfs:label>
    <hasClinicalEffects>Can change drug effectiveness.</hasClinicalEffects>
    <hasInteractionDescription>Smoking or nicotine use may influence how your body processes fosfomycin.</hasInteractionDescription>
    <hasManagementAdvice>Consider avoiding nicotine or discuss with your doctor.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R029"/>
    <hasReference rdf:resource="http://example.org/ontology#R030"/>
    <interactsWith rdf:resource="http://example.org/ontology#S027"/>
  </rdf:Description>
