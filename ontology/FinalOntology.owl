  <rdf:Description rdf:about="http://example.org/ontology#W112">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W112</rdfs:label>
    <hasWarningHeadline>Pregnancy</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasWarningText>Sulfonamides may cause kernicterus in babies during the first month of life by displacing bilirubin from plasma albumin. Sulfonamides should therefore be avoided as far as possible during the last month of pregnancy. Trimethoprim may interfere with folic acid metabolism and animal experiments have shown that administration of very high doses of trimethoprim during organ development may give rise to birth defects typical of folic acid antagonism. If a trimethoprim-sulfonamide combination is given during pregnancy, folic acid supplementation may be required. Because trimethoprim and sulfamethoxazole may interfere with folic acid metabolism, DBL Sulfamethoxazole 400 mg and Trimethoprim 80 mg should be used during pregnancy only if the potential benefit justifies the potential risk to the fetus.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE025">
    <rdf:type rdf:resource="http://example.org/ontology#MetallicTaste"/>
    <rdfs:label>Metallic Taste</rdfs:label>
    <hasDuration>Few hours</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R024"/>
    <hasSideEffectDescription>Altered or metallic taste in the mouth.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare__overdose-related"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#HaemolysisInG6PDDeficiency">
