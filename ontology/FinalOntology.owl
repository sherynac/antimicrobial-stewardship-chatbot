  <rdf:Description rdf:about="http://example.org/ontology#ITN078">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN078</rdfs:label>
    <hasClinicalEffects>Reduces effectiveness and may cause breakthrough bleeding</hasClinicalEffects>
    <hasInteractionDescription>Concomitant use</hasInteractionDescription>
    <hasManagementAdvice>Patient should be informed of reduced efficacy</hasManagementAdvice>
