  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN027">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN027</rdfs:label>
    <hasClinicalEffects>Reduced drug effectiveness.</hasClinicalEffects>
    <hasInteractionDescription>Dairy products can interfere with absorption.</hasInteractionDescription>
    <hasManagementAdvice>Take the drug 2 hours before of after consuming dairy.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <interactsWith rdf:resource="http://example.org/ontology#S021"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP059">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP059</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasStewardshipDescription>Administered orally as a solid dosage form. General medical practice for antibiotics involves taking the medication for the full prescribed duration even if symptoms improve.</hasStewardshipDescription>
  </rdf:Description>
