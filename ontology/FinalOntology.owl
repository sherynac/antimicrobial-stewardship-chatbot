    <retrievedFrom>https://my.clevelandclinic.org/health/symptoms/myalgia-muscle-pain</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Not_specified">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Not specified</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE543">
    <rdf:type rdf:resource="http://example.org/ontology#PeripheralNeuropathy"/>
    <rdfs:label>Peripheral Neuropathy</rdfs:label>
    <hasDuration>Weeks to Months</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Rare__usually_with_long-term_use_or_kidney_problems"/>
    <hasSideEffectDescription>Numbness, tingling, or weakness in hands/feet.</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R163"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#PeripheralEdema">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Peripheral Edema</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Caused_by_allergies">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Caused by allergies</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE269">
    <rdf:type rdf:resource="http://example.org/ontology#VaginalYeastInfection"/>
    <rdfs:label>Vaginal Yeast Infection</rdfs:label>
    <hasSideEffectDescription>Itching, irritation, or thick white discharge due to changes in flora.</hasSideEffectDescription>
    <hasDuration>3–7 days</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#During_after_treatment"/>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE298">
    <rdf:type rdf:resource="http://example.org/ontology#Dizziness"/>
    <rdfs:label>Dizziness</rdfs:label>
    <hasSideEffectDescription>May cause lightheadedness that affects daily activities.</hasSideEffectDescription>
    <hasDuration>Short-term</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Occasionally_reported"/>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#May_appear_during_or_after_treatment">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>May appear during or after treatment</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W259">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W259</rdfs:label>
    <hasWarningText>Taking too much can cause severe nausea, vomiting, stomach pain, or other serious health problems; seek medical help immediately.</hasWarningText>
    <hasReference rdf:resource="http://example.org/ontology#R160"/>
    <hasWarningHeadline>Over Use</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#During_or_following_discontinuance_of_amoxicillin">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>During or following discontinuance of amoxicillin</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#During_shortly_after_treatment">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>During/shortly after treatment</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#LossOfAppetite">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Loss of Appetite</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W233">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W233</rdfs:label>
    <hasWarningHeadline>Avoidance</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R127"/>
    <hasWarningText>Avoid prolonged use.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN048">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN048</rdfs:label>
    <hasInteractionDescription>Concurrent use of rifampicin and Comazole results in shortening of plasma half life of trimethoprim.</hasInteractionDescription>
    <hasManagementAdvice>Monitor clinical response as trimethoprim levels may be reduced. Consider alternative therapy.</hasManagementAdvice>
    <interactsWith rdf:resource="http://example.org/ontology#S036"/>
    <hasReference rdf:resource="http://example.org/ontology#R031"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Diarrhea">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Diarrhea</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R255">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R255</rdfs:label>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2024</publishedIn>
    <hasReferenceTitle>Acute kidney injury</hasReferenceTitle>
    <retrievedFrom>https://www.mayoclinic.org/diseases-conditions/kidney-failure/symptoms-causes/syc-20369048</retrievedFrom>
    <hasAuthor>Mayo Clinic</hasAuthor>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN204">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN204</rdfs:label>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
    <hasClinicalEffects>Elevated serum theophylline levels and increased risk of a patient developing CNS or other adverse reactions.</hasClinicalEffects>
    <hasInteractionDescription>Concomitant administration of ciprofloxacin with theophylline decreases the clearance of theophylline</hasInteractionDescription>
    <interactsWith rdf:resource="http://example.org/ontology#S088"/>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE308">
    <rdf:type rdf:resource="http://example.org/ontology#HypersensitivityReactions"/>
    <rdfs:label>Hypersensitivity Reactions</rdfs:label>
    <hasSideEffectDescription>immune system overreacts and attacks something that isn’t harmful, like food, pollen, medications or even parts of your own body</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R259"/>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <whichIs rdf:resource="http://example.org/ontology#Rare"/>
    <hasDuration>May be prolonged</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE277">
    <rdf:type rdf:resource="http://example.org/ontology#CardiacEffects"/>
    <rdfs:label>Cardiac Effects</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Not_specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <hasDuration>Not specified</hasDuration>
    <hasSideEffectDescription>QT prolongation and Torsade de Pointes</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN269">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN269</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R166"/>
    <hasInteractionDescription>Trimethoprim may increase serum concentrations of some drugs, including phenytoin, digoxin, procainamide, rosiglitazone, and repaglinidine, potentiating their effect. This may be due to competitive inhibition of renal excretion, decreased metabolism, or both.</hasInteractionDescription>
    <hasClinicalEffects>Not Specified</hasClinicalEffects>
    <interactsWith rdf:resource="http://example.org/ontology#S188"/>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasReferenceTitle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>has reference title</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE069">
    <rdf:type rdf:resource="http://example.org/ontology#Hypophosphatemia"/>
    <rdfs:label>Hypophosphatemia</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Common__can_happen_while_on_drug"/>
    <hasDuration>During treatment</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasReference rdf:resource="http://example.org/ontology#R027"/>
    <hasSideEffectDescription>Low phosphate; may cause weakness or bone/muscle pain; usually mild.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S001">
    <rdf:type rdf:resource="http://example.org/ontology#Beverage"/>
    <rdfs:label>Beer</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R001"/>
    <hasSubstanceDescription>like san miguel</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN060">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN060</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasInteractionDescription>Probenecid decreases the renal tubular secretion of amoxicillin</hasInteractionDescription>
    <interactsWith rdf:resource="http://example.org/ontology#S040"/>
    <hasManagementAdvice>Concomitant use should be managed by a healthcare provider</hasManagementAdvice>
    <hasClinicalEffects>Increased and prolonged blood levels of amoxicillin</hasClinicalEffects>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE051">
    <rdf:type rdf:resource="http://example.org/ontology#Nephritis"/>
    <rdfs:label>Nephritis</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <hasReference rdf:resource="http://example.org/ontology#R061"/>
    <hasSideEffectDescription>Minor side effect; inflammation of one or both kidneys, which can leak protein into urine and impair the body's ability to absorb water and lead to tissue swelling</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R229">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R229</rdfs:label>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2024</publishedIn>
    <hasReferenceTitle>Tremor</hasReferenceTitle>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <retrievedFrom>https://my.clevelandclinic.org/health/symptoms/tremor</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W171">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W171</rdfs:label>
    <hasWarningHeadline>Intracranial Hypertension (Pseudotumor Cerebri)</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasWarningText>Intracranial hypertension (IH, pseudotumor cerebri) has been assciated with the use of tetracyclines including Doxycycline. Clinical manifestations of IH include headache, blurred vision, diplopia, and vision loss; papilledema can be found on fundoscopy. Women of childbearing age who are overweight or have history of IH are at greater risk for developing tetracycline associated IH.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#After_the_first_dose">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>After the first dose</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE138">
    <rdf:type rdf:resource="http://example.org/ontology#ToxicEpidermalNecrolysis"/>
    <rdfs:label>Toxic epidermal necrolysis</rdfs:label>
    <hasDuration>Not specified</hasDuration>
    <hasSideEffectDescription>Toxic epidermal necrolysis (TEN) is potentially life-threatening acute mucocutaneous Syndrome. It usually occurs because of inappropriate immune reactions to certain drugs.</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R033"/>
    <whichIs rdf:resource="http://example.org/ontology#Not_specified"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W217">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W217</rdfs:label>
    <hasWarningHeadline>Epileptic, history of Central Nervous System (CNS) disorders, myastenia gravis and glucose-6-phosphate dehydrogenase deficiency</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasWarningText>Caution should be taken when giving ciprofloxacin to epileptic patients and to those with history of Central Nervous System (CNS) disorders, myasthenia gravis and glucose-6-phosphate dehydrogenase deficiency.; Ciprofloxacin may exacerbate or unmask symptoms of myasthenia gravis.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S105">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Cisapride / Pimozide / Astemizole / Terfenadine</rdfs:label>
    <hasSubstanceDescription>Various drugs metabolized by the cytochrome P-450 system.</hasSubstanceDescription>
    <hasReference rdf:resource="http://example.org/ontology#R001"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R164">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
