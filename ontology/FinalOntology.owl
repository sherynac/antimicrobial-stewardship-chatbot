    <hasReference rdf:resource="http://example.org/ontology#R157"/>
    <hasWarningHeadline>Kidney Disease Warning</hasWarningHeadline>
    <hasWarningText>Should not be used if kidneys are not workingas well as they should be. If there is a concern about the health of the kidneys, the healthcare provider may do tests to determine if the kidneys are working well enough to take this medicine.</hasWarningText>
  </rdf:Description>
