    <hasDurationOf>May last if not treated early</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Rare__higher_risk_in_kidney_disease"/>
    <hasReference rdf:resource="http://example.org/ontology#R158"/>
    <hasSideEffectDescription>Damage to nerves that may cause numbness, tingling, burning, or weakness in the hands and feet. Risk is higher in patients with kidney problems or long-term use.</hasSideEffectDescription>
  </rdf:Description>
