    <owl:disjointWith rdf:resource="http://example.org/ontology#IVInfusion"/>
    <owl:disjointWith rdf:resource="http://example.org/ontology#InjectionConcentrate"/>
    <owl:disjointWith rdf:resource="http://example.org/ontology#OralDrops"/>
    <owl:disjointWith rdf:resource="http://example.org/ontology#OralSuspension"/>
