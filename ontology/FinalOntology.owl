  <rdf:Description rdf:about="http://example.org/ontology#W272">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W272</rdfs:label>
    <hasWarningText>Nitrofurantoin passes into breastmilk in very small amounts. Caution should be used when giving this medicine to breastfeeding mothers, and the infant should be observed for any unusual symptoms.</hasWarningText>
