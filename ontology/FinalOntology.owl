  <rdf:Description rdf:about="http://example.org/ontology#ITN211">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN211</rdfs:label>
    <interactsWith rdf:resource="http://example.org/ontology#S156"/>
    <hasInteractionDescription>Not Specified</hasInteractionDescription>
    <hasClinicalEffects>Naproxen and chloroquine were found to cause adverse neurological effect with the addition of ciprofloxacin.</hasClinicalEffects>
    <hasManagementAdvice>Effect was reduced when the antirheumatic drugs were discontinued.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
  </rdf:Description>
