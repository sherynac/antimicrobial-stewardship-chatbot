  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN030">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN030</rdfs:label>
    <hasInteractionDescription>Drinking alcohol while taking fosfomycin may increase the risk of side effects.</hasInteractionDescription>
    <hasClinicalEffects>May cause dizziness or nausea.</hasClinicalEffects>
    <hasManagementAdvice>Moderate use is generally safe; consult your doctor if unsure.</hasManagementAdvice>
    <interactsWith rdf:resource="http://example.org/ontology#S024"/>
