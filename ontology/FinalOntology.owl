  <rdf:Description rdf:about="http://example.org/ontology#I033">
    <rdf:type rdf:resource="http://example.org/ontology#LowerUrinaryTractInfection"/>
    <rdfs:label>Lower Urinary Tract Infection</rdfs:label>
    <hasSymptoms>more frequent urination, pain, burning, or other discomfort during urination, a sudden urge to urinate (even if you just went), feeling unable to empty the bladder fully, urine that’s cloudy or slightly colored with blood, urine that smells more pungent than usual, and abdominal or pelvic pain</hasSymptoms>
    <hasReference rdf:resource="http://example.org/ontology#R266"/>
    <hasReference rdf:resource="http://example.org/ontology#R031"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Early_during_treatment">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Early during treatment</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R177">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R177</rdfs:label>
    <hasAuthor>Yale Medicine</hasAuthor>
    <hasReferenceTitle>Hepatotoxicity (liver toxicity)</hasReferenceTitle>
    <retrievedFrom>https://www.yalemedicine.org/clinical-keywords/hepatotoxicity</retrievedFrom>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</publishedIn>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE350">
    <rdf:type rdf:resource="http://example.org/ontology#ErythemaMultiforme"/>
    <rdfs:label>erythema multiforme</rdfs:label>
    <hasSideEffectDescription>painful or uncomfortable rash on skin</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R197"/>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <whichIs rdf:resource="http://example.org/ontology#rare"/>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W071">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W071</rdfs:label>
    <hasWarningText>No adverse effects have been found on breast-fed infants whose mothers were receiving cefotaxime</hasWarningText>
    <hasReference rdf:resource="http://example.org/ontology#R014"/>
    <hasWarningHeadline>Breastfeeding</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE224">
    <rdf:type rdf:resource="http://example.org/ontology#HepaticNecrosis"/>
    <rdfs:label>hepatic necrosis</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R306"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasDuration>Not specified</hasDuration>
    <hasSideEffectDescription>The clinical course of acute hepatic necrosis resembles an acute, toxic injury to the liver with sudden and precipitous onset, marked elevations in serum aminotransferase levels, and early signs of hepatic (or other organ) dysfunction or failure despite minimal or no jaundice. Rapid recovery after withdrawal of the agent is also typical. Other organ failure, such as lung, kidney or bone marrow, may also be present and may overshadow the hepatic injury. Acute hepatic necrosis is typically caused by a direct hepatotoxin and is usually dose dependent and “expected”, rather than idiosyncratic.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W222">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W222</rdfs:label>
    <hasWarningHeadline>Elderly</hasWarningHeadline>
    <hasWarningText>Dose of ciprofloxacin should be reduced in the elderly as increased bioavailability and reduced renal clearance were seen probably due to absorption or first pass elimination</hasWarningText>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE265">
    <rdf:type rdf:resource="http://example.org/ontology#Hypersensitivity"/>
    <rdfs:label>Hypersensitivity</rdfs:label>
    <hasSideEffectDescription>Anaphylaxis, exanthema, bullous dermatitis, Stevens-Johnson syndrome (SJS), and pruritus</hasSideEffectDescription>
    <hasDuration>Not specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R016"/>
    <whichIs rdf:resource="http://example.org/ontology#Not_specified"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R180">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R180</rdfs:label>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</publishedIn>
    <retrievedFrom>https://www.osmosis.org/answers/blood-urea-nitrogen</retrievedFrom>
    <hasAuthor>Osmosis from ELSEVIER</hasAuthor>
    <hasReferenceTitle>Blood Urea Nitrogen (BUN)</hasReferenceTitle>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE553">
    <rdf:type rdf:resource="http://example.org/ontology#PeripheralNeuropathy"/>
    <rdfs:label>Peripheral Neuropathy</rdfs:label>
    <hasSideEffectDescription>Nerve damage that causes numbness, tingling, burning sensation, or weakness in the hands and feet. Treatment should be stopped if symptoms appear.</hasSideEffectDescription>
    <hasDuration>May develop gradually and can be long-lasting or permanent if not stopped early</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#More_likely_with_prolonged_use_or_in_high-risk_patients"/>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S190">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Zidovudine</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R166"/>
    <hasSubstanceDescription>Antiretroviral (NRTI).</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP174">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP174</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasStewardshipDescription>Nitrofurantoin should only be used to treat urinary tract infections caused by bacteria that are sensitive to the medicine. It should not be used for viral infections or infections outside the urinary tract. Using the medicine only when needed helps prevent bacteria from becoming resistant and keeps the drug effective in the future.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S080">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Thiazide diuretics</rdfs:label>
    <hasSubstanceDescription>Used for hypertension/fluid control; may affect renal drug excretion.</hasSubstanceDescription>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasClinicalEffects">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>has clinical effects</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I047">
    <rdf:type rdf:resource="http://example.org/ontology#UrinaryDisease"/>
    <rdfs:label>Mild to Severe Chronic Bacterial Prostatis</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasReference rdf:resource="http://example.org/ontology#R071"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#MildToSevere"/>
    <hasSymptoms>Fever, chills, painful and frequent urination or have trouble urinating,</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R146">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R146</rdfs:label>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2023</publishedIn>
    <hasAuthor>Mayo Clinic</hasAuthor>
    <hasReferenceTitle>C. difficile infection</hasReferenceTitle>
    <retrievedFrom>https://www.mayoclinic.org/diseases-conditions/c-difficile/symptoms-causes/syc-20351691</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE124">
    <rdf:type rdf:resource="http://example.org/ontology#Dysgeusia"/>
    <rdfs:label>Dysgeusia</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasReference rdf:resource="http://example.org/ontology#R070"/>
    <hasSideEffectDescription>all foods taste metallic, sweet, sour or bitter</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W124">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W124</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasWarningHeadline>Toxicity Management</hasWarningHeadline>
    <hasWarningText>May cause nausea, vomiting, diarrhea, crystalluria, and allergic manifestations. Symptomatic treatment is required for almost all patients. Problems are unlikely if adequate fluid intake and urinary output are maintained; however crystalluria and hemorrhagic cystitis are possible.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP077">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP077</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasStewardshipDescription>Store powder and reconstituted suspension in a dry place below 30°C; protect from light.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W049">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W049</rdfs:label>
    <hasWarningText>May pass into breast milk. If you are breast-feeding and are taking fosfomycin, it may affect your baby.</hasWarningText>
    <hasReference rdf:resource="http://example.org/ontology#R029"/>
    <hasWarningHeadline>Breastfeeding</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S167">
    <rdf:type rdf:resource="http://example.org/ontology#Food"/>
    <rdfs:label>Food</rdfs:label>
    <hasSubstanceDescription>Taking Macrodantin with food helps the medicine to be absorbed better into the bloodstream and reduces stomach irritation. Eating meals or snacks at the same time as the medicine can also help prevent nausea or vomiting, making the treatment easier to tolerate.</hasSubstanceDescription>
    <hasReference rdf:resource="http://example.org/ontology#R157"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I021">
    <rdf:type rdf:resource="http://example.org/ontology#AcuteUncomplicatedUrinaryTractInfectionUTI"/>
    <rdfs:label>Acute Uncomplicated Urinary Tract Infection (UTI)</rdfs:label>
    <hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasSymptoms>Strong and frequent urge to urinate, burning or painful feeling when urinating, urine may look cloudy, dark, or have a strong bad smell; Some people may feel mild lower belly pain or discomfort.</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R311">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R311</rdfs:label>
    <hasReferenceTitle>Acute Generalized Exanthematous Pustulosis</hasReferenceTitle>
    <hasAuthor>National Institutes of Health</hasAuthor>
    <retrievedFrom>https://www.ncbi.nlm.nih.gov/books/NBK592407/</retrievedFrom>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</publishedIn>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I010">
    <rdf:type rdf:resource="http://example.org/ontology#CommunityAcquiredPneumoniaCAP"/>
    <rdfs:label>Mild to Severe Community-Acquired Pneumonia (CAP)</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R263"/>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#MildToSevere"/>
    <hasSymptoms>symptoms may include shortness of breath, coughing, heavy sputum, fever and chills, chest pain that is worse when you breathe or cough, upper belly (abdomen) pain with nausea, vomiting, or diarrhea</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN263">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN263</rdfs:label>
    <hasInteractionDescription>Sulfamethoxazole and other sulfonamides may potentiate the effects of some drugs, such as oral anticoagulants, methotrexate, and phenytoin; this may be due to displacement of the drug from plasma protein binding sites or to inhibition of metabolism.</hasInteractionDescription>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R166"/>
    <interactsWith rdf:resource="http://example.org/ontology#S182"/>
    <hasClinicalEffects>Not Specified</hasClinicalEffects>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN237">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN237</rdfs:label>
    <hasManagementAdvice>Drug monitoring when these drugs are given together is advised.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R129"/>
    <interactsWith rdf:resource="http://example.org/ontology#S161"/>
    <hasClinicalEffects>Elevated carbamazepine levels have been reported when administered concomitantly with cefixime.</hasClinicalEffects>
    <hasInteractionDescription>Elevated carbamazepine levels</hasInteractionDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W129">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W129</rdfs:label>
    <hasWarningText>Symptoms include allergic reactions, nausea, vomiting, and diarrhea. High doses may cause crystalluria, potentially leading to renal failure, which is generally reversible upon cessation</hasWarningText>
    <hasWarningHeadline>Toxicity and Renal Risk</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R016"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#IntracranialHypertension">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Intracranial Hypertension</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE128">
    <rdf:type rdf:resource="http://example.org/ontology#HotFlush"/>
    <rdfs:label>Hot flush</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasSideEffectDescription>sudden feeling of warmth in the upper body mostly affecting the face, neck and chest</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#VaginalItchingOrDischarge">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Vaginal Itching or Discharge</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP047">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP047</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <hasStewardshipDescription>Store at temperatures not exceeding 30°C</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN241">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN241</rdfs:label>
    <hasClinicalEffects>Increased prothrombin time, with or without clinical bleeding, has been reported when cefixime is given concomitantly.</hasClinicalEffects>
    <hasInteractionDescription>Increased prothrombin time, with or without clinical bleeding, has been reported when cefixime is given concomitantly.</hasInteractionDescription>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R129"/>
    <interactsWith rdf:resource="http://example.org/ontology#S164"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#InjectionSite">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Injection Site</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R117">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R117</rdfs:label>
    <hasReferenceTitle>Itchy skin (pruritus)</hasReferenceTitle>
    <hasAuthor>Mayo Clinic</hasAuthor>
    <retrievedFrom>https://www.mayoclinic.org/diseases-conditions/itchy-skin/symptoms-causes/syc-20355006</retrievedFrom>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2024</publishedIn>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE453">
    <rdf:type rdf:resource="http://example.org/ontology#Dyspepsia"/>
    <rdfs:label>Dyspepsia</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Common"/>
    <hasSideEffectDescription>Pain or discomfort in the upper abdomen</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN081">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN081</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasClinicalEffects>Reduced antibacterial effectiveness of TMP‑SMX</hasClinicalEffects>
    <hasManagementAdvice>Avoid PABA supplements. They may reduce TMP‑SMX efficacy.</hasManagementAdvice>
    <hasInteractionDescription>Para-aminobenzoic acid (PABA) or its derivatives may antagonise the antibacterial effects of sulfamethoxazole.</hasInteractionDescription>
    <interactsWith rdf:resource="http://example.org/ontology#S055"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE641">
    <rdf:type rdf:resource="http://example.org/ontology#Granulocytopenia"/>
    <rdfs:label>granulocytopenia</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R220"/>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasSideEffectDescription>due to a decrease in bone marrow production resulting from defects in the growth and differentiation of granulocytes</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE549">
    <rdf:type rdf:resource="http://example.org/ontology#Anorexia"/>
    <rdfs:label>Anorexia</rdfs:label>
    <hasSideEffectDescription>Reduced desire to eat or feeling full quickly. The patient may eat less than usual because of stomach discomfort.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Can_develop_gradually_while_taking_the_medicine"/>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasDuration>May last during the period of treatment</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R142">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R142</rdfs:label>
    <hasReferenceTitle>Pseudomembranous colitis</hasReferenceTitle>
    <retrievedFrom>https://my.clevelandclinic.org/health/diseases/17718-pseudomembranous-colitis</retrievedFrom>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2023</publishedIn>
    <hasAuthor>Cleveland Clinic</hasAuthor>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I030">
    <rdf:type rdf:resource="http://example.org/ontology#LowerRespiratoryTractInfection"/>
    <rdfs:label>Lower Respiratory Tract Infection</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R133"/>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasReference rdf:resource="http://example.org/ontology#R020"/>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasReference rdf:resource="http://example.org/ontology#R014"/>
    <hasReference rdf:resource="http://example.org/ontology#R016"/>
    <hasReference rdf:resource="http://example.org/ontology#R137"/>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasReference rdf:resource="http://example.org/ontology#R127"/>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasSymptoms>cough, that might include mucus, shortness of breath, tight chest, or wheezing, sneezing, sore throat, blocked nose, change or loss of taste and smell, headache</hasSymptoms>
    <hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Arthralgia">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Arthralgia</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE646">
    <rdf:type rdf:resource="http://example.org/ontology#Anxiety"/>
    <rdfs:label>anxiety</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R225"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasSideEffectDescription>intense, excessive and persistent worry and fear about everyday situations</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE098">
    <rdf:type rdf:resource="http://example.org/ontology#SymptomsOfBowelInflammation"/>
    <rdfs:label>Symptoms of Bowel Inflammation</rdfs:label>
    <hasDuration>Short-term</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Rare_but_serious"/>
    <hasReference rdf:resource="http://example.org/ontology#R029"/>
    <hasReference rdf:resource="http://example.org/ontology#R030"/>
    <hasSideEffectDescription>Persistent or bloody diarrhea with abdominal pain and/or fever; seek doctor immediately.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE169">
    <rdf:type rdf:resource="http://example.org/ontology#Vomiting"/>
    <rdfs:label>Vomiting</rdfs:label>
    <hasSideEffectDescription>Gastrointestinal disturbance</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN068">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN068</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R032"/>
    <hasClinicalEffects>Increased risk of kidney damage (AKI), elevated creatinine</hasClinicalEffects>
    <interactsWith rdf:resource="http://example.org/ontology#S038"/>
    <hasInteractionDescription>Possible additive nephrotoxicity when given concurrently</hasInteractionDescription>
    <hasManagementAdvice>Monitor renal function (BUN, creatinine), ensure hydration, adjust dose if needed</hasManagementAdvice>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE616">
    <rdf:type rdf:resource="http://example.org/ontology#Urticaria"/>
    <rdfs:label>urticaria</rdfs:label>
    <hasSideEffectDescription>a skin rash that’s often very itchy, often results from an allergic reaction to food or something you’ve touched</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R249"/>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
