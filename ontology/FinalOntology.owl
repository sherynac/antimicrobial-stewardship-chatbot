    <rdf:type rdf:resource="http://example.org/ontology#ToxicEpidermalNecrolysis"/>
    <rdfs:label>Toxic epidermal necrolysis</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasReference rdf:resource="http://example.org/ontology#R121"/>
    <hasSideEffectDescription>It causes peeling and blistering skin over much of the body, including the mouth, eyes, and genitals.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ModerateToSevere">
    <rdf:type rdf:resource="http://example.org/ontology#Severity"/>
