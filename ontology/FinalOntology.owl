  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I061">
    <rdf:type rdf:resource="http://example.org/ontology#GenitalInfections"/>
    <rdfs:label>Genital Infections</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R166"/>
    <hasReference rdf:resource="http://example.org/ontology#R269"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
    <hasSymptoms>Burning or itching, discharge or odor, pain around the pelvis, burning and pain when passing urine or with bowel movements, having to go to the bathroom often, and sores, bumps or blisters on genital, anus or mouth</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE504">
    <rdf:type rdf:resource="http://example.org/ontology#CDifficileAssociatedDiarrhea"/>
    <rdfs:label>Clostridium difficile-associated diarrhea</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R146"/>
    <hasSideEffectDescription>is a bacterium that causes an infection of the colon, the longest part of the large intestine.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ncc9caf714a1e4eda918fdaa09880ac90b61">
    <rdf:first rdf:resource="http://example.org/ontology#ModerateToSevere"/>
    <rdf:rest rdf:nodeID="ncc9caf714a1e4eda918fdaa09880ac90b62"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W255">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W255</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R160"/>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasWarningText>May cause allergic reactions, which can be serious. Stop using nitrofurantoin and get help right away if any of the following symptoms of a serious allergic reaction: Breathing problems or wheezing, racing heart, fever or general ill feeling, swollen lymph nodes, swelling of the face, lips, mouth, tongue, or throat, trouble swallowing or throat tightness, itching, skin rash, or pale red bumps on the skin called hives, nausea or vomiting, or dizziness, feeling lightheaded , or fainting</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN197">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN197</rdfs:label>
    <hasInteractionDescription>Possible co-resistance between macrolide antibiotic and azithromycin (e.g. erythromycin) as well as lincomycin and clindamycin is to look at</hasInteractionDescription>
    <hasManagementAdvice>Concomitant use of several medical products from the same group of substances is not recommended</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <interactsWith rdf:resource="http://example.org/ontology#S153"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN065">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN065</rdfs:label>
    <hasClinicalEffects>Reduced efficacy of oral contraceptives</hasClinicalEffects>
    <hasInteractionDescription>Amoxil may affect gut flora, leading to lower estrogen reabsorption</hasInteractionDescription>
    <hasManagementAdvice>Be aware of potential reduced effectiveness of birth control while taking this antibiotic</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <interactsWith rdf:resource="http://example.org/ontology#S041"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W060">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W060</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <hasWarningHeadline>Co-administration</hasWarningHeadline>
    <hasWarningText>Do not take with ergot derivatives</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE173">
    <rdf:type rdf:resource="http://example.org/ontology#Leukopenia"/>
    <rdfs:label>Leukopenia</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R276"/>
    <hasSideEffectDescription>Leukopenia (low white blood cell count) happens when you have a lower-than-normal number of white blood cells. Specifically, you have fewer neutrophils than normal. Neutrophils are white blood cells that act as your immune system’s first line of defense. Without enough white blood cells, you’re more vulnerable to developing infections.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#RustColoredUrine">
