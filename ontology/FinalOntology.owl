  <rdf:Description rdf:about="http://example.org/ontology#S165">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Probenecid</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R158"/>
    <hasSubstanceDescription>Probenecid is a medicine commonly used to treat gout by reducing uric acid in the body. It can affect how the kidneys remove other medicines, including Macrodantin. Taking them together may reduce the amount of nitrofurantoin that is cleared from the body, which can increase the drug levels and potentially casuse side effects.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE182">
    <rdf:type rdf:resource="http://example.org/ontology#Purpura"/>
    <rdfs:label>purpura</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R185"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasSideEffectDescription>Purpura causes red, purple or brown blood spots on your skin. It happens when small blood vessels leak blood under your skin’s surface.</hasSideEffectDescription>
    <hasDuration>Not specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W003">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W003</rdfs:label>
    <hasWarningText>Monurol should not be used in patients with known allergy to fosfomyxin or any of its ingredients.</hasWarningText>
    <hasReference rdf:resource="http://example.org/ontology#R022"/>
    <hasReference rdf:resource="http://example.org/ontology#R023"/>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE575">
    <rdf:type rdf:resource="http://example.org/ontology#Pruritus"/>
    <rdfs:label>pruritus</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R213"/>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Common"/>
    <hasSideEffectDescription>causes you to feel the need to scratch your skin to get relief</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE470">
    <rdf:type rdf:resource="http://example.org/ontology#Drowsiness"/>
    <rdfs:label>Drowsiness</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>feeling tired and wanting to fall asleep</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#CardiacArrhythmias">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Cardiac Arrhythmias</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN272">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN272</rdfs:label>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
    <interactsWith rdf:resource="http://example.org/ontology#S191"/>
    <hasReference rdf:resource="http://example.org/ontology#R166"/>
    <hasInteractionDescription>Trimethoprim has been reported to reduce the renal excretion and increase blood concentrations of zidovudine, zalcitabine, and lamivudine.</hasInteractionDescription>
    <hasClinicalEffects>Not Specified</hasClinicalEffects>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE677">
    <rdf:type rdf:resource="http://example.org/ontology#Hepatic"/>
    <rdfs:label>Hepatic</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>Moderate rise in aminotransferase and/or alanine aminotransferase enzymes.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Rare"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN245">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN245</rdfs:label>
    <hasClinicalEffects>Not Specified</hasClinicalEffects>
    <hasInteractionDescription>Not Specified</hasInteractionDescription>
    <hasReference rdf:resource="http://example.org/ontology#R133"/>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
    <interactsWith rdf:resource="http://example.org/ontology#S019"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W170">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W170</rdfs:label>
    <hasWarningHeadline>Arrythmia Risk</hasWarningHeadline>
    <hasWarningText>May cause QT prolongation leading to Torsade de Pointes. Use with caution in at-risk patients.</hasWarningText>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W103">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W103</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R031"/>
    <hasWarningText>Nausea, vomiting, dizziness and confusion are likely symptoms of overdosage.</hasWarningText>
    <hasWarningHeadline>Gastronintestinal Effects</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN083">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN083</rdfs:label>
    <interactsWith rdf:resource="http://example.org/ontology#S057"/>
    <hasInteractionDescription>Increased effects and side effects of phenytoin (folate deficiencies) could occur when sulfamethoxazole/trimethoprim is given concurrently. Sulfamethoxazole/trimethoprim may inhibit the hepatic metabolism of phenytoin (a CYP2C9 substrate). Oral sulfamethoxazole/trimethoprim, given at a common clinical dosage, increased the phenytoin half-life by 39% and decreased the phenytoin metabolic clearance rate by 27%. When administering these drugs concurrently, one should be alert for possible excessive phenytoin effect.</hasInteractionDescription>
    <hasClinicalEffects>Phenytoin toxicity. Nystagmus, ataxia, confusion</hasClinicalEffects>
    <hasManagementAdvice>Monitor levels and for toxicity. Adjust dose as needed.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE239">
    <rdf:type rdf:resource="http://example.org/ontology#Myalgia"/>
    <rdfs:label>myalgia</rdfs:label>
    <hasSideEffectDescription>Myalgia is the medical term for muscle pain, which has many causes. Many of them are easy to treat at home. But myalgia can also be a symptom of disease, especially when it’s widespread and long-lasting.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R252"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasDuration>Not specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE317">
    <rdf:type rdf:resource="http://example.org/ontology#InflammatoryLesionsWithMonilialOvergrowth"/>
    <rdfs:label>inflammatory lesions (with monilial overgrowth)</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R173"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R011"/>
    <hasSideEffectDescription>An overgrowth of the fungus Candida causes a vaginal yeast infection. A vaginal yeast infection causes the skin around vagina to burn and itch, and it may change the consistency of vaginal discharge</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#rare"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE203">
    <rdf:type rdf:resource="http://example.org/ontology#Hallucinations"/>
    <rdfs:label>Hallucinations</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R126"/>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasDuration>Not specified</hasDuration>
    <hasSideEffectDescription>Hallucinations are false perceptions of sensory experiences. Some hallucinations are normal, such as those caused by falling asleep or waking up. But others may be a sign of a more serious condition like schizophrenia or dementia.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP116">
    <rdf:type rdf:resource="http://example.org/ontology#FoodAndTiming"/>
    <rdfs:label>SP116</rdfs:label>
    <hasStewardshipDescription>May be taken with or without food: May be taken during or between meals. Swallow whole, do not crush.</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
  </rdf:Description>
