  <rdf:Description rdf:about="http://example.org/ontology#SE405">
    <rdf:type rdf:resource="http://example.org/ontology#CentralNervousSystemEffects"/>
    <rdfs:label>Central Nervous System Effects</rdfs:label>
    <hasSideEffectDescription>Toxic psychoses, hallucination, or paranoia; depression, or suicidal thoughts; anxiety, agitation, restlessness, or nervousness; confusion, delirium, disorientation, or disturbances in attention; insomnia or nightmares; memory impairment.</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#After_the_first_dose"/>
  </rdf:Description>
