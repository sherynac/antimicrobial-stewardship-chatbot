  <rdf:Description rdf:about="http://example.org/ontology#ITN061">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN061</rdfs:label>
    <hasClinicalEffects>Reduced efficacy of oral contraceptives</hasClinicalEffects>
    <hasInteractionDescription>Amoxil may affect gut flora, leading to lower estrogen reabsorption</hasInteractionDescription>
    <hasManagementAdvice>Be aware of potential reduced effectiveness of birth control while taking this antibiotic</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <interactsWith rdf:resource="http://example.org/ontology#S041"/>
  </rdf:Description>
