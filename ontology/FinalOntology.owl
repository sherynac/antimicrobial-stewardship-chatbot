  <rdf:Description rdf:about="http://example.org/ontology#SE553">
    <rdf:type rdf:resource="http://example.org/ontology#PeripheralNeuropathy"/>
    <rdfs:label>Peripheral Neuropathy</rdfs:label>
    <hasDurationOf>May develop gradually and can be long-lasting or permanent if not stopped early</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#More_likely_with_prolonged_use_or_in_high-risk_patients"/>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasSideEffectDescription>Nerve damage that causes numbness, tingling, burning sensation, or weakness in the hands and feet. Treatment should be stopped if symptoms appear.</hasSideEffectDescription>
  </rdf:Description>
