    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W161</rdfs:label>
    <hasWarningText>Do not use in children aged 8 years and below because of the effect of tetracyclines in teeth (permanent discoloration and possibly enamel hypoplasia) and bone.</hasWarningText>
    <hasWarningHeadline>Pediatric Use</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W156">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W156</rdfs:label>
    <hasWarningHeadline>Renal and Hepatic Impairment</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R020"/>
    <hasWarningText>Caution is advised in patients with severe renal insufficiency or impaired hepatic function. Fatal hepatic failure has been reported in some cases.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R320">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R320</rdfs:label>
