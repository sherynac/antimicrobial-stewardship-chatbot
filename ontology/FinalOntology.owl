  <rdf:Description rdf:about="http://example.org/ontology#ITN037">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN037</rdfs:label>
    <hasClinicalEffects>None specifically reported.</hasClinicalEffects>
    <interactsWith rdf:resource="http://example.org/ontology#S028"/>
    <hasReference rdf:resource="http://example.org/ontology#R014"/>
    <hasInteractionDescription>Probenecid reduces the renal clearance of cefatoxime, resulting in higher and prolonged plasma concentrations of cefotaxime and its desacetyl metabolite.</hasInteractionDescription>
    <hasManagementAdvice>Monitor for adverse effects if taken with these medications. Consult doctor or pharmacist.</hasManagementAdvice>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S004">
