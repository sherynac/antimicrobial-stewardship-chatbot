  <rdf:Description rdf:about="http://example.org/ontology#ITN196">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN196</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasClinicalEffects>Causal relationship has not been established</hasClinicalEffects>
    <hasManagementAdvice>Consideration should be given to the frequency of monitoring prothrombin time when azithromycin is used in patients receiving coumarin-type oral anticoagulants</hasManagementAdvice>
    <hasInteractionDescription>Potentiated anticoagulation subsequent to co-administration of azithromycin and coumarin-type oral anticoagulants.</hasInteractionDescription>
    <interactsWith rdf:resource="http://example.org/ontology#S152"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE247">
    <rdf:type rdf:resource="http://example.org/ontology#GastrointestinalEffects"/>
    <rdfs:label>Gastrointestinal Effects</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>Includes nausea, vomiting, enterocolitis, and diarrhea.</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <whichIs rdf:resource="http://example.org/ontology#Common"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W066">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W066</rdfs:label>
    <hasWarningHeadline>Breastfeeding</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <hasWarningText>Unknown if Azithromycin is excreted in breast milk. Caution should be taken when administered to a nursing woman.</hasWarningText>
  </rdf:Description>
