    <rdf:type rdf:resource="http://example.org/ontology#CDifficileAssociatedDiarrhea"/>
    <rdfs:label>Clostridium difficile-associated diarrhea</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R146"/>
    <hasSideEffectDescription>is a bacterium that causes an infection of the colon, the longest part of the large intestine.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP075">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP075</rdfs:label>
    <hasStewardshipDescription>Administer as a liquid suspension (typically 5 mL per dose). Can be taken w/ meals for better absorption &amp; to reduce Gastrointestinal discomfort.</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S076">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Aminoglycosides (Gentamicin / Amikacin)</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <hasSubstanceDescription>Increased risk of nephrotoxicity (kidney damage) and ototoxicity (hearing loss) when taken with Cephalosporins.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W002">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W002</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <hasWarningText>Azithromycin, at the recommended dose, should not be relied upon to treat syphilis. Antimicrobial agents used in high doses for short periods of time to treat non-gonococcal urethritis may mask or delay the symptoms of incubating syphilis. All patients with sexually-transmitted urethritis or cervicitis should have a serologic test for syphilis and appropriate cultures for gonorrhea performed at the time of diagnosis. Appropriate antimicrobial therapy and follow-up tests for these diseases should be initiated if infection is confirmed.</hasWarningText>
    <hasWarningHeadline>Syphilis</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN127">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN127</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R011"/>
    <hasInteractionDescription>phenytoin decrease the half-life of doxycycline</hasInteractionDescription>
    <interactsWith rdf:resource="http://example.org/ontology#S101"/>
    <hasManagementAdvice>Avoid taking together</hasManagementAdvice>
    <hasClinicalEffects>Decreased absorption</hasClinicalEffects>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#StevensJohnsonSyndrome">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Stevens-Johnson Syndrome</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Dizziness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Dizziness</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W254">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W254</rdfs:label>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R157"/>
    <hasWarningText>Do not use if you are allergic to nitrofurantoin or any of its ingredients. May cause serious allergic reactions like swelling, rash, itching, trouble breathing, or dizziness. Seek medical help immediately if these occur.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE175">
    <rdf:type rdf:resource="http://example.org/ontology#Thrombocytopenia"/>
    <rdfs:label>Thrombocytopenia</rdfs:label>
    <hasSideEffectDescription>Thrombocytopenia occurs when your bone marrow doesn’t make enough platelets. Platelets are blood cells that form blood clots to help stop bleeding. People with this condition may bleed a lot and the bleeding may be hard to stop. Thrombocytopenia affects people with certain medical conditions like autoimmune disease or who take certain medications.</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R140"/>
    <hasDuration>Not specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n0e9bfaaca0144c75b7bd81f48c0754bfb24">
    <rdf:first rdf:resource="http://example.org/ontology#Suspension"/>
    <rdf:rest rdf:nodeID="n0e9bfaaca0144c75b7bd81f48c0754bfb25"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP113">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP113</rdfs:label>
    <hasStewardshipDescription>Store at temperatures not exceeding 30°C. Protect from light</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R013"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN192">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN192</rdfs:label>
    <interactsWith rdf:resource="http://example.org/ontology#S092"/>
    <hasClinicalEffects>If azithromycin and P-gp substrates are administered concomitantly, the possibility of eleventaed serum concentrations of the subtrate should be considered</hasClinicalEffects>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
    <hasInteractionDescription>Concomitant administration with macrolide antibiotics, including azithromycin result in increased serum levels of the P-glycoprotein substrate</hasInteractionDescription>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S188">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Repaglinidine</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R166"/>
    <hasSubstanceDescription>Oral antidiabetic (CYP2C8 substrate).</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#LegionnairesDisease">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#RespiratoryDisease"/>
