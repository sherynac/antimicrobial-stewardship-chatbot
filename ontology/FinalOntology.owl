    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasWarningHeadline>Co-administration</hasWarningHeadline>
    <hasWarningText>Due to theoretical possibility of ergotism, azithromycin and ergot derivatives should not be co-administered.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE406">
