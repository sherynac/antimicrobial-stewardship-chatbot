    <rdfs:label>ITN191</rdfs:label>
    <hasClinicalEffects>If azithromycin and P-gp substrates are administered concomitantly, the possibility of eleventaed serum concentrations of the subtrate should be considered</hasClinicalEffects>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
