    <hasReference rdf:resource="http://example.org/ontology#R229"/>
    <hasSideEffectDescription>body movement that’s out of your control</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W001">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W001</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <hasWarningHeadline>Pneumonia</hasWarningHeadline>
    <hasWarningText>Not recommended for people with pneumonia who cannot take medicine by mouth. This includes those who are very sick, need to stay in the hospital, have serious infections, are older or frail, or have serious health problems that weaken the immune system.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN168">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN168</rdfs:label>
    <hasClinicalEffects>Decreased absorption</hasClinicalEffects>
    <hasInteractionDescription>Carbamazepine decrease the half-life of doxycycline</hasInteractionDescription>
    <hasManagementAdvice>Avoid taking together</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <interactsWith rdf:resource="http://example.org/ontology#S100"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R104">
