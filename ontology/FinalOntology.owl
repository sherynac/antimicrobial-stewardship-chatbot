    <hasReference rdf:resource="http://example.org/ontology#R024"/>
    <hasWarningHeadline>Breastfeeding</hasWarningHeadline>
    <hasWarningText>It is unknown if Fosfomycin Tromethamine passes into breast milk. Talk to your doctor before using while nursing.</hasWarningText>
  </rdf:Description>
