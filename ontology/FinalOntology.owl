    <hasReference rdf:resource="http://example.org/ontology#R031"/>
    <hasSubstanceDescription>Antimalarial antifolate agent.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S156">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Naproxen and chloroquine</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R111"/>
    <hasReference rdf:resource="http://example.org/ontology#R112"/>
    <hasSubstanceDescription>Naproxen helps relieve inflammation and pain associated with muscle, joint or tendon disorders.; Chloroquine is used to prevent and treat malaria. It is also used to treat liver infection caused by protozoa (extraintestinal amebiasis).</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE141">
    <rdf:type rdf:resource="http://example.org/ontology#AngioedemaAndCholestaticJaundice"/>
    <rdfs:label>Angioedema and cholestatic jaundice</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Happens_during_multiple-dose_regimen"/>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <hasReference rdf:resource="http://example.org/ontology#R064"/>
    <hasSideEffectDescription>Swelling in the tissue under your skin, commonly seen in the lips, eyelids, tongue, genitals, hands or feet; yellowing of skin and whites of the eyes</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I017">
    <rdf:type rdf:resource="http://example.org/ontology#ComplicatedUrinaryTractInfectionCUTI"/>
    <rdfs:label>Moderate to Severe Complicated Urinary Tract Infection (cUTI)</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <hasReference rdf:resource="http://example.org/ontology#R027"/>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#ModerateToSevere"/>
    <hasSymptoms>Painful urination, frequent urination, fever, lower abdominal pain, cloudy or foul-smelling urine.</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN043">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN043</rdfs:label>
    <hasInteractionDescription>In elderly patients concurrently receiving diuretics, mainly thiazide, there appears to be an increased risk of thrombocytopenia with purpura.</hasInteractionDescription>
    <hasManagementAdvice>Use TMP-SMX with caution in elderly patients receiving thiazide diuretics</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R031"/>
    <interactsWith rdf:resource="http://example.org/ontology#S031"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W267">
