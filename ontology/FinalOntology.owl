  <rdf:Description rdf:about="http://example.org/ontology#ITN143">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN143</rdfs:label>
    <hasClinicalEffects>Results in increased quetiapine concentrations; risk of malignant neuroleptic syndrome.</hasClinicalEffects>
    <hasInteractionDescription>Inhibition of the CYP3A enzyme by Clarithromycin.</hasInteractionDescription>
    <hasManagementAdvice>Avoid combination unless clinically necessary; requires close monitoring and potential dose reductions.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <interactsWith rdf:resource="http://example.org/ontology#S117"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W141">
