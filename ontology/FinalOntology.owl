  <rdf:Description rdf:about="http://example.org/ontology#SE230">
    <rdf:type rdf:resource="http://example.org/ontology#Angioedema"/>
    <rdfs:label>angioedema</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R064"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasDuration>Not specified</hasDuration>
    <hasSideEffectDescription>Angioedema is swelling in the tissue under your skin. It’s most common in your lips, eyelids, tongue, genitals, hands and feet. Causes include allergies, medication side effects, vibrations, inherited gene changes and some health conditions.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
