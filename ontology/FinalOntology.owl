  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP160">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP160</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R158"/>
    <hasStewardshipDescription>Always finish the full prescribed course of nitrofurantoin, even if you start feeling better. Stopping early can allow bacteria to survive, potentially causing the infection to come back and increasing the chance of resistance.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W085">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W085</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasWarningText>Should not be given to patients with a history of hypersensitivity to β-lactam antibiotics (e.g., penicillins, cephalosporins).</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE598">
    <rdf:type rdf:resource="http://example.org/ontology#Somnolence"/>
    <rdfs:label>somnolence</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R233"/>
    <hasSideEffectDescription>drowsiness or excessive sleepiness, is wanting to fall asleep</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE550">
    <rdf:type rdf:resource="http://example.org/ontology#AbdominalPain"/>
    <rdfs:label>Abdominal Pain</rdfs:label>
    <hasDurationOf>Usually temporary; may last several hours to days</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Can_appear_during_early_treatment"/>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
