    <rdfs:label>Prothrombin Time</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE410">
    <rdf:type rdf:resource="http://example.org/ontology#AorticAneurysmAndDissection"/>
    <rdfs:label>Risk of Aortic Aneurysm and Dissection</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#two_months_after_intake"/>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasSideEffectDescription>sudden abdominal, chest or back pain,</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE417">
    <rdf:type rdf:resource="http://example.org/ontology#RenalImpairment"/>
