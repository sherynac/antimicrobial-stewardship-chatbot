  <rdf:Description rdf:about="http://example.org/ontology#S141">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Multivalent cations</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasSubstanceDescription>solution containing multivalent cations</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP145">
    <rdf:type rdf:resource="http://example.org/ontology#FoodAndTiming"/>
    <rdfs:label>SP145</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R091"/>
    <hasStewardshipDescription>Do not use Ciprofloxacin simulataneously with antacid preparations containing Magnesium Hydroxide or Aluminum Hydrocide. An interval of at least 2 hours must be respected between the administration of an antacid and Ciprofloxacin.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S158">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Ethacrinic Acid</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R145"/>
    <hasSubstanceDescription>ETHACRYNIC ACID reduces swelling related to heart, kidney, liver, or lung disease. It may also be used to reduce swelling caused by cancer. It helps your kidneys remove more fluid and salt from your blood through the urine. It belongs to a group of medications called diuretics.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#RecurrentFever">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Recurrent Fever</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE012">
    <rdf:type rdf:resource="http://example.org/ontology#Nausea"/>
    <rdfs:label>Nausea</rdfs:label>
    <hasDurationOf>1-2 days</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Common__may_occur_shortly_after_taking"/>
    <hasReference rdf:resource="http://example.org/ontology#R024"/>
    <hasSideEffectDescription>Feeling of queasiness or stomach upset.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP084">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP084</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <hasStewardshipDescription>Full Course: Complete the entire prescribed course, even if symptoms improve, to prevent bacterial resistance.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP171">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP171</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R163"/>
    <hasReference rdf:resource="http://example.org/ontology#R164"/>
    <hasStewardshipDescription>Take doses with food and at the same time each day; measure liquid carefully.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W192">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W192</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasWarningHeadline>Use in Pregnancy</hasWarningHeadline>
    <hasWarningText>Levofloxacin should be used during pregnancy only if the potential benefit justifies the potential risk to the fetus.</hasWarningText>
  </rdf:Description>
