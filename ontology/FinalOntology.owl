    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasWarningHeadline>Pregnancy</hasWarningHeadline>
    <hasWarningText>The drug should not be used in pregnant women unless the potential benefits justify the potential risks to the fetus</hasWarningText>
  </rdf:Description>
