    <rdfs:label>Hypersensitivity</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE546">
    <rdf:type rdf:resource="http://example.org/ontology#AllergicReactions"/>
    <rdfs:label>Allergic Reactions</rdfs:label>
    <hasDurationOf>Minutes to Hours</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Rare__can_happen_anytime"/>
    <hasReference rdf:resource="http://example.org/ontology#R163"/>
    <hasReference rdf:resource="http://example.org/ontology#R164"/>
    <hasSideEffectDescription>Rash, swelling, anaphylaxis.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W268">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W268</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasWarningText>Do not use Nitrofurantoin  if the patient has a known allergy to this medicine. Taking it again may cause serious allergic reactions such as skin rash, swelling, breathing difficulty, or other harmful effects.</hasWarningText>
  </rdf:Description>
