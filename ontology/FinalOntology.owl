  <rdf:Description rdf:about="http://example.org/ontology#ITN019">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN019</rdfs:label>
    <hasClinicalEffects>None specifically reported.</hasClinicalEffects>
    <hasInteractionDescription>Antacids containing aluminum or magnesium salts can reduce the rate, but not the extent, of its absorption</hasInteractionDescription>
    <hasManagementAdvice>Azithromycin should be given at least 1 before or 2 hours after the antacid</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <interactsWith rdf:resource="http://example.org/ontology#S003"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W146">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W146</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R011"/>
    <hasWarningHeadline>Pediatric Use</hasWarningHeadline>
    <hasWarningText>Do not use in children aged 8 years and below because of the effect of tetracyclines in teeth (permanent discoloration and possibly enamel hypoplasia) and bone.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN010">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN010</rdfs:label>
    <hasClinicalEffects>Lower peak blood level but same total amount excreted in urine.</hasClinicalEffects>
    <hasInteractionDescription>A high-fat meal may slow the absorption of Fosfomycin Tromethamine.</hasInteractionDescription>
    <hasManagementAdvice>Can be taken with or without food.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R024"/>
    <interactsWith rdf:resource="http://example.org/ontology#S009"/>
  </rdf:Description>
