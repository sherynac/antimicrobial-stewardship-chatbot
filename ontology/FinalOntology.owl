    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Pyrimethamine</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R031"/>
    <hasSubstanceDescription>Antimalarial antifolate agent.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE232">
    <rdf:type rdf:resource="http://example.org/ontology#ErythemaMultiforme"/>
    <rdfs:label>erythema multiforme</rdfs:label>
    <hasSideEffectDescription>Erythema multiforme is your body’s reaction to an illness, infection or medicine. This condition affects your skin and causes a painful, itchy rash that looks like a bulls-eye or a target.</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R119"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasDuration>Not specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP052">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP052</rdfs:label>
    <hasStewardshipDescription>Azithromycin is not intended to treat suitable severe infections where fast high blood concentrations of antibiotic have to be achieved,</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
  </rdf:Description>
