    <rdfs:label>W208</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasWarningText>Patients must not take when they have hypersensitivity to ciprofloxacin and other quinolone antibiotics</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W175">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W175</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R013"/>
    <hasWarningHeadline>Overdose Treatment Guidance</hasWarningHeadline>
    <hasWarningText>In case of overdosage, discontinue medication. Treat symptomatically and institute supportive measures. Dialysis does not alter serum half-life and thus would not be of benefit in treating cases of overdosage.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W174">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W174</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasWarningHeadline>Overdose Treatment Guidance</hasWarningHeadline>
    <hasWarningText>In case of overdosage, discontinue medication, treat symptomatically and institute supportive measures. Dialysis does not alter serum half-life and thus would not be of benefit in treating cases of overdosage.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R135">
