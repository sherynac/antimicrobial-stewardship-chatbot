    <hasReference rdf:resource="http://example.org/ontology#R212"/>
    <hasSideEffectDescription>can be red, inflamed, bumpy as well as dry, itchy or painful</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W257">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W257</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R161"/>
    <hasWarningHeadline>Late Pregnancy Use</hasWarningHeadline>
    <hasWarningText>Do not take Macrobid in the last 2-4 weeks of pregnancy.</hasWarningText>
  </rdf:Description>
