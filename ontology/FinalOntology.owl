  <rdf:Description rdf:about="http://example.org/ontology#W218">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W218</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R091"/>
    <hasWarningHeadline>Epileptic, history of Central Nervous System (CNS) disorders</hasWarningHeadline>
    <hasWarningText>In epileptics and in patients who have suffered from previous CNS disorders (e.g. lowered convulsion threshold, previous history of convulsion, reduced cerebral blood flow, altered brain structure or stroke), Ciprofloxacin should only be used where the benefits of treatment exceed the risks, since these patients are endangered because of possible central nervous side effects.</hasWarningText>
  </rdf:Description>
