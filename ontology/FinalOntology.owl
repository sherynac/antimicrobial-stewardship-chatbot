  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I055">
    <rdf:type rdf:resource="http://example.org/ontology#Pyelonephritis"/>
    <rdfs:label>Mild to Severe Pyelonephritis</rdfs:label>
    <hasSymptoms>fever, pain in lower back, chills, pain when peeing, bloody or cloudy pee that might smell bad, urgent or frequent need to pee</hasSymptoms>
    <hasReference rdf:resource="http://example.org/ontology#R129"/>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasReference rdf:resource="http://example.org/ontology#R130"/>
