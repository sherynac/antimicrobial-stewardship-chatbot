  <rdf:Description rdf:about="http://example.org/ontology#ITN105">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN105</rdfs:label>
    <hasClinicalEffects>Reduced clearance by inhibiting renal tubular secretion.</hasClinicalEffects>
    <hasInteractionDescription>Penicillins (concomitant).</hasInteractionDescription>
    <hasManagementAdvice>Carefully monitor patients receiving both medications.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <interactsWith rdf:resource="http://example.org/ontology#S079"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN087">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN087</rdfs:label>
    <hasClinicalEffects>Megaloblastic anemia</hasClinicalEffects>
    <hasInteractionDescription>Occasional reports suggest that patients receiving pyrimethamine as malarial prophylaxis at doses in excess of 25 mg weekly may develop megaloblastic anaemia should sulfamethoxazole/trimethoprim be prescribed concurrently.</hasInteractionDescription>
    <hasManagementAdvice>Avoid combination. Monitor CBC for anemia.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <interactsWith rdf:resource="http://example.org/ontology#S061"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W100">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W100</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasWarningHeadline>Cardiovascular events</hasWarningHeadline>
    <hasWarningText>Use with caution in patients with ongoing proarrthymic conditions (especially women and elderly patients) such as: congenital or documented QT prolongation; patients currently receiving treatment with other substances that prolong QT interval, such as antiarrythmics of classes IA (quinidine and procainamide) and class III (dofelitide, amiodarone, and sotalol), cisparide and terfenadine; antipsychotic agents such as pimozide; antidepressants such as citalopram; fluoroquinolones such as moxiflaxin and levoflaxin; patients with electrolyte disturbance, particularly in cases of hypokalaemia and hypomagnesaemia; patients with bradycardia, cardiac arrhythmia or severe cardiac insufficiency.</hasWarningText>
  </rdf:Description>
