  <rdf:Description rdf:about="http://example.org/ontology#W193">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W193</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasWarningHeadline>Use in Pregnancy</hasWarningHeadline>
    <hasWarningText>Levofloxacin should be used during pregnancy only if the potential benefit justifies the potential risk to the fetus.</hasWarningText>
  </rdf:Description>
