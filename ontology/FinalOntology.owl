    <hasReference rdf:resource="http://example.org/ontology#R030"/>
    <hasStewardshipDescription>Take the full single-dose treatment exactly as prescribed, even if symptoms improve quickly.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE246">
    <rdf:type rdf:resource="http://example.org/ontology#CentralNervousSystemEffects"/>
    <rdfs:label>Central Nervous System Effects</rdfs:label>
