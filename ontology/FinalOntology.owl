    <rdfs:label>Headache</rdfs:label>
    <hasDuration>Not specified</hasDuration>
    <hasSideEffectDescription>Headaches are a very common condition that most people will experience many times during their lives. The main symptom of a headache is pain in your head or face.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
