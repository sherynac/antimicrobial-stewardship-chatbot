    <hasSeverityType rdf:resource="http://example.org/ontology#MildToSevere"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W019">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W019</rdfs:label>
    <hasWarningText>Antibiotic use may cause abdominal pain or tenderness, fever, severe diarrhea due to C. difficile.</hasWarningText>
    <hasWarningHeadline>Clostridioides difficile-Associated Diarrhea (CDAD)</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE399">
    <rdf:type rdf:resource="http://example.org/ontology#CDifficileAssociatedDiarrhea"/>
    <rdfs:label>Clostridium difficile-associated diarrhea</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasSideEffectDescription>Diarrhea to fatal colitis</hasSideEffectDescription>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  </rdf:Description>
