    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE328">
    <rdf:type rdf:resource="http://example.org/ontology#AnaphylactoidPurpura"/>
    <rdfs:label>anaphylactoid purpura</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R011"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R184"/>
    <hasSideEffectDescription>Henoch-Schönlein purpura (HSP), or anaphylactoid purpura, is an acute, self-limited small-vessel vasculitis</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#frequency_not_reported"/>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE197">
    <rdf:type rdf:resource="http://example.org/ontology#Hyperkalaemia"/>
    <rdfs:label>Hyperkalaemia</rdfs:label>
    <hasSideEffectDescription>Hyperkalemia is a condition in which you have high potassium levels in your blood. You may not have any symptoms, or they may be easy to dismiss. Severe symptoms may cause muscle weakness or affect your heart.</hasSideEffectDescription>
    <hasDuration>Not specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R289"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <whichIs rdf:resource="http://example.org/ontology#Very_common"/>
  </rdf:Description>
