    <hasReference rdf:resource="http://example.org/ontology#R016"/>
    <hasWarningText>Prohibited for patients with a known hypersensitivity to penicillins or cephalosporins. Forbidden for patients with infectious mononucleosis due to the high risk of a maculopapular rash</hasWarningText>
  </rdf:Description>
