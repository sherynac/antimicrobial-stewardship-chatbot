  <rdf:Description rdf:about="http://example.org/ontology#ITN020">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN020</rdfs:label>
    <interactsWith rdf:resource="http://example.org/ontology#S014"/>
    <hasManagementAdvice>Monitor for adverse effects if taken with these medications. Consult doctor or pharmacist.</hasManagementAdvice>
    <hasInteractionDescription>Azithromycin has little or no effect on hepatic cytochrome P450 enzymes, so may or may not interact with astemizole.</hasInteractionDescription>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <hasClinicalEffects>None specifically reported.</hasClinicalEffects>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN074">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN074</rdfs:label>
    <hasManagementAdvice>May be taken with meals to reduce Gastrointestinal discomfort and improve absorption</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasInteractionDescription>Ingestion alongside the medication</hasInteractionDescription>
    <interactsWith rdf:resource="http://example.org/ontology#S048"/>
    <hasClinicalEffects>Has no significant influence on amoxicillin absorption</hasClinicalEffects>
  </rdf:Description>
