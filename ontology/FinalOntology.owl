    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#MildToModerate"/>
    <hasSymptoms>Cough, greenish/yellowish mucus, mild or high fever, shaking, chills, shortness of breath when you exert yourself</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN116">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN116</rdfs:label>
    <hasClinicalEffects>Potentiates anticoagulant effects.</hasClinicalEffects>
    <hasInteractionDescription>Concurrent use.</hasInteractionDescription>
    <interactsWith rdf:resource="http://example.org/ontology#S090"/>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <hasManagementAdvice>Monitor prothrombin time carefully.</hasManagementAdvice>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE503">
    <rdf:type rdf:resource="http://example.org/ontology#Seizures"/>
    <rdfs:label>Seizures</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R147"/>
    <hasSideEffectDescription>abnormal electrical activity in your brain. It causes changes in awareness and muscle control.</hasSideEffectDescription>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I020">
    <rdf:type rdf:resource="http://example.org/ontology#UncomplicatedUrinaryTractInfectionUTI"/>
    <rdfs:label>Mild to Severe Uncomplicated Urinary Tract Infection (UTI)</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasReference rdf:resource="http://example.org/ontology#R264"/>
    <hasSymptoms>urinary frequency, urgency, dysuria, and suprapubic discomfort.</hasSymptoms>
    <hasSeverityType rdf:resource="http://example.org/ontology#MildToSevere"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S138">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Nonsteroidal Anti-inflammatory Drugs (NSAIDs)</rdfs:label>
    <hasSubstanceDescription>medications that reduce inflammation, pain and fever.</hasSubstanceDescription>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S055">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Para‑aminobenzoic acid (PABA) / derivatives</rdfs:label>
    <hasSubstanceDescription>Folate precursor</hasSubstanceDescription>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S182">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Oral Anticoagulants</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R166"/>
    <hasSubstanceDescription>Blood-thinning medications.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP129">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP129</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasStewardshipDescription>Store at temperatures not exceeding 30°C</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP124">
    <rdf:type rdf:resource="http://example.org/ontology#FoodAndTiming"/>
    <rdfs:label>SP124</rdfs:label>
    <hasStewardshipDescription>Azithromycin should be taken at least one hour before or two hours after administration of food and antacid preparations</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R003">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R003</rdfs:label>
    <retrievedFrom>https://www.who.int/publications/i/item/9789241515481</retrievedFrom>
    <hasReferenceTitle>Antimicrobial Stewardship Programmes in Health-care Facilities in Low- and Middle-Income Countries</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2019</publishedIn>
    <hasAuthor>World Health Organization</hasAuthor>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN106">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN106</rdfs:label>
    <hasManagementAdvice>Monitor renal function and electrolyte levels (Potassium/Sodium).</hasManagementAdvice>
    <hasClinicalEffects>Potential for fluid/electrolyte imbalance and increased risk of kidney strain.</hasClinicalEffects>
    <interactsWith rdf:resource="http://example.org/ontology#S080"/>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <hasInteractionDescription>Concurrent Nephrotoxic use.</hasInteractionDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE183">
    <rdf:type rdf:resource="http://example.org/ontology#HaemolysisInG6PDDeficiency"/>
    <rdfs:label>haemolysis in certain susceptible G-6-PD deficient patients</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R282"/>
    <hasSideEffectDescription>Hemolysis is the medical term used to describe the destruction of red blood cells. Your body is constantly destroying old or damaged red blood cells and replacing them with new ones.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasDuration>Not specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN167">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN167</rdfs:label>
    <hasInteractionDescription>Barbiturates decrease the half-life of doxycycline</hasInteractionDescription>
    <hasClinicalEffects>Decreased absorption</hasClinicalEffects>
    <hasManagementAdvice>Avoid taking together</hasManagementAdvice>
    <interactsWith rdf:resource="http://example.org/ontology#S099"/>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE349">
    <rdf:type rdf:resource="http://example.org/ontology#StevensJohnsonSyndrome"/>
    <rdfs:label>Stevens-Johnson&#13;
syndrome</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasReference rdf:resource="http://example.org/ontology#R195"/>
    <hasSideEffectDescription>rare, serious disorder of the skin and mucous membranes</hasSideEffectDescription>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#mild">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>mild</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W058">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W058</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <hasWarningText>Do not take if you have hypersensitivity to the azithromycin, or any macrolide antibiotics.</hasWarningText>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE572">
    <rdf:type rdf:resource="http://example.org/ontology#Vomiting"/>
    <rdfs:label>vomiting</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R210"/>
    <hasSideEffectDescription>muscles in your belly, chest, neck and head work together to push whatever’s in your stomach out</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Common"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#VentricularTachycardia">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Ventricular Tachycardia</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S162">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Chloramphenicol</rdfs:label>
    <hasSubstanceDescription>An antibiotic medication used to treat a variety of serious infections caused by bacteria but carries a high risk of causing serious bone marrow problems and is not frequently used.</hasSubstanceDescription>
    <hasReference rdf:resource="http://example.org/ontology#R152"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Cefumax">
    <rdf:type rdf:resource="http://example.org/ontology#Brand"/>
    <rdfs:label>Cefumax</rdfs:label>
    <hasWarning rdf:resource="http://example.org/ontology#W084"/>
    <hasWarning rdf:resource="http://example.org/ontology#W083"/>
    <managedAs rdf:resource="http://example.org/ontology#SP069"/>
    <managedAs rdf:resource="http://example.org/ontology#SP070"/>
