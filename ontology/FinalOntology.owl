    <rdfs:label>During/after treatment</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE461">
    <rdf:type rdf:resource="http://example.org/ontology#Pruritus"/>
    <rdfs:label>Pruritus</rdfs:label>
