  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE360">
    <rdf:type rdf:resource="http://example.org/ontology#SerumSickness"/>
    <rdfs:label>serum sickness</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#frequency_not_reported"/>
