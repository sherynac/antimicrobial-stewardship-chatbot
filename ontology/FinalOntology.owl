    <rdfs:label>W138</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <hasWarningHeadline>Embryotoxicity &amp; Milk Distribution</hasWarningHeadline>
    <hasWarningText>Should not be used in pregnant women unless no alternative is appropriate; high doses are associated with embryotoxicity in animals. Detected in breast milk; exercise caution when nursing.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W142">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W142</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <hasWarningHeadline>Hypersensitivity &amp; Drug Blocks</hasWarningHeadline>
    <hasWarningText>Prohibited for patients with known hypersensitivity to macrolides. Concurrent use with astemizole, cisapride, or terfenadine is strictly forbidden.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN177">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN177</rdfs:label>
