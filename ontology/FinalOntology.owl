    <hasReference rdf:resource="http://example.org/ontology#R184"/>
    <hasSideEffectDescription>Henoch-Schönlein purpura (HSP), or anaphylactoid purpura, is an acute, self-limited small-vessel vasculitis</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S132">
