  <rdf:Description rdf:about="http://example.org/ontology#I050">
    <rdf:type rdf:resource="http://example.org/ontology#InhalationAnthrax"/>
    <rdfs:label>Inhalation Anthrax</rdfs:label>
    <hasSymptoms>Fever and chills, heavy sweats, chest pain, cough, or shortness of breath, confusion or dizziness, nausea, vomiting, or stomach pains, headache or body aches, and extreme tiredness</hasSymptoms>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasReference rdf:resource="http://example.org/ontology#R099"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Rare__may_happen">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Rare, may happen</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W192">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W192</rdfs:label>
    <hasWarningText>Levofloxacin should be used during pregnancy only if the potential benefit justifies the potential risk to the fetus.</hasWarningText>
    <hasWarningHeadline>Use in Pregnancy</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP066">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP066</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasStewardshipDescription>Once water is added (reconstituted), the drops must be stored at refrigerated temperatures (between 2-8°C). The medicine will retain its potency for 7 days under these conditions</hasStewardshipDescription>
  </rdf:Description>
