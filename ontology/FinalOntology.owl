    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Aminoglycosides (Gentamicin / Amikacin)</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <hasSubstanceDescription>Increased risk of nephrotoxicity (kidney damage) and ototoxicity (hearing loss) when taken with Cephalosporins.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R305">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R305</rdfs:label>
    <hasAuthor>National Library of Medicine</hasAuthor>
    <hasReferenceTitle>Cholestatic Jaundice</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</publishedIn>
    <retrievedFrom>https://www.ncbi.nlm.nih.gov/books/NBK482279/</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#BloodBilirubinIncreased">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Blood Bilirubin Increased</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP072">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP072</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasStewardshipDescription>Doses should be given every 8 or 12 hours for neonates/infants &lt; 3 months.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W230">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W230</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R127"/>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasWarningText>Hypersensitivity to cefixime or other cephalosporins.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W241">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W241</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R129"/>
    <hasWarningHeadline>Antibotic Resistance</hasWarningHeadline>
    <hasWarningText>Prescribing cefixime in the absence of a proven or strongly suspected bacterial infection or a prophylactic indication is unlikely to provide benefit to the patient and increases the risk of antibiotic resistance.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W098">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W098</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasWarningHeadline>Newborns &amp; Infants</hasWarningHeadline>
    <hasWarningText>Use with caution in newborns due to risk of jaundice from sodium benzoate.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN103">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN103</rdfs:label>
    <hasClinicalEffects>Increased risk of bleeding; rare prolongation of prothrombin time; elevated INR.</hasClinicalEffects>
    <hasInteractionDescription>Concurrent use with amoxicillin or cefuroxime.</hasInteractionDescription>
    <hasManagementAdvice>Undertake appropriate monitoring (e.g., INR); adjust dose as needed.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <interactsWith rdf:resource="http://example.org/ontology#S077"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R276">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R276</rdfs:label>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <hasReferenceTitle>Low White Blood Cell Count (Leukopenia)</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2022</publishedIn>
    <retrievedFrom>https://my.clevelandclinic.org/health/diseases/17706-low-white-blood-cell-count</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R099">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R099</rdfs:label>
    <hasAuthor>US Centers for Disease Control and Prevention</hasAuthor>
    <hasReferenceTitle>About Anthrax</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</publishedIn>
