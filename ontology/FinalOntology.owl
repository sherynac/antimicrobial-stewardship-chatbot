  <rdf:Description rdf:about="http://example.org/ontology#ITN248">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN248</rdfs:label>
    <hasClinicalEffects>Reduced antibacterial effectiveness can lead to slower infections recovery, persistent infection, or increased risk of bacterial resistance.</hasClinicalEffects>
    <hasInteractionDescription>When taken together, fluoroquinolone antibiotics may have an antagonistic effect on nitrofurantoin, meaning the two drugs can interfere with each other's ability to kill bacteria.</hasInteractionDescription>
    <hasManagementAdvice>Avoid combining nitrofurantoin with fluoroquinolone antibiotics unless directed by a doctor. If both are needed, careful monitoring and alternative dosing strategies may be required.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R159"/>
    <interactsWith rdf:resource="http://example.org/ontology#S167"/>
  </rdf:Description>
