  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE571">
    <rdf:type rdf:resource="http://example.org/ontology#AbdominalPain"/>
    <rdfs:label>abdominal pain</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Common"/>
    <hasReference rdf:resource="http://example.org/ontology#R209"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasSideEffectDescription>stomachache</hasSideEffectDescription>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE434">
    <rdf:type rdf:resource="http://example.org/ontology#Restlessness"/>
    <rdfs:label>Restlessness</rdfs:label>
    <hasSideEffectDescription>pacing, constant movements of the legs, inability to sit or stand still, rocking from foot to foot, feeling tense or uncomfortable, feeling anxious</hasSideEffectDescription>
    <hasDuration>Not Specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R115"/>
    <hasReference rdf:resource="http://example.org/ontology#R091"/>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W191">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W191</rdfs:label>
    <hasWarningHeadline>Renal insufficiency</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasWarningText>Levofloxacin should be administered with caution in the presence of renal insufficiency. Careful clinical observation and appropriate laboratory studies should be performed prior to and during therapy since elimination of levofloxacin may be reduced. In patients with impaired renal function (creatinine clearance&lt;50 mL/min), adjustment of dose regimen is necessary to avoid the accumulation of levofloxacin due to decreased clearance.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W037">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W037</rdfs:label>
    <hasWarningHeadline>Clostridioides difficile-Associated Diarrhea (CDAD)</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasWarningText>This has been reported with nearly all systemic antibacterial agents, including CONTEPO. Evaluate patients if diarrhea occurs.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE044">
    <rdf:type rdf:resource="http://example.org/ontology#ChestPain"/>
    <rdfs:label>Chest pain</rdfs:label>
    <hasSideEffectDescription>Minor side effect; Pain felt between neck and belly</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasDuration>Not Specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE472">
    <rdf:type rdf:resource="http://example.org/ontology#Agitation"/>
    <rdfs:label>Agitation</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R125"/>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasSideEffectDescription>feeling of irritability, mental distress or severe restlessness.</hasSideEffectDescription>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN055">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN055</rdfs:label>
    <hasManagementAdvice>Avoid combination or closely monitor CBC for megaloblastic anemia.</hasManagementAdvice>
    <hasInteractionDescription>Occasionally reports suggest that patients receiving pyrimethamine as malarial prophylaxis in doses exceeding 25 mg weekly may develop megaloblastic anaemia if Co- trimoxazole be prescribed concurrently.</hasInteractionDescription>
    <hasReference rdf:resource="http://example.org/ontology#R031"/>
    <interactsWith rdf:resource="http://example.org/ontology#S032"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN058">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN058</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R031"/>
    <interactsWith rdf:resource="http://example.org/ontology#S035"/>
    <hasInteractionDescription>Comazole also may inhibit the hepatic metabolism of phenytoin. A 39% increase in phenytoin half-life and 27% decrease in the metabolic clearance rate of phenytoin have been observed following administration of Comazole of normal clinical dosages. If these two drugs are given concurrently it is important to remain alert for signs of phenytoin toxicity.</hasInteractionDescription>
    <hasManagementAdvice>Monitor serum phenytoin levels and signs of toxicity. Dose adjustment may be required.</hasManagementAdvice>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE671">
    <rdf:type rdf:resource="http://example.org/ontology#Arthralgia"/>
    <rdfs:label>arthralgia</rdfs:label>
    <hasSideEffectDescription>joint pain that can be felt in the joints throughout your body</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R250"/>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE488">
    <rdf:type rdf:resource="http://example.org/ontology#PseudomembranousColitis"/>
    <rdfs:label>Pseudomembranous colitis</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasSideEffectDescription>An inflammatory process that occurs when your colon lining is being injured. Plaques called “pseudomembranes” develop at the site of the injury.</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R142"/>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN036">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN036</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R014"/>
    <interactsWith rdf:resource="http://example.org/ontology#S030"/>
    <hasInteractionDescription>The total body clearance of cefotaxime has been reduced in patients with normal and reduced renal function by ureidopenicillins azlocillin.</hasInteractionDescription>
    <hasClinicalEffects>None specifically reported.</hasClinicalEffects>
    <hasManagementAdvice>Monitor for adverse effects if taken with these medications. Consult doctor or pharmacist.</hasManagementAdvice>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP161">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP161</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R159"/>
    <hasStewardshipDescription>Keep track of any unusual symptoms such as breathing difficulties, chest pain, cough, or numbness and tingling in the hands or feet. Report these promptly to a healthcare provider to prevent serious complicaions.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN085">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN085</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <interactsWith rdf:resource="http://example.org/ontology#S059"/>
    <hasManagementAdvice>Monitor for thrombocytopenia. Avoid if high risk.</hasManagementAdvice>
    <hasInteractionDescription>An increased incidence of thrombocytopenia is reported when this combination is used in the elderly.</hasInteractionDescription>
    <hasClinicalEffects>Thrombocytopenia, purpura</hasClinicalEffects>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE416">
    <rdf:type rdf:resource="http://example.org/ontology#MentalAlertness"/>
    <rdfs:label>Mental Alertness</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasSideEffectDescription>Dizziness, lightheadedness, vertigo and visual disturbance</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE427">
    <rdf:type rdf:resource="http://example.org/ontology#ToxicPsychosis"/>
    <rdfs:label>Toxic Psychosis</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasSideEffectDescription>Form of psychosis that is attributed to substance intoxication, withdrawal or recent consumption of psychoactive drugs.</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S008">
    <rdf:type rdf:resource="http://example.org/ontology#Beverage"/>
    <rdfs:label>Whiskey</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R024"/>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <hasSubstanceDescription>An alcoholic beverage. General caution advised.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W080">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W080</rdfs:label>
    <hasWarningHeadline>Pregnancy</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R031"/>
    <hasWarningText>Comazole is contraindicated during pregnancy. If pregnancy cannot be excluded, possible risks should be balanced against the expected therapeutic effect. Comazole should not be given during pregnancy especially in late pregnancy because of risk of kernicterus.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP028">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP028</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasReference rdf:resource="http://example.org/ontology#R027"/>
    <hasStewardshipDescription>Report any severe side effects or unusual symptoms to your healthcare provider. Kidney and liver function may need monitorng during treatment.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP131">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP131</rdfs:label>
    <hasStewardshipDescription>Protect from light</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#FoodAndTiming">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#StewardshipPrinciple"/>
    <owl:disjointWith rdf:resource="http://example.org/ontology#Storage"/>
    <owl:differentFrom rdf:resource="http://example.org/ontology#Storage"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I049">
    <rdf:type rdf:resource="http://example.org/ontology#UrinaryTractInfections"/>
    <rdfs:label>Urinary Tract Infections</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R091"/>
    <hasReference rdf:resource="http://example.org/ontology#R127"/>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasReference rdf:resource="http://example.org/ontology#R010"/>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasReference rdf:resource="http://example.org/ontology#R098"/>
    <hasReference rdf:resource="http://example.org/ontology#R166"/>
    <hasReference rdf:resource="http://example.org/ontology#R129"/>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
    <hasSymptoms>Pain in your flank, abdomen, pelvic area or lower back, pressure in the lower part of your pelvis, cloudy, foul-smelling pee, urinary incontinence, frequent urination, urge incontinence, pain when you pee (dysuria), and blood in your pee (hematuria).</hasSymptoms>
  </rdf:Description>
