    <rdfs:label>Esophageal Ulcerations</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S174">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Probenecid</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasSubstanceDescription>A medicine commonly used to treat gout. It works by helping the body remove uric acid through the urine. It affects how the kidneys handle certain medicines.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE264">
    <rdf:type rdf:resource="http://example.org/ontology#HemicAndLymphatic"/>
    <rdfs:label>Hemic and Lymphatic</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R016"/>
    <hasSideEffectDescription>Anemia (including hemolytic), leukopenia, neutropenia, and thrombocytopenia.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#AnaphylacticReaction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Anaphylactic Reaction</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE564">
    <rdf:type rdf:resource="http://example.org/ontology#Insomnia"/>
    <rdfs:label>insomnia</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Common"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R202"/>
    <hasSideEffectDescription>experience disruptions in how you feel or function because you aren’t sleeping well or sleeping enough.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#IncreasedHepaticEnzymes">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Increased Hepatic Enzymes</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE292">
    <rdf:type rdf:resource="http://example.org/ontology#Vertigo"/>
    <rdfs:label>Vertigo</rdfs:label>
    <hasDurationOf>During treatment</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasSideEffectDescription>A temporary feeling of spinning or dizziness.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S149">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Corticosteroid</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R107"/>
    <hasSubstanceDescription>Corticosteroids can treat many causes of inflammation in your body. They’re also known as glucocorticoids or the shortened name steroids. It can be administered via an injection, a cream for your skin or orally.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasBrandName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has brand name</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Antibiotic"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Brand"/>
    <owl:inverseOf rdf:resource="http://example.org/ontology#isBrandOf"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE362">
    <rdf:type rdf:resource="http://example.org/ontology#ExacerbationOfSystemicLupusErythematosus"/>
    <rdfs:label>exacerbation of systemic lupus erythematosus</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#frequency_not_reported"/>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R187"/>
    <hasSideEffectDescription>systemic autoimmune disease with multisystem involvement and is associated with significant morbidity and mortality</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE164">
    <rdf:type rdf:resource="http://example.org/ontology#Pruritus"/>
    <rdfs:label>Pruritus</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasSideEffectDescription>Itching</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE560">
    <rdf:type rdf:resource="http://example.org/ontology#SkinRash"/>
    <rdfs:label>Skin Rash</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R116"/>
    <hasSideEffectDescription>Skin rashes can be red, inflamed, bumpy as well as dry, itchy or painful. The main cause is dermatitis, which is when your skin reacts to allergens or irritants. Bacteria, viruses, allergens and conditions including eczema, hives, and psoriasis can be the source of skin rashes.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE162">
    <rdf:type rdf:resource="http://example.org/ontology#Vomiting"/>
    <rdfs:label>Vomiting</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasSideEffectDescription>Gastrointestinal disturbance</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W127">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W127</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R016"/>
    <hasWarningHeadline>Neonates, Infants, and Elderly</hasWarningHeadline>
    <hasWarningText>Neonates and young infants have incompletely developed renal function, delaying drug elimination. Elderly patients should have doses selected with care due to likely decreased renal function</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ReductionInNeutrophilCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Reduction in Neutrophil Count</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I056">
    <rdf:type rdf:resource="http://example.org/ontology#UncomplicatedGonorrhea"/>
    <rdfs:label>Uncomplicated Gonorrhea</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R014"/>
    <hasReference rdf:resource="http://example.org/ontology#R032"/>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <hasReference rdf:resource="http://example.org/ontology#R128"/>
    <hasReference rdf:resource="http://example.org/ontology#R129"/>
    <hasReference rdf:resource="http://example.org/ontology#R136"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
    <hasSymptoms>Often, gonorrhea doesn’t cause symptoms, especially in women.</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE397">
    <rdf:type rdf:resource="http://example.org/ontology#DropInBloodPressure"/>
    <rdfs:label>Drop in Blood Pressure</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ncc9caf714a1e4eda918fdaa09880ac90b54">
    <rdf:first rdf:resource="http://example.org/ontology#PowderForIVInfusion"/>
    <rdf:rest rdf:nodeID="ncc9caf714a1e4eda918fdaa09880ac90b55"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S193">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Dapsone</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R166"/>
    <hasSubstanceDescription>Antimicrobial used in leprosy.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W256">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W256</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R160"/>
    <hasWarningHeadline>Kidney Problems</hasWarningHeadline>
    <hasWarningText>Avoid Macrobid if your kidneys are not working well; poor kidney function can make the medicine less effective and increase side effects.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W262">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W262</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R163"/>
    <hasWarningHeadline>Do not use near term or in infants under 1 month</hasWarningHeadline>
    <hasWarningText>pregnant patients at term (38 weeks to 42 weeks gestation), during labor and delivery, or when the onset of labor is imminent and in pediatric patients younger than 1 month of age because of the possibility of hemolytic anemia due to immature erythrocyte enzyme systems (glutathione instability)</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP005">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP005</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R022"/>
    <hasReference rdf:resource="http://example.org/ontology#R023"/>
    <hasStewardshipDescription>Do not use in children under 12 years old.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W190">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W190</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasWarningHeadline>QT interval prolongation</hasWarningHeadline>
    <hasWarningText>Caution should be taken when using fluoroquinolones, including levofloxacin, in patients with known risk factors for prolongation of the QT interval such as, for example: congenital long QT syndrome; concomitant use of drugs that are known to prolong the QT interval (e.g., Class IA and III antiarrhythmics, tricyclic antidepressants, macrolides); uncorrected electrolyte imbalance (e.g., hypokalemia, hypomagnesemia); elderly: cardiac disease (e.g.. heart failure, myocardial infarction, bradycardia).</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W276">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W276</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasWarningHeadline>Risk of Peripheral Neuropathy</hasWarningHeadline>
    <hasWarningText>Withdraw if signs of peripheral neuropathy occur.</hasWarningText>
  </rdf:Description>
