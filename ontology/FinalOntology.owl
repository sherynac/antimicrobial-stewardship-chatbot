    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasWarningHeadline>Fertility</hasWarningHeadline>
    <hasWarningText>Animal studies have shown reduced pregnancy rate upon the administration of azithromycin. The clinical relevance for humans is unknown.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W239">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
