  <rdf:Description rdf:about="http://example.org/ontology#SE187">
    <rdf:type rdf:resource="http://example.org/ontology#HypersensitivityVasculitisHenochSchonleinPurpura"/>
    <rdfs:label>hypersensitivity vasculitis resembling Henoch-Schönlein purpura</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R285"/>
    <hasSideEffectDescription>Henoch-Schonlein purpura causes the small blood vessels in the skin, joints, intestines and kidneys to become inflamed and bleed. The most noticeable symptom of this form of vasculitis is a rash that often appears on the legs and feet. Henoch-Schonlein purpura also can cause belly pain and aching joints. Rarely, the condition may cause serious kidney damage.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE405">
    <rdf:type rdf:resource="http://example.org/ontology#CentralNervousSystemEffects"/>
    <rdfs:label>Central Nervous System Effects</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#After_the_first_dose"/>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasSideEffectDescription>Toxic psychoses, hallucination, or paranoia; depression, or suicidal thoughts; anxiety, agitation, restlessness, or nervousness; confusion, delirium, disorientation, or disturbances in attention; insomnia or nightmares; memory impairment.</hasSideEffectDescription>
  </rdf:Description>
