    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <hasStewardshipDescription>May be taken with meals to reduce gastrointestinal discomfort</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE212">
    <rdf:type rdf:resource="http://example.org/ontology#Tinnitus"/>
    <rdfs:label>tinnitus</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R135"/>
    <hasSideEffectDescription>Tinnitus fills your ears with sounds no one else hears. It’s a common issue affecting more than 50 million people in the United States. Tinnitus can be severe, affecting people’s daily lives. Tinnitus isn’t a disease. It’s a symptom of several medical conditions.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE365">
