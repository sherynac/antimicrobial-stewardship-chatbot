  <rdf:Description rdf:about="http://example.org/ontology#R309">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R309</rdfs:label>
    <retrievedFrom>https://www.webmd.com/skin-problems-and-treatments/what-is-exfoliative-dermatitis</retrievedFrom>
    <hasReferenceTitle>What Is Exfoliative Dermatitis?</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</publishedIn>
    <hasAuthor>Medscape</hasAuthor>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP143">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP143</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasStewardshipDescription>In the event of acute overdosage, reversible renal toxicity has been reported in some cases. It is recommended to monitor renal function and to administer magnesium- or calcium-containing antacids which reduce the absorption of ciprofloxacin.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Hypocalcemia">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Hypocalcemia</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE519">
    <rdf:type rdf:resource="http://example.org/ontology#UrineColorChange"/>
    <rdfs:label>Urine Color</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R157"/>
    <whichIs rdf:resource="http://example.org/ontology#Very_common"/>
    <hasSideEffectDescription>The urine may turn dark yellow or brown in color. This is harmless and happens because the drug is being removed through the urine. It is not sign of kidney damage.</hasSideEffectDescription>
    <hasDuration>While taking the drug</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP031">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP031</rdfs:label>
    <hasStewardshipDescription>Practice good hygiene to reduce infection spread; drink enough fluids.</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R029"/>
    <hasReference rdf:resource="http://example.org/ontology#R030"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S146">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Probenecid and cimetidine</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R010"/>
    <hasSubstanceDescription>drugs that affect the tubular renal secretion</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE676">
    <rdf:type rdf:resource="http://example.org/ontology#AcuteRenalFailure"/>
    <rdfs:label>acute renal failure</rdfs:label>
    <hasSideEffectDescription>when the kidneys suddenly can't filter waste products from the blood</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R255"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
