  <rdf:Description rdf:about="http://example.org/ontology#S162">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Chloramphenicol</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R152"/>
    <hasSubstanceDescription>An antibiotic medication used to treat a variety of serious infections caused by bacteria but carries a high risk of causing serious bone marrow problems and is not frequently used.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Dyspnea">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Dyspnea</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W010">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W010</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R024"/>
    <hasWarningHeadline>Clostridium difficile-associated diarrhea (CDAD)</hasWarningHeadline>
    <hasWarningText>Clostridium difficile associated diarrhea (CDAD) has been reported with use of nearly all antibacterial agents, including Fosfomycin Tromethamine, and may range in severity from mild diarrhea to fatal colitis. Treatment with antibacterial agents alters the normal flora of the colon leading to overgrowth of C. difficile.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN266">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN266</rdfs:label>
    <hasClinicalEffects>Not Specified</hasClinicalEffects>
    <hasInteractionDescription>Trimethoprim may increase serum concentrations of some drugs, including phenytoin, digoxin, procainamide, rosiglitazone, and repaglinidine, potentiating their effect. This may be due to competitive inhibition of renal excretion, decreased metabolism, or both.</hasInteractionDescription>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R166"/>
    <interactsWith rdf:resource="http://example.org/ontology#S185"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W011">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W011</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R024"/>
    <hasWarningHeadline>Pregnancy</hasWarningHeadline>
    <hasWarningText>There are, however, no adequate and well-controlled studies in pregnant women. Because animal reproduction studies are not always predictive of human response, this drug should be used during pregnancy only if clearly needed.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S119">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Oral Hypoglycemic Agents / Insulin</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasSubstanceDescription>Medications used to manage blood sugar in diabetes.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S003">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Antacid</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R001"/>
    <hasSubstanceDescription>used for acid reflux</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP173">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP173</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R163"/>
    <hasStewardshipDescription>Store at room temperature (20-25 degrees celcius), protect from light and freezing, use within 30 days after opening.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R094">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R094</rdfs:label>
    <hasAuthor>Clinicalinfo.HIV.gov</hasAuthor>
    <hasReferenceTitle>Disseminated Mycobacterium avium Complex Disease</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</publishedIn>
    <retrievedFrom>https://clinicalinfo.hiv.gov/en/guidelines/hiv-clinical-guidelines-adult-and-adolescent-opportunistic-infections/disseminated</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP119">
    <rdf:type rdf:resource="http://example.org/ontology#FoodAndTiming"/>
    <rdfs:label>SP119</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasStewardshipDescription>May be taken with or without food</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN015">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN015</rdfs:label>
    <hasClinicalEffects>Fluid retention, high blood pressure, worsening heart failure.</hasClinicalEffects>
    <hasInteractionDescription>Fosfomycin contains sodium, and additional sodium from IV fluids may increase total sodium load.</hasInteractionDescription>
    <hasManagementAdvice>Monitor sodium levels and fluid status.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <interactsWith rdf:resource="http://example.org/ontology#S013"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE151">
    <rdf:type rdf:resource="http://example.org/ontology#Vaginitis"/>
    <rdfs:label>Vaginitis</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <hasSideEffectDescription>Inflammation of the vagina</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE584">
    <rdf:type rdf:resource="http://example.org/ontology#Hyperglycemia"/>
    <rdfs:label>hyperglycemia</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R222"/>
    <hasSideEffectDescription>high blood sugar</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W271">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W271</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasWarningHeadline>Pregnancy at Term</hasWarningHeadline>
    <hasWarningText>Nitrofurantoin should not be used during pregnancy (labor and delivery).</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE283">
    <rdf:type rdf:resource="http://example.org/ontology#NervousSystemEffects"/>
    <rdfs:label>Nervous System Effects</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Common"/>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasSideEffectDescription>Headache and abnormal taste (dysgeusia).</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S131">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Quetiapine</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasSubstanceDescription>An atypical antipsychotic medication.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W206">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W206</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R091"/>
    <hasWarningHeadline>Children and Adolescents</hasWarningHeadline>
    <hasWarningText>Ciprofloxacin must not be administered to children and adolescents, since there is no experience on the drug's safety in these patient groups; On the basis of animal studies, it is not entirely improbable that the drug could cause damage to articular cartilage in the immature organism.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#MetallicTaste">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Metallic Taste</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE240">
    <rdf:type rdf:resource="http://example.org/ontology#RenalImpairment"/>
    <rdfs:label>Renal impairment</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R254"/>
    <hasSideEffectDescription>Kidney failure is a condition in which one or both of your kidneys no longer work on their own. Causes include diabetes, high blood pressure and acute kidney injuries. Symptoms include fatigue, nausea and vomiting, swelling, changes in how often you go to the bathroom and brain fog.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN089">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN089</rdfs:label>
    <hasClinicalEffects>Hyperkalemia</hasClinicalEffects>
    <hasInteractionDescription>Due to the potassium sparing effects of sulfamethoxazole/trimethoprim, caution should be used when other agents that increase serum potassium, such as angiotensin converting enzyme inhibitors, angiotensin receptor blockers, potassium sparing diuretics and prednisolone, are co-administered. In the literature, two cases of hyperkalaemia in elderly patients have been reported after concomitant intake of sulfamethoxazole/trimethoprim and an angiotensin converting enzyme inhibitor.</hasInteractionDescription>
    <hasManagementAdvice>Monitor serum potassium. Avoid in high-risk patients.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <interactsWith rdf:resource="http://example.org/ontology#S063"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R186">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R186</rdfs:label>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <hasReferenceTitle>Serum Sickness</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2024</publishedIn>
    <retrievedFrom>https://my.clevelandclinic.org/health/diseases/serum-sickness</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W046">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W046</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R029"/>
    <hasWarningHeadline>Dizziness</hasWarningHeadline>
    <hasWarningText>Fosfomycin may cause dizziness, affecting ability to drive or operate machinery.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN253">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN253</rdfs:label>
    <hasClinicalEffects>Blood levels of Furadantin may rise, increasing side effect risks, while effectiveness in treating urinary tract infections may decrease.</hasClinicalEffects>
    <hasInteractionDescription>Sulfinpyrazone, another uricosuric agent, can similarly interfere with kidney excretion of Furadantin.</hasInteractionDescription>
    <hasManagementAdvice>Monitor for side effects and infection signs. Your doctor may need to adjust treatment. Avoid combining without supervision.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R163"/>
    <interactsWith rdf:resource="http://example.org/ontology#S172"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE515">
    <rdf:type rdf:resource="http://example.org/ontology#Nausea"/>
    <rdfs:label>Nausea</rdfs:label>
    <hasDurationOf>Short-term</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Early_in_treatment"/>
    <hasReference rdf:resource="http://example.org/ontology#R157"/>
    <hasSideEffectDescription>A sick feeling in the stomach that may make the patient feel like vomiting. It usually improves when the medicine is taken with food.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S011">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Vancomycin</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <hasSubstanceDescription>An antibiotic that may cause kidney strain, especially with other nephrotoxic drugs.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S029">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Mezlocillin</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R014"/>
    <hasSubstanceDescription>Also known as Ureidopenicillins azlocillin, may reduce total body clearance of cefotaxime in patients with normal and reduced renal function.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Common">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Common</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasFoodAndTimingRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has food and timing rule</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Brand"/>
    <rdfs:range rdf:resource="http://example.org/ontology#FoodAndTiming"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE535">
    <rdf:type rdf:resource="http://example.org/ontology#UpsetStomach"/>
    <rdfs:label>Upset Stomach</rdfs:label>
    <hasDurationOf>Few hours to 1 day</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Usually_appears_at_start"/>
    <hasReference rdf:resource="http://example.org/ontology#R163"/>
    <hasReference rdf:resource="http://example.org/ontology#R164"/>
    <hasSideEffectDescription>Stomach discomfort or mild pain.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN210">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN210</rdfs:label>
    <hasClinicalEffects>The possibility of interfering with the absorption of fluoroquinolones may be present in dairy products with high calcium content</hasClinicalEffects>
    <hasInteractionDescription>Not Specified</hasInteractionDescription>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <interactsWith rdf:resource="http://example.org/ontology#S021"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R174">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R174</rdfs:label>
    <hasAuthor>Infectious Disease Advisor</hasAuthor>
    <hasReferenceTitle>Maculopapular Rash</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</publishedIn>
    <retrievedFrom>https://www.infectiousdiseaseadvisor.com/ddi/maculopapular-rash/</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE304">
    <rdf:type rdf:resource="http://example.org/ontology#Rash"/>
    <rdfs:label>Rash</rdfs:label>
    <hasDurationOf>Short-term</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Rare_but_serious"/>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasSideEffectDescription>Skin rash; contact a doctor if it persists or worsens.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE269">
    <rdf:type rdf:resource="http://example.org/ontology#VaginalYeastInfection"/>
    <rdfs:label>Vaginal Yeast Infection</rdfs:label>
    <hasDurationOf>3–7 days</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#During_after_treatment"/>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <hasSideEffectDescription>Itching, irritation, or thick white discharge due to changes in flora.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE083">
    <rdf:type rdf:resource="http://example.org/ontology#CDifficileAssociatedDiarrhea"/>
    <rdfs:label>C. difficile-associated diarrhea</rdfs:label>
    <hasDurationOf>During or weeks after therapy</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasSideEffectDescription>Severe diarrhea cause by bacterial overgrowth; requires medical attention.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE488">
    <rdf:type rdf:resource="http://example.org/ontology#PseudomembranousColitis"/>
    <rdfs:label>Pseudomembranous colitis</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R142"/>
    <hasSideEffectDescription>An inflammatory process that occurs when your colon lining is being injured. Plaques called “pseudomembranes” develop at the site of the injury.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN207">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN207</rdfs:label>
    <hasClinicalEffects>In one study, seizures had developed after concomitant use of ciprofloxacin with theophylline</hasClinicalEffects>
    <hasInteractionDescription>Ciprofloxacin may interfere with the clearance of drugs metabolized by the liver such as theophylline on account of the ability of ciprofloxacin to inhibit hepatic metabolism</hasInteractionDescription>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <interactsWith rdf:resource="http://example.org/ontology#S088"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE465">
    <rdf:type rdf:resource="http://example.org/ontology#StevensJohnsonSyndrome"/>
    <rdfs:label>Stevens-Johnson Syndrome</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasReference rdf:resource="http://example.org/ontology#R120"/>
    <hasSideEffectDescription>Fever, sore mouth and throat, fatigue, burning eyes, unexplained widespread skin pain, red or purple rash that spreads, blisters on your skin and the mucous membranes of the mouth, nose, eyes and genitals, shedding of skin within days after blisters form</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP073">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP073</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasStewardshipDescription>Store in a dry place at temperatures not exceeding 30°C and protect from light.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN050">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN050</rdfs:label>
    <hasClinicalEffects>Dose adjustment of azithromycin is not recommended when administered in combination with nelfinavir.</hasClinicalEffects>
    <hasInteractionDescription>Co-administration with a single oral dose of azithromycin resulted in increased azithromycin serum concetration.</hasInteractionDescription>
    <hasManagementAdvice>Close monitoring for known adverse effects of azithromycin, such as liver enzyme abnormalities and hearing impairment.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <interactsWith rdf:resource="http://example.org/ontology#S037"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Amoxil">
    <rdf:type rdf:resource="http://example.org/ontology#Brand"/>
    <rdfs:label>Amoxil</rdfs:label>
    <hasPresentation rdf:resource="http://example.org/ontology#A016"/>
    <hasPresentation rdf:resource="http://example.org/ontology#A017"/>
    <hasPresentation rdf:resource="http://example.org/ontology#A054"/>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R055">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R055</rdfs:label>
    <hasAuthor>National Library of Medicine</hasAuthor>
    <hasReferenceTitle>Pharyngitis</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</publishedIn>
    <retrievedFrom>https://medlineplus.gov/ency/article/000655.htm</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W236">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W236</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R128"/>
    <hasWarningHeadline>Use in Children</hasWarningHeadline>
    <hasWarningText>The safety and efficacy of cefixime in children less than six (6) months old have not been established. The incidence of GI adverse reactions such as diarrhea and loose stools, in children receiving cefixime suspension, was comparable to the incidence seen in adults receiving cefixime tablets.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S155">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Antacids</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasSubstanceDescription>Medicines that relieve heartburn specifically those that contain magnesium hydroxide or aluminum hydroxide</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE166">
    <rdf:type rdf:resource="http://example.org/ontology#SkinRash"/>
    <rdfs:label>Skin Rash</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Common"/>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasSideEffectDescription>A general skin reaction</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R210">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
