  <rdf:Description rdf:about="http://example.org/ontology#SE033">
    <rdf:type rdf:resource="http://example.org/ontology#HypersensitivityReactions"/>
    <rdfs:label>Hypersensitivity Reactions</rdfs:label>
    <hasSideEffectDescription>Severe allergic reaction such as swelling, breathing difficulty, or hives. Needs urgent care.</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <whichIs rdf:resource="http://example.org/ontology#Rare_but_serious"/>
    <hasDuration>Immediate or shortly after dose</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN064">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN064</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasInteractionDescription>Probenecid decreases the renal tubular secretion of amoxicillin</hasInteractionDescription>
    <interactsWith rdf:resource="http://example.org/ontology#S040"/>
    <hasManagementAdvice>Concomitant use should be managed by a healthcare provider</hasManagementAdvice>
    <hasClinicalEffects>Increased and prolonged blood levels of amoxicillin</hasClinicalEffects>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R023">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R023</rdfs:label>
    <hasReferenceTitle>Monurol (Fosfomycin Tromethamine)</hasReferenceTitle>
    <retrievedFrom>https://www.rxlist.com/monurol-drug.htm</retrievedFrom>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2023</publishedIn>
    <hasAuthor>John P. Cunha, DO, FACOEP (RxList)</hasAuthor>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN033">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN033</rdfs:label>
    <interactsWith rdf:resource="http://example.org/ontology#S027"/>
    <hasReference rdf:resource="http://example.org/ontology#R029"/>
    <hasReference rdf:resource="http://example.org/ontology#R030"/>
    <hasClinicalEffects>Can change drug effectiveness.</hasClinicalEffects>
    <hasInteractionDescription>Smoking or nicotine use may influence how your body processes fosfomycin.</hasInteractionDescription>
    <hasManagementAdvice>Consider avoiding nicotine or discuss with your doctor.</hasManagementAdvice>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE100">
    <rdf:type rdf:resource="http://example.org/ontology#HypersensitivityReactions"/>
    <rdfs:label>Hypersensitivity Reactions</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R014"/>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>Includes skin rashes, urticaria, eosinophilia, fever, reactions resembling serum sickness,, and anaphylaxis.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I007">
    <rdf:type rdf:resource="http://example.org/ontology#AcuteMaxillarySinusitis"/>
    <rdfs:label>Acute Maxillary Sinusitis</rdfs:label>
    <hasSymptoms>an infection in your sinuses that typically lasts seven to 10 days</hasSymptoms>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasReference rdf:resource="http://example.org/ontology#R262"/>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R190">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R190</rdfs:label>
    <hasReferenceTitle>Neutropenia</hasReferenceTitle>
    <hasAuthor>Mayo Clinic</hasAuthor>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</publishedIn>
    <retrievedFrom>https://www.mayoclinic.org/symptoms/neutropenia/basics/definition/sym-20050854</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W029">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W029</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <hasWarningHeadline>Cardiac Risk</hasWarningHeadline>
    <hasWarningText>Prolonged cardiac repolarization and QT interval, imparting a risk of developing cardiac arrhythmia and torsades de pointes, have been seen in treatment with other macrolides. A similar effect with azithromycin cannot be completely ruled out in patients at increased risk for prolonged cardiac repolarization.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I066">
    <rdf:type rdf:resource="http://example.org/ontology#AcuteBacterialExacerbationOfChronicBronchitis"/>
    <rdfs:label>Mild to Moderate Acute Bacterial Exacerbation of Chronic Bronchitis</rdfs:label>
    <hasSeverityType rdf:resource="http://example.org/ontology#MildToModerate"/>
    <hasSymptoms>persistent cough that lasts one to three weeks, shortness of breath, fever, runny nose, and tiredness</hasSymptoms>
    <hasReference rdf:resource="http://example.org/ontology#R270"/>
    <hasReference rdf:resource="http://example.org/ontology#R032"/>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN246">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN246</rdfs:label>
    <hasInteractionDescription>This drug reduces the kidney's ability to remove nitrofurantoin from the body, which can make the antibiotic stay longer in the bloodstream.</hasInteractionDescription>
    <hasClinicalEffects>Higher levels of nitrofurantoin in the body can increase the risk of side effects such as nausea, liver problems, nerve issues, and general toxicity.</hasClinicalEffects>
    <hasManagementAdvice>Avoid taking probenecid and nitrofurantoin together. If combination is necessary, monitor closely for side effects and adjust dosage under medical supervision.</hasManagementAdvice>
    <interactsWith rdf:resource="http://example.org/ontology#S165"/>
    <hasReference rdf:resource="http://example.org/ontology#R158"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP048">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP048</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <hasStewardshipDescription>Store at temperatures not exceeding 30°C</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE366">
    <rdf:type rdf:resource="http://example.org/ontology#Thrombocytopenia"/>
    <rdfs:label>thrombocytopenia</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R189"/>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <whichIs rdf:resource="http://example.org/ontology#rare"/>
    <hasSideEffectDescription>low blood platelet count</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE593">
    <rdf:type rdf:resource="http://example.org/ontology#Paresthesia"/>
    <rdfs:label>paresthesia</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R230"/>
    <hasSideEffectDescription>the feeling of tingling, numbness or “pins and needles</hasSideEffectDescription>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W269">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W269</rdfs:label>
    <hasWarningHeadline>Anuria or Oliguria</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasWarningText>This medicine should not be used in patients who are not producing urine (anuria) or producing very little urine (oliguria). Because the drug is removed through the urine, it will not work properly and may build up in the body, increasing the risk of side effects.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN050">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN050</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <hasInteractionDescription>Co-administration with a single oral dose of azithromycin resulted in increased azithromycin serum concetration.</hasInteractionDescription>
    <hasClinicalEffects>Dose adjustment of azithromycin is not recommended when administered in combination with nelfinavir.</hasClinicalEffects>
    <interactsWith rdf:resource="http://example.org/ontology#S037"/>
    <hasManagementAdvice>Close monitoring for known adverse effects of azithromycin, such as liver enzyme abnormalities and hearing impairment.</hasManagementAdvice>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R221">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R221</rdfs:label>
    <hasReferenceTitle>Allergies</hasReferenceTitle>
    <retrievedFrom>https://my.clevelandclinic.org/health/diseases/8610-allergies</retrievedFrom>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</publishedIn>
    <hasAuthor>Cleveland Clinic</hasAuthor>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W032">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W032</rdfs:label>
    <hasWarningText>Reactions such as rash, urticaria and anaphylaxis were reported with the use of CONTEPO. Before initiating therapy with CONTEPO, it is important to inquire about previous hypersensitivity reactions to oral or parenteral fosfomycin. If an allergic reaction occurs, discontinue CONTEPO immediately.</hasWarningText>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R070">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R070</rdfs:label>
    <hasReferenceTitle>Dysguesia</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2024</publishedIn>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <retrievedFrom>https://my.clevelandclinic.org/health/diseases/22047-dysgeusia</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R258">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R258</rdfs:label>
    <hasReferenceTitle>Neutropenia</hasReferenceTitle>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2022</publishedIn>
