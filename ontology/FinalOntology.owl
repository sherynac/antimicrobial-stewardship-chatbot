  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#AcuteBacterialSinusitis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Acute Bacterial Sinusitis</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#RespiratoryDisease"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP023">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP023</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <hasStewardshipDescription>Use proper infection control practices in hospital settings to prevent the spread of resistant bacteria.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Rare_and_usually_associated_with_long-term_use">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Rare and usually associated with long-term use</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R153">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R153</rdfs:label>
    <hasAuthor>DrugBank</hasAuthor>
    <hasReferenceTitle>Nifedipine</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</publishedIn>
    <retrievedFrom>https://go.drugbank.com/drugs/DB01115</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE480">
    <rdf:type rdf:resource="http://example.org/ontology#Dysesthesia"/>
    <rdfs:label>Dysesthesia</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasReference rdf:resource="http://example.org/ontology#R132"/>
    <hasSideEffectDescription>Dysesthesia is a set of symptoms that revolve around unusual touch-based sensations. It can refer to sensations that are unexpected or feel unpleasant, painful or just strange.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP111">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP111</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R011"/>
    <hasStewardshipDescription>Store at temperatures not exceeding 30°C</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Tinnitus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Tinnitus</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W235">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W235</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R128"/>
    <hasWarningHeadline>Hemolytic Anemia</hasWarningHeadline>
    <hasWarningText>Cefixime should not be used in patients with a history of cephalosporin-associated hemolytic anemia since the recurrence of hemolysis is much more severe.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#During_treatment">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>During treatment</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R045">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R045</rdfs:label>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <hasReferenceTitle>Nongonococcal Urethritis</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2024</publishedIn>
    <retrievedFrom>https://my.clevelandclinic.org/health/diseases/4426-nongonococcal-urethritis</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP068">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP068</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasStewardshipDescription>Complete the full 7-day potency period as prescribed; any remaining reconstituted liquid should be discarded after 7 days</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W053">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W053</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasWarningHeadline>Taking higher than recommended dose</hasWarningHeadline>
    <hasWarningText>Adverse effects experienced at doses higher than recommended are similar to those seen at normal doses. Symptoms of a macrolide antibiotic overdose typically include reversible hearing loss, severe nausea, vomiting, and diarrhea. In case of an overdose, administration of medicinal charcoal is recommended, along with general symptomatic treatment and supportive measures as needed.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE147">
    <rdf:type rdf:resource="http://example.org/ontology#Dyspepsia"/>
    <rdfs:label>Dyspepsia</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <hasSideEffectDescription>Pain or discomfort in the upper abdomen</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#A056">
    <rdf:type rdf:resource="http://example.org/ontology#Tablet"/>
    <rdfs:label>Tablet</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#OralThrush">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Oral Thrush</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP021">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP021</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <hasStewardshipDescription>Observe for signs of allergic reactions during and after infusion.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R081">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R081</rdfs:label>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <hasReferenceTitle>Pneumonia</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2022</publishedIn>
    <retrievedFrom>https://my.clevelandclinic.org/health/diseases/4471-pneumonia</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Can_appear_anytime">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Can appear anytime</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE203">
    <rdf:type rdf:resource="http://example.org/ontology#Hallucinations"/>
    <rdfs:label>Hallucinations</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R126"/>
    <hasSideEffectDescription>Hallucinations are false perceptions of sensory experiences. Some hallucinations are normal, such as those caused by falling asleep or waking up. But others may be a sign of a more serious condition like schizophrenia or dementia.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#NonGonococcalUrethritis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Non-Gonococcal Urethritis</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#UrinaryDisease"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W148">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W148</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasWarningHeadline>Pediatric Use</hasWarningHeadline>
    <hasWarningText>The use of drugs of the tetracycline class during tooth development (last half of pregnancy, infancy and childhood to the age of 8 years) may cause permanent discoloration of the teeth (yellow-gray-brown).</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Dyspepsia">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Dyspepsia</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN246">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN246</rdfs:label>
    <hasClinicalEffects>Higher levels of nitrofurantoin in the body can increase the risk of side effects such as nausea, liver problems, nerve issues, and general toxicity.</hasClinicalEffects>
    <hasInteractionDescription>This drug reduces the kidney's ability to remove nitrofurantoin from the body, which can make the antibiotic stay longer in the bloodstream.</hasInteractionDescription>
    <hasManagementAdvice>Avoid taking probenecid and nitrofurantoin together. If combination is necessary, monitor closely for side effects and adjust dosage under medical supervision.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R158"/>
    <interactsWith rdf:resource="http://example.org/ontology#S165"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Photosensitivity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Photosensitivity</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Pneumonia">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Pneumonia</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#RespiratoryDisease"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN063">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN063</rdfs:label>
    <hasClinicalEffects>Potential for altered blood clotting (increased INR)</hasClinicalEffects>
    <hasInteractionDescription>Rare cases of increased INR have been reported in the literature for patients on these medications</hasInteractionDescription>
    <hasManagementAdvice>Prothrombin time or INR should be carefully monitored when starting or stopping Amoxil</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <interactsWith rdf:resource="http://example.org/ontology#S043"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W282">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W282</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R166"/>
    <hasWarningHeadline>Breastfeeding and Infants</hasWarningHeadline>
    <hasWarningText>No adverse effects have been seen in breast-fed infants whose mothers were
taking cotrimoxazole, and the last available guidance from the American
Academy of Pediatrics considered that it was therefore usually compatible with
breast feeding.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R067">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R067</rdfs:label>
    <hasAuthor>National Library of Medicine</hasAuthor>
    <hasReferenceTitle>Gastroenteritis</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2022</publishedIn>
    <retrievedFrom>https://medlineplus.gov/gastroenteritis.html</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I055">
    <rdf:type rdf:resource="http://example.org/ontology#Pyelonephritis"/>
    <rdfs:label>Mild to Severe Pyelonephritis</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R003"/>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasReference rdf:resource="http://example.org/ontology#R129"/>
    <hasReference rdf:resource="http://example.org/ontology#R130"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#MildToSevere"/>
    <hasSymptoms>fever, pain in lower back, chills, pain when peeing, bloody or cloudy pee that might smell bad, urgent or frequent need to pee</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I008">
    <rdf:type rdf:resource="http://example.org/ontology#AcuteMaxillarySinusitis"/>
    <rdfs:label>Mild to Moderate Acute Maxillary Sinusitis</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R010"/>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <hasReference rdf:resource="http://example.org/ontology#R262"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#MildToModerate"/>
    <hasSymptoms>an infection in your sinuses that typically lasts seven to 10 days</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#mild">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>mild</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE185">
    <rdf:type rdf:resource="http://example.org/ontology#AnaphylacticReaction"/>
    <rdfs:label>anaphylactic reaction</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R283"/>
    <hasSideEffectDescription>Anaphylaxis is when you have a severe allergic reaction. Most commonly, it happens after you eat certain foods or get stung by an insect. Going into anaphylactic shock can be life-threatening.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SeriousPulmonaryReaction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Serious Pulmonary Reaction</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Somnolence">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Somnolence</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Beverage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Substance"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Can_appear_after_taking_first_doses">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Can appear after taking first doses</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN052">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN052</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S145">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Theophylline, fenbufen or similar non-steroidal anti-inflammatory drugs</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R010"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE562">
    <rdf:type rdf:resource="http://example.org/ontology#Neutropenia"/>
    <rdfs:label>Neutropenia</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R139"/>
    <hasSideEffectDescription>Neutropenia involves having lower-than-normal levels of neutrophils (a type of white blood cell) in your blood.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W183">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W183</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasWarningHeadline>Abscence of Suspected Bacterial Infection</hasWarningHeadline>
    <hasWarningText>Prescribing levofloxacin in the absence of a proven or strongly suspected bacterial infection or a prophylactic indication is unlikely to provide benefit to the patient and increases the risk of the development of drug-resistant bacteria.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ChronicBacterialProstatitis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Chronic Bacterial Prostatitis</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#UrinaryDisease"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP062">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP062</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasStewardshipDescription>Ensure doses are taken at regular intervals as prescribed to maintain effective blood levels.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W211">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W211</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasWarningHeadline>Nursing Mothers</hasWarningHeadline>
    <hasWarningText>Ciprofloxacin is excreted in human milk; The amount of ciprofloxacin absorbed by the infant is unknown; Due to potential serious adverse reactions to infants nursing from mothers taking ciprofloxacin, a decision should be made whether to discontinue nursing or to discontinue the drug, depending on the importance of the drug to the mother.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Drowsiness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Drowsiness</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE428">
    <rdf:type rdf:resource="http://example.org/ontology#ToxicPsychosis"/>
    <rdfs:label>Toxic Psychosis</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasSideEffectDescription>Form of psychosis that is attributed to substance intoxication, withdrawal or recent consumption of psychoactive drugs.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Appears_when_on_drug">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Appears when on drug</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S106">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Oral Hypoglycemic Agents / Insulin</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R001"/>
    <hasSubstanceDescription>Medications used to manage blood sugar in diabetes.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP105">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP105</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasStewardshipDescription>Oral administration: The usual dose is 250 mg twice daily, though this may be increased to 500 mg twice daily for severe infections.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP096">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP096</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasStewardshipDescription>Tablets should be swallowed whole and can be taken with or without food. Take every 12 hours as prescribed.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R025">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R025</rdfs:label>
    <hasAuthor>Brian J. Werth, PharmD; reviewed by Brenda L. Tesini, MD (Merck Manual)</hasAuthor>
    <hasReferenceTitle>Fosfomycin</hasReferenceTitle>
    <retrievedFrom>https://www.merckmanuals.com/professional/infectious-diseases/bacteria-and-antibacterial-medications/fosfomycin</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Tremor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Tremor</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP001">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP001</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R022"/>
    <hasReference rdf:resource="http://example.org/ontology#R023"/>
    <hasStewardshipDescription>Use Monurol only for confirmed uncomplicated urinary tract infections in adult women. Do not use for kidney infections or perinephric abscess.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE448">
    <rdf:type rdf:resource="http://example.org/ontology#Rash"/>
    <rdfs:label>Rash</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasReference rdf:resource="http://example.org/ontology#R116"/>
    <hasSideEffectDescription>red, inflamed, bumpy as well as dry, itchy or painful</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE380">
    <rdf:type rdf:resource="http://example.org/ontology#ErythematousRashes"/>
    <rdfs:label>erythematous rashes</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#common"/>
    <hasReference rdf:resource="http://example.org/ontology#R013"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R175"/>
    <hasSideEffectDescription>painful or uncomfortable rash on skin</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W079">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W079</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R031"/>
    <hasWarningHeadline>Pediatric Use</hasWarningHeadline>
    <hasWarningText>Comazole should not be given to premature and newborn infants during the first week of life.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S104">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Quetiapine</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R001"/>
    <hasSubstanceDescription>An atypical antipsychotic medication.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP035">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP035</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <hasStewardshipDescription>For people with advanced HIV infection, to treat a serious illness called Mycobacterium avium complex (MAC) disease, it is taken with another drug called ethambutol (at the recommended dose)</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP118">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP118</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasStewardshipDescription>Store at temperatures not exceeding 30°C, Protect from sunlight and moisture.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP060">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP060</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasStewardshipDescription>Store the capsules in a dry place at temperatures not exceeding 25°C</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP010">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP010</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R024"/>
    <hasStewardshipDescription>Patients should take the full dose as instructed and dissolve the powder in water before drinking.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP176">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP176</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasStewardshipDescription>During prolonged therapy, especially in elderly patients, liver and lung function should be checked regularly. Patients with existing lung, liver, nerve, or kidney problems should be monitored closely. If symptoms such as breathing difficulty, numbness, tingling, or weakness occur, the medicine should be stopped and medical advice sought immediately.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R218">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R218</rdfs:label>
    <hasAuthor>Mayo Clinic</hasAuthor>
    <hasReferenceTitle>Anemia</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2023</publishedIn>
    <retrievedFrom>https://www.mayoclinic.org/diseases-conditions/anemia/symptoms-causes/syc-20351360</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE231">
    <rdf:type rdf:resource="http://example.org/ontology#FixedDrugEruption"/>
    <rdfs:label>fixed drug eruption</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R310"/>
    <hasSideEffectDescription>The term fixed drug eruption (FDE) describes the development of one or more annular or oval erythematous patches as a result of systemic exposure to a drug. A vesicle or bulla may or may not occur at the center of  patch and these reactions normally resolve with hyperpigmentation and may recur at the same site with reexposure to the drug. Repeated exposure to the offending drug may also cause new lesions to develop in addition to lighting up the older hyperpigmented lesions. Lesions can occur anywhere on the body (ie, face, tongue, hands, feet, torso, extremities, and genitalia) but genitalia and oral muscosa are often favored.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W061">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W061</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasWarningHeadline>Pregnancy</hasWarningHeadline>
    <hasWarningText>The safety of azithromycin has not been confirmed with regard to the use of the active substance during pregnancy. Therefore, azithromycin should only be used during pregnancy if the benefit outweighs the risk.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE252">
    <rdf:type rdf:resource="http://example.org/ontology#Diarrhea"/>
    <rdfs:label>Diarrhea</rdfs:label>
    <hasDurationOf>2–3 days</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#During_or_shortly_after_treatment"/>
    <hasReference rdf:resource="http://example.org/ontology#R032"/>
    <hasSideEffectDescription>Loose or watery stools; usually mild, but should be monitored for severity.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE516">
    <rdf:type rdf:resource="http://example.org/ontology#Vomiting"/>
    <rdfs:label>Vomiting</rdfs:label>
    <hasDurationOf>Short-term</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Early_in_treatment"/>
    <hasReference rdf:resource="http://example.org/ontology#R157"/>
    <hasSideEffectDescription>Forceful emptying of stomach contents. It may happen if the medicine irritates the stomach. Taking the capsule with meals may reduce this effect.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP098">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP098</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasStewardshipDescription>Store at temperatures not exceeding 30°C and protect from light.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE533">
    <rdf:type rdf:resource="http://example.org/ontology#Vomiting"/>
    <rdfs:label>Vomiting</rdfs:label>
    <hasDurationOf>Few hours to 1 day</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Often_appears_when_starting_the_drug"/>
    <hasReference rdf:resource="http://example.org/ontology#R163"/>
    <hasReference rdf:resource="http://example.org/ontology#R164"/>
    <hasSideEffectDescription>Throwing up.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W139">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W139</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <hasWarningHeadline>Elderly Risk</hasWarningHeadline>
    <hasWarningText>Elderly patients are at higher risk for colchicine toxicity.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#LiverEnzymeElevation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Liver Enzyme Elevation</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W074">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W074</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R031"/>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasWarningText>Comazole is contraindicated in patients with marked liver parenchymal damage. It is also contraindicated in patients with severe renal insufficiency when repeated determinations of the plasma concentration cannot be made. Except in rare circumstances Comazole should not be given to patient with serious haematological disorders. The combination has occasionally been administered to patients receiving cytotoxic agents for the treatment of leukemias, without evidence of any adverse effect on the bone marrow or peripheral blood. Comazole should not be administered to patients with a history of hypersensitivity to sulphonamides or trimethoprim. Comazole is contraindicated in G6PD (Glucose-6-phosphate dehydrogenase
deficiency). Treatment must be immediately discontinued on the appearance of a skin rash or any element of blood count reduced.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ncc9caf714a1e4eda918fdaa09880ac90b31">
    <rdf:first rdf:resource="http://example.org/ontology#Brand"/>
    <rdf:rest rdf:nodeID="ncc9caf714a1e4eda918fdaa09880ac90b32"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W120">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W120</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasWarningText>Hypersensitivity to penicillins and to any ingredient in the products. Patients with infectious mononucleosis due to possible development of rash during therapy.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasPattern">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>which is</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Pattern"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W157">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W157</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R020"/>
    <hasWarningHeadline>Gastrointestinal and Mental Effects</hasWarningHeadline>
    <hasWarningText>Large amounts produce GI symptoms. A patient ingesting 8 grams showed altered mental status, paranoid behaviour, hypokalemia, and hypoxemia.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP057">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP057</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R031"/>
    <hasStewardshipDescription>Store at temperatures below 30C, in a tight, light resistant container, protect from light.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN016">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN016</rdfs:label>
    <hasClinicalEffects>Increased discomfort or nausea.</hasClinicalEffects>
    <hasInteractionDescription>Alcohol does not directly interact, but it may worsen side effects like dizziness or stomach upset.</hasInteractionDescription>
    <hasManagementAdvice>Limit or avoid alcohol during therapy.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <interactsWith rdf:resource="http://example.org/ontology#S006"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I020">
    <rdf:type rdf:resource="http://example.org/ontology#UncomplicatedUrinaryTractInfectionUTI"/>
    <rdfs:label>Mild to Severe Uncomplicated Urinary Tract Infection (UTI)</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasReference rdf:resource="http://example.org/ontology#R264"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#MildToSevere"/>
    <hasSymptoms>urinary frequency, urgency, dysuria, and suprapubic discomfort.</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE255">
    <rdf:type rdf:resource="http://example.org/ontology#Headache"/>
    <rdfs:label>Headache</rdfs:label>
    <hasDurationOf>1–3 days</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#During_treatment"/>
    <hasReference rdf:resource="http://example.org/ontology#R032"/>
    <hasSideEffectDescription>Mild to moderate aching in the head.</hasSideEffectDescription>
  </rdf:Description>
