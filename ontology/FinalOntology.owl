    <hasSubstanceDescription>Immunosuppressant</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE034">
    <rdf:type rdf:resource="http://example.org/ontology#Hypokalemia"/>
    <rdfs:label>Hypokalemia</rdfs:label>
    <hasDurationOf>During prolonged or high-dose use</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#More_common_in_long-term_therapy"/>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <hasSideEffectDescription>Low potassium levels which may cause weakness, muscle cramps, or irregular heartbeat.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP022">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP022</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <hasStewardshipDescription>Complete the full prescribed duration even if symptoms improve early.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W215">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W215</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasWarningHeadline>Children and Adolescents</hasWarningHeadline>
    <hasWarningText>Do not take ciprofloxacin if you are a child or an adolescent. Ciprofloxacin was reported to cause arthralgia and degenerative changes in joints that bear weight in young animals.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE250">
    <rdf:type rdf:resource="http://example.org/ontology#Hepatic"/>
    <rdfs:label>Hepatic</rdfs:label>
