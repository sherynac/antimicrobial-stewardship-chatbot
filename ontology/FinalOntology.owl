    <rdf:type rdf:resource="http://example.org/ontology#Food"/>
    <rdfs:label>Food</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasSubstanceDescription>Dietary intake consumed during or near dose administration.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE179">
    <rdf:type rdf:resource="http://example.org/ontology#HaemolyticAnaemia"/>
    <rdfs:label>haemolytic anaemia</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R280"/>
    <hasSideEffectDescription>Hemolytic anemia is a blood disorder that typically happens when your red blood cells break down or die faster than your body can replace them with new blood cells. People may develop hemolytic anemia by inheriting genetic conditions that cause anemia, certain infections and certain medications.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE375">
    <rdf:type rdf:resource="http://example.org/ontology#Glossitis"/>
    <rdfs:label>glossitis</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R013"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R170"/>
    <hasSideEffectDescription>inflammation of tongue</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasStorageRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has storage rule</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Brand"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Storage"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN122">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN122</rdfs:label>
    <hasClinicalEffects>bacteriostatic drugs interfere with the bactericidal action of penicillin</hasClinicalEffects>
    <hasInteractionDescription>Since bacteriostatic drugs interfere with the bactericidal action of penicillin, it is advisable to avoid giving tetracyclines in conjuction with penicillin</hasInteractionDescription>
    <hasManagementAdvice>avoid giving tetracyclines in conjuction with penicillin</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R011"/>
    <interactsWith rdf:resource="http://example.org/ontology#S096"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I050">
    <rdf:type rdf:resource="http://example.org/ontology#InhalationAnthrax"/>
    <rdfs:label>Inhalation Anthrax</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasReference rdf:resource="http://example.org/ontology#R099"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
    <hasSymptoms>Fever and chills, heavy sweats, chest pain, cough, or shortness of breath, confusion or dizziness, nausea, vomiting, or stomach pains, headache or body aches, and extreme tiredness</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I062">
    <rdf:type rdf:resource="http://example.org/ontology#AcuteBacterialExacerbationOfChronicBronchitis"/>
    <rdfs:label>Mild to Severe Acute Bacterial Exacerbation of Chronic Bronchitis</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasReference rdf:resource="http://example.org/ontology#R270"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#MildToSevere"/>
    <hasSymptoms>persistent cough that lasts one to three weeks, shortness of breath, fever, runny nose, and tiredness</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN137">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN137</rdfs:label>
    <hasClinicalEffects>77% increase in Clarithromycin AUC and 100% decrease in 14-OH Clarithromycin AUC.</hasClinicalEffects>
    <hasInteractionDescription>Concomitant administration with Clarithromycin.</hasInteractionDescription>
    <hasManagementAdvice>Dosage adjustment should be considered, especially in patients with renal impairment.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <interactsWith rdf:resource="http://example.org/ontology#S111"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN139">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN139</rdfs:label>
    <hasClinicalEffects>Potential for cumulative damage to auditory or vestibular functions.</hasClinicalEffects>
    <hasInteractionDescription>Use of Clarithromycin alongside other ototoxic agents.</hasInteractionDescription>
    <hasManagementAdvice>Monitor vestibular and auditory function during and after treatment.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <interactsWith rdf:resource="http://example.org/ontology#S113"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE286">
    <rdf:type rdf:resource="http://example.org/ontology#CentralNervousSystemEffects"/>
    <rdfs:label>Central Nervous System Effects</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Common___1_100_to__1_10_"/>
    <hasReference rdf:resource="http://example.org/ontology#R020"/>
    <hasSideEffectDescription>Insomnia, headache, dysgeusia (taste perversion), diarrhea, vomiting, dyspepsia, nausea, and abdominal pain.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN254">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN254</rdfs:label>
    <hasClinicalEffects>This may reduce the effectiveness of Furadantin in treating urinary infections, though exact clinical impact is uncertain.</hasClinicalEffects>
    <hasInteractionDescription>Propantheline, an anticholinergic drug, can alter kidney excretion of Furadantin, slightly changing how much antibiotic reaches the urine.</hasInteractionDescription>
    <hasManagementAdvice>Your doctor may monitor infection progress. Report any persistent symptoms and continue therapy exactly as prescribed.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R163"/>
    <interactsWith rdf:resource="http://example.org/ontology#S173"/>
  </rdf:Description>
