  <rdf:Description rdf:about="http://example.org/ontology#W152">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W152</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasWarningHeadline>Gastrointestinal and Mental Effects</hasWarningHeadline>
    <hasWarningText>Symptoms include abdominal pain, nausea, vomiting, and diarrhea. High doses (8g) may cause altered mental status and paranoid behavior.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W170">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W170</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <hasWarningHeadline>Arrythmia Risk</hasWarningHeadline>
    <hasWarningText>May cause QT prolongation leading to Torsade de Pointes. Use with caution in at-risk patients.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S167">
    <rdf:type rdf:resource="http://example.org/ontology#Food"/>
    <rdfs:label>Food</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R157"/>
    <hasSubstanceDescription>Taking Macrodantin with food helps the medicine to be absorbed better into the bloodstream and reduces stomach irritation. Eating meals or snacks at the same time as the medicine can also help prevent nausea or vomiting, making the treatment easier to tolerate.</hasSubstanceDescription>
  </rdf:Description>
