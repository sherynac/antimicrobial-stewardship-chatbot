    <whichIs rdf:resource="http://example.org/ontology#Common___1_100_to__1_10_"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R072"/>
    <hasDuration>Not specified</hasDuration>
    <hasSideEffectDescription>Clostridioides difficile is a bacterium that causes an infection of the colon, the longest part of the large intestine. Symptoms can range from diarrhea to life-threatening damage to the colon. The bacterium is often called C. difficile or C. diff.</hasSideEffectDescription>
  </rdf:Description>
