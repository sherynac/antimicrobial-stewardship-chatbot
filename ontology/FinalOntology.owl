    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R309"/>
    <hasSideEffectDescription>Exfoliative dermatitis is a serious skin condition that causes extreme shedding of the top layers of your skin. It may cover most of your body and lead to so much skin damage that your body can’t keep warm. Dehydration is also a risk due to your skin losing its ability to hold onto moisture.</hasSideEffectDescription>
  </rdf:Description>
