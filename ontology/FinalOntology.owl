    <hasAuthor>Cleveland Clinic</hasAuthor>
    <retrievedFrom>https://my.clevelandclinic.org/health/symptoms/4167-abdominal-pain</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE053">
