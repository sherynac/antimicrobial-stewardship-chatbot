    <rdfs:label>SP095</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasStewardshipDescription>If used with other ototoxic drugs (like aminoglycosides), monitor vestibular and auditory function</hasStewardshipDescription>
  </rdf:Description>
