  <rdf:Description rdf:about="http://example.org/ontology#SE178">
    <rdf:type rdf:resource="http://example.org/ontology#AplasticAnaemia"/>
    <rdfs:label>Aplastic anaemia</rdfs:label>
    <hasSideEffectDescription>Aplastic anemia is a rare but serious blood disorder. It happens when something damages your bone marrow so it can’t make enough new blood cells and platelets. Left untreated, aplastic anemia is a life-threatening condition.</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R279"/>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasDuration>Not specified</hasDuration>
  </rdf:Description>
