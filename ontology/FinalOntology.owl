  <rdf:Description rdf:about="http://example.org/ontology#SE554">
    <rdf:type rdf:resource="http://example.org/ontology#ExfoliativeDermatitis"/>
    <rdfs:label>Exfoliative Dermatitis</rdfs:label>
    <hasDurationOf>Duration varies; may last until medicine is stopped</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Rare_but_serious_reaction_during_treatment"/>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasSideEffectDescription>Severe skin reaction where the skin becomes red, irritated, and may peel off. Medical attention is required immediately.</hasSideEffectDescription>
