    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasWarningText>Dosed at 25-50 mg/kg body weight/day in divided doses every 8 or 12 hours.</hasWarningText>
    <hasWarningHeadline>Infants &gt; 3 Months &amp; Children &lt; 40 kg</hasWarningHeadline>
  </rdf:Description>
