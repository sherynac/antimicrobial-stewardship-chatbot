    <hasWarningText>It should not be given to patients with known hypersensitivity to trimethoprim or sulfonamides or with documented megaloblastic anaemia secondary to folate deficiency.</hasWarningText>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
  </rdf:Description>
