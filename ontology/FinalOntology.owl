    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2024</publishedIn>
    <retrievedFrom>https://my.clevelandclinic.org/health/symptoms/transaminitis</retrievedFrom>
  </rdf:Description>
