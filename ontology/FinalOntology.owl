    <rdf:first rdf:resource="http://example.org/ontology#Indication"/>
    <rdf:rest rdf:nodeID="ncc9caf714a1e4eda918fdaa09880ac90b5"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S071">
