    <rdfs:label>Nausea</rdfs:label>
    <hasDurationOf>Short-term; during treatment</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#May_occur_during_or_shortly_after_infusion"/>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <hasSideEffectDescription>Feeling sick to the stomach. Usually mild to temporary.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN167">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN167</rdfs:label>
    <hasClinicalEffects>Decreased absorption</hasClinicalEffects>
    <hasInteractionDescription>Barbiturates decrease the half-life of doxycycline</hasInteractionDescription>
    <hasManagementAdvice>Avoid taking together</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <interactsWith rdf:resource="http://example.org/ontology#S099"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE177">
    <rdf:type rdf:resource="http://example.org/ontology#MegaloblasticAnaemia"/>
    <rdfs:label>Megaloblastic anaemia</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R278"/>
    <hasSideEffectDescription>Megaloblastic anemia is a form of macrocytic anemia, a blood disorder that happens when your bone marrow produces stem cells that make abnormally large red blood cells. Megaloblastic anemia is a type of vitamin deficiency anemia that happens when you don’t get enough vitamin B12 and/or vitamin B9 (folate).</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE627">
    <rdf:type rdf:resource="http://example.org/ontology#Nausea"/>
    <rdfs:label>nausea</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
