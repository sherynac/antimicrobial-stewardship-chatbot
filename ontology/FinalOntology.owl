    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W119</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasWarningHeadline>Low Toxicity Symptoms</hasWarningHeadline>
    <hasWarningText>May cause nausea, vomiting, diarrhea, crystalluria, and allergic manifestations. Symptomatic treatment is required for almost all patients. Problems are unlikely if adequate fluid intake and urinary output are maintained; however crystalluria and hemorrhagic cystitis are possible.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN024">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN024</rdfs:label>
    <hasClinicalEffects>Prolonged bleeding or easy bruising.</hasClinicalEffects>
    <hasInteractionDescription>May increase risk of bleeding when used together.</hasInteractionDescription>
    <hasManagementAdvice>Monitor INR/blood clotting; adjust warfarin dose if necessary.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R027"/>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <interactsWith rdf:resource="http://example.org/ontology#S018"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R014">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R014</rdfs:label>
    <hasAuthor>Monthly Index of Medical Specialties</hasAuthor>
    <hasReferenceTitle>Ximvex</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</publishedIn>
    <retrievedFrom>https://www.mims.com/philippines/drug/info/ximvex</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W016">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W016</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <hasWarningHeadline>Taking higher than recommended dose</hasWarningHeadline>
    <hasWarningText>Similar effects noted on regular doses. Adverse events experienced in higher than recommended dose were similar effects noted on regular doses. The typical symptoms of an overdose include reversible loss of hearing, severe nausea, vomiting and diarrhea.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP071">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP071</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasStewardshipDescription>Administer via dropper. Can be taken with or without food; taking with meals can reduce Gastrointestinal discomfort.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN005">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN005</rdfs:label>
    <hasClinicalEffects>Lower blood and urine levels of fosfomycin.</hasClinicalEffects>
    <hasInteractionDescription>Metoclopramide may lower the absorption of Fosfomycin Tromethamine by speeding up digestion.</hasInteractionDescription>
    <hasManagementAdvice>Avoid using together with Fosfomycin if possible. If needed, monitor for treatment effectiveness.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R024"/>
    <interactsWith rdf:resource="http://example.org/ontology#S004"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W212">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W212</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasWarningHeadline>Acute Overdosage</hasWarningHeadline>
    <hasWarningText>In the event of acute overdosage, reversible renal toxicity has been reported in some cases; Make sure to monitor renal (kidney) function and administer magnesium- or calcium-containing antacids which reduce absorption of ciprofloxacin.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP163">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP163</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R157"/>
    <hasStewardshipDescription>Store nitrofurantoin in a cool, dry place at room temperature, away from direct sunlight, moisture, or heat. Proper storage helps maintain the effectiveness and safety of the medication throughout its shelf life.</hasStewardshipDescription>
  </rdf:Description>
