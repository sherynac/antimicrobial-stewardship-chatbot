    <interactsWith rdf:resource="http://example.org/ontology#S028"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN062">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN062</rdfs:label>
    <hasClinicalEffects>Increased likelihood of allergic skin reactions</hasClinicalEffects>
    <hasInteractionDescription>Administered concurrently during treatment with amoxicillin</hasInteractionDescription>
    <hasManagementAdvice>Inform your doctor if you are taking allopurinol</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
