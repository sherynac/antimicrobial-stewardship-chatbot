    <rdfs:label>Sulphonylureas</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasSubstanceDescription>Oral hypoglycemics</hasSubstanceDescription>
  </rdf:Description>
