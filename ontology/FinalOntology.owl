    <rdfs:label>Liver Enzyme Values</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE607">
    <rdf:type rdf:resource="http://example.org/ontology#Stomatitis"/>
    <rdfs:label>stomatitis</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R241"/>
    <hasSideEffectDescription>inflammation in the tissue lining your mouth or lips</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE091">
    <rdf:type rdf:resource="http://example.org/ontology#Heartburn"/>
    <rdfs:label>Heartburn</rdfs:label>
    <hasDurationOf>Short-term</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Occasionally_reported"/>
    <hasReference rdf:resource="http://example.org/ontology#R029"/>
    <hasReference rdf:resource="http://example.org/ontology#R030"/>
    <hasSideEffectDescription>Mild discomfort or burning in chest.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN250">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN250</rdfs:label>
    <hasClinicalEffects>Higher blood levels can increase your risk of side effects like nausea, headache, or nerve problems. Lower urine levels may make Macrobid less effective, leading to persistent urinary infections.</hasClinicalEffects>
    <hasInteractionDescription>Drugs like probenecid or sulfinpyrazone (used for gout) can block the way your kidneys remove Macrobid from your blood. This can cause higher levels of the drug in your body but lower levels in your urine where it is needed to fight bacteria.</hasInteractionDescription>
    <hasManagementAdvice>Your doctor may monitor your blood and urine closely if you take these drugs with Macrobid. They may adjust your dose or suggest using a different medication combination to avoid problems.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R161"/>
    <interactsWith rdf:resource="http://example.org/ontology#S169"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP182">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP182</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasStewardshipDescription>Once the vial is removed from the carton, the infusion solution must be used within three days.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W029">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W029</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <hasWarningHeadline>Cardiac Risk</hasWarningHeadline>
    <hasWarningText>Prolonged cardiac repolarization and QT interval, imparting a risk of developing cardiac arrhythmia and torsades de pointes, have been seen in treatment with other macrolides. A similar effect with azithromycin cannot be completely ruled out in patients at increased risk for prolonged cardiac repolarization.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE204">
    <rdf:type rdf:resource="http://example.org/ontology#PsychoticDisorder"/>
    <rdfs:label>Psychotic disorder</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_known"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R296"/>
    <hasSideEffectDescription>Psychosis is the term for a collection of symptoms that happen when a person has trouble telling the difference between what’s real and what’s not. This disconnection from reality can happen for several reasons, including many different mental and physical conditions.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE267">
    <rdf:type rdf:resource="http://example.org/ontology#Neurologic"/>
    <rdfs:label>Neurologic</rdfs:label>
    <hasDurationOf>1–3 days</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#During_treatment"/>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <hasSideEffectDescription>Headache (mild to moderate) or Dizziness (lightheadedness).</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Insomnia">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
