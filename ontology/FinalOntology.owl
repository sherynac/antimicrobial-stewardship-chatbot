    <hasReference rdf:resource="http://example.org/ontology#R020"/>
    <hasDuration>Not specified</hasDuration>
    <hasSideEffectDescription>Rash, hyperhidrosis, and abnormal liver function tests (LFT).</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN091">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN091</rdfs:label>
    <hasClinicalEffects>Increased TMP-SMX blood levels, risk of adverse effects</hasClinicalEffects>
    <interactsWith rdf:resource="http://example.org/ontology#S065"/>
    <hasInteractionDescription>May occur in patients who are also receiving urinary acidifiers, oral anticoagulants, phenylbutazone, oxyphenbutazone and indomethacin.</hasInteractionDescription>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasManagementAdvice>Avoid combination. Monitor for toxicity.</hasManagementAdvice>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE512">
    <rdf:type rdf:resource="http://example.org/ontology#Eosinophilia"/>
    <rdfs:label>Eosinophilia</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R133"/>
    <hasReference rdf:resource="http://example.org/ontology#R155"/>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>Eosinophilia happens when the body produces an unusually high number of eosinophils - one of the white blood cells that support your immune system.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R198">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R198</rdfs:label>
