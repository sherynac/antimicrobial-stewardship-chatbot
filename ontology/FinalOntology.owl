  <rdf:Description rdf:about="http://example.org/ontology#W169">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W169</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasWarningHeadline>Cross Resistance</hasWarningHeadline>
    <hasWarningText>Not recommended for infections caused by erythromycin-resistant Gram-positive bacteria or MRSA (Methicillin-resistant Staphylococcus aureus). Consider local resistance patterns before use.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN107">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN107</rdfs:label>
    <hasClinicalEffects>Increased incidence of skin rashes, especially in hyperuricemic patients.</hasClinicalEffects>
    <hasInteractionDescription>Concurrent use with amoxicillin.</hasInteractionDescription>
    <hasManagementAdvice>Inform your doctor if you are taking allopurinol; monitor for skin changes.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <interactsWith rdf:resource="http://example.org/ontology#S081"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN165">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN165</rdfs:label>
    <hasClinicalEffects>Decreased absorption</hasClinicalEffects>
    <hasInteractionDescription>Absorption of tetracyclines is impaired by antacids containing aluminum, calcium, or magnesium and iron-containing preparations</hasInteractionDescription>
    <hasManagementAdvice>Avoid taking together</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <interactsWith rdf:resource="http://example.org/ontology#S097"/>
  </rdf:Description>
