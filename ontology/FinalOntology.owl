    <hasReferenceTitle>Heart Palpitations</hasReferenceTitle>
    <hasAuthor>Cleveland Clinic</hasAuthor>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W143">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W143</rdfs:label>
    <hasWarningText>Hypersensitivity to any of the tetracyclines.</hasWarningText>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R011"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W231">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W231</rdfs:label>
    <hasWarningText>Hypersensitivity to penicillins.</hasWarningText>
    <hasReference rdf:resource="http://example.org/ontology#R127"/>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W216">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W216</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasWarningText>Use it with caution if you are pregnant or a lactating mother.; Ciprofloxacin is excreted in breast milk; Ciprofloxacin was reported to cause arthralgia and degenerative changes in joints that bear weight in young animals.</hasWarningText>
    <hasWarningHeadline>Pregnant and Nursing Mothers</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#LowerUrinaryTractInfection">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#UrinaryDisease"/>
    <rdfs:label>Lower Urinary Tract Infection</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S038">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Gentamicin / Amikacin</rdfs:label>
    <hasSubstanceDescription>Aminoglycoside antibiotics. Increased risk of nephrotoxicity (kidney damage) and ototoxicity (hearing loss) when taken with Cephalosporins.</hasSubstanceDescription>
    <hasReference rdf:resource="http://example.org/ontology#R032"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE625">
    <rdf:type rdf:resource="http://example.org/ontology#Dizziness"/>
    <rdfs:label>dizziness</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Common"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R204"/>
