    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasReference rdf:resource="http://example.org/ontology#R262"/>
    <hasSymptoms>an infection in your sinuses that typically lasts seven to 10 days</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE199">
    <rdf:type rdf:resource="http://example.org/ontology#Hyponatraemia"/>
    <rdfs:label>hyponatraemia</rdfs:label>
    <hasSideEffectDescription>Hyponatremia is when the amount of sodium in your blood is too low. Common causes include heart, liver, kidney and brain diseases, hormone issues and medications.</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R290"/>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasDuration>Not specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W013">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W013</rdfs:label>
    <hasWarningText>The safety and effectiveness of Fosfomycin Tromethamine in children under 12 years have not been established in adequate and well-controlled studies.</hasWarningText>
    <hasWarningHeadline>Pediatric Use</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R024"/>
  </rdf:Description>
