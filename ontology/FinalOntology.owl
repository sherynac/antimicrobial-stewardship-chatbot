    <hasSideEffectDescription>muscles in your belly, chest, neck and head work together to push whatever’s in your stomach out</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Common"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I031">
    <rdf:type rdf:resource="http://example.org/ontology#UpperRespiratoryTractInfection"/>
