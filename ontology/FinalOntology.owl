    <hasReference rdf:resource="http://example.org/ontology#R113"/>
    <hasSubstanceDescription>Opioids are common, effective painkillers. But healthcare providers use them cautiously because of the possible side effects. Examples of common opioid medications include codeine, fentanyl, and hydrocodone.</hasSubstanceDescription>
  </rdf:Description>
