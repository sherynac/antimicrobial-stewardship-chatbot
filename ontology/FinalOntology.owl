  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R040">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R040</rdfs:label>
    <hasAuthor>Segal, L. N., Weiden, M. D., &amp; Horowitz, H.W.</hasAuthor>
    <hasReferenceTitle>Acute Exacerbations of Chronic Obstructive Pulmonary Disease</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2014</publishedIn>
    <retrievedFrom>https://pmc.ncbi.nlm.nih.gov/articles/PMC7152150/</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN274">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN274</rdfs:label>
    <hasClinicalEffects>Not Specified</hasClinicalEffects>
    <hasInteractionDescription>Trimethoprim and dapsone increase each other's serum concentrations.</hasInteractionDescription>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R001"/>
    <interactsWith rdf:resource="http://example.org/ontology#S193"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W179">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W179</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasWarningHeadline>Caution to People with CNS disorder</hasWarningHeadline>
    <hasWarningText>As with other quinolones, levofloxacin should be used with caution in patients with a known or suspected central nervous system (CNS) disorder that may predispose them to seizures or lower the seizure threshold (e.g., severe cerebral arteriosclerosis, epilepsy) or in the presence of other risk factors that may predispose them to seizures or lower the seizure threshold (e.g., certain drug therapy, renal dysfunction).</hasWarningText>
  </rdf:Description>
