  <rdf:Description rdf:about="http://example.org/ontology#SE301">
    <rdf:type rdf:resource="http://example.org/ontology#Nausea"/>
    <rdfs:label>Nausea</rdfs:label>
    <hasDurationOf>Short-term</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Occasionally_reported"/>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasSideEffectDescription>Feeling of sickness or queasiness.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Can_occur_sooner_after_taking">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Can occur sooner after taking</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE356">
    <rdf:type rdf:resource="http://example.org/ontology#Urticaria"/>
    <rdfs:label>urticaria</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#frequency_not_reported"/>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R181"/>
    <hasSideEffectDescription>Hives (also called urticaria) refers to raised and splotchy areas of skin that can be caused by an allergic reaction to something</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN025">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN025</rdfs:label>
    <hasClinicalEffects>Kidney injury or electrolyte imbalance.</hasClinicalEffects>
    <hasInteractionDescription>Using with other nephrotoxic antibiotics increases risk of kidney damage.</hasInteractionDescription>
    <hasManagementAdvice>Monitor kidney funcation; avoid combination if possible.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R027"/>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <interactsWith rdf:resource="http://example.org/ontology#S019"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN171">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN171</rdfs:label>
    <hasClinicalEffects>render oral contraceptives less effective</hasClinicalEffects>
    <hasInteractionDescription>Concurrent use of tetracycline may render oral contraceptives less effective</hasInteractionDescription>
    <hasManagementAdvice>Avoid taking together</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <interactsWith rdf:resource="http://example.org/ontology#S103"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W078">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W078</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R031"/>
    <hasWarningHeadline>Lactation</hasWarningHeadline>
    <hasWarningText>Despite the excretion of trimethoprim and sulphamethoxazole into breast milk, the administration of comazole to lactating women represents a negligible risk to the suckling infants. It also should be used with caution in nursing
mothers because it can pass the placenta and is excreted in breast milk and may cause kernicterus.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I003">
    <rdf:type rdf:resource="http://example.org/ontology#AcuteBacterialSinusitis"/>
    <rdfs:label>Mild to Moderate Acute Bacterial Sinusitis</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R013"/>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#MildToModerate"/>
    <hasSymptoms>Colored, thick mucus (from nose or down throat), stuffy, blocked nose, face feels full, pressured, or painful, can't smell things well (or at all), fever</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE583">
    <rdf:type rdf:resource="http://example.org/ontology#AllergicReaction"/>
    <rdfs:label>allergic reaction</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R221"/>
    <hasSideEffectDescription>immune system overreacts to something that’s usually not harmful — like pollen, pet dander and certain foods</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasSideEffect">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has side effect</rdfs:label>
    <rdfs:domain rdf:nodeID="ncc9caf714a1e4eda918fdaa09880ac90b17"/>
    <rdfs:inverseOf rdf:resource="http://example.org/ontology#sideEffectOf"/>
    <rdfs:range rdf:resource="http://example.org/ontology#SideEffect"/>
    <owl:propertyChainAxiom rdf:nodeID="ncc9caf714a1e4eda918fdaa09880ac90b21"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W117">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W117</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasWarningHeadline>Neonates and Infants &lt; 3 Months</hasWarningHeadline>
    <hasWarningText>Specifically dosed at 20-30 mg/kg body weight/day in divided doses every 12 hours.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Leukopenia">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Leukopenia</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE340">
    <rdf:type rdf:resource="http://example.org/ontology#Nausea"/>
    <rdfs:label>nausea</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#common"/>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R168"/>
    <hasSideEffectDescription>a feeling of sickness or discomfort in the stomach</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN175">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN175</rdfs:label>
    <hasClinicalEffects>Decreased absorption</hasClinicalEffects>
    <hasInteractionDescription>Absorption of tetracyclines is impaired by Bismuth Subsalicylate</hasInteractionDescription>
    <hasManagementAdvice>Avoid taking together</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R013"/>
    <interactsWith rdf:resource="http://example.org/ontology#S098"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE625">
    <rdf:type rdf:resource="http://example.org/ontology#Dizziness"/>
    <rdfs:label>dizziness</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Common"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R204"/>
    <hasSideEffectDescription>sensations, such as feeling faint, woozy, weak or wobbly</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN116">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN116</rdfs:label>
    <hasClinicalEffects>Potentiates anticoagulant effects.</hasClinicalEffects>
    <hasInteractionDescription>Concurrent use.</hasInteractionDescription>
    <hasManagementAdvice>Monitor prothrombin time carefully.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <interactsWith rdf:resource="http://example.org/ontology#S090"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W198">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W198</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasWarningHeadline>Use in children</hasWarningHeadline>
    <hasWarningText>Quinolones, including levofloxacin, cause arthropathy and osteochondrosis in juvenile animals of several species. Levofloxacin is indicated in pediatric patients ≥6 months old, for inhalational anthrax (post- exposure) and for the treatment of plague, including pneumonic and septicemic plague due to Yersinia pestis and prophylaxis for plague. The risk-benefit assessment indicates that administration of levofloxacin to pediatric patients is appropriate. Safety and effectiveness in pediatric patients &lt;6 months old have not been established.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W171">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W171</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasWarningHeadline>Intracranial Hypertension (Pseudotumor Cerebri)</hasWarningHeadline>
    <hasWarningText>Intracranial hypertension (IH, pseudotumor cerebri) has been assciated with the use of tetracyclines including Doxycycline. Clinical manifestations of IH include headache, blurred vision, diplopia, and vision loss; papilledema can be found on fundoscopy. Women of childbearing age who are overweight or have history of IH are at greater risk for developing tetracycline associated IH.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP174">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP174</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasStewardshipDescription>Nitrofurantoin should only be used to treat urinary tract infections caused by bacteria that are sensitive to the medicine. It should not be used for viral infections or infections outside the urinary tract. Using the medicine only when needed helps prevent bacteria from becoming resistant and keeps the drug effective in the future.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I053">
    <rdf:type rdf:resource="http://example.org/ontology#Tuberculosis"/>
    <rdfs:label>Tuberculosis</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasReference rdf:resource="http://example.org/ontology#R103"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
    <hasSymptoms>A bad cough that lasts 3 weeks or longer, pain in the chest, coughing up blood or sputum (phlegm) from deep inside the lungs</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R020">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R020</rdfs:label>
    <hasAuthor>Monthly Index of Medical Specialties</hasAuthor>
    <hasReferenceTitle>Kracid</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</publishedIn>
    <retrievedFrom>https://www.mims.com/philippines/drug/info/kracid</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W151">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W151</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasWarningHeadline>Skin Reactions</hasWarningHeadline>
    <hasWarningText>Severe skin reactions, such as exfoliative dermatitis, erythema multiforme, Steven-Johnson syndrome, toxic epidermal necrolysis, and drug reaction with eosinophilia and systemic symptoms (DRESS) have been reported in patients receiving doxycycline.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R032">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R032</rdfs:label>
    <hasAuthor>Monthly Index of Medical Specialties</hasAuthor>
    <hasReferenceTitle>Cefumax</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</publishedIn>
    <retrievedFrom>https://www.mims.com/philippines/drug/info/cefumax</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN187">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN187</rdfs:label>
    <hasClinicalEffects>Lowers renal clearance</hasClinicalEffects>
    <hasInteractionDescription>The renal clearance of levofloxacin is reduced by cimetidine (24%) and probenecid (34%).</hasInteractionDescription>
    <hasManagementAdvice>Caution should be exercised when levofloxacin is coadministered with drugs that affect the tubular renal secretion such as probenecid and cimetidine, especially in renally impaired patients.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R010"/>
    <interactsWith rdf:resource="http://example.org/ontology#S146"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE468">
    <rdf:type rdf:resource="http://example.org/ontology#Anaphylaxis"/>
    <rdfs:label>anaphylaxis</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasReference rdf:resource="http://example.org/ontology#R122"/>
    <hasSideEffectDescription>skin reactions, including hives and itching and flushed or pale skin; low blood pressure (hypotension); constriction of the airways and a swollen tongue or throat, which can cause wheezing and trouble breathing; a weak and rapid pulse; nausea, vomiting or diarrhea; dizziness or fainting</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R189">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R189</rdfs:label>
    <hasAuthor>Mayo Clinic</hasAuthor>
    <hasReferenceTitle>Thrombocytopenia (low platelet count)</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</publishedIn>
    <retrievedFrom>https://www.mayoclinic.org/diseases-conditions/thrombocytopenia/symptoms-causes/syc-20378293</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S050">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Probenecid</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasSubstanceDescription>Gout treatment</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN060">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN060</rdfs:label>
    <hasClinicalEffects>Increased and prolonged blood levels of amoxicillin</hasClinicalEffects>
    <hasInteractionDescription>Probenecid decreases the renal tubular secretion of amoxicillin</hasInteractionDescription>
    <hasManagementAdvice>Concomitant use should be managed by a healthcare provider</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <interactsWith rdf:resource="http://example.org/ontology#S040"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Frequent">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Frequent</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W082">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W082</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R031"/>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasWarningText>Comazole is contraindicated in patients with marked liver parenchymal damage. It is also contraindicated in patients with severe renal insufficiency when repeated determinations of the plasma concentration cannot be made. Except in rare circumstances Comazole should not be given to patient with serious haematological disorders. The combination has occasionally been administered to patients receiving cytotoxic agents for the treatment of leukemias, without evidence of any adverse effect on the bone marrow or peripheral blood. Comazole should not be administered to patients with a history of hypersensitivity to sulphonamides or trimethoprim. Comazole is contraindicated in G6PD (Glucose-6-phosphate dehydrogenase
deficiency). Treatment must be immediately discontinued on the appearance of a skin rash or any element of blood count reduced.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#PowderForOralSuspension">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
