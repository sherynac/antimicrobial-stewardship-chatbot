  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE316">
    <rdf:type rdf:resource="http://example.org/ontology#Enterocolitis"/>
    <rdfs:label>enterocolitis</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R172"/>
    <hasReference rdf:resource="http://example.org/ontology#R011"/>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>inflammation of both the small and large intestines</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W131">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W131</rdfs:label>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <hasWarningText>Cefuroxime (as Axetil) products are contraindicated in patients with known allergy to the cephalosporin group of antibiotics.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R230">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R230</rdfs:label>
    <hasReferenceTitle>Paresthesia</hasReferenceTitle>
    <retrievedFrom>https://my.clevelandclinic.org/health/symptoms/24932-paresthesia</retrievedFrom>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2023</publishedIn>
    <hasAuthor>Cleveland Clinic</hasAuthor>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#IncreasedEosinophilCountBasophilsMonocytesAndNeutrophils">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Increased Eosinophil Count, Basophils, Monocytes and Neutrophils</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE184">
    <rdf:type rdf:resource="http://example.org/ontology#SerumSickness"/>
    <rdfs:label>Serum sickness</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R186"/>
    <hasDuration>Not specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasSideEffectDescription>Serum sickness is an allergic reaction to certain proteins in medicines. Symptoms may include hives, swelling, fever, rash and joint pain.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE286">
    <rdf:type rdf:resource="http://example.org/ontology#CentralNervousSystemEffects"/>
    <rdfs:label>Central Nervous System Effects</rdfs:label>
    <hasSideEffectDescription>Insomnia, headache, dysgeusia (taste perversion), diarrhea, vomiting, dyspepsia, nausea, and abdominal pain.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Common___1_100_to__1_10_"/>
    <hasDuration>Not specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R020"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE266">
    <rdf:type rdf:resource="http://example.org/ontology#Gastrointestinal"/>
    <rdfs:label>Gastrointestinal</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#During_shortly_after_treatment"/>
    <hasDuration>2–3 days</hasDuration>
    <hasSideEffectDescription>Diarrhea (usually mild), Nausea, Vomiting, or Stomach pain/cramping.</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP090">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP090</rdfs:label>
    <hasStewardshipDescription>Monitor for the development of diarrhea, which may indicate pseudomembranous colitis. Regularly check blood levels for theophylline, digoxin, or carbamazepine if used concurrently.</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W179">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W179</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasWarningHeadline>Caution to People with CNS disorder</hasWarningHeadline>
    <hasWarningText>As with other quinolones, levofloxacin should be used with caution in patients with a known or suspected central nervous system (CNS) disorder that may predispose them to seizures or lower the seizure threshold (e.g., severe cerebral arteriosclerosis, epilepsy) or in the presence of other risk factors that may predispose them to seizures or lower the seizure threshold (e.g., certain drug therapy, renal dysfunction).</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE001">
    <rdf:type rdf:resource="http://example.org/ontology#Diarrhea"/>
    <rdfs:label>Diarrhea</rdfs:label>
    <hasDuration>Not specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Not_specified"/>
    <hasSideEffectDescription>Loose or watery stools; may resolve after stopping medication.</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R022"/>
    <hasReference rdf:resource="http://example.org/ontology#R023"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S087">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Ritonavir / HIV-PIs</rdfs:label>
    <hasSubstanceDescription>Protease Inhibitors</hasSubstanceDescription>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE210">
    <rdf:type rdf:resource="http://example.org/ontology#Dizziness"/>
    <rdfs:label>dizziness</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R300"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasSideEffectDescription>Dizziness is a common issue. If you have dizziness, you may feel woozy and disoriented. You may feel as if you’re about to lose your balance. Many things may make you dizzy, such as anxiety or a reaction to medication. But dizziness may be a symptom of an underlying medical issue.</hasSideEffectDescription>
    <hasDuration>Not specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP162">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP162</rdfs:label>
    <hasStewardshipDescription>Do not share your nitrofurantoin with other people, even if they have similar symptoms. Using someone else's medicine can be unsafe and may contribute to ineffective treatment or antibiotic resistance.</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R158"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#AcuteBacterialExacerbationOfChronicBronchitis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#RespiratoryDisease"/>
    <rdfs:label>Acute Bacterial Exacerbation Of Chronic Bronchitis</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I052">
    <rdf:type rdf:resource="http://example.org/ontology#QFever"/>
    <rdfs:label>Mild to Severe Q Fever</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasReference rdf:resource="http://example.org/ontology#R102"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#MildToSevere"/>
    <hasSymptoms>fever, fatigue, headache, malaise, myalgia, chills or sweats, cough, nausea, vomiting, diarrhea</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE496">
    <rdf:type rdf:resource="http://example.org/ontology#Thrombocytopenia"/>
    <rdfs:label>thrombocytopenia</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>low blood platelet count</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R140"/>
    <hasReference rdf:resource="http://example.org/ontology#R133"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE228">
    <rdf:type rdf:resource="http://example.org/ontology#PhotosensitivityReaction"/>
    <rdfs:label>Photosensitivity reaction</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R063"/>
    <hasDuration>Not specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasSideEffectDescription>Photosensitivity is when your skin reacts negatively to sunlight or UV rays. It causes an itchy, painful rash. Unlike a sunburn, symptoms can appear within minutes.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S144">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Sucralfate</rdfs:label>
    <hasSubstanceDescription>Sucralfate tablet</hasSubstanceDescription>
    <hasReference rdf:resource="http://example.org/ontology#R010"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W280">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W280</rdfs:label>
    <hasWarningHeadline>Foliate Deficiency</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R166"/>
    <hasWarningText>Cotrimoxazole should not be given to patients with actual or possible folate
deficiency.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE173">
    <rdf:type rdf:resource="http://example.org/ontology#Leukopenia"/>
    <rdfs:label>Leukopenia</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R276"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasDuration>Not specified</hasDuration>
    <hasSideEffectDescription>Leukopenia (low white blood cell count) happens when you have a lower-than-normal number of white blood cells. Specifically, you have fewer neutrophils than normal. Neutrophils are white blood cells that act as your immune system’s first line of defense. Without enough white blood cells, you’re more vulnerable to developing infections.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE379">
    <rdf:type rdf:resource="http://example.org/ontology#Maculopapular"/>
    <rdfs:label>maculopapular</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R013"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R174"/>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>discolored areas of skin (macules) and elevated lesions (papules)</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#common"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE642">
    <rdf:type rdf:resource="http://example.org/ontology#AllergicReaction"/>
    <rdfs:label>allergic reaction</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R221"/>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>immune system overreacts to something that’s usually not harmful — like pollen, pet dander and certain foods</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN255">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN255</rdfs:label>
    <hasManagementAdvice>Avoid using together unless prescribed by a doctor. The healthcare provider may monitor closely for side effects or adjust the treatment if necessary.</hasManagementAdvice>
    <hasClinicalEffects>Higher levels of Nitrofurantoin may build up in the blood, increasing the risk of side effects. At the same time, lower levels in the urine may reduce its ability to effectively kill bacteria in urinary tract infections.</hasClinicalEffects>
    <interactsWith rdf:resource="http://example.org/ontology#S174"/>
    <hasInteractionDescription>Probenecid reduces the kidney's ability to remove Nitrofurantoin from the body through urine. This causes the drug to stay longer in the bloodstream instead of being properly excreted into the urine where it is needed to treat infection.</hasInteractionDescription>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R271">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R271</rdfs:label>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2023</publishedIn>
    <hasAuthor>Gabrielle, K.</hasAuthor>
    <hasReferenceTitle>What Are the Symptoms of a Complicated Urinary Tract Infection (UTI)?</hasReferenceTitle>
    <retrievedFrom>https://www.healthline.com/health/complicated-uti-symptoms#symptoms</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W125">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W125</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasWarningHeadline>Penicillin Sensitivity</hasWarningHeadline>
    <hasWarningText>Hypersensitivity to penicillins and to any ingredient in the products. Patients with infectious mononucleosis due to possible development of rash during therapy.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R210">
