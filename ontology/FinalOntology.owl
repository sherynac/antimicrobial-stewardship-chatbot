    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Exacerbation of Myasthenia Gravis</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN271">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN271</rdfs:label>
    <hasClinicalEffects>Not Specified</hasClinicalEffects>
    <interactsWith rdf:resource="http://example.org/ontology#S190"/>
    <hasInteractionDescription>Trimethoprim has been reported to reduce the renal excretion and increase blood concentrations of zidovudine, zalcitabine, and lamivudine.</hasInteractionDescription>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R166"/>
  </rdf:Description>
