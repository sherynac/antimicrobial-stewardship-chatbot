    <hasSideEffectDescription>Lung infiltrates refer to abnormal substances or fluids within the lung tissue that can arise from various causes, including infections, pulmonary hemorrhage, drug toxicity, leukemic infiltration, and pulmonary edema, particularly in patients with hematologic malignancies.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W004">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W004</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R023"/>
    <hasWarningHeadline>Clostridium difficile-associated diarrhea (CDAD)</hasWarningHeadline>
    <hasWarningText>Clostridium difficile associated diarrhea (CDAD) has been reported with use of nearly all antibacterial agents, including MONUROL, and may range in severity from mild diarrhea to fatal colitis.</hasWarningText>
  </rdf:Description>
