  <rdf:Description rdf:about="http://example.org/ontology#W182">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W182</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasWarningHeadline>QT interval</hasWarningHeadline>
    <hasWarningText>Levofloxacin should be avoided in patients with known prolongation of the QT interval, patients with uncorrected hypokalemia and patients receiving class IA (quinidine, procainamide) or class III (amiodarone, sotalol) antiarrhythmic agents. Elderly patients may be more susceptible to drug-associated effects on the QT interval.</hasWarningText>
  </rdf:Description>
