  <rdf:Description rdf:about="http://example.org/ontology#SE532">
    <rdf:type rdf:resource="http://example.org/ontology#Nausea"/>
    <rdfs:label>Nausea</rdfs:label>
    <hasSideEffectDescription>Feeling sick in the stomach.</hasSideEffectDescription>
