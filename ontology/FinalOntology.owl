    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W256</rdfs:label>
    <hasWarningText>Avoid Macrobid if your kidneys are not working well; poor kidney function can make the medicine less effective and increase side effects.</hasWarningText>
    <hasReference rdf:resource="http://example.org/ontology#R160"/>
    <hasWarningHeadline>Kidney Problems</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I058">
    <rdf:type rdf:resource="http://example.org/ontology#RecurrentUrinaryTractInfection"/>
    <rdfs:label>Mild Recurrent Urinary Tract Infection</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R161"/>
    <hasReference rdf:resource="http://example.org/ontology#R162"/>
    <hasReference rdf:resource="http://example.org/ontology#R159"/>
    <hasSymptoms>Repeated bladder infections, urgency to urinate, discomfort in lower abdomen.</hasSymptoms>
    <hasSeverityType rdf:resource="http://example.org/ontology#Mild"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W169">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W169</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasWarningHeadline>Cross Resistance</hasWarningHeadline>
    <hasWarningText>Not recommended for infections caused by erythromycin-resistant Gram-positive bacteria or MRSA (Methicillin-resistant Staphylococcus aureus). Consider local resistance patterns before use.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I059">
    <rdf:type rdf:resource="http://example.org/ontology#BladderInfection"/>
    <rdfs:label>Mild to Moderate Bladder Infection</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasSymptoms>Pain or pressure in the lower abdomen and a burning feeling during urination. The person may need to urinate very often. Urine may appear cloudy and sometimes may have small amounts of blood.</hasSymptoms>
    <hasSeverityType rdf:resource="http://example.org/ontology#MildToModerate"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Neurologic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Neurologic</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE550">
    <rdf:type rdf:resource="http://example.org/ontology#AbdominalPain"/>
    <rdfs:label>Abdominal Pain</rdfs:label>
    <hasDuration>Usually temporary; may last several hours to days</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <whichIs rdf:resource="http://example.org/ontology#Can_appear_during_early_treatment"/>
    <hasSideEffectDescription>Pain or discomfort in the stomach or lower belly area. It may feel like cramping, pressure, or aching.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R077">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R077</rdfs:label>
    <retrievedFrom>https://www.drugs.com/sfx/doxycycline-side-effects.html</retrievedFrom>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2024</publishedIn>
    <hasReferenceTitle>Doxycycline Side Effects</hasReferenceTitle>
    <hasAuthor>Drugs.com</hasAuthor>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE491">
    <rdf:type rdf:resource="http://example.org/ontology#RenalImpairment"/>
    <rdfs:label>Renal Impairment</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R141"/>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>a condition in which one or both of your kidneys no longer work on their own.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN005">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN005</rdfs:label>
    <hasClinicalEffects>Lower blood and urine levels of fosfomycin.</hasClinicalEffects>
    <hasInteractionDescription>Metoclopramide may lower the absorption of Fosfomycin Tromethamine by speeding up digestion.</hasInteractionDescription>
    <hasManagementAdvice>Avoid using together with Fosfomycin if possible. If needed, monitor for treatment effectiveness.</hasManagementAdvice>
    <interactsWith rdf:resource="http://example.org/ontology#S004"/>
    <hasReference rdf:resource="http://example.org/ontology#R024"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S022">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Antacids</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasSubstanceDescription>Medications that reduce stomach acid, often contaiing magnesium or aluminum.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W166">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W166</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasWarningHeadline>Renal and Hepatic Impairment</hasWarningHeadline>
    <hasWarningText>Caution is advised in patients with severe renal insufficiency or impaired hepatic function. Fatal hepatic failure has been reported in some cases.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE388">
    <rdf:type rdf:resource="http://example.org/ontology#ExacerbationOfSystemicLupusErythematosus"/>
    <rdfs:label>exacerbation of systemic lupus erythematosus</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R187"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R013"/>
    <hasSideEffectDescription>systemic autoimmune disease with multisystem involvement and is associated with significant morbidity and mortality</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#frequency_not_reported"/>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP003">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP003</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R023"/>
    <hasReference rdf:resource="http://example.org/ontology#R022"/>
    <hasStewardshipDescription>Take the full single-dose as instructed. Do not repeat the dose unless prescribed by a doctor.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP140">
    <rdf:type rdf:resource="http://example.org/ontology#FoodAndTiming"/>
    <rdfs:label>SP140</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasStewardshipDescription>Do not take with antacids, iron or dairy products</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP057">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP057</rdfs:label>
    <hasStewardshipDescription>Store at temperatures below 30C, in a tight, light resistant container, protect from light.</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R031"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE209">
    <rdf:type rdf:resource="http://example.org/ontology#Ataxia"/>
    <rdfs:label>ataxia</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R299"/>
    <hasSideEffectDescription>Ataxia is when you have problems coordinating how your muscles work, leading to awkward, unwieldy or clumsy movements. It’s a possible symptom with a wide range of conditions or circumstances, or it can happen as a stand-alone condition.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasDuration>Not specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP014">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP014</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <hasStewardshipDescription>Use IV fosfomycin only for confirmed or strongly suspected bacterial infections. It should not be used for viral infections.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE037">
    <rdf:type rdf:resource="http://example.org/ontology#Nausea"/>
    <rdfs:label>Nausea</rdfs:label>
    <hasSideEffectDescription>Effects are usually mild. Sensation of having to vomit or having the urge to vomit.</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <hasReference rdf:resource="http://example.org/ontology#R056"/>
    <whichIs rdf:resource="http://example.org/ontology#Common"/>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Hypoglycaemia">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Hypoglycaemia</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S059">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Diuretics (thiazides)</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasSubstanceDescription>Diuretics in elderly</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Contraindication">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Warning"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE260">
    <rdf:type rdf:resource="http://example.org/ontology#SoreThroatOrStuffyNose"/>
    <rdfs:label>Sore Throat / Stuffy Nose</rdfs:label>
    <hasDuration>1–3 days</hasDuration>
    <hasSideEffectDescription>Mild irritation of the upper respiratory tract.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#During_treatment"/>
    <hasReference rdf:resource="http://example.org/ontology#R032"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#HaemolyticAnaemia">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Haemolytic Anaemia</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Palpitation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Palpitation</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE229">
    <rdf:type rdf:resource="http://example.org/ontology#DermatitisExfoliative"/>
    <rdfs:label>dermatitis exfoliative</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R309"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasSideEffectDescription>Exfoliative dermatitis is a serious skin condition that causes extreme shedding of the top layers of your skin. It may cover most of your body and lead to so much skin damage that your body can’t keep warm. Dehydration is also a risk due to your skin losing its ability to hold onto moisture.</hasSideEffectDescription>
    <hasDuration>Not specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#RecurrentFever">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Recurrent Fever</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP157">
    <rdf:type rdf:resource="http://example.org/ontology#FoodAndTiming"/>
    <rdfs:label>SP157</rdfs:label>
    <hasStewardshipDescription>May be taken with or without food.</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R129"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE261">
    <rdf:type rdf:resource="http://example.org/ontology#ToothDiscoloration"/>
    <rdfs:label>Tooth Discoloration</rdfs:label>
    <hasDuration>Reversible (via brushing)</hasDuration>
    <hasSideEffectDescription>Brown, yellow, or gray staining; can be reduced or eliminated with dental cleaning.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Mostly_in_pediatric_patients"/>
    <hasReference rdf:resource="http://example.org/ontology#R016"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R107">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R107</rdfs:label>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2024</publishedIn>
    <hasReferenceTitle>Corticosteroids (Glucocorticoids)</hasReferenceTitle>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <retrievedFrom>https://my.clevelandclinic.org/health/treatments/corticosteroids-glucocorticoids</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Can_occur_during_treatment">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Can occur during treatment</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP006">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP006</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R022"/>
    <hasReference rdf:resource="http://example.org/ontology#R023"/>
    <hasStewardshipDescription>Pregnant or breastfeeding women should consult their doctor before taking Monurol.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R196">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R196</rdfs:label>
    <hasReferenceTitle>Toxic Epidermal Necrolysis (TEN)</hasReferenceTitle>
    <retrievedFrom>https://my.clevelandclinic.org/health/diseases/21616-toxic-epidermal-necrolysis-ten</retrievedFrom>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2021</publishedIn>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE526">
    <rdf:type rdf:resource="http://example.org/ontology#VaginalItchingOrDischarge"/>
    <rdfs:label>Vaginal Itching or Discharge</rdfs:label>
    <hasSideEffectDescription>Mild irritation or unusual discharge in females.</hasSideEffectDescription>
    <hasDuration>Days to weeks</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R161"/>
    <whichIs rdf:resource="http://example.org/ontology#May_appear_while_taking_medicine"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R260">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R260</rdfs:label>
    <retrievedFrom>https://www.mayoclinic.org/diseases-conditions/stevens-johnson-syndrome/symptoms-causes/syc-20355936</retrievedFrom>
    <hasReferenceTitle>Stevens-Johnson syndrome</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</publishedIn>
    <hasAuthor>Mayo Clinic</hasAuthor>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S156">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Naproxen and chloroquine</rdfs:label>
    <hasSubstanceDescription>Naproxen helps relieve inflammation and pain associated with muscle, joint or tendon disorders.; Chloroquine is used to prevent and treat malaria. It is also used to treat liver infection caused by protozoa (extraintestinal amebiasis).</hasSubstanceDescription>
    <hasReference rdf:resource="http://example.org/ontology#R112"/>
    <hasReference rdf:resource="http://example.org/ontology#R111"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I048">
    <rdf:type rdf:resource="http://example.org/ontology#UrinaryDisease"/>
    <rdfs:label>Chronic Bacterial Prostatis</rdfs:label>
    <hasSymptoms>Fever, chills, painful and frequent urination or have trouble urinating,</hasSymptoms>
    <hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
    <hasReference rdf:resource="http://example.org/ontology#R071"/>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP085">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP085</rdfs:label>
    <hasStewardshipDescription>Allergic Reactions: Watch for rashes, itching, or swelling (anaphylaxis).</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE245">
    <rdf:type rdf:resource="http://example.org/ontology#HematologicAndLymphaticSystems"/>
    <rdfs:label>Hematologic and Lymphatic Systems</rdfs:label>
    <hasSideEffectDescription>Includes anemia, thrombocytopenia, and leukopenia; resolves after stopping therapy.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN084">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN084</rdfs:label>
    <hasInteractionDescription>Concomitant use may result in potentiation of hypoglycaemia in occasional patients.</hasInteractionDescription>
    <interactsWith rdf:resource="http://example.org/ontology#S058"/>
    <hasClinicalEffects>Hypoglycemia</hasClinicalEffects>
    <hasManagementAdvice>Monitor blood glucose for potentiated hypoglycemia.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R291">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R291</rdfs:label>
    <retrievedFrom>https://my.clevelandclinic.org/health/diseases/21184-rhabdomyolysis</retrievedFrom>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2023</publishedIn>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <hasReferenceTitle>Rhabdomyolysis</hasReferenceTitle>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W026">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W026</rdfs:label>
    <hasWarningText>In patients with impaired renal function, the elimination half-life is increased proportionally to the degree of renal insufficiency. Patients with creatinine clearance values of 40 mL/min or less require dose adjustments</hasWarningText>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <hasWarningHeadline>Geriatric Use</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN057">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN057</rdfs:label>
    <interactsWith rdf:resource="http://example.org/ontology#S034"/>
    <hasManagementAdvice>Monitor INR closely and reduce warfarin dose if necessary.</hasManagementAdvice>
    <hasInteractionDescription>It has been reported that comazole may displace the anticoagulant warfarin. Careful control of the anticoagulant therapy during treatment with Comazole is advisable.</hasInteractionDescription>
    <hasReference rdf:resource="http://example.org/ontology#R031"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Not_specifically_classified_by_frequency__but_reported_in_children">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Not specifically classified by frequency, but reported in children</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE609">
    <rdf:type rdf:resource="http://example.org/ontology#Esophagitis"/>
    <rdfs:label>esophagitis</rdfs:label>
    <hasSideEffectDescription>inflammation in your esophagus</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R243"/>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE011">
    <rdf:type rdf:resource="http://example.org/ontology#Diarrhea"/>
    <rdfs:label>Diarrhea</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Common__early_during_treatment"/>
    <hasReference rdf:resource="http://example.org/ontology#R024"/>
    <hasDuration>1-3 days</hasDuration>
    <hasSideEffectDescription>Loose or watery stools, usually mild and temporary.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP166">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP166</rdfs:label>
    <hasStewardshipDescription>Take the medicine exactly as prescribed, at the correct times, with food; skipping doses reduces effectiveness.</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R160"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP078">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP078</rdfs:label>
    <hasStewardshipDescription>Monitor for superinfections during prolonged use and observe for renal output in overdose cases.</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SodiumOverload">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Sodium Overload</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R029">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R029</rdfs:label>
    <retrievedFrom>https://www.rexall.ca/article/drug/view/id/17202/</retrievedFrom>
    <hasReferenceTitle>Jamp-Fosfomycin</hasReferenceTitle>
    <hasAuthor>Rexall Pharmacy Group Ltd.</hasAuthor>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</publishedIn>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE318">
    <rdf:type rdf:resource="http://example.org/ontology#Maculopapular"/>
    <rdfs:label>maculopapular</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R174"/>
    <hasReference rdf:resource="http://example.org/ontology#R011"/>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>discolored areas of skin (macules) and elevated lesions (papules)</hasSideEffectDescription>
