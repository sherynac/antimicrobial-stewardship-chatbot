  <rdf:Description rdf:about="http://example.org/ontology#SE580">
    <rdf:type rdf:resource="http://example.org/ontology#Anemia"/>
    <rdfs:label>anemia</rdfs:label>
    <hasSideEffectDescription>a problem of not having enough healthy red blood cells or hemoglobin to carry oxygen to the body's tissues</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R218"/>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W243">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W243</rdfs:label>
    <hasWarningText>Reproduction studies performed in mice and rats up to 400 times the human dose have not revealed evidence of harm to the fetus. There are no adequate and well-controlled studies in pregnant women, and the drug should be used during pregnancy only when clearly needed.</hasWarningText>
    <hasWarningHeadline>Pregnancy</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R129"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN067">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN067</rdfs:label>
    <hasInteractionDescription>Rare cases of increased INR have been reported in the literature for patients on these medications</hasInteractionDescription>
    <interactsWith rdf:resource="http://example.org/ontology#S043"/>
    <hasClinicalEffects>Potential for altered blood clotting (increased INR)</hasClinicalEffects>
    <hasManagementAdvice>Prothrombin time or INR should be carefully monitored when starting or stopping Amoxil</hasManagementAdvice>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W173">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W173</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasWarningText>Photosensitivity manifested by an exaggerated sunburn has been observed in some individuals taking tetracyclines. Patients apt to be exposed to direct sunlight or ultraviolet light should be advised that this reaction can occur with tetracycline drugs, and treatment should be discontinued at the first evidence of skin erythema.</hasWarningText>
    <hasWarningHeadline>Photosensitivity</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP102">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP102</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R020"/>
    <hasStewardshipDescription>Store at temperatures not exceeding 30°C. The shelf life is 36 months.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE578">
    <rdf:type rdf:resource="http://example.org/ontology#ChestPain"/>
    <rdfs:label>chest pain</rdfs:label>
    <hasSideEffectDescription>pain or discomfort in the area between the neck and belly</hasSideEffectDescription>
    <hasDuration>Not Specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R216"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <whichIs rdf:resource="http://example.org/ontology#Common"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE400">
    <rdf:type rdf:resource="http://example.org/ontology#Hypoglycaemia"/>
    <rdfs:label>Hypoglycemia</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN134">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN134</rdfs:label>
    <interactsWith rdf:resource="http://example.org/ontology#S108"/>
    <hasClinicalEffects>Adults: Decreased mean plasma concentration. Children: Increased peak concentration (Cmax​) and extent of absorption (AUC).</hasClinicalEffects>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasManagementAdvice>May be administered with or without food and can be taken with milk.</hasManagementAdvice>
    <hasInteractionDescription>Absorption under fed vs. fasting conditions.</hasInteractionDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP114">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP114</rdfs:label>
    <hasStewardshipDescription>Store at temperatures not exceeding 30°C. Protect from sunlight and moisture.</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE422">
    <rdf:type rdf:resource="http://example.org/ontology#Convulsions"/>
    <rdfs:label>Convulsions</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasReference rdf:resource="http://example.org/ontology#R114"/>
    <hasSideEffectDescription>Surge of abnormal electrical activity in the brain. Temporary loss of consciousness and uncontrollable movements.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE218">
    <rdf:type rdf:resource="http://example.org/ontology#Diarrhea"/>
    <rdfs:label>Diarrhea</rdfs:label>
    <hasDuration>Not specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R207"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <whichIs rdf:resource="http://example.org/ontology#Common"/>
    <hasSideEffectDescription>Diarrhea means having a loose, watery stool during a bowel movement. It’s common in both children and adults and usually goes away on its own within a few days.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP082">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP082</rdfs:label>
    <hasStewardshipDescription>Maintain adequate fluid intake and urinary output to reduce the possibility of crystalluria. Periodic assessment of renal, hepatic, and hematopoietic functions is recommended during prolonged therapy.</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R016"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Uveitis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Uveitis</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN168">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN168</rdfs:label>
    <hasClinicalEffects>Decreased absorption</hasClinicalEffects>
    <interactsWith rdf:resource="http://example.org/ontology#S100"/>
    <hasInteractionDescription>Carbamazepine decrease the half-life of doxycycline</hasInteractionDescription>
    <hasManagementAdvice>Avoid taking together</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN225">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN225</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R0133"/>
    <hasClinicalEffects>Not Specified</hasClinicalEffects>
    <interactsWith rdf:resource="http://example.org/ontology#S006"/>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
    <hasInteractionDescription>Disulfiram-like reaction</hasInteractionDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE258">
    <rdf:type rdf:resource="http://example.org/ontology#RashOrHives"/>
    <rdfs:label>Rash / Hives</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R032"/>
    <hasDuration>1–3 days</hasDuration>
    <hasSideEffectDescription>Mild skin redness, itching, or small bumps.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#During_treatment"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN198">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN198</rdfs:label>
    <hasClinicalEffects>May affect ability to drive and use machines</hasClinicalEffects>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <interactsWith rdf:resource="http://example.org/ontology#S154"/>
    <hasManagementAdvice>Patients who drive and operate machines must not take ciprofloxacin with alcohol.</hasManagementAdvice>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE567">
    <rdf:type rdf:resource="http://example.org/ontology#Dyspnea"/>
    <rdfs:label>dyspnea</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R205"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <whichIs rdf:resource="http://example.org/ontology#Common"/>
    <hasSideEffectDescription>is the feeling that you can’t get enough air into your lungs</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R085">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R085</rdfs:label>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2023</publishedIn>
    <retrievedFrom>https://www.ncbi.nlm.nih.gov/books/NBK470332/</retrievedFrom>
    <hasAuthor>National Library of Medicine</hasAuthor>
    <hasReferenceTitle>Acute Otitis Media</hasReferenceTitle>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE560">
    <rdf:type rdf:resource="http://example.org/ontology#SkinRash"/>
    <rdfs:label>Skin Rash</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>Skin rashes can be red, inflamed, bumpy as well as dry, itchy or painful. The main cause is dermatitis, which is when your skin reacts to allergens or irritants. Bacteria, viruses, allergens and conditions including eczema, hives, and psoriasis can be the source of skin rashes.</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R116"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN011">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN011</rdfs:label>
    <hasManagementAdvice>Avoid combined use with Fosfomycin if possible. Monitor treatment response.</hasManagementAdvice>
    <interactsWith rdf:resource="http://example.org/ontology#S004"/>
    <hasInteractionDescription>Metoclopramide may lower fosfomycin levels in the body by affecting how it is distributed.</hasInteractionDescription>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <hasClinicalEffects>Reduced antibiotic effectiveness.</hasClinicalEffects>
  </rdf:Description>
