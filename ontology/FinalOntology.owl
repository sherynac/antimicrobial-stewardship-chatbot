    <rdf:type rdf:resource="http://example.org/ontology#SevereCutaneousAdverseReactions"/>
    <rdfs:label>Severe Cutaneous Adverse Reactions</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>Toxic epidermal necrolysis, Stevens-Johnson syndrome and drug rash with eosinophilia and systemic symptoms (DRESS).</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R128"/>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#CommunityAcquiredPneumoniaCAP">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#RespiratoryDisease"/>
    <rdfs:label>Community-Acquired Pneumonia (CAP)</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP128">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP128</rdfs:label>
    <hasStewardshipDescription>Store at temperatures not exceeding 30°C</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN260">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN260</rdfs:label>
    <interactsWith rdf:resource="http://example.org/ontology#S179"/>
    <hasClinicalEffects>The medicine may not work as effectively, and the infection may persist or return.</hasClinicalEffects>
    <hasManagementAdvice>Avoid unnecessary use of urinary alkalinisers while taking Nitrofurantoin. Inform your doctor about all medications being used.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasInteractionDescription>Urinary alkalinisers increase urine pH (make urine more alkaline), which can decrease the activity of Nitrofurantoin.</hasInteractionDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE112">
    <rdf:type rdf:resource="http://example.org/ontology#Leukopenia"/>
    <rdfs:label>Leukopenia</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasSideEffectDescription>lower-than-normal number of white blood cells</hasSideEffectDescription>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE515">
    <rdf:type rdf:resource="http://example.org/ontology#Nausea"/>
    <rdfs:label>Nausea</rdfs:label>
    <hasSideEffectDescription>A sick feeling in the stomach that may make the patient feel like vomiting. It usually improves when the medicine is taken with food.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Early_in_treatment"/>
    <hasDuration>Short-term</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R157"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE520">
    <rdf:type rdf:resource="http://example.org/ontology#LungReaction"/>
    <rdfs:label>Lung Reaction</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Rare_but_serious"/>
    <hasSideEffectDescription>May cause cough, chest pain, fever, and difficulty breathing. Acute reactions can happen suddenly within days, while chronic reactions may develop after long-term use. Medical attention is needed immediately.</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R159"/>
    <hasDuration>Can be sudden or develop with long-term use</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE076">
    <rdf:type rdf:resource="http://example.org/ontology#PeripheralEdema"/>
    <rdfs:label>Peripheral Edema</rdfs:label>
    <hasDuration>During treatment</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Rare__may_happen"/>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasSideEffectDescription>Swelling in hands, feet, or ankles; usually mild.</hasSideEffectDescription>
  </rdf:Description>
