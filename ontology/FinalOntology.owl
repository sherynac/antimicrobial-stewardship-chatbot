  <rdf:Description rdf:about="http://example.org/ontology#SE378">
    <rdf:type rdf:resource="http://example.org/ontology#InflammatoryLesionsWithMonilialOvergrowth"/>
    <rdfs:label>inflammatory lesions (with monilial overgrowth)</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R173"/>
    <hasReference rdf:resource="http://example.org/ontology#R013"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasSideEffectDescription>An overgrowth of the fungus Candida causes a vaginal yeast infection. A vaginal yeast infection causes the skin around vagina to burn and itch, and it may change the consistency of vaginal discharge</hasSideEffectDescription>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#rare"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE332">
    <rdf:type rdf:resource="http://example.org/ontology#HemolyticAnemia"/>
    <rdfs:label>hemolytic anemia</rdfs:label>
    <hasSideEffectDescription>a disorder in which red blood cells are destroyed faster than they can be made</hasSideEffectDescription>
    <hasDuration>Not Specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R188"/>
    <hasReference rdf:resource="http://example.org/ontology#R011"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <whichIs rdf:resource="http://example.org/ontology#rare"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W181">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W181</rdfs:label>
    <hasWarningText>Levofloxacin should be discontinued if the patient experiences symptoms of neuropathy including pain, burning, tingling, numbness and/or weakness or other alterations of sensation including light touch, pain, temperature position sense and vibratory sensation in order to prevent the development of an irreversible condition.</hasWarningText>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasWarningHeadline>Neuropathy Symptoms</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE401">
    <rdf:type rdf:resource="http://example.org/ontology#HepatobiliaryDisorder"/>
    <rdfs:label>Hepatobiliary Disorder</rdfs:label>
    <hasSideEffectDescription>Anorexia, Jaundice, Dark Urine, Pruritus or tender abdomen.</hasSideEffectDescription>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I008">
    <rdf:type rdf:resource="http://example.org/ontology#AcuteMaxillarySinusitis"/>
    <rdfs:label>Mild to Moderate Acute Maxillary Sinusitis</rdfs:label>
    <hasSeverityType rdf:resource="http://example.org/ontology#MildToModerate"/>
    <hasReference rdf:resource="http://example.org/ontology#R010"/>
