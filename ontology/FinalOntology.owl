    <hasSubstanceDescription>Vitamin K antagonist anticoagulant.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W240">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W240</rdfs:label>
    <hasWarningText>The safety and efficacy of cefixime have not been established in patients with gastrointestinal malabsorption.</hasWarningText>
    <hasWarningHeadline>Gastrointestinal Malabsorption</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R129"/>
  </rdf:Description>
