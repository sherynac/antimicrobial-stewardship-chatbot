    <owl:disjointWith rdf:resource="http://example.org/ontology#SolutionForInfusion"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE432">
    <rdf:type rdf:resource="http://example.org/ontology#Nausea"/>
    <rdfs:label>Nausea</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R056"/>
    <hasReference rdf:resource="http://example.org/ontology#R091"/>
    <hasSideEffectDescription>Sensation of having to vomit or having the urge to vomit.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE013">
    <rdf:type rdf:resource="http://example.org/ontology#Vaginitis"/>
    <rdfs:label>Vaginitis</rdfs:label>
    <hasDurationOf>Several days</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Occasionally"/>
    <hasReference rdf:resource="http://example.org/ontology#R024"/>
    <hasSideEffectDescription>Irritation or infection of the vagina, may cause itching or discharge.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ExacerbationOfMyastheniaGravis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Exacerbation of Myasthenia Gravis</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#A033">
    <rdf:type rdf:resource="http://example.org/ontology#Tablet"/>
    <rdfs:label>Tablet</rdfs:label>
    <hasAdministrationAndAdherenceRule rdf:resource="http://example.org/ontology#SP070"/>
    <hasInteraction rdf:resource="http://example.org/ontology#ITN069"/>
    <hasWarning rdf:resource="http://example.org/ontology#W084"/>
    <treats rdf:resource="http://example.org/ontology#I011"/>
    <treats rdf:resource="http://example.org/ontology#I012"/>
    <treats rdf:resource="http://example.org/ontology#I018"/>
    <treats rdf:resource="http://example.org/ontology#I056"/>
    <treats rdf:resource="http://example.org/ontology#I066"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP136">
    <rdf:type rdf:resource="http://example.org/ontology#FoodAndTiming"/>
    <rdfs:label>SP136</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasStewardshipDescription>May be taken with meals to minimize gastrointestinal discomfort</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#IncreasedAlkalinePhosphatase">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Increased Alkaline Phosphatase</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W068">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W068</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasWarningText>Taking can cause rare serious allergic reactions (including angioneurotic oedema, anaphylaxis, which have been rarely fatal) and dermatologic reactions, such as acute generalised exanthematous pustulosis (AGEP), Stevens-Johnson syndrome, toxic epidermal necrolysis (rarely fatal), and drug reaction with eosinophilia and systemic symptoms (DRESS), have been reported. Some reactions have required prolonged observation and treatment. If any of these hypersensitivity reactions occur, discontinue azithromycin immediately and institute appropriate emergency therapy.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN002">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN002</rdfs:label>
    <hasInteractionDescription>Reduces absorption</hasInteractionDescription>
    <interactsWith rdf:resource="http://example.org/ontology#2"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W186">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W186</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasWarningHeadline>Patients with renal impairment</hasWarningHeadline>
    <hasWarningText>Since Levofloxacin is excreted mainly by the kidneys, the dose of Levofloxacin should be adjusted in patients with renal impairment.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Megaloblastosis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Megaloblastosis</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#AorticAneurysmAndDissection">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Aortic Aneurysm and Dissection</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R182">
