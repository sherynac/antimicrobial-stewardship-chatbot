    <hasClinicalEffects>Increased serum digoxin concentrations.</hasClinicalEffects>
    <hasInteractionDescription>Concurrent use.</hasInteractionDescription>
    <hasManagementAdvice>Consider monitoring serum digoxin.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <interactsWith rdf:resource="http://example.org/ontology#S091"/>
  </rdf:Description>
