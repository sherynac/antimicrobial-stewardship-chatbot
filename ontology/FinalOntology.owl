    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN124</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R011"/>
    <hasInteractionDescription>Absorption of tetracyclines is impaired by Bismuth Subsalicylate</hasInteractionDescription>
    <interactsWith rdf:resource="http://example.org/ontology#S098"/>
    <hasManagementAdvice>Avoid taking together</hasManagementAdvice>
    <hasClinicalEffects>Decreased absorption</hasClinicalEffects>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE601">
    <rdf:type rdf:resource="http://example.org/ontology#CardiacArrest"/>
    <rdfs:label>cardiac arrest</rdfs:label>
    <hasSideEffectDescription>your heart stops pumping blood, you become unconscious</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R236"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W190">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W190</rdfs:label>
    <hasWarningHeadline>QT interval prolongation</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasWarningText>Caution should be taken when using fluoroquinolones, including levofloxacin, in patients with known risk factors for prolongation of the QT interval such as, for example: congenital long QT syndrome; concomitant use of drugs that are known to prolong the QT interval (e.g., Class IA and III antiarrhythmics, tricyclic antidepressants, macrolides); uncorrected electrolyte imbalance (e.g., hypokalemia, hypomagnesemia); elderly: cardiac disease (e.g.. heart failure, myocardial infarction, bradycardia).</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R127">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R127</rdfs:label>
    <hasAuthor>Monthly Index of Medical Specialties</hasAuthor>
    <retrievedFrom>https://www.mims.com/philippines/drug/info/triocef</retrievedFrom>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</publishedIn>
    <hasReferenceTitle>Triocef</hasReferenceTitle>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE506">
    <rdf:type rdf:resource="http://example.org/ontology#Seizures"/>
    <rdfs:label>Seizures</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>abnormal electrical activity in your brain. It causes changes in awareness and muscle control.</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R147"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W273">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W273</rdfs:label>
    <hasWarningText>This medicine should not be given to infants younger than 1 month old.</hasWarningText>
    <hasWarningHeadline>Infants Under 1 Month</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN144">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN144</rdfs:label>
    <hasClinicalEffects>May result in death due to cardiac arrhythmias (QT prolongation, ventricular tachycardia, and Torsades de pointes).</hasClinicalEffects>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasManagementAdvice>Contraindicated.</hasManagementAdvice>
    <interactsWith rdf:resource="http://example.org/ontology#S118"/>
    <hasInteractionDescription>Concurrent use with Clarithromycin.</hasInteractionDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE627">
    <rdf:type rdf:resource="http://example.org/ontology#Nausea"/>
    <rdfs:label>nausea</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R206"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <whichIs rdf:resource="http://example.org/ontology#Common"/>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>feel like your stomach is ready to do somersaults, sending whatever’s inside right back up and out</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE420">
