  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN264">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN264</rdfs:label>
    <hasClinicalEffects>Not Specified</hasClinicalEffects>
    <interactsWith rdf:resource="http://example.org/ontology#S183"/>
