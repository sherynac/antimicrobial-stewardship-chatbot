  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W093">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W093</rdfs:label>
    <hasWarningText>High doses may cause crystalluria, potentially leading to renal failure. Maintain adequate fluid intake.</hasWarningText>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasWarningHeadline>Crystalluria &amp; Renal Risk</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN015">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN015</rdfs:label>
    <interactsWith rdf:resource="http://example.org/ontology#S013"/>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <hasClinicalEffects>Fluid retention, high blood pressure, worsening heart failure.</hasClinicalEffects>
    <hasManagementAdvice>Monitor sodium levels and fluid status.</hasManagementAdvice>
    <hasInteractionDescription>Fosfomycin contains sodium, and additional sodium from IV fluids may increase total sodium load.</hasInteractionDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R289">
