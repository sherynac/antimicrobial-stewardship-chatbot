  <rdf:Description rdf:about="http://example.org/ontology#SE312">
    <rdf:type rdf:resource="http://example.org/ontology#Nausea"/>
    <rdfs:label>nausea</rdfs:label>
    <hasSideEffectDescription>a feeling of sickness or discomfort in the stomach</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R168"/>
    <hasReference rdf:resource="http://example.org/ontology#R011"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#common"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN046">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN046</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R031"/>
    <hasManagementAdvice>Monitor INR closely and reduce warfarin dose if necessary.</hasManagementAdvice>
    <hasInteractionDescription>It has been reported that comazole may displace the anticoagulant warfarin. Careful control of the anticoagulant therapy during treatment with Comazole is advisable.</hasInteractionDescription>
    <interactsWith rdf:resource="http://example.org/ontology#S034"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP033">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP033</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R030"/>
    <hasReference rdf:resource="http://example.org/ontology#R029"/>
    <hasStewardshipDescription>Contact your doctor if severe side effects occur. Kidney function may require monitoring.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W145">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W145</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R011"/>
    <hasWarningHeadline>Pregnancy</hasWarningHeadline>
    <hasWarningText>Category D. do not use tetracycline during pregnancy. Tetracyclines readily cross the placenta, are found in fetal tissues and can have toxic effects on the developing fetus (retardation of skeletal development). Evidence of embryotoxicity has also been noted in animals treated early in pregnancy.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W110">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W110</rdfs:label>
    <hasWarningText>Treatment of streptococcal pharyngitis.</hasWarningText>
    <hasWarningHeadline>Streptococcal Pharyngitis Treatment</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SecondaryInfectionsInChronicRespiratoryDiseases">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#RespiratoryDisease"/>
    <rdfs:label>Secondary Infections In Chronic Respiratory Diseases</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP089">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP089</rdfs:label>
    <hasStewardshipDescription>Store powder and reconstituted suspension at temperatures not exceeding 30°C. Reconstituted suspension is stable for 14 days. Do not refrigerate.</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S180">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Paminobenzoic Acid and its Derivatives</rdfs:label>
    <hasSubstanceDescription>Folate precursor compounds.</hasSubstanceDescription>
    <hasReference rdf:resource="http://example.org/ontology#R166"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN208">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN208</rdfs:label>
    <hasClinicalEffects>Reduces absorption of ciprofloxacin as well as other fluoroquinolones.</hasClinicalEffects>
    <hasManagementAdvice>Ciprofloxacin is not recommended to be administered orally within 4 hours of taking magnesium, aluminum or iron and zinc salts-containing antacids</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasInteractionDescription>Not Specified</hasInteractionDescription>
    <interactsWith rdf:resource="http://example.org/ontology#S098"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W057">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W057</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <hasWarningText>Do not take if you have hypersensitivity to the azithromycin, or any macrolide antibiotics.</hasWarningText>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE231">
    <rdf:type rdf:resource="http://example.org/ontology#FixedDrugEruption"/>
    <rdfs:label>fixed drug eruption</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R310"/>
    <hasSideEffectDescription>The term fixed drug eruption (FDE) describes the development of one or more annular or oval erythematous patches as a result of systemic exposure to a drug. A vesicle or bulla may or may not occur at the center of  patch and these reactions normally resolve with hyperpigmentation and may recur at the same site with reexposure to the drug. Repeated exposure to the offending drug may also cause new lesions to develop in addition to lighting up the older hyperpigmented lesions. Lesions can occur anywhere on the body (ie, face, tongue, hands, feet, torso, extremities, and genitalia) but genitalia and oral muscosa are often favored.</hasSideEffectDescription>
    <hasDuration>Not specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S083">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Rifampicin</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <hasSubstanceDescription>Potent enzyme-inducing antibiotic; may reduce effectiveness of concurrent meds.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I011">
    <rdf:type rdf:resource="http://example.org/ontology#Tonsillitis"/>
    <rdfs:label>Tonsillitis</rdfs:label>
    <hasSymptoms>Sore throat, swollen tonsils, trouble swallowing, white or yellow coating on the tonsils, swollen glands in the neck. fever, bad breath</hasSymptoms>
    <hasReference rdf:resource="http://example.org/ontology#R128"/>
    <hasReference rdf:resource="http://example.org/ontology#R032"/>
    <hasReference rdf:resource="http://example.org/ontology#R129"/>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <hasReference rdf:resource="http://example.org/ontology#R043"/>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN184">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN184</rdfs:label>
    <hasInteractionDescription>Levofloxacin absorption is significantly reduced</hasInteractionDescription>
    <hasManagementAdvice>It is recommended that preparations containing iron salts, or magnesium-or aluminum-containing antacids should not be taken 2 hours before or after Levofloxacin tablet administration.</hasManagementAdvice>
    <interactsWith rdf:resource="http://example.org/ontology#S143"/>
    <hasClinicalEffects>Decreased absorption</hasClinicalEffects>
    <hasReference rdf:resource="http://example.org/ontology#R010"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE528">
    <rdf:type rdf:resource="http://example.org/ontology#AllergicReactions"/>
    <rdfs:label>Allergic Reactions</rdfs:label>
    <hasSideEffectDescription>Rash, swelling, trouble breathing; serious, seek help immediately.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Can_appear_anytime"/>
    <hasDuration>Until treatment stopped</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R160"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE204">
    <rdf:type rdf:resource="http://example.org/ontology#PsychoticDisorder"/>
    <rdfs:label>Psychotic disorder</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R296"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <whichIs rdf:resource="http://example.org/ontology#Not_known"/>
    <hasDuration>Not specified</hasDuration>
    <hasSideEffectDescription>Psychosis is the term for a collection of symptoms that happen when a person has trouble telling the difference between what’s real and what’s not. This disconnection from reality can happen for several reasons, including many different mental and physical conditions.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#isBrandOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://example.org/ontology#Brand"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Antibiotic"/>
    <rdfs:label>is brand of</rdfs:label>
    <owl:inverseOf rdf:resource="http://example.org/ontology#hasBrandName"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Purpura">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Purpura</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#LiverProblems">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Liver Problems</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W010">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W010</rdfs:label>
    <hasWarningHeadline>Clostridium difficile-associated diarrhea (CDAD)</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R024"/>
    <hasWarningText>Clostridium difficile associated diarrhea (CDAD) has been reported with use of nearly all antibacterial agents, including Fosfomycin Tromethamine, and may range in severity from mild diarrhea to fatal colitis. Treatment with antibacterial agents alters the normal flora of the colon leading to overgrowth of C. difficile.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R186">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R186</rdfs:label>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <hasReferenceTitle>Serum Sickness</hasReferenceTitle>
    <retrievedFrom>https://my.clevelandclinic.org/health/diseases/serum-sickness</retrievedFrom>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2024</publishedIn>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE192">
    <rdf:type rdf:resource="http://example.org/ontology#Thrombocytopenia"/>
    <rdfs:label>thrombocytopenia</rdfs:label>
    <hasDuration>Not specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R140"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasSideEffectDescription>Thrombocytopenia occurs when your bone marrow doesn’t make enough platelets. Platelets are blood cells that form blood clots to help stop bleeding. People with this condition may bleed a lot and the bleeding may be hard to stop. Thrombocytopenia affects people with certain medical conditions like autoimmune disease or who take certain medications.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W121">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W121</rdfs:label>
    <hasWarningText>Administered to pregnant women without evidence of fetal harm; use with caution in breastfeeding mothers because it is distributed into milk and may sensitize infants.</hasWarningText>
    <hasWarningHeadline>Safe for Mother; Monitor Baby</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE633">
    <rdf:type rdf:resource="http://example.org/ontology#Rash"/>
    <rdfs:label>rash</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R212"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>can be red, inflamed, bumpy as well as dry, itchy or painful</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Common"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#StomatitisOrGlossitis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Anorexia</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W097">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W097</rdfs:label>
    <hasWarningHeadline>Newborn Jaundice Risk</hasWarningHeadline>
    <hasWarningText>Contains sodium benzoate which is a mild irritant to the skin, eyes and mucus membrane. It may increase risk of jaundice in newborn babies</hasWarningText>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Can_develop_gradually_while_taking_the_medicine">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Can develop gradually while taking the medicine</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE529">
    <rdf:type rdf:resource="http://example.org/ontology#PeripheralNeuropathy"/>
    <rdfs:label>Peripheral Neuropathy</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R162"/>
    <hasSideEffectDescription>Numbness, tingling, or pain in hands or feet; may becoe permanent if untreated.</hasSideEffectDescription>
    <hasDuration>Weeks to Months</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Rare__can_appear_with_long-term_use"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP034">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP034</rdfs:label>
    <hasStewardshipDescription>For people with advanced HIV infection, to prevent a serious illness called Mycobacterium avium complex (MAC) disease, it can be taken by itself or together with another drug called rifabutin (at the recommended dose)</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R038">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R038</rdfs:label>
    <hasAuthor>Monthly Index of Medical Specialties</hasAuthor>
    <hasReferenceTitle>Zithrocare 200/ Zithrocare 500</hasReferenceTitle>
    <retrievedFrom>https://www.mims.com/philippines/drug/info/zithrocare-200-zithrocare-500/presentation-and-price</retrievedFrom>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</publishedIn>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP041">
    <rdf:type rdf:resource="http://example.org/ontology#FoodAndTiming"/>
    <rdfs:label>SP041</rdfs:label>
    <hasStewardshipDescription>May be taken with or without food</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W070">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W070</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R014"/>
    <hasWarningText>No adverse effects have been found on breast-fed infants whose mothers were receiving cefotaxime</hasWarningText>
    <hasWarningHeadline>Breastfeeding</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#MetallicTaste">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Metallic Taste</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W211">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W211</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasWarningText>Ciprofloxacin is excreted in human milk; The amount of ciprofloxacin absorbed by the infant is unknown; Due to potential serious adverse reactions to infants nursing from mothers taking ciprofloxacin, a decision should be made whether to discontinue nursing or to discontinue the drug, depending on the importance of the drug to the mother.</hasWarningText>
    <hasWarningHeadline>Nursing Mothers</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#AcutePyelonephritis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#UrinaryDisease"/>
    <rdfs:label>Acute Pyelonephritis</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN182">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN182</rdfs:label>
    <hasInteractionDescription>Interfere with the gastrointestinal absorption of levofloxacin</hasInteractionDescription>
    <hasManagementAdvice>These agents should be taken at least 2 hours before or 2 hours after levofloxacin administration.</hasManagementAdvice>
    <interactsWith rdf:resource="http://example.org/ontology#S140"/>
    <hasClinicalEffects>systemic levels considerably lower than desired</hasClinicalEffects>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W062">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W062</rdfs:label>
    <hasWarningText>Azithromycin is secreted into human breast milk. A risk to the newborn/infant cannot be excluded. A decision must be made whether to discontinue breastfeeding or discontinue the drug, taking into account the benefit of breastfeeding to the child and the benefit of therapy to the mother.</hasWarningText>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasWarningHeadline>Breastfeeding</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W027">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W027</rdfs:label>
    <hasWarningHeadline>Impaired hepatic functions</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <hasWarningText>Due to limited data in subjects with Glomerular Filtration Rate &lt; 10 mL/min, caution should be exercised when taking azithrymycin for these patients</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP164">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP164</rdfs:label>
    <hasStewardshipDescription>Take Macrobid only for urinary infections proven or strongly suspected; do not use for colds or other viruses.</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R160"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE359">
    <rdf:type rdf:resource="http://example.org/ontology#AnaphylactoidPurpura"/>
    <rdfs:label>anaphylactoid purpura</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R184"/>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasSideEffectDescription>raised, reddish-purple rash, commonly on the legs, buttocks, and feet</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#frequency_not_reported"/>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#sideEffectOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Brand"/>
    <rdfs:label>side effect of</rdfs:label>
    <owl:inverseOf rdf:resource="http://example.org/ontology#hasSideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Vertigo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Vertigo</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE030">
    <rdf:type rdf:resource="http://example.org/ontology#Headache"/>
    <rdfs:label>Headache</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#May_appear_during_therapy"/>
    <hasSideEffectDescription>Mild to moderate head pain.</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <hasDuration>Temporary</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE136">
    <rdf:type rdf:resource="http://example.org/ontology#ToxicEpidermalNecrolysis"/>
    <rdfs:label>Toxic epidermal necrolysis</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Not_specified"/>
    <hasSideEffectDescription>Toxic epidermal necrolysis (TEN) is potentially life-threatening acute mucocutaneous Syndrome. It usually occurs because of inappropriate immune reactions to certain drugs.</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R033"/>
    <hasDuration>Not specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE516">
    <rdf:type rdf:resource="http://example.org/ontology#Vomiting"/>
    <rdfs:label>Vomiting</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Early_in_treatment"/>
    <hasReference rdf:resource="http://example.org/ontology#R157"/>
    <hasSideEffectDescription>Forceful emptying of stomach contents. It may happen if the medicine irritates the stomach. Taking the capsule with meals may reduce this effect.</hasSideEffectDescription>
    <hasDuration>Short-term</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R031">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R031</rdfs:label>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</publishedIn>
    <hasAuthor>Monthly Index of Medical Specialties</hasAuthor>
    <hasReferenceTitle>Comazole</hasReferenceTitle>
    <retrievedFrom>https://www.mims.com/malaysia/drug/info/comazole</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP011">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP011</rdfs:label>
    <hasStewardshipDescription>Monitor symptoms; if they do not improve within 2-3 days or if they return, contact a healthcare provider for further evaluation</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R024"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W012">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W012</rdfs:label>
    <hasWarningHeadline>Breastfeeding</hasWarningHeadline>
    <hasWarningText>It is unknown if Fosfomycin Tromethamine passes into breast milk. Talk to your doctor before using while nursing.</hasWarningText>
    <hasReference rdf:resource="http://example.org/ontology#R024"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP012">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP012</rdfs:label>
    <hasStewardshipDescription>Monitor for diarrhea or water or bloody stools after antibiotic use, which could indicate C. difficile infection.</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R024"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN173">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN173</rdfs:label>
    <hasClinicalEffects>bacteriostatic drugs interfere with the bactericidal action of penicillin</hasClinicalEffects>
    <interactsWith rdf:resource="http://example.org/ontology#S096"/>
    <hasInteractionDescription>Since bacteriostatic drugs interfere with the bactericidal action of penicillin, it is advisable to avoid giving tetracyclines in conjuction with penicillin</hasInteractionDescription>
    <hasReference rdf:resource="http://example.org/ontology#R013"/>
    <hasManagementAdvice>avoid giving tetracyclines in conjuction with penicillin</hasManagementAdvice>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#GenitourinaryTractInfection">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#UrinaryDisease"/>
    <rdfs:label>Genitourinary Tract Infection</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE394">
    <rdf:type rdf:resource="http://example.org/ontology#CDifficileAssociatedDiarrhea"/>
    <rdfs:label>Clostridium difficile-associated diarrhea</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasSideEffectDescription>Diarrhea to fatal colitis</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE168">
    <rdf:type rdf:resource="http://example.org/ontology#Nausea"/>
    <rdfs:label>Nausea</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <whichIs rdf:resource="http://example.org/ontology#Common"/>
    <hasSideEffectDescription>Gastrointestinal disturbance</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#RenalImpairment">
