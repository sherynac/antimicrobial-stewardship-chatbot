  <rdf:Description rdf:about="http://example.org/ontology#SE403">
    <rdf:type rdf:resource="http://example.org/ontology#TendinitisAndTendonRupture"/>
    <rdfs:label>Tendinitis and Tendon Rupture</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Within_hours_or_days"/>
    <hasSideEffectDescription>Increased risk of tendinitis and tendon rupture involving the achillies rendon, rorator cuffm the hande, the biceps, the thumb, and other tendon sites</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R058">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R058</rdfs:label>
    <hasReferenceTitle>Abdominal Pain</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2024</publishedIn>
    <hasAuthor>National Library of Medicine</hasAuthor>
    <retrievedFrom>https://medlineplus.gov/ency/article/003120.htm</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S045">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Probenecid</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasSubstanceDescription>Gout medication</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE004">
    <rdf:type rdf:resource="http://example.org/ontology#Headache"/>
    <rdfs:label>Headache</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R023"/>
    <hasReference rdf:resource="http://example.org/ontology#R022"/>
    <whichIs rdf:resource="http://example.org/ontology#During_treatment"/>
    <hasDuration>1-3 days</hasDuration>
    <hasSideEffectDescription>Mild to moderate pain in the head.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN082">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN082</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasManagementAdvice>Monitor INR/PT. Adjust dose to avoid over-anticoagulation.</hasManagementAdvice>
    <hasClinicalEffects>Prolonged PT/INR, increased bleeding risk</hasClinicalEffects>
    <interactsWith rdf:resource="http://example.org/ontology#S056"/>
    <hasInteractionDescription>Anticoagulant activity may be increased by concurrent treatment with sulfamethoxazole/trimethoprim. It has been reported that sulfamethoxazole/trimethoprim may prolong the prothrombin time in patients who are receiving the anticoagulant warfarin (a CYP2C9 substrate). This interaction should be kept in mind when sulfamethoxazole/trimethoprim is given to patients already on anticoagulant therapy, and the coagulation time should be reassessed.</hasInteractionDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R295">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R295</rdfs:label>
    <hasReferenceTitle>Depression</hasReferenceTitle>
    <retrievedFrom>https://my.clevelandclinic.org/health/diseases/9290-depression</retrievedFrom>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2023</publishedIn>
    <hasAuthor>Cleveland Clinic</hasAuthor>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SinglePneumonia">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#RespiratoryDisease"/>
    <rdfs:label>Single Pneumonia</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE271">
    <rdf:type rdf:resource="http://example.org/ontology#SystemicRare"/>
    <rdfs:label>Systemic (Rare)</rdfs:label>
    <hasSideEffectDescription>Hematologic (Anemia) or Hepatic (moderate rise in liver enzymes).</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <whichIs rdf:resource="http://example.org/ontology#Rare"/>
    <hasDuration>Reversible</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#PsychoticDisorder">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Psychotic Disorder</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN093">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN093</rdfs:label>
    <hasManagementAdvice>Contraindicated with TMP‑SMX. Avoid co-administration</hasManagementAdvice>
    <interactsWith rdf:resource="http://example.org/ontology#S067"/>
    <hasInteractionDescription>Concurrent administration is contraindicated. Elevated plasma concentrations of dofetilide have been reported following concurrent administration of trimethoprim and dofetilide. Increased plasma concentrations of dofetilide may cause serious ventricular arrhythmias associated with QT interval prolongation, including torsade de pointes.</hasInteractionDescription>
    <hasClinicalEffects>Elevated dofetilide levels is linear with QT prolongation, torsade de pointes, serious ventricular arrhythmias</hasClinicalEffects>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#QTIntervalProlongation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Prolongation of the QT Interval</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE274">
    <rdf:type rdf:resource="http://example.org/ontology#HearingLoss"/>
    <rdfs:label>Hearing Loss</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Occasionally"/>
    <hasSideEffectDescription>Reported upon discontinuation of treatment.</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <hasDuration>Usually Reversible</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W160">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W160</rdfs:label>
    <hasWarningHeadline>Lactation</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasWarningText>Tetracyclines are excreted in breast milk. A dosage of 2g/day for 3 days has achieved a milk plasma ratio of 0.6 to 0.8.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Overdosage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Warning"/>
    <owl:disjointWith rdf:resource="http://example.org/ontology#Contraindication"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN056">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN056</rdfs:label>
    <interactsWith rdf:resource="http://example.org/ontology#S033"/>
    <hasManagementAdvice>Monitor for enhanced drug effects and adjust doses as needed.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R031"/>
    <hasInteractionDescription>Cotrimoxazole has been shown to potentiate activity of strongly serum protein-bound drugs like oral hypoglycaemic or anticoagulant.</hasInteractionDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP072">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP072</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasStewardshipDescription>Doses should be given every 8 or 12 hours for neonates/infants &lt; 3 months.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE041">
    <rdf:type rdf:resource="http://example.org/ontology#Headache"/>
    <rdfs:label>Headache</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Rare"/>
    <hasSideEffectDescription>Discomfort in the head or face</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S094">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Statins (e.g., Lovastatin)</rdfs:label>
    <hasSubstanceDescription>Cholesterol drug</hasSubstanceDescription>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE027">
    <rdf:type rdf:resource="http://example.org/ontology#Nausea"/>
    <rdfs:label>Nausea</rdfs:label>
    <hasSideEffectDescription>Feeling sick to the stomach. Usually mild to temporary.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#May_occur_during_or_shortly_after_infusion"/>
    <hasDuration>Short-term; during treatment</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE120">
    <rdf:type rdf:resource="http://example.org/ontology#Agitation"/>
    <rdfs:label>Agitation</rdfs:label>
    <hasSideEffectDescription>state of severe restlessness or inner tension</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Rare"/>
    <hasDuration>Not Specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE181">
    <rdf:type rdf:resource="http://example.org/ontology#Eosinophilia"/>
    <rdfs:label>eosinophilia</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R068"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasDuration>Not specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasSideEffectDescription>Eosinophilia happens when your body produces an unusually high number of eosinophils. Eosinophils are one of several white blood cells that support your immune system.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE323">
    <rdf:type rdf:resource="http://example.org/ontology#EsophagealUlcerations"/>
    <rdfs:label>esophageal ulcerations</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R011"/>
    <hasReference rdf:resource="http://example.org/ontology#R179"/>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>open sores or breaks in the esophageal mucosa</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE556">
    <rdf:type rdf:resource="http://example.org/ontology#LupusLikeSyndrome"/>
    <rdfs:label>Lupus-like Syndrome</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Rare_and_usually_associated_with_long-term_use"/>
    <hasDuration>Nat develop during prolonged therapy; improves after stopping medicine</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasSideEffectDescription>A reaction that causes symptoms similar to lupus, such as joint pain, muscle pain, fever, and skin rash. Symptoms usually improve when the medicine is discontinued.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R256">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
