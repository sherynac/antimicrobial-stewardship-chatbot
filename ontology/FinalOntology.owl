    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN003</rdfs:label>
    <hasInteractionDescription>Absorption</hasInteractionDescription>
    <interactsWith rdf:resource="http://example.org/ontology#3"/>
  </rdf:Description>
