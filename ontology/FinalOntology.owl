    <hasInteractionDescription>Cimetidine does not affect Fosfomycin Tromethamine absorption or blood levels.</hasInteractionDescription>
    <hasManagementAdvice>No speicla precautions needed.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R024"/>
