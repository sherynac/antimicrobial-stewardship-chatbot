    <rdfs:label>Bismuth Subsalicylate</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R048"/>
    <hasSubstanceDescription>Treats occasional diarrhea</hasSubstanceDescription>
  </rdf:Description>
