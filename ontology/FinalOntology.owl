  <rdf:Description rdf:about="http://example.org/ontology#SE431">
    <rdf:type rdf:resource="http://example.org/ontology#AbdominalPain"/>
    <rdfs:label>Abdominal Pain</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R058"/>
    <hasReference rdf:resource="http://example.org/ontology#R091"/>
    <hasSideEffectDescription>Pain felt anywhere between the chest and groin.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W102">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W102</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasWarningHeadline>Infantile hypertrophic pyloric stenosis (IHPS)</hasWarningHeadline>
    <hasWarningText>Following the use of azithromycin in neonates (treatment up to 42 days of life), infantile hypertrophic pyloric stenosis (IHPS) has been reported. Parents and caregiviers should contact physician if vomiting/irritability occurs.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP162">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP162</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R158"/>
    <hasStewardshipDescription>Do not share your nitrofurantoin with other people, even if they have similar symptoms. Using someone else's medicine can be unsafe and may contribute to ineffective treatment or antibiotic resistance.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#RenalTubularAcidosis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Renal Tubular Acidosis</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W030">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W030</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <hasWarningHeadline>Pregnancy</hasWarningHeadline>
    <hasWarningText>Pregnancy Category B: In the animal studies, no evidence of harm to the fetus due to azithromycin was found. There are, however, no adequate and well-controlled studies in pregnant women. Because animal reproduction studies are not always predictive of human response, azithromycin should be used during pregnancy only if clearly needed.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE343">
    <rdf:type rdf:resource="http://example.org/ontology#Dysphagia"/>
    <rdfs:label>dysphagia</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R171"/>
    <hasSideEffectDescription>difficulty swallowing</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I063">
    <rdf:type rdf:resource="http://example.org/ontology#ComplicatedUrinaryTractInfectionCUTI"/>
    <rdfs:label>Complicated Urinary Tract Infection (cUTI)</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R271"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
    <hasSymptoms>fever or chills, pain in the lower back or side, and overall malaise</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R265">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R265</rdfs:label>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <hasReferenceTitle>Upper Respiratory Infection (URI)</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</publishedIn>
    <retrievedFrom>https://my.clevelandclinic.org/health/diseases/4022-upper-respiratory-infection</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP172">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP172</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R163"/>
    <hasStewardshipDescription>Watch for side effects like lung problems, liver issues, or nerve problems, especially with long-term use.</hasStewardshipDescription>
  </rdf:Description>
