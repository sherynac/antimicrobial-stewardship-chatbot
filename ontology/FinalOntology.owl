  <rdf:Description rdf:about="http://example.org/ontology#SE002">
    <rdf:type rdf:resource="http://example.org/ontology#Nausea"/>
    <rdfs:label>Nausea</rdfs:label>
    <hasDurationOf>1-3 days</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Early_during_treatment"/>
    <hasReference rdf:resource="http://example.org/ontology#R022"/>
    <hasReference rdf:resource="http://example.org/ontology#R023"/>
    <hasSideEffectDescription>Feeling of sickness or upset stomach.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R236">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R236</rdfs:label>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <hasReferenceTitle>Cardiac Arrest</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</publishedIn>
    <retrievedFrom>https://my.clevelandclinic.org/health/diseases/21736-cardiac-arrest</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#DropInBloodPressure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Drop in Blood Pressure</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE658">
    <rdf:type rdf:resource="http://example.org/ontology#Palpitations"/>
    <rdfs:label>palpitations</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R237"/>
    <hasSideEffectDescription>can feel like pounding, flip-flopping or the wrong amount of heartbeats</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ncc9caf714a1e4eda918fdaa09880ac90b47">
    <rdf:first rdf:resource="http://example.org/ontology#GranulesForOralSuspension"/>
    <rdf:rest rdf:nodeID="ncc9caf714a1e4eda918fdaa09880ac90b48"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W264">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W264</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R163"/>
    <hasWarningHeadline>Renal Impairment</hasWarningHeadline>
    <hasWarningText>patients who have anuria, oliguria, or significant impairment of renal function (creatinine clearance under 60 mL per minute or clinically significant elevated serum creatinine) due to an increased risk of toxicity resulting from impaired excretion of the drug</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE570">
    <rdf:type rdf:resource="http://example.org/ontology#Constipation"/>
    <rdfs:label>constipation</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Common"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R208"/>
    <hasSideEffectDescription>passing fewer than three stools a week or having a difficult time passing stool</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S146">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Probenecid and cimetidine</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R010"/>
    <hasSubstanceDescription>drugs that affect the tubular renal secretion</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W103">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W103</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R031"/>
    <hasWarningHeadline>Gastronintestinal Effects</hasWarningHeadline>
    <hasWarningText>Nausea, vomiting, dizziness and confusion are likely symptoms of overdosage.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W069">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W069</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasWarningHeadline>Hepatotoxicity</hasWarningHeadline>
    <hasWarningText>Use with caution for patients with significant hepatic (liver) disease as cases of fulminant hepatitis leading to life-threatening liver failure have been reported with azithromycin. In case of signs and symptoms of liver dysfunction, such as rapid developing asthenia associated with jaundice, dark urine, bleeding tendency or hepatic encephalopathy. Azithromycin administration should be stopped if liver dysfunction has emerged.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S040">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Probenecid</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasSubstanceDescription>Medication often used for gout.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN255">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN255</rdfs:label>
    <hasClinicalEffects>Higher levels of Nitrofurantoin may build up in the blood, increasing the risk of side effects. At the same time, lower levels in the urine may reduce its ability to effectively kill bacteria in urinary tract infections.</hasClinicalEffects>
    <hasInteractionDescription>Probenecid reduces the kidney's ability to remove Nitrofurantoin from the body through urine. This causes the drug to stay longer in the bloodstream instead of being properly excreted into the urine where it is needed to treat infection.</hasInteractionDescription>
    <hasManagementAdvice>Avoid using together unless prescribed by a doctor. The healthcare provider may monitor closely for side effects or adjust the treatment if necessary.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <interactsWith rdf:resource="http://example.org/ontology#S174"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W162">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W162</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasWarningHeadline>Gastrointestinal and Mental Effects</hasWarningHeadline>
    <hasWarningText>Symptoms include abdominal pain, nausea, vomiting, and diarrhea. High doses (8g) may cause altered mental status and paranoid behavior.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R249">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R249</rdfs:label>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <hasReferenceTitle>Hives</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2022</publishedIn>
    <retrievedFrom>https://my.clevelandclinic.org/health/diseases/8630-hives</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W163">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W163</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasWarningHeadline>Allergic Reactions and Dangerous Combinations</hasWarningHeadline>
    <hasWarningText>Contraindicated for patients with known hypersensitivity to macrolides or history of drug-induced hepatic dysfunction. Also contraindicated with drugs like cisapride, simvastatin, or lovastatin.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE198">
    <rdf:type rdf:resource="http://example.org/ontology#Hypoglycaemia"/>
    <rdfs:label>Hypoglycaemia</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R292"/>
    <hasSideEffectDescription>Hypoglycemia (low blood sugar) is common in people who have diabetes. But it can also sometimes affect people without diabetes.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN045">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN045</rdfs:label>
    <hasInteractionDescription>Cotrimoxazole has been shown to potentiate activity of strongly serum protein-bound drugs like oral hypoglycaemic or anticoagulant.</hasInteractionDescription>
    <hasManagementAdvice>Monitor for enhanced drug effects and adjust doses as needed.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R031"/>
    <interactsWith rdf:resource="http://example.org/ontology#S033"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Occasional_during_use">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Occasional during use</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP078">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP078</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasStewardshipDescription>Monitor for superinfections during prolonged use and observe for renal output in overdose cases.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE051">
    <rdf:type rdf:resource="http://example.org/ontology#Nephritis"/>
    <rdfs:label>Nephritis</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <hasReference rdf:resource="http://example.org/ontology#R061"/>
    <hasSideEffectDescription>Minor side effect; inflammation of one or both kidneys, which can leak protein into urine and impair the body's ability to absorb water and lead to tissue swelling</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN150">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN150</rdfs:label>
    <hasClinicalEffects>Not explicitly detailed but implies increased toxicity.</hasClinicalEffects>
    <hasInteractionDescription>Concomitant administration.</hasInteractionDescription>
    <hasManagementAdvice>Contraindicated.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R020"/>
    <interactsWith rdf:resource="http://example.org/ontology#S124"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE379">
    <rdf:type rdf:resource="http://example.org/ontology#Maculopapular"/>
    <rdfs:label>maculopapular</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#common"/>
    <hasReference rdf:resource="http://example.org/ontology#R013"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R174"/>
    <hasSideEffectDescription>discolored areas of skin (macules) and elevated lesions (papules)</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Early_during_treatment">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Early during treatment</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasWarning">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has warning</rdfs:label>
    <rdfs:domain rdf:nodeID="ncc9caf714a1e4eda918fdaa09880ac90b24"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Warning"/>
    <owl:propertyChainAxiom rdf:nodeID="ncc9caf714a1e4eda918fdaa09880ac90b27"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE249">
    <rdf:type rdf:resource="http://example.org/ontology#HematologicAndLymphaticSystems"/>
    <rdfs:label>Hematologic and Lymphatic Systems</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasSideEffectDescription>Includes anemia, thrombocytopenia, and leukopenia; resolves after stopping therapy.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W203">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W203</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasWarningHeadline>Lactation</hasWarningHeadline>
    <hasWarningText>Levofloxacin has not been measured in human milk. However, based on the ofloxacin data, it can be presumed that levofloxacin will be excreted in human milk. Therefore, a decision should be made whether to discontinue breastfeeding or to discontinue the drug, taking into account the importance of the drug to the mother as well as the possible serious adverse effects to the infant.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE235">
    <rdf:type rdf:resource="http://example.org/ontology#AcuteGeneralisedExanthematousPustulosis"/>
    <rdfs:label>acute&#13;
generalised exanthematous pustulosis</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R311"/>
    <hasSideEffectDescription>Acute generalized exanthematous pustulosis (AGEP) comprises a severe cutaneous adverse reaction marked by the abrupt onset of sterile, nonfollicular pinpoint pustules on an erythematous base. Drug exposure, most frequently systemic antibiotics, is the primary cause, although viral infections and environmental triggers have also been implicated. Genetic predisposition, advanced age, and comorbid immune dysregulation are considered risk factors. AGEP is most often attributed to a type IV hypersensitivity mechanism involving drug-specific T cells, neutrophil activation, and cytokine release, although the pathophysiology remains incompletely characterized.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Zolmed">
    <rdf:type rdf:resource="http://example.org/ontology#Brand"/>
    <rdfs:label>Zolmed</rdfs:label>
    <hasPresentation rdf:resource="http://example.org/ontology#A036"/>
    <hasPresentation rdf:resource="http://example.org/ontology#A055"/>
    <hasPresentation rdf:resource="http://example.org/ontology#A056"/>
    <hasReference rdf:resource="http://example.org/ontology#R166"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R128">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R128</rdfs:label>
    <hasAuthor>Monthly Index of Medical Specialties</hasAuthor>
    <hasReferenceTitle>RiteMed Cefixime</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</publishedIn>
    <retrievedFrom>https://www.mims.com/philippines/drug/info/ritemed-cefixime</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R267">
