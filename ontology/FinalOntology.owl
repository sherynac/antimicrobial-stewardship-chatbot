  <rdf:Description rdf:about="http://example.org/ontology#ITN049">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN049</rdfs:label>
    <hasClinicalEffects>None specifically reported in the dedicated drug interaction study.</hasClinicalEffects>
    <hasInteractionDescription>Concurrent use of warfarin and azithromycin may potentiate the effects of oral anticoagulants.</hasInteractionDescription>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <hasManagementAdvice>Prothrombin time should be carefully monitored while patients are receiving azithromycin and oral anticoagulants concurrently</hasManagementAdvice>
    <interactsWith rdf:resource="http://example.org/ontology#S018"/>
  </rdf:Description>
