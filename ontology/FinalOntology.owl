    <rdfs:label>Infusion Site Reaction</rdfs:label>
    <hasDurationOf>Short-term</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Rare__may_happen"/>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasSideEffectDescription>Pain, redness, or swelling at IV site; usually mild.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R223">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R223</rdfs:label>
    <hasAuthor>Mayo Clinic</hasAuthor>
    <hasReferenceTitle>Hypoglycemia</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2023</publishedIn>
