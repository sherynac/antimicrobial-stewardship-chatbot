    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#two_months_after_the_administration_of_antibacterial_agents_"/>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
