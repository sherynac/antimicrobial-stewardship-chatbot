    <hasSymptoms>A bad cough that lasts 3 weeks or longer, pain in the chest, coughing up blood or sputum (phlegm) from deep inside the lungs</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN027">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN027</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasManagementAdvice>Take the drug 2 hours before of after consuming dairy.</hasManagementAdvice>
    <hasInteractionDescription>Dairy products can interfere with absorption.</hasInteractionDescription>
    <hasClinicalEffects>Reduced drug effectiveness.</hasClinicalEffects>
    <interactsWith rdf:resource="http://example.org/ontology#S021"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R226">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
