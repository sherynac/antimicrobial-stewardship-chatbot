    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Warfarin and other anticoagulants</rdfs:label>
    <hasSubstanceDescription>are a family of medications that stop your blood from clotting too easily.</hasSubstanceDescription>
    <hasReference rdf:resource="http://example.org/ontology#R154"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#FallInProthrombinActivity">
