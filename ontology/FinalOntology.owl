  <rdf:Description rdf:about="http://example.org/ontology#ITN241">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN241</rdfs:label>
    <hasClinicalEffects>Increased prothrombin time, with or without clinical bleeding, has been reported when cefixime is given concomitantly.</hasClinicalEffects>
    <hasInteractionDescription>Increased prothrombin time, with or without clinical bleeding, has been reported when cefixime is given concomitantly.</hasInteractionDescription>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
