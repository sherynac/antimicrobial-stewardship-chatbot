  <rdf:Description rdf:about="http://example.org/ontology#SE408">
    <rdf:type rdf:resource="http://example.org/ontology#HypersensitivityReactions"/>
    <rdfs:label>Hypersensitivity Reactions</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Following_the_first_dose"/>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasSideEffectDescription>Cardiovascular collapse, hypotension/shock, seizure, loss of consciousness, tingling, angioedema (including tongue, laryngeal, throat, or facial edema/swelling), airway obstruction (including bronchospasm, shortness of breath, and acute respiratory distress), dyspnea, urticaria, itching, and other serious skin reactions. Levofloxacin should be discontinued immediately at the first appearance of a skin rash or any other sign of hypersensitivity</hasSideEffectDescription>
  </rdf:Description>
