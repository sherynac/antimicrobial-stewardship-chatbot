    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R058"/>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasSideEffectDescription>Pain felt anywhere between the chest and groin.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ncc9caf714a1e4eda918fdaa09880ac90b20">
