    <rdfs:label>Bacteriostatic Agents</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R016"/>
    <hasSubstanceDescription>e.g., Tetracyclines, Macrolides</hasSubstanceDescription>
