  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W087">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W087</rdfs:label>
    <hasWarningText>Antibiotic use may cause mild to life-threatening pseudomembranous colitis. Discontinue if prolonged or significant diarrhea or abdominal cramps occur.</hasWarningText>
    <hasWarningHeadline>Pseudomembranous Colitis</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Rare__more_likely_with_long-term_use">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Rare; more likely with long-term use</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE590">
    <rdf:type rdf:resource="http://example.org/ontology#AbnormalDreaming"/>
    <rdfs:label>abnormal dreaming</rdfs:label>
    <hasSideEffectDescription>pattern of repeated frightening and vivid dreams that affects your quality of life</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R228"/>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN203">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN203</rdfs:label>
    <interactsWith rdf:resource="http://example.org/ontology#S088"/>
    <hasClinicalEffects>Elevated serum theophylline levels and increased risk of a patient developing CNS or other adverse reactions.</hasClinicalEffects>
    <hasInteractionDescription>Concomitant administration of ciprofloxacin with theophylline decreases the clearance of theophylline</hasInteractionDescription>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE469">
    <rdf:type rdf:resource="http://example.org/ontology#Tremor"/>
    <rdfs:label>Tremor</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasReference rdf:resource="http://example.org/ontology#R123"/>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasSideEffectDescription>type of body movement that’s out of your control. It looks like shakiness and can affect many different body parts.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#UncomplicatedGonorrhea">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#UrinaryDisease"/>
    <rdfs:label>Uncomplicated Gonorrhea</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE678">
    <rdf:type rdf:resource="http://example.org/ontology#CentralNervousSystemEffects"/>
    <rdfs:label>Central Nervous System Effects</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>Reversable hyperactivity, agitation, anxiety, insomnia, confusion, behavioral changes, and/or dizziness.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W043">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W043</rdfs:label>
    <hasWarningHeadline>Geriatric Use</hasWarningHeadline>
    <hasWarningText>Elderly patients are more likely to have decreased cardiac and renal function, care should be taken in dose selection, and electrolytes, fluid status, and renal function should be monitored. Dosage adjustment in elderly patients should take into account renal function</hasWarningText>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W278">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W278</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R166"/>
    <hasWarningHeadline>Sulfite-Related Allergic and Anaphylactic Reactions</hasWarningHeadline>
    <hasWarningText>Sodium metabisulfite contains a sulfite that may cause allergic type reactions,
including anaphylactic symptoms and life threatening or less severe asthmatic
episode in certain susceptible persons.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN256">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN256</rdfs:label>
    <interactsWith rdf:resource="http://example.org/ontology#S175"/>
    <hasManagementAdvice>Use with caution and only under medical supervision. Report any unusual side effects or persistent infection symptoms.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasInteractionDescription>Sulfinpyrazone also decreases the excretion of Nitrofurantoin by the kidneys. This changes the normal balance of the drug in the body.</hasInteractionDescription>
    <hasClinicalEffects>Increased blood levels may raise the chance of side effects, while decreased urinary levels may reduce the drug's effectiveness in treating urinary infections.</hasClinicalEffects>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R312">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R312</rdfs:label>
    <hasAuthor>National Institutes of Health</hasAuthor>
    <retrievedFrom>https://www.ncbi.nlm.nih.gov/books/NBK559142/</retrievedFrom>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</publishedIn>
    <hasReferenceTitle>Acute Febrile Neutrophilic Dermatosis</hasReferenceTitle>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE158">
    <rdf:type rdf:resource="http://example.org/ontology#Photosensitivity"/>
    <rdfs:label>Photosensitivity</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <hasReference rdf:resource="http://example.org/ontology#R063"/>
    <hasSideEffectDescription>Skin reacts negatively to sunlight or UV rays that causes an itchy, painful rash</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN118">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN118</rdfs:label>
    <interactsWith rdf:resource="http://example.org/ontology#S092"/>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <hasManagementAdvice>Avoid combination if possible.</hasManagementAdvice>
    <hasClinicalEffects>Reported colchicine toxicity, especially in the elderly.</hasClinicalEffects>
    <hasInteractionDescription>Concurrent use.</hasInteractionDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN233">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN233</rdfs:label>
    <hasInteractionDescription>Elevated carbamazepine levels</hasInteractionDescription>
    <hasClinicalEffects>Not Specified</hasClinicalEffects>
    <hasManagementAdvice>Drug monitoring when these drugs are given together is advised.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R128"/>
    <interactsWith rdf:resource="http://example.org/ontology#S161"/>
  </rdf:Description>
