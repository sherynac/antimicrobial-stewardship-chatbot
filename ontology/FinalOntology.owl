    <hasSeverityType rdf:resource="http://example.org/ontology#Severe"/>
    <hasSymptoms>Cough, fever, shortness of breath, chest pain, thick mucus</hasSymptoms>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
