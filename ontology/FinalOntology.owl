  <rdf:Description rdf:about="http://example.org/ontology#SE251">
    <rdf:type rdf:resource="http://example.org/ontology#InjectionSiteReaction"/>
    <rdfs:label>Injection Site Reaction</rdfs:label>
    <hasDurationOf>5 days</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#During_or_immediately_after_administration"/>
    <hasReference rdf:resource="http://example.org/ontology#R032"/>
    <hasReference rdf:resource="http://example.org/ontology#R322"/>
    <hasSideEffectDescription>Pain, swelling, or redness at the site where the medicine was injected.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W124">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W124</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasWarningHeadline>Toxicity Management</hasWarningHeadline>
    <hasWarningText>May cause nausea, vomiting, diarrhea, crystalluria, and allergic manifestations. Symptomatic treatment is required for almost all patients. Problems are unlikely if adequate fluid intake and urinary output are maintained; however crystalluria and hemorrhagic cystitis are possible.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP080">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP080</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R016"/>
    <hasStewardshipDescription>Usual duration is 5 to 14 days. Continue treatment for at least 48 to 72 hours after becoming asymptomatic. Take for at least 10 days for β-hemolytic streptococcal infections to prevent rheumatic fever.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W134">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W134</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasWarningText>Strictly prohibited for patients with a history of hypersensitivity to penicillins or any ingredient in the product.</hasWarningText>
  </rdf:Description>
