    <hasSideEffectDescription>Reversable hyperactivity, agitation, anxiety, insomnia, confusion, behavioral changes, and/or dizziness.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE665">
    <rdf:type rdf:resource="http://example.org/ontology#Gastroenteritis"/>
