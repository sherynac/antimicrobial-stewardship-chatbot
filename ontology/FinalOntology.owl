  <rdf:Description rdf:about="http://example.org/ontology#SE223">
    <rdf:type rdf:resource="http://example.org/ontology#JaundiceCholestatic"/>
    <rdfs:label>Jaundice cholestatic</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R305"/>
    <hasSideEffectDescription>Cholestatic jaundice results from impaired bile flow, accumulating bile components, such as bilirubin, in the bloodstream. This condition can be classified as intrahepatic, caused by issues within the liver, or extrahepatic, resulting from obstructions outside the liver. Common clinical manifestations include jaundice, pruritus, fatigue, malabsorption of fats and fat-soluble vitamins, and the appearance of skin lesions such as xanthomas.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S087">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
