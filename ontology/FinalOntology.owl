    <hasReference rdf:resource="http://example.org/ontology#R024"/>
    <hasStewardshipDescription>Only a single oral dose is recommended. Repeating daily doses does not improve effectiveness and increases side effects.</hasStewardshipDescription>
  </rdf:Description>
