    <hasPattern rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasSideEffectDescription>A skin reaction (hives)</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W047">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W047</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R029"/>
    <hasWarningHeadline>Kidney Function</hasWarningHeadline>
    <hasWarningText>Reduced kidney function may affect dosing and effectiveness of this medication, and whether any special monitoring is needed.</hasWarningText>
  </rdf:Description>
