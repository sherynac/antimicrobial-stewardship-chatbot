    <hasPattern rdf:resource="http://example.org/ontology#Rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasSideEffectDescription>Moderate rise in aminotransferase and/or alanine aminotransferase enzymes.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN182">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN182</rdfs:label>
    <hasClinicalEffects>systemic levels considerably lower than desired</hasClinicalEffects>
    <hasInteractionDescription>Interfere with the gastrointestinal absorption of levofloxacin</hasInteractionDescription>
    <hasManagementAdvice>These agents should be taken at least 2 hours before or 2 hours after levofloxacin administration.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <interactsWith rdf:resource="http://example.org/ontology#S140"/>
  </rdf:Description>
