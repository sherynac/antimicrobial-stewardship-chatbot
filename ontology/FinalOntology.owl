    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <hasSideEffectDescription>Diarrhea (usually mild), Nausea, Vomiting, or Stomach pain/cramping.</hasSideEffectDescription>
  </rdf:Description>
