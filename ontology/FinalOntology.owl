    <hasWarningHeadline>Clostridioides difficile-Associated Diarrhea (CDAD)</hasWarningHeadline>
    <hasWarningText>This has been reported with nearly all systemic antibacterial agents, including CONTEPO. Evaluate patients if diarrhea occurs.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN108">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
