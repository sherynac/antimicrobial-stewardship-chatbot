    <hasReference rdf:resource="http://example.org/ontology#R059"/>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <hasSideEffectDescription>Feeling like your heart is missing heartbeats, racing or pounding felt in chest, throat or neck; Pain felt between neck and belly</hasSideEffectDescription>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  </rdf:Description>
