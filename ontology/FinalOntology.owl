  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE338">
    <rdf:type rdf:resource="http://example.org/ontology#Diarrhea"/>
    <rdfs:label>diarrhea</rdfs:label>
    <hasDurationOf>2 months or more</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#infrequent"/>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasSideEffectDescription>May occur after a patient stop taking doxycycline</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN140">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN140</rdfs:label>
    <hasClinicalEffects>The overall extent of absorption remains unaffected.</hasClinicalEffects>
    <hasInteractionDescription>Delays the onset of absorption and increases the peak time (tmax​) from 2 to 2.5 hours.</hasInteractionDescription>
    <hasManagementAdvice>May be taken with or without food.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <interactsWith rdf:resource="http://example.org/ontology#S114"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP103">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP103</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R020"/>
    <hasStewardshipDescription>Monitor for signs of hepatic failure, especially in those with pre-existing liver disease. Also, monitor for the development of drug-resistant organisms during H. pylori therapy.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE531">
    <rdf:type rdf:resource="http://example.org/ontology#PulmonaryProblems"/>
    <rdfs:label>Pulmonary Problems</rdfs:label>
    <hasDurationOf>Weeks to Months</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Rare__more_likely_with_long-term_use"/>
    <hasReference rdf:resource="http://example.org/ontology#R162"/>
    <hasSideEffectDescription>Trouble breathing, cough, chest pain; can be serious.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S054">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Methotrexate</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasSubstanceDescription>Antifolate chemotherapy/immunosuppressant</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE404">
    <rdf:type rdf:resource="http://example.org/ontology#PeripheralNeuropathy"/>
    <rdfs:label>Peripheral Neuropathy</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasSideEffectDescription>Paresthesias, hypoesthesias, dysesthesias and weakness</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE555">
    <rdf:type rdf:resource="http://example.org/ontology#ErythemaMultiforme"/>
    <rdfs:label>Erythema Multiforme</rdfs:label>
    <hasDurationOf>Duration varies; may resolve after stopping the drug</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Rare_skin_reaction_during_use"/>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasSideEffectDescription>A skin condition causing red patches, spots, or blister-like lesions on the skin. It may be mild or severe.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN204">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN204</rdfs:label>
    <hasClinicalEffects>Elevated serum theophylline levels and increased risk of a patient developing CNS or other adverse reactions.</hasClinicalEffects>
    <hasInteractionDescription>Concomitant administration of ciprofloxacin with theophylline decreases the clearance of theophylline</hasInteractionDescription>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <interactsWith rdf:resource="http://example.org/ontology#S088"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I002">
    <rdf:type rdf:resource="http://example.org/ontology#AcuteBacterialExacerbationsOfCOPD"/>
    <rdfs:label>Mild to Moderate Acute Bacterial Exacerbations of COPD</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <hasReference rdf:resource="http://example.org/ontology#R040"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#MildToModerate"/>
    <hasSymptoms>increased wheezing, fever without another identified cause, or an increase in heart rate or respiratory rate greater than 20% from baseline.</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE382">
    <rdf:type rdf:resource="http://example.org/ontology#Urticaria"/>
    <rdfs:label>urticaria</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#frequency_not_reported"/>
    <hasReference rdf:resource="http://example.org/ontology#R013"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R181"/>
    <hasSideEffectDescription>Hives (also called urticaria) refers to raised and splotchy areas of skin that can be caused by an allergic reaction to something</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE022">
    <rdf:type rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Pharyngitis</rdfs:label>
    <hasDurationOf>1-3 days</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R024"/>
    <hasSideEffectDescription>Sore throat or mild irritation in the throat.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R151">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R151</rdfs:label>
    <hasAuthor>Maan J. S. et al.</hasAuthor>
    <hasReferenceTitle>Carbamazepine</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2023</publishedIn>
    <retrievedFrom>https://www.ncbi.nlm.nih.gov/books/NBK482455/</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W191">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W191</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasWarningHeadline>Renal insufficiency</hasWarningHeadline>
    <hasWarningText>Levofloxacin should be administered with caution in the presence of renal insufficiency. Careful clinical observation and appropriate laboratory studies should be performed prior to and during therapy since elimination of levofloxacin may be reduced. In patients with impaired renal function (creatinine clearance&lt;50 mL/min), adjustment of dose regimen is necessary to avoid the accumulation of levofloxacin due to decreased clearance.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S123">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Ergot alkaloids (e.g., Ergotamine)</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R020"/>
    <hasSubstanceDescription>Migraine medications.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN100">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN100</rdfs:label>
    <hasClinicalEffects>Reduced efficacy of combined oral contraceptives.</hasClinicalEffects>
    <hasInteractionDescription>Effect on gut flora.</hasInteractionDescription>
    <hasManagementAdvice>Be aware of potential for reduced birth control effectiveness</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R016"/>
    <interactsWith rdf:resource="http://example.org/ontology#S074"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R059">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R059</rdfs:label>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <hasReferenceTitle>Heart Palpitations</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2022</publishedIn>
    <retrievedFrom>https://my.clevelandclinic.org/health/diseases/17084-heart-palpitations</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE137">
    <rdf:type rdf:resource="http://example.org/ontology#StevensJohnsonSyndrome"/>
    <rdfs:label>Stevens-Johnson Syndrome</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R034"/>
    <hasSideEffectDescription>Stevens-Johnson syndrome (SJS) is a rare, serious disorder of the skin and mucous membranes. It's usually a reaction to medication that starts with flu-like symptoms, followed by a painful rash that spreads and blisters. Then the top layer of affected skin dies, sheds and begins to heal after several days.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W217">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W217</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasWarningHeadline>Epileptic, history of Central Nervous System (CNS) disorders, myastenia gravis and glucose-6-phosphate dehydrogenase deficiency</hasWarningHeadline>
    <hasWarningText>Caution should be taken when giving ciprofloxacin to epileptic patients and to those with history of Central Nervous System (CNS) disorders, myasthenia gravis and glucose-6-phosphate dehydrogenase deficiency.; Ciprofloxacin may exacerbate or unmask symptoms of myasthenia gravis.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP144">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP144</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasStewardshipDescription>In the event of acute overdosage, reversible renal toxicity has been reported in some cases. It is recommended to monitor renal function and to administer magnesium- or calcium-containing antacids which reduce the absorption of ciprofloxacin.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S144">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Sucralfate</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R010"/>
    <hasSubstanceDescription>Sucralfate tablet</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Interaction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="ncc9caf714a1e4eda918fdaa09880ac90b66"/>
    <rdfs:subClassOf rdf:nodeID="ncc9caf714a1e4eda918fdaa09880ac90b67"/>
    <owl:disjointWith rdf:resource="http://example.org/ontology#Indication"/>
    <owl:disjointWith rdf:resource="http://example.org/ontology#Pattern"/>
    <owl:disjointWith rdf:resource="http://example.org/ontology#Severity"/>
    <owl:disjointWith rdf:resource="http://example.org/ontology#SideEffect"/>
    <owl:disjointWith rdf:resource="http://example.org/ontology#Warning"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE571">
    <rdf:type rdf:resource="http://example.org/ontology#AbdominalPain"/>
    <rdfs:label>abdominal pain</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Common"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R209"/>
    <hasSideEffectDescription>stomachache</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE617">
    <rdf:type rdf:resource="http://example.org/ontology#Arthralgia"/>
    <rdfs:label>arthralgia</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R250"/>
    <hasSideEffectDescription>joint pain that can be felt in the joints throughout your body</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN047">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN047</rdfs:label>
    <hasInteractionDescription>Comazole also may inhibit the hepatic metabolism of phenytoin. A 39% increase in phenytoin half-life and 27% decrease in the metabolic clearance rate of phenytoin have been observed following administration of Comazole of normal clinical dosages. If these two drugs are given concurrently it is important to remain alert for signs of phenytoin toxicity.</hasInteractionDescription>
    <hasManagementAdvice>Monitor serum phenytoin levels and signs of toxicity. Dose adjustment may be required.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R031"/>
    <interactsWith rdf:resource="http://example.org/ontology#S035"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP146">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP146</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R091"/>
    <hasStewardshipDescription>Patients receiving Ciprofloxacin must be well hydrated to prevent crystalluria. Excessive alkalinisation of urine should be avoided.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasSeverityType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has severity type</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Indication"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Severity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP054">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP054</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R014"/>
    <hasStewardshipDescription>Store at temperatures not exceeding 30°C</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP014">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP014</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <hasStewardshipDescription>Use IV fosfomycin only for confirmed or strongly suspected bacterial infections. It should not be used for viral infections.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W231">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W231</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R127"/>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasWarningText>Hypersensitivity to penicillins.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W259">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W259</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R160"/>
    <hasWarningHeadline>Over Use</hasWarningHeadline>
    <hasWarningText>Taking too much can cause severe nausea, vomiting, stomach pain, or other serious health problems; seek medical help immediately.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R201">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R201</rdfs:label>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <hasReferenceTitle>Jarisch–Herxheimer Reaction</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</publishedIn>
    <retrievedFrom>https://my.clevelandclinic.org/health/diseases/herxheimer-reaction</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R193">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R193</rdfs:label>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <hasReferenceTitle>Idiopathic Intracranial Hypertension</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</publishedIn>
    <retrievedFrom>https://my.clevelandclinic.org/health/diseases/21968-idiopathic-intracranial-hypertension</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP181">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP181</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasStewardshipDescription>Keep in the pack until required.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#HepaticNecrosis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Hepatic Necrosis</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I027">
    <rdf:type rdf:resource="http://example.org/ontology#ChronicBronchitis"/>
    <rdfs:label>Chronic Bronchitis</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <hasReference rdf:resource="http://example.org/ontology#R020"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE534">
    <rdf:type rdf:resource="http://example.org/ontology#LossOfAppetite"/>
    <rdfs:label>Loss of Appetite</rdfs:label>
    <hasDurationOf>Few days</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Can_appear_anytime_during_use"/>
    <hasReference rdf:resource="http://example.org/ontology#R163"/>
    <hasReference rdf:resource="http://example.org/ontology#R164"/>
    <hasSideEffectDescription>Not feeling hungry.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W274">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W274</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasWarningHeadline>Elderly</hasWarningHeadline>
    <hasWarningText>Elderly patients using this medicine for a long time should have their liver and lung function checked regularly. Older adults may be more sensitive to possible side effects affecting the lungs of liver.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN092">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN092</rdfs:label>
    <hasClinicalEffects>Increased drug levels or potentiation, hypoglycemia, toxicity</hasClinicalEffects>
    <hasInteractionDescription>Trimethoprim is an inhibitor of CYP2C8 as well as an OCT2 transporter. Sulfamethoxazole is an inhibitor of CYP2C9. Caution is recommended when DBL Sulfamethoxazole 400 mg and Trimethoprim 80 mg is co-administered with drugs that are substrates of CYP2C8 and 2C9 or OCT2. Sulfamethoxazole/trimethoprim potentiates the effect of oral hypoglycaemics that are metabolised by CYP2C8 (e.g. pioglitazone, repaglinide, and rosiglitazone) or CYP2C9 (e.g. glipizide and glyburide) or eliminated renally via OCT2 (e.g. metformin). Additional monitoring of blood glucose may be warranted.</hasInteractionDescription>
    <hasManagementAdvice>Monitor for altered effects. Adjust therapy based on response.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <interactsWith rdf:resource="http://example.org/ontology#S066"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN188">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN188</rdfs:label>
    <hasClinicalEffects>Incerase half-life</hasClinicalEffects>
    <hasInteractionDescription>The half-life of ciclosporin was increased by 33%</hasInteractionDescription>
    <hasReference rdf:resource="http://example.org/ontology#R010"/>
    <interactsWith rdf:resource="http://example.org/ontology#S147"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Macrobid">
    <rdf:type rdf:resource="http://example.org/ontology#Brand"/>
    <rdfs:label>Macrobid</rdfs:label>
    <hasPresentation rdf:resource="http://example.org/ontology#A051"/>
    <hasReference rdf:resource="http://example.org/ontology#R156"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN169">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN169</rdfs:label>
    <hasClinicalEffects>Decreased absorption</hasClinicalEffects>
    <hasInteractionDescription>phenytoin decrease the half-life of doxycycline</hasInteractionDescription>
    <hasManagementAdvice>Avoid taking together</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <interactsWith rdf:resource="http://example.org/ontology#S101"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN046">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN046</rdfs:label>
    <hasInteractionDescription>It has been reported that comazole may displace the anticoagulant warfarin. Careful control of the anticoagulant therapy during treatment with Comazole is advisable.</hasInteractionDescription>
    <hasManagementAdvice>Monitor INR closely and reduce warfarin dose if necessary.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R031"/>
    <interactsWith rdf:resource="http://example.org/ontology#S034"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE032">
    <rdf:type rdf:resource="http://example.org/ontology#Rash"/>
    <rdfs:label>Rash</rdfs:label>
    <hasDurationOf>Temporary</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Can_occur_during_treatment"/>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <hasSideEffectDescription>Skin redness or itching due to allergic reaction.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasStewardshipDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>has stewardship description</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#StewardshipPrinciple"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE352">
    <rdf:type rdf:resource="http://example.org/ontology#Maculopapular"/>
    <rdfs:label>maculopapular</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#common"/>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R174"/>
    <hasSideEffectDescription>discolored areas of skin (macules) and elevated lesions (papules)</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE244">
    <rdf:type rdf:resource="http://example.org/ontology#HypersensitivityReactions"/>
    <rdfs:label>Hypersensitivity Reactions</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Fairly_Frequent"/>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
