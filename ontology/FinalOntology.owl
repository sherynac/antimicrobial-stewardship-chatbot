    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasSideEffectDescription>Minor side effect; false sensation of motion such as spinning or swaying</hasSideEffectDescription>
  </rdf:Description>
