    <rdfs:label>R267</rdfs:label>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <hasReferenceTitle>Urinary Tract Infections</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2023</publishedIn>
    <retrievedFrom>https://my.clevelandclinic.org/health/diseases/9135-urinary-tract-infections</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#IncreasedEosinophilCountBasophilsMonocytesAndNeutrophils">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Increased Eosinophil Count, Basophils, Monocytes and Neutrophils</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W224">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W224</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R133"/>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasWarningText>Should not be used if patient has a history of allergy or hypersensitivity to cephalosporins</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#OtherSeriousAndSometimesFatalReactions">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Other Serious and Sometimes Fatal Reactions</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP061">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP061</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasStewardshipDescription>Monitor for common side effects such as skin rash, nausea, and diarrhea. If taking anticoagulants, prothrombin time or INR should be carefully monitored when starting or stopping treatment.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R044">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R044</rdfs:label>
    <hasAuthor>National Library of Medicine</hasAuthor>
    <hasReferenceTitle>Urethritis</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2024</publishedIn>
    <retrievedFrom>https://medlineplus.gov/ency/article/000439.htm</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE603">
    <rdf:type rdf:resource="http://example.org/ontology#VentricularTachycardia"/>
    <rdfs:label>ventricular tachycardia</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R238"/>
    <hasSideEffectDescription>fast, abnormal heart rhythm (arrhythmia) that comes from atypical electrical signals in your heart’s lower chambers</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP082">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP082</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R016"/>
    <hasStewardshipDescription>Maintain adequate fluid intake and urinary output to reduce the possibility of crystalluria. Periodic assessment of renal, hepatic, and hematopoietic functions is recommended during prolonged therapy.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN258">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN258</rdfs:label>
    <hasClinicalEffects>The combined use may decrease the overall antibacterial action, leading to reduced treatment effectiveness and possible treatment failure.</hasClinicalEffects>
    <hasInteractionDescription>Quinolone antibacterials may have antagonistic effects when used together with Nitrofurantoin. This means the medicines may reduce each other's effectiveness.</hasInteractionDescription>
    <hasManagementAdvice>Avoid combining these antibiotics unless specifically directed by a physician. Follow medical advice carefully.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <interactsWith rdf:resource="http://example.org/ontology#S177"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Glossitis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Glossitis</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN192">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN192</rdfs:label>
    <hasClinicalEffects>If azithromycin and P-gp substrates are administered concomitantly, the possibility of eleventaed serum concentrations of the subtrate should be considered</hasClinicalEffects>
    <hasInteractionDescription>Concomitant administration with macrolide antibiotics, including azithromycin result in increased serum levels of the P-glycoprotein substrate</hasInteractionDescription>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <interactsWith rdf:resource="http://example.org/ontology#S092"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#AcuteBacterialExacerbationOfChronicBronchitis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Acute Bacterial Exacerbation Of Chronic Bronchitis</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#RespiratoryDisease"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#AbdominalPain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Abdominal Pain</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Fosfomycin_Tromethamine">
    <rdf:type rdf:resource="http://example.org/ontology#Brand"/>
    <rdfs:label>Fosfomycin Tromethamine</rdfs:label>
    <hasPresentation rdf:resource="http://example.org/ontology#A026"/>
