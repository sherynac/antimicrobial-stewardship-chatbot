    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP081</rdfs:label>
    <hasStewardshipDescription>Store in a dry place at temperatures not exceeding 30°C. Protect from light to ensure optimal shelf-life.</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R016"/>
  </rdf:Description>
