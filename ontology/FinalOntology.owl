    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R176"/>
    <hasSideEffectDescription>redness and scaling of the skin</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP055">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP055</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R014"/>
    <hasStewardshipDescription>Protect from light</hasStewardshipDescription>
  </rdf:Description>
