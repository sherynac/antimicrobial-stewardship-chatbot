    <hasReference rdf:resource="http://example.org/ontology#R221"/>
    <hasSideEffectDescription>immune system overreacts to something that’s usually not harmful — like pollen, pet dander and certain foods</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN159">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN159</rdfs:label>
    <hasClinicalEffects>Can result in significant hypoglycemia (low blood sugar)</hasClinicalEffects>
    <hasInteractionDescription>Concomitant use with clarithromycin</hasInteractionDescription>
    <hasManagementAdvice>Careful monitoring of blood glucose levels is recommended.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <interactsWith rdf:resource="http://example.org/ontology#S133"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE135">
    <rdf:type rdf:resource="http://example.org/ontology#StevensJohnsonSyndrome"/>
    <rdfs:label>Stevens-Johnson Syndrome</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R034"/>
    <hasSideEffectDescription>Stevens-Johnson syndrome (SJS) is a rare, serious disorder of the skin and mucous membranes. It's usually a reaction to medication that starts with flu-like symptoms, followed by a painful rash that spreads and blisters. Then the top layer of affected skin dies, sheds and begins to heal after several days.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE217">
    <rdf:type rdf:resource="http://example.org/ontology#Nausea"/>
    <rdfs:label>Nausea</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Common"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R204"/>
    <hasSideEffectDescription>Nausea can make it feel like your stomach is ready to do somersaults, sending whatever’s inside right back up and out.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#LegionnairesDisease">
