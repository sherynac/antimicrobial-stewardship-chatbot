  <rdf:Description rdf:about="http://example.org/ontology#SE228">
    <rdf:type rdf:resource="http://example.org/ontology#PhotosensitivityReaction"/>
    <rdfs:label>Photosensitivity reaction</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R063"/>
    <hasSideEffectDescription>Photosensitivity is when your skin reacts negatively to sunlight or UV rays. It causes an itchy, painful rash. Unlike a sunburn, symptoms can appear within minutes.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE385">
    <rdf:type rdf:resource="http://example.org/ontology#AnaphylactoidPurpura"/>
