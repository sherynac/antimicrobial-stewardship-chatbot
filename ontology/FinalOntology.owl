  <rdf:Description rdf:about="http://example.org/ontology#ITN236">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN236</rdfs:label>
    <hasClinicalEffects>Concomitant administration of probenecid reportedly increases Cmax and AUC of cefixime and decreases renal clearance and volume of distribution of the drug.</hasClinicalEffects>
    <hasInteractionDescription>Increases Cmax and AUC of cefixime and decreases renal clearance and volume of distribution of the drug.</hasInteractionDescription>
    <interactsWith rdf:resource="http://example.org/ontology#S028"/>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R128"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Arrhythmias">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Arrhythmias</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE459">
    <rdf:type rdf:resource="http://example.org/ontology#Restlessness"/>
    <rdfs:label>Restlessness</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasReference rdf:resource="http://example.org/ontology#R115"/>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>pacing, constant movements of the legs, inability to sit or stand still, rocking from foot to foot, feeling tense or uncomfortable, feeling anxious</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Common"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S009">
    <rdf:type rdf:resource="http://example.org/ontology#Food"/>
    <rdfs:label>High-Fat Meal</rdfs:label>
    <hasSubstanceDescription>A meal high in fat can reduce Fosfomycin peak blood levels and delay absorption, but overall urinary excretion is unchanged.</hasSubstanceDescription>
    <hasReference rdf:resource="http://example.org/ontology#R024"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R072">
