    <owl:differentFrom rdf:resource="http://example.org/ontology#IVInjection"/>
    <owl:differentFrom rdf:resource="http://example.org/ontology#Syrup"/>
    <owl:differentFrom rdf:resource="http://example.org/ontology#Suspension"/>
    <owl:differentFrom rdf:resource="http://example.org/ontology#Ointment"/>
  </rdf:Description>
