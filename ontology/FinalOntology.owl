  <rdf:Description rdf:about="http://example.org/ontology#W114">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W114</rdfs:label>
    <hasWarningHeadline>Gastrointestinal, Neurologic, and Hematologic Effects</hasWarningHeadline>
    <hasWarningText>Include anorexia, colic, nausea, vomiting, dizziness, headache, drowsiness, and unconsciousness. Pyrexia, haematuria, and crystalluria may be noted. Blood dyscrasias and jaundice are potential late manifestations of overdosage. Signs of acute overdosage with trimethoprim include nausea, vomiting, dizziness, headache, mental depression, confusion, and bone marrow depression.</hasWarningText>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP065">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP065</rdfs:label>
    <hasStewardshipDescription>Before the water is added, the powder should be stored in a dry place at temperatures not exceeding 25°C</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
  </rdf:Description>
