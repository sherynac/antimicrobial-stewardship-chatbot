    <rdfs:label>W228</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R127"/>
    <hasWarningHeadline>Allergy</hasWarningHeadline>
    <hasWarningText>History of allergy.</hasWarningText>
  </rdf:Description>
