  <rdf:Description rdf:about="http://example.org/ontology#ITN184">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN184</rdfs:label>
    <hasClinicalEffects>Decreased absorption</hasClinicalEffects>
    <hasInteractionDescription>Levofloxacin absorption is significantly reduced</hasInteractionDescription>
    <hasManagementAdvice>It is recommended that preparations containing iron salts, or magnesium-or aluminum-containing antacids should not be taken 2 hours before or after Levofloxacin tablet administration.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R010"/>
    <interactsWith rdf:resource="http://example.org/ontology#S143"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE640">
    <rdf:type rdf:resource="http://example.org/ontology#Thrombocytopenia"/>
    <rdfs:label>thrombocytopenia</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R219"/>
    <hasSideEffectDescription>low blood platelet count</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE447">
    <rdf:type rdf:resource="http://example.org/ontology#Restlessness"/>
    <rdfs:label>Restlessness</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasReference rdf:resource="http://example.org/ontology#R115"/>
    <hasSideEffectDescription>pacing, constant movements of the legs, inability to sit or stand still, rocking from foot to foot, feeling tense or uncomfortable, feeling anxious</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I018">
    <rdf:type rdf:resource="http://example.org/ontology#UncomplicatedUrinaryTractInfectionUTI"/>
    <rdfs:label>Mild to Moderate Uncomplicated Urinary Tract Infection (UTI)</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R029"/>
    <hasReference rdf:resource="http://example.org/ontology#R030"/>
    <hasReference rdf:resource="http://example.org/ontology#R032"/>
    <hasReference rdf:resource="http://example.org/ontology#R158"/>
    <hasReference rdf:resource="http://example.org/ontology#R163"/>
    <hasReference rdf:resource="http://example.org/ontology#R164"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#MildToModerate"/>
    <hasSymptoms>Painful or frequent urination, lower abdominal pain, back pain, urgency to urinate, cloudy urine, strong urine smell.</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S176">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Magnesium Trisilicate</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasSubstanceDescription>A type of antacid used to relieve stomach pain, heartburn, and indigestion. It works by neutralizing stomach acid.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE510">
    <rdf:type rdf:resource="http://example.org/ontology#Eosinophilia"/>
    <rdfs:label>Eosinophilia</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R133"/>
    <hasReference rdf:resource="http://example.org/ontology#R155"/>
    <hasSideEffectDescription>Eosinophilia happens when the body produces an unusually high number of eosinophils - one of the white blood cells that support your immune system.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R320">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R320</rdfs:label>
    <hasAuthor>M. Pestel</hasAuthor>
    <hasReferenceTitle>Doxycycline in the treatment of respiratory tract infections. Results of a pan-European multi-centre trial</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1975</publishedIn>
    <retrievedFrom>https://pubmed.ncbi.nlm.nih.gov/1098877/</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE129">
    <rdf:type rdf:resource="http://example.org/ontology#Diarrhea"/>
    <rdfs:label>Diarrhea</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_Common"/>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasSideEffectDescription>Loose, watery stools.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W281">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W281</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R166"/>
    <hasWarningHeadline>Infants</hasWarningHeadline>
    <hasWarningText>No adverse effects have been seen in breast-fed infants whose mothers were
taking cotrimoxazole, and the last available guidance from the American
Academy of Pediatrics considered that it was therefore usually compatible with
breast feeding.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN039">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN039</rdfs:label>
    <hasClinicalEffects>None specifically reported.</hasClinicalEffects>
    <hasInteractionDescription>The total body clearance of cefotaxime has been reduced in patients with normal and reduced renal function by ureidopenicillins azlocillin.</hasInteractionDescription>
    <hasManagementAdvice>Monitor for adverse effects if taken with these medications. Consult doctor or pharmacist.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R014"/>
    <interactsWith rdf:resource="http://example.org/ontology#S030"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE206">
    <rdf:type rdf:resource="http://example.org/ontology#MeningitisAseptic"/>
    <rdfs:label>Meningitis aseptic</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R297"/>
    <hasSideEffectDescription>Aseptic meningitis is an inflammatory condition of the meninges characterized by cerebrospinal fluid pleocytosis and negative bacterial cultures. Although generally considered a benign illness, it encompasses a wide range of etiologies and clinical manifestations, which vary depending on the underlying cause and the patient's immune status.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S043">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Anticoagulants (e.g., Warfarin, Acenocoumarol)</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasSubstanceDescription>Blood thinners used to prevent clots.</hasSubstanceDescription>
  </rdf:Description>
