    <hasAuthor>Cleveland Clinic</hasAuthor>
    <hasReferenceTitle>Vomiting (Emesis)</hasReferenceTitle>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE487">
    <rdf:type rdf:resource="http://example.org/ontology#Convulsions"/>
    <rdfs:label>Convulsions</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R114"/>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>Surge of abnormal electrical activity in the brain. Temporary loss of consciousness and uncontrollable movements.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S132">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Cisapride / Pimozide / Astemizole / Terfenadine</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasSubstanceDescription>Various drugs metabolized by the cytochrome P-450 system.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W258">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W258</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R161"/>
    <hasWarningText>Macrobid should not be used in babies under 1 month old.</hasWarningText>
    <hasWarningHeadline>Newborn Use</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE143">
    <rdf:type rdf:resource="http://example.org/ontology#Vomiting"/>
