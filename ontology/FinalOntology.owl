  <rdf:Description rdf:about="http://example.org/ontology#W269">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W269</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasWarningHeadline>Anuria or Oliguria</hasWarningHeadline>
    <hasWarningText>This medicine should not be used in patients who are not producing urine (anuria) or producing very little urine (oliguria). Because the drug is removed through the urine, it will not work properly and may build up in the body, increasing the risk of side effects.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S121">
