  <rdf:Description rdf:about="http://example.org/ontology#W031">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W031</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <hasWarningHeadline>Breastfeeding</hasWarningHeadline>
    <hasWarningText>It is not known whether azithromycin is excreted in human milk. Caution should be exercised when azithromycin is administered to a nursing woman.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE222">
    <rdf:type rdf:resource="http://example.org/ontology#Pancreatitis"/>
    <rdfs:label>pancreatitis</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R242"/>
    <hasDuration>Not specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasSideEffectDescription>Pancreatitis is inflammation in your pancreas. It’s usually temporary (acute) but can also be a life-long (chronic) condition. The most common symptom is abdominal pain. The most common causes are alcohol use and gallstones.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#isPresentationOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
