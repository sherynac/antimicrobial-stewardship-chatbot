    <rdf:type rdf:resource="http://example.org/ontology#Emesis"/>
    <rdfs:label>Emesis</rdfs:label>
    <hasSideEffectDescription>Throwing up stomach contents. It may be mild or moderate and often happens together with nausea.</hasSideEffectDescription>
    <hasDuration>Short-term; may occur occasionally during treatment</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#May_occur_after_taking_a_dose__especially_if_stomach_upset_happens"/>
