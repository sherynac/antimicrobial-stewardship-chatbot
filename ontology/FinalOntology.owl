    <hasAuthor>Mayo Clinic</hasAuthor>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE240">
    <rdf:type rdf:resource="http://example.org/ontology#RenalImpairment"/>
    <rdfs:label>Renal impairment</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R254"/>
    <hasSideEffectDescription>Kidney failure is a condition in which one or both of your kidneys no longer work on their own. Causes include diabetes, high blood pressure and acute kidney injuries. Symptoms include fatigue, nausea and vomiting, swelling, changes in how often you go to the bathroom and brain fog.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasDuration>Not specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R028">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R028</rdfs:label>
    <hasReferenceTitle>Contepo</hasReferenceTitle>
    <hasAuthor>Meitheal Pharmaceuticals Inc.</hasAuthor>
    <retrievedFrom>https://r.search.yahoo.com/_ylt=AwrPofbCO4hpLAIAFACzRwx.;_ylu=Y29sbwNzZzMEcG9zAzEEdnRpZAMEc2VjA3Ny/RV=2/RE=1771745474/RO=10/RU=https%3a%2f%2fwww.accessdata.fda.gov%2fdrugsatfda_docs%2flabel%2f2025%2f212271s000lbl.pdf/RK=2/RS=hgL7Vx9ENhIJsz16Cns5BPJGrJ4-</retrievedFrom>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</publishedIn>
  </rdf:Description>
