  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE644">
    <rdf:type rdf:resource="http://example.org/ontology#Hypoglycaemia"/>
    <rdfs:label>hypoglycemia</rdfs:label>
    <hasSideEffectDescription>condition in which your blood sugar (glucose) level is lower than the standard range</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R223"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE291">
    <rdf:type rdf:resource="http://example.org/ontology#CDifficileAssociatedDiarrhea"/>
    <rdfs:label>C. difficile-associated diarrhea</rdfs:label>
    <hasDuration>During or weeks after therapy</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <whichIs rdf:resource="http://example.org/ontology#Severe_and_potentially_life-threatening"/>
    <hasSideEffectDescription>Remember that while diarrhea is a recognized side effect of cefuroxime, it is generally mild and transient in most cases.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W117">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W117</rdfs:label>
    <hasWarningHeadline>Neonates and Infants &lt; 3 Months</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasWarningText>Specifically dosed at 20-30 mg/kg body weight/day in divided doses every 12 hours.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#JaundiceCholestatic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Jaundice Cholestatic</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R308">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R308</rdfs:label>
    <hasReferenceTitle>Bilirubin Test</hasReferenceTitle>
    <hasAuthor>Mayo Clinic</hasAuthor>
    <retrievedFrom>https://www.mayoclinic.org/tests-procedures/bilirubin/about/pac-20393041</retrievedFrom>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2024</publishedIn>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN172">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN172</rdfs:label>
    <hasManagementAdvice>Reduction of dose may be necessary</hasManagementAdvice>
    <interactsWith rdf:resource="http://example.org/ontology#S095"/>
    <hasInteractionDescription>Concomitant therapy of tetracycline with anticoagulants may result to prolongation of prothrombin time. Reduction of dose may be necessary.</hasInteractionDescription>
    <hasReference rdf:resource="http://example.org/ontology#R013"/>
    <hasClinicalEffects>Prolongation of prothrombin time</hasClinicalEffects>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S041">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Combined Oral Contraceptives</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasSubstanceDescription>Hormonal birth control pills.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN142">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN142</rdfs:label>
    <hasInteractionDescription>Concomitant use with macrolides like Clarithromycin.</hasInteractionDescription>
    <interactsWith rdf:resource="http://example.org/ontology#S116"/>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasClinicalEffects>Increased statin concentrations; rare reports of rhabdomyolysis and myopathy.</hasClinicalEffects>
    <hasManagementAdvice>Contraindicated. Use the lowest dose of other statins or a statin not dependent on CYP3A (e.g., fluvastatin).</hasManagementAdvice>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W060">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W060</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <hasWarningHeadline>Co-administration</hasWarningHeadline>
    <hasWarningText>Do not take with ergot derivatives</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE320">
    <rdf:type rdf:resource="http://example.org/ontology#ExfoliativeDermatitis"/>
    <rdfs:label>exfoliative dermatitis</rdfs:label>
    <hasSideEffectDescription>redness and scaling of the skin</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R011"/>
    <hasReference rdf:resource="http://example.org/ontology#R176"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <whichIs rdf:resource="http://example.org/ontology#uncommon"/>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE617">
    <rdf:type rdf:resource="http://example.org/ontology#Arthralgia"/>
    <rdfs:label>arthralgia</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R250"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasSideEffectDescription>joint pain that can be felt in the joints throughout your body</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ErythemaMultiforme">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Erythema Multiforme</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W065">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W065</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <hasWarningHeadline>Pregnancy</hasWarningHeadline>
    <hasWarningText>Should only be used during pregnancy if it is clearly indicated. Caution should be taken when administered to a pregnant woman.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Somnolence">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Somnolence</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I034">
    <rdf:type rdf:resource="http://example.org/ontology#AtypicalPneumonia"/>
    <rdfs:label>Mild Atypical pneumonia</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasReference rdf:resource="http://example.org/ontology#R011"/>
    <hasReference rdf:resource="http://example.org/ontology#R080"/>
    <hasReference rdf:resource="http://example.org/ontology#R266"/>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasSymptoms>Sore throat, extreme tiredness, chest pain, low-grade fever, mild chills, cough, sneezing, headache</hasSymptoms>
    <hasSeverityType rdf:resource="http://example.org/ontology#Mild"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasBrandName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/ontology#Antibiotic"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Brand"/>
    <rdfs:label>has brand name</rdfs:label>
    <owl:inverseOf rdf:resource="http://example.org/ontology#isBrandOf"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE643">
    <rdf:type rdf:resource="http://example.org/ontology#Hyperglycemia"/>
    <rdfs:label>hyperglycemia</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R222"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasSideEffectDescription>high blood sugar</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN149">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN149</rdfs:label>
    <interactsWith rdf:resource="http://example.org/ontology#S123"/>
    <hasInteractionDescription>Concomitant administration.</hasInteractionDescription>
    <hasClinicalEffects>May result in ergot toxicity.</hasClinicalEffects>
    <hasReference rdf:resource="http://example.org/ontology#R020"/>
    <hasManagementAdvice>Contraindicated.</hasManagementAdvice>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE495">
    <rdf:type rdf:resource="http://example.org/ontology#Neutropenia"/>
    <rdfs:label>Neutropenia</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasDuration>Not Specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R139"/>
    <hasReference rdf:resource="http://example.org/ontology#R133"/>
    <hasSideEffectDescription>having low levels of neutrophils (a type of white blood cell) in blood</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE329">
    <rdf:type rdf:resource="http://example.org/ontology#Purpura"/>
    <rdfs:label>purpura</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R185"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R011"/>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>purple, red or brown spots and patches on skin</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#frequency_not_reported"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I004">
    <rdf:type rdf:resource="http://example.org/ontology#SinusInfectionSinusitis"/>
    <rdfs:label>Mild Sinus Infection (Sinusitis)</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasReference rdf:resource="http://example.org/ontology#R138"/>
    <hasReference rdf:resource="http://example.org/ontology#R128"/>
    <hasReference rdf:resource="http://example.org/ontology#R129"/>
    <hasReference rdf:resource="http://example.org/ontology#R020"/>
    <hasSymptoms>facial pain, a stuffy or runny nose, and sometimes a fever</hasSymptoms>
    <hasSeverityType rdf:resource="http://example.org/ontology#Mild"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE067">
    <rdf:type rdf:resource="http://example.org/ontology#Hypernatremia"/>
    <rdfs:label>Hypernatremia</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasReference rdf:resource="http://example.org/ontology#R027"/>
    <hasSideEffectDescription>High sodium in blood; may cause thirst, swelling, or confusion if severe.</hasSideEffectDescription>
    <hasDuration>During treatment</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Common__can_happen_while_on_drug"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S054">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Methotrexate</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasSubstanceDescription>Antifolate chemotherapy/immunosuppressant</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#OtherSeriousAndSometimesFatalReactions">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Other Serious and Sometimes Fatal Reactions</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R082">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R082</rdfs:label>
    <retrievedFrom>https://pharmeasy.in/blog/vaccine-lobar-pneumonia-what-is-it-causes-symptoms-treatment/</retrievedFrom>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</publishedIn>
    <hasReferenceTitle>Lobar Pneumonia: What Is It, Causes, Symptoms &amp; Treatment</hasReferenceTitle>
    <hasAuthor>PharmEasy</hasAuthor>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S075">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Probenecid</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R016"/>
    <hasSubstanceDescription>Gout/Renal agent</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R106">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R106</rdfs:label>
    <retrievedFrom>https://www.mims.com/philippines/drug/info/terfenadine?mtype=generic</retrievedFrom>
    <hasReferenceTitle>Terfenadine</hasReferenceTitle>
    <hasAuthor>Monthly Index of Medical Specialties</hasAuthor>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</publishedIn>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP176">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP176</rdfs:label>
    <hasStewardshipDescription>During prolonged therapy, especially in elderly patients, liver and lung function should be checked regularly. Patients with existing lung, liver, nerve, or kidney problems should be monitored closely. If symptoms such as breathing difficulty, numbness, tingling, or weakness occur, the medicine should be stopped and medical advice sought immediately.</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W188">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W188</rdfs:label>
    <hasWarningHeadline>Patients treated with Vitamin K antagonists</hasWarningHeadline>
    <hasWarningText>Due to possible increase in coagulation tests (PT/INR) and/or bleeding in patients treated with levofloxacin in combination with a vitamin K antagonist (e.g., warfarin), coagulation tests should be monitored when these drugs are given concomitantly.</hasWarningText>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasSubstanceDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/ontology#Substance"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>has substance description</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN123">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN123</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R011"/>
    <interactsWith rdf:resource="http://example.org/ontology#S097"/>
    <hasClinicalEffects>Decreased absorption</hasClinicalEffects>
    <hasManagementAdvice>Avoid taking together</hasManagementAdvice>
    <hasInteractionDescription>Absorption of tetracyclines is impaired by antacids containing aluminum, calcium, or magnesium and iron-containing preparations</hasInteractionDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE375">
    <rdf:type rdf:resource="http://example.org/ontology#Glossitis"/>
    <rdfs:label>glossitis</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R013"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R170"/>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>inflammation of tongue</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE610">
    <rdf:type rdf:resource="http://example.org/ontology#Gastroenteritis"/>
    <rdfs:label>gastroenteritis</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasSideEffectDescription>inflammation that spreads from your stomach into your intestines, causing pain, vomiting and diarrhea</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R244"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP025">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP025</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R027"/>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasStewardshipDescription>Only use Contepo when prescribed by a healthcare professional for a confirmed infection. Avoid using for viral infections like colds or flu.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#AbnormalDreaming">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Abnormal Dreaming</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP177">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP177</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasStewardshipDescription>To reduce the risk of side effects, avoid use in patients with contraindications such as anuria, oliguria, hepatitis, late pregnancy, or infants under 1 month old. Careful patient selection helps prevent serious complications.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE547">
    <rdf:type rdf:resource="http://example.org/ontology#Nausea"/>
    <rdfs:label>Nausea</rdfs:label>
    <hasDuration>Short-term; may last a few hours to a few days</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Commonly_appears_early_in_treatment__especially_if_taken_without_food"/>
    <hasSideEffectDescription>A feeling of sickness in the stomach that may make the patient feel like vomiting. It may improve when the medicine is taken with meals.</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE451">
    <rdf:type rdf:resource="http://example.org/ontology#Diarrhea"/>
    <rdfs:label>Diarrhea</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R076"/>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <whichIs rdf:resource="http://example.org/ontology#Common"/>
    <hasSideEffectDescription>Loose, watery stool during a bowl movement</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W180">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W180</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasWarningText>Levofloxacin should be discontinued if the patient experiences pain, inflammation or rupture of a tendon. Patients should rest and refrain from exercise until the diagnosis of tendonitis or tendon rupture has been confidently excluded. Tendon rupture can occur during or after therapy with quinolones, including levofloxacin.</hasWarningText>
    <hasWarningHeadline>Pain, Inflamation or Rupture of a tendon</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE196">
    <rdf:type rdf:resource="http://example.org/ontology#Rhabdomyolysis"/>
    <rdfs:label>rhabdomyolysis</rdfs:label>
    <hasDuration>Not specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R291"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasSideEffectDescription>Rhabdomyolysis is a rare muscle injury where your muscles break down. This is a life-threatening condition that can happen after an injury or excessive exercise without rest.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W203">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W203</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasWarningText>Levofloxacin has not been measured in human milk. However, based on the ofloxacin data, it can be presumed that levofloxacin will be excreted in human milk. Therefore, a decision should be made whether to discontinue breastfeeding or to discontinue the drug, taking into account the importance of the drug to the mother as well as the possible serious adverse effects to the infant.</hasWarningText>
    <hasWarningHeadline>Lactation</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN177">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN177</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R013"/>
    <hasClinicalEffects>Decreased absorption</hasClinicalEffects>
    <hasInteractionDescription>Carbamazepine decrease the half-life of doxycycline</hasInteractionDescription>
    <hasManagementAdvice>Avoid taking together</hasManagementAdvice>
    <interactsWith rdf:resource="http://example.org/ontology#S100"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R097">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R097</rdfs:label>
    <retrievedFrom>https://www.mims.com/philippines/disease/bronchitis-chronic-in-acute-exacerbation/disease-summary</retrievedFrom>
    <hasAuthor>Monthly Index of Medical Specialties</hasAuthor>
    <hasReferenceTitle>Bronchitis - Chronic in Acute Exacerbation Disease Summary</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2024</publishedIn>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE670">
    <rdf:type rdf:resource="http://example.org/ontology#Urticaria"/>
    <rdfs:label>urticaria</rdfs:label>
    <hasSideEffectDescription>a skin rash that’s often very itchy, often results from an allergic reaction to food or something you’ve touched</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R249"/>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN079">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN079</rdfs:label>
    <hasManagementAdvice>May be taken with meals for better absorption and less Gastrointestinal discomfort</hasManagementAdvice>
    <interactsWith rdf:resource="http://example.org/ontology#S053"/>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasInteractionDescription>Taking medication during meals</hasInteractionDescription>
    <hasClinicalEffects>Absorption is 90% and is not significantly affected by food</hasClinicalEffects>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#interactsWith">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Substance"/>
    <rdfs:label>interacts with</rdfs:label>
    <owl:inverseOf rdf:resource="http://example.org/ontology#isInvolvedIn"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE330">
    <rdf:type rdf:resource="http://example.org/ontology#SerumSickness"/>
    <rdfs:label>serum sickness</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R011"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R186"/>
    <hasSideEffectDescription>allergic reaction to certain proteins in medicines</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#frequency_not_reported"/>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP097">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP097</rdfs:label>
    <hasStewardshipDescription>For respiratory infections, the usual duration is 7-14 days. Dosage for renal impairment (CrCl &lt;30 mL/min) should be reduced by half.</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE629">
    <rdf:type rdf:resource="http://example.org/ontology#Constipation"/>
    <rdfs:label>constipation</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Common"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R208"/>
    <hasSideEffectDescription>passing fewer than three stools a week or having a difficult time passing stool</hasSideEffectDescription>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE647">
    <rdf:type rdf:resource="http://example.org/ontology#Agitation"/>
    <rdfs:label>agitation</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R226"/>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>state of severe restlessness or inner tension</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W056">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W056</rdfs:label>
    <hasWarningText>Hypersensitivity to the active substance, erythromycin, any macrolide or ketolide antibiotic, or to any of the excipients.</hasWarningText>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#UrinaryDisease">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Indication"/>
    <owl:disjointWith rdf:resource="http://example.org/ontology#RespiratoryDisease"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE257">
    <rdf:type rdf:resource="http://example.org/ontology#VaginalYeastInfection"/>
    <rdfs:label>Vaginal Yeast Infection</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R032"/>
    <whichIs rdf:resource="http://example.org/ontology#During_or_after_treatment"/>
    <hasDuration>3–7 days</hasDuration>
    <hasSideEffectDescription>Itching, irritation, or thick white discharge due to changes in bacterial flora.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN153">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN153</rdfs:label>
    <interactsWith rdf:resource="http://example.org/ontology#S127"/>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasClinicalEffects>Increased risk of ototoxicity (hearing/balance damage)</hasClinicalEffects>
    <hasInteractionDescription>Concomitant use with drugs that cause hearing damage</hasInteractionDescription>
    <hasManagementAdvice>Use with extreme caution; monitor hearing and balance.</hasManagementAdvice>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W034">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W034</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasWarningHeadline>QT Prolongation</hasWarningHeadline>
    <hasWarningText>The risk of QT prolongation may increase in patients with electrolyte abnormalities (such as hypokalemia and hypocalcemia), patients with conditions that have potential to cause electrolyte imbalance (such as renal impairment), or patients taking other drugs affecting electrolyte balance or QT prolongation. Avoid CONTEPO in patients with known QT prolongation or ventricular arrhythmias, including a history of torsade de pointes.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ImpairedHearing">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Impaired Hearing</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE130">
    <rdf:type rdf:resource="http://example.org/ontology#Vomiting"/>
    <rdfs:label>Vomiting</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasReference rdf:resource="http://example.org/ontology#R057"/>
    <whichIs rdf:resource="http://example.org/ontology#Common"/>
    <hasSideEffectDescription>Effects are usually mild. Forceful ejection stomach contents through the mouth.</hasSideEffectDescription>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SystemicLupusErythematosus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Systemic Lupus Erythematosus</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN097">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN097</rdfs:label>
    <hasClinicalEffects>May interfere with the bactericidal effects of amoxicillin.</hasClinicalEffects>
    <hasReference rdf:resource="http://example.org/ontology#R016"/>
    <hasManagementAdvice>Clinical significance is not well documented.</hasManagementAdvice>
    <hasInteractionDescription>Interference in vitro.</hasInteractionDescription>
    <interactsWith rdf:resource="http://example.org/ontology#S071"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN244">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN244</rdfs:label>
    <interactsWith rdf:resource="http://example.org/ontology#S019"/>
    <hasClinicalEffects>Not Specified</hasClinicalEffects>
    <hasInteractionDescription>Not Specified</hasInteractionDescription>
    <hasReference rdf:resource="http://example.org/ontology#R133"/>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S140">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Antacids, Sucralfate, Metal Cations, Multivitamins</rdfs:label>
    <hasSubstanceDescription>Antacids containing magnesium or aluminum, as well as sucralfate metal cations such as iron and multivitamin preparations with zinc</hasSubstanceDescription>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S113">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Ototoxic Drugs (e.g., Aminoglycosides)</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasSubstanceDescription>Drugs that can cause hearing or balance damage.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN209">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN209</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasClinicalEffects>May reduce absorption of ciprofloxacin and other quinolones</hasClinicalEffects>
    <hasInteractionDescription>Sucralfate releases aluminum ions in the stomach</hasInteractionDescription>
    <interactsWith rdf:resource="http://example.org/ontology#S144"/>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I039">
    <rdf:type rdf:resource="http://example.org/ontology#AcuteBronchitis"/>
    <rdfs:label>Mild to Moderate Acute bronchitis</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R320"/>
    <hasReference rdf:resource="http://example.org/ontology#R128"/>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasReference rdf:resource="http://example.org/ontology#R011"/>
    <hasReference rdf:resource="http://example.org/ontology#R129"/>
    <hasReference rdf:resource="http://example.org/ontology#R084"/>
    <hasReference rdf:resource="http://example.org/ontology#R319"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#MildToModerate"/>
    <hasSymptoms>cough, chest soreness, feeling tired and achy, back and muscle pain, headache, runny nose, slight fever, shortness of breath, sore throat, watery eyes, wheezing</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W141">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W141</rdfs:label>
    <hasWarningHeadline>Gastrointestinal Symptoms &amp; Supportive Care</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <hasWarningText>Overdose causes abdominal pain, vomiting, nausea, and diarrhea. Treat with prompt elimination of unabsorbed drug and supportive measures.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE481">
    <rdf:type rdf:resource="http://example.org/ontology#Catatonia"/>
    <rdfs:label>Catatonia</rdfs:label>
    <hasSideEffectDescription>Catatonia is a disorder that disrupts a person’s awareness of the world around them. People with this condition sometimes react very little or not at all to their surroundings, or might behave in ways that are unusual, unexpected or unsafe to themselves or others.</hasSideEffectDescription>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasReference rdf:resource="http://example.org/ontology#R134"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE659">
    <rdf:type rdf:resource="http://example.org/ontology#VentricularTachycardia"/>
    <rdfs:label>ventricular tachycardia</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R238"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasSideEffectDescription>fast, abnormal heart rhythm (arrhythmia) that comes from atypical electrical signals in your heart’s lower chambers</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE368">
    <rdf:type rdf:resource="http://example.org/ontology#Eosinophilia"/>
    <rdfs:label>eosinophilia</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R191"/>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasSideEffectDescription>increase of circulating eosinophils &gt;500 /mm^3</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#rare"/>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasSymptoms">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/ontology#Indication"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>has symptoms</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN103">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN103</rdfs:label>
    <hasManagementAdvice>Undertake appropriate monitoring (e.g., INR); adjust dose as needed.</hasManagementAdvice>
    <interactsWith rdf:resource="http://example.org/ontology#S077"/>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <hasInteractionDescription>Concurrent use with amoxicillin or cefuroxime.</hasInteractionDescription>
    <hasClinicalEffects>Increased risk of bleeding; rare prolongation of prothrombin time; elevated INR.</hasClinicalEffects>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W251">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W251</rdfs:label>
    <hasWarningText>Should not be used in babies under 1 month of age.</hasWarningText>
    <hasWarningHeadline>Infants Under 1 Month</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R157"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN257">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN257</rdfs:label>
    <hasManagementAdvice>Avoid taking magnesium-containing antacids at the same time. If necessary, separate doses by several hours. Consult a healthcare provider before combining.</hasManagementAdvice>
    <interactsWith rdf:resource="http://example.org/ontology#S176"/>
    <hasInteractionDescription>Magnesium Trisilicate reduces the absorption of Nitrofurantoin from the stomach and intestines. This means less of the antibiotic enters the bloodstream.</hasInteractionDescription>
    <hasClinicalEffects>Lower absorption can reduce the amount of medicine reaching the urine. making treatment less effective. The infection may not fully clear.</hasClinicalEffects>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP134">
    <rdf:type rdf:resource="http://example.org/ontology#FoodAndTiming"/>
    <rdfs:label>SP134</rdfs:label>
    <hasStewardshipDescription>Do not take with antacids, iron or dairy products</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE285">
    <rdf:type rdf:resource="http://example.org/ontology#GastrointestinalEffects"/>
    <rdfs:label>Gastrointestinal Effects</rdfs:label>
    <hasSideEffectDescription>Insomnia, headache, dysgeusia (taste perversion), diarrhea, vomiting, dyspepsia, nausea, and abdominal pain.</hasSideEffectDescription>
    <hasDuration>Not specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R020"/>
    <whichIs rdf:resource="http://example.org/ontology#Common___1_100_to__1_10_"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE096">
    <rdf:type rdf:resource="http://example.org/ontology#VaginalItching"/>
    <rdfs:label>Vaginal Itching</rdfs:label>
    <hasDuration>Short-term</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R030"/>
    <hasReference rdf:resource="http://example.org/ontology#R029"/>
    <hasSideEffectDescription>Mild itching; may indicate yeast overgrowth.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#PseudomembranousOrCDifficileColitis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Pseudomembranous / C. Difficile Colitis</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I027">
    <rdf:type rdf:resource="http://example.org/ontology#ChronicBronchitis"/>
    <rdfs:label>Chronic Bronchitis</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <hasReference rdf:resource="http://example.org/ontology#R020"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Mild">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdf:type rdf:resource="http://example.org/ontology#Severity"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Severity"/>
    <rdfs:label>Mild</rdfs:label>
    <owl:disjointWith rdf:resource="http://example.org/ontology#MildToSevere"/>
    <owl:disjointWith rdf:resource="http://example.org/ontology#ModerateToSevere"/>
    <owl:disjointWith rdf:resource="http://example.org/ontology#Severe"/>
    <owl:disjointWith rdf:resource="http://example.org/ontology#InitialTherapy"/>
    <owl:differentFrom rdf:resource="http://example.org/ontology#MildToSevere"/>
    <owl:differentFrom rdf:resource="http://example.org/ontology#ModerateToSevere"/>
    <owl:differentFrom rdf:resource="http://example.org/ontology#Severe"/>
    <owl:differentFrom rdf:resource="http://example.org/ontology#InitialTherapy"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I042">
    <rdf:type rdf:resource="http://example.org/ontology#Bronchiectasis"/>
    <rdfs:label>Bronchiectasis</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R088"/>
    <hasReference rdf:resource="http://example.org/ontology#R003"/>
    <hasReference rdf:resource="http://example.org/ontology#R128"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
    <hasSymptoms>cough with lots of mucus and pus, repeated colds, bad-smelling mucus, shortness of breath, wheezing, coughing up blood</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE082">
    <rdf:type rdf:resource="http://example.org/ontology#TorsadeDePointes"/>
    <rdfs:label>Torsade de pointes</rdfs:label>
    <hasSideEffectDescription>Rare heart rthythm proble; can be life-threatening; monitored in high-risk patients.</hasSideEffectDescription>
    <hasDuration>During treatment</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S154">
    <rdf:type rdf:resource="http://example.org/ontology#Beverage"/>
    <rdfs:label>Alcohol</rdfs:label>
    <hasSubstanceDescription>Any drink that contains alcohol like beer, wine, vodka, and others</hasSubstanceDescription>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#May_appear_during_therapy">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>May appear during therapy</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S079">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Ureidopenicillins (Azlocillin)</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <hasSubstanceDescription>Penicillin-class antibiotic that may decrease renal clearance of other drugs.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Fatigue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Fatigue</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R020">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R020</rdfs:label>
    <retrievedFrom>https://www.mims.com/philippines/drug/info/kracid</retrievedFrom>
    <hasReferenceTitle>Kracid</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</publishedIn>
    <hasAuthor>Monthly Index of Medical Specialties</hasAuthor>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE582">
    <rdf:type rdf:resource="http://example.org/ontology#Granulocytopenia"/>
    <rdfs:label>granulocytopenia</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R220"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasSideEffectDescription>due to a decrease in bone marrow production resulting from defects in the growth and differentiation of granulocytes</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n0e9bfaaca0144c75b7bd81f48c0754bfb17">
    <rdf:first rdf:resource="http://example.org/ontology#Severe"/>
    <rdf:rest rdf:nodeID="n0e9bfaaca0144c75b7bd81f48c0754bfb18"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP109">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP109</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasStewardshipDescription>Use for treating tonsillitis, pharyngitis and acute otitis media (ear infection) for patients with hypersensitivity to beta-lactam antibiotics or when such treatment is not suitable for other reasons.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R092">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R092</rdfs:label>
    <hasReferenceTitle>Xypen</hasReferenceTitle>
    <hasAuthor>Monthly Index of Medical Specialties</hasAuthor>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</publishedIn>
    <retrievedFrom>https://www.mims.com/philippines/drug/info/xypen</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE180">
    <rdf:type rdf:resource="http://example.org/ontology#Methaemoglobinaemia"/>
    <rdfs:label>methaemoglobinaemia</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R281"/>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasSideEffectDescription>Methemoglobinemia (MetHb) is a rare blood disorder that affects how red blood cells deliver oxygen throughout your body. Not everyone has symptoms, but nearly all people with this condition have skin, nails or lips that are a distinctive shade of blue or purple.</hasSideEffectDescription>
    <hasDuration>Not specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN148">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN148</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R020"/>
    <interactsWith rdf:resource="http://example.org/ontology#S122"/>
    <hasClinicalEffects>Elevated drug levels, QT prolongation, and serious cardiac arrhythmias.</hasClinicalEffects>
    <hasInteractionDescription>Concomitant use with clarithromycin.</hasInteractionDescription>
    <hasManagementAdvice>Contraindicated.</hasManagementAdvice>
  </rdf:Description>
