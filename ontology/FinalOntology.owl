    <hasPattern rdf:resource="http://example.org/ontology#Common"/>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <hasReference rdf:resource="http://example.org/ontology#R076"/>
    <hasSideEffectDescription>Effects are usually mild. Loose, watery stools during a bowl movement</hasSideEffectDescription>
  </rdf:Description>
