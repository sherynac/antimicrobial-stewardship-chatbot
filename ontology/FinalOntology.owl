  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE403">
    <rdf:type rdf:resource="http://example.org/ontology#TendinitisAndTendonRupture"/>
    <rdfs:label>Tendinitis and Tendon Rupture</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Within_hours_or_days"/>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasSideEffectDescription>Increased risk of tendinitis and tendon rupture involving the achillies rendon, rorator cuffm the hande, the biceps, the thumb, and other tendon sites</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R237">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R237</rdfs:label>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <hasReferenceTitle>Heart Palpitations</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2022</publishedIn>
    <retrievedFrom>https://my.clevelandclinic.org/health/diseases/17084-heart-palpitations</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE234">
    <rdf:type rdf:resource="http://example.org/ontology#ToxicEpidermalNecrolysis"/>
    <rdfs:label>toxic epidermal necrolysis</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R121"/>
    <hasSideEffectDescription>Toxic epidermal necrolysis (TEN) is a life-threatening skin condition. It causes peeling and blistering skin over much of the body, including the mouth, eyes, and genitals. TEN is the most severe form of Stevens-Johnson syndrome.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R030">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R030</rdfs:label>
    <hasAuthor>MedBroadcast</hasAuthor>
    <hasReferenceTitle>Jamp-Fosfomycin</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</publishedIn>
    <retrievedFrom>https://medbroadcast.com/drug/getdrug/jamp-fosfomycin</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN247">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN247</rdfs:label>
    <hasClinicalEffects>Reduced absorption can make the antibiotic less effective at treating urinary tract infections, potentially allowing the bacteria to persist or worsen.</hasClinicalEffects>
    <hasInteractionDescription>Antacids that contain magnesium can bind with nitrofurantoin in the stomach or intestines and reduce how much of the drugs is absorbed into the blood.</hasInteractionDescription>
    <hasManagementAdvice>Do not take nitrofurantoin at the same time as magnesium-containing antacids. Take the antibiotic at least 2 hours before or after antacids to ensure proper absorption.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R157"/>
    <interactsWith rdf:resource="http://example.org/ontology#S166"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R015">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R015</rdfs:label>
    <hasAuthor>Monthly Index of Medical Specialties</hasAuthor>
    <hasReferenceTitle>Amoxil/Amoxil Forte</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</publishedIn>
    <retrievedFrom>https://www.mims.com/philippines/drug/info/amoxil-amoxil-forte</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE027">
