    <rdf:type rdf:resource="http://example.org/ontology#FoodAndTiming"/>
    <rdfs:label>SP154</rdfs:label>
    <hasStewardshipDescription>May be given without regard to meals.</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R128"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE382">
    <rdf:type rdf:resource="http://example.org/ontology#Urticaria"/>
    <rdfs:label>urticaria</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R181"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R013"/>
    <whichIs rdf:resource="http://example.org/ontology#frequency_not_reported"/>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>Hives (also called urticaria) refers to raised and splotchy areas of skin that can be caused by an allergic reaction to something</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE660">
    <rdf:type rdf:resource="http://example.org/ontology#VentricularArrhythmia"/>
    <rdfs:label>ventricular arrhythmia</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>abnormal heart rhythms that make the lower chambers of your heart twitch instead of pump</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R239"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP070">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP070</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R032"/>
    <hasStewardshipDescription>Must be taken orally at prescribed intervals, completing the full course to fully treat infection and prevent resistance.</hasStewardshipDescription>
  </rdf:Description>
