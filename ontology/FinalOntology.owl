    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasSideEffectDescription>reduced and plasma elimination</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#GenitalMoniliasis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Genital Moniliasis</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE036">
    <rdf:type rdf:resource="http://example.org/ontology#SodiumOverload"/>
    <rdfs:label>Sodium Overload</rdfs:label>
    <hasDurationOf>During treatment</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#More_likely_in_high_doses"/>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <hasSideEffectDescription>High sodium levels that may worsen heart failure or high blood pressure.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE575">
    <rdf:type rdf:resource="http://example.org/ontology#Pruritus"/>
    <rdfs:label>pruritus</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Common"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R213"/>
    <hasSideEffectDescription>causes you to feel the need to scratch your skin to get relief</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Angioedema">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Angioedema</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I060">
    <rdf:type rdf:resource="http://example.org/ontology#RecurrentUrinaryTractInfection"/>
    <rdfs:label>Mild to Moderate (can worsen if untreated) Recurrent Urinary Tract Infection</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasSymptoms>Repeated episodes of urinary burning, urgency, and discomfort that happen several times over a period of months. Symptoms are similar to previous bladder infections.</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Within_two_months">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Within two months</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#UrinaryDisease">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Indication"/>
    <owl:disjointWith rdf:resource="http://example.org/ontology#RespiratoryDisease"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W167">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W167</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasWarningHeadline>Gastrointestinal and Mental Effects</hasWarningHeadline>
    <hasWarningText>Large amounts produce GI symptoms. A patient ingesting 8 grams showed altered mental status, paranoid behaviour, hypokalemia, and hypoxemia.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP027">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP027</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R027"/>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasStewardshipDescription>Complete the full course of Contepo even if you feel better to prevent bacterial resistance. Do not skip doses.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R291">
