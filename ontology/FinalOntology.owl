  <rdf:Description rdf:about="http://example.org/ontology#AcuteMaxillarySinusitis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#RespiratoryDisease"/>
    <rdfs:label>Acute Maxillary Sinusitis</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE279">
    <rdf:type rdf:resource="http://example.org/ontology#CentralNervousSystemEffects"/>
    <rdfs:label>Central Nervous System Effects</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Not_specified"/>
    <hasDuration>Not specified</hasDuration>
    <hasSideEffectDescription>Diarrhea, nausea, abnormal taste, dyspepsia, and abdominal pain.</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN259">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN259</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasManagementAdvice>Use cautiously. The doctor may monitor treatment response and adjust therapy if needed.</hasManagementAdvice>
    <hasClinicalEffects>Reduced antibacterial activity may occur, leading to incomplete treatment of urinary tract infections.</hasClinicalEffects>
    <interactsWith rdf:resource="http://example.org/ontology#S178"/>
    <hasInteractionDescription>Carbonic anhydrase inhibitors reduce the effectiveness of Nitrofurantoin by making the urine less acidic. Nitrofurantoin works better in acidic urine.</hasInteractionDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R275">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R275</rdfs:label>
    <retrievedFrom>https://www.mims.com/philippines/disease/hepatitis-viral-pediatric/disease-summary</retrievedFrom>
    <hasAuthor>Monthly Index of Medical Specialties</hasAuthor>
    <hasReferenceTitle>Hepatitis</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2024</publishedIn>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE295">
    <rdf:type rdf:resource="http://example.org/ontology#AbdominalPain"/>
    <rdfs:label>Abdominal Pain</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Can_occur_sooner_after_taking"/>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasDuration>Short-term</hasDuration>
    <hasSideEffectDescription>A side effect is an unwanted response to a medication when it is taken in normal doses. Side effects can be mild or severe, temporary or permanent.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Rash">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Rash</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE099">
    <rdf:type rdf:resource="http://example.org/ontology#HypersensitivityReactions"/>
    <rdfs:label>Hypersensitivity Reactions</rdfs:label>
    <hasSideEffectDescription>Includes skin rashes, urticaria, eosinophilia, fever, reactions resembling serum sickness,, and anaphylaxis.</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R014"/>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W069">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W069</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasWarningHeadline>Hepatotoxicity</hasWarningHeadline>
    <hasWarningText>Use with caution for patients with significant hepatic (liver) disease as cases of fulminant hepatitis leading to life-threatening liver failure have been reported with azithromycin. In case of signs and symptoms of liver dysfunction, such as rapid developing asthenia associated with jaundice, dark urine, bleeding tendency or hepatic encephalopathy. Azithromycin administration should be stopped if liver dysfunction has emerged.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W038">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W038</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasWarningHeadline>Development of Drug-Resistant Bacteria</hasWarningHeadline>
    <hasWarningText>Prescribing CONTEPO in the absence of a proven or strongly suspected bacterial infection indication is unlikely to provide benefit to the patient and increases the risk of the development of drug resistant bacteria</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE367">
    <rdf:type rdf:resource="http://example.org/ontology#Neutropenia"/>
    <rdfs:label>neutropenia</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R190"/>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <whichIs rdf:resource="http://example.org/ontology#rare"/>
    <hasSideEffectDescription>having low levels of neutrophils (a type of white blood cell) in blood</hasSideEffectDescription>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
