  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I014">
    <rdf:type rdf:resource="http://example.org/ontology#Urethritis"/>
    <rdfs:label>Urethritis</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R003"/>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <hasReference rdf:resource="http://example.org/ontology#R044"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
    <hasSymptoms>Men: blood in the urine or semen, burning pain while urinating, discharge from penis, frequent urination, itching, tenderness, or swelling in penis, enlarged lymph nodes in the groin area, pain with intercourse or ejaculation Women: abdominal pain, burning pain while urinating, fever and chills, frequent urination, pelvic pain, pain with intercourse, vaginal discharge</hasSymptoms>
  </rdf:Description>
