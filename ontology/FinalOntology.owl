  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN109">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN109</rdfs:label>
    <hasClinicalEffects>Reduced efficacy of the antibiotic or other oral medications.</hasClinicalEffects>
    <hasInteractionDescription>Effect on gut flora / interference.</hasInteractionDescription>
    <hasManagementAdvice>Monitor for therapeutic failure; be aware of potential for reduced drug effectiveness.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <interactsWith rdf:resource="http://example.org/ontology#S083"/>
  </rdf:Description>
