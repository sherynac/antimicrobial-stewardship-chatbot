  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W102">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W102</rdfs:label>
    <hasWarningHeadline>Infantile hypertrophic pyloric stenosis (IHPS)</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasWarningText>Following the use of azithromycin in neonates (treatment up to 42 days of life), infantile hypertrophic pyloric stenosis (IHPS) has been reported. Parents and caregiviers should contact physician if vomiting/irritability occurs.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R317">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R317</rdfs:label>
    <hasAuthor>Indian Journal of Pathology and Oncology</hasAuthor>
    <hasReferenceTitle>A diagnostic and therapeutic conflict with masked megaloblastosis</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2022</publishedIn>
    <retrievedFrom>https://ijpo.co.in/archive/volume/9/issue/2/article/18208#:~:text=Megaloblastosis%20is%20a%20cytomorphological%20diagnostic,cells%20(i.e.%2C%20normoblasts).</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE287">
    <rdf:type rdf:resource="http://example.org/ontology#SkinAndSystemicReactions"/>
    <rdfs:label>Skin &amp; Systemic Reactions</rdfs:label>
