  <rdf:Description rdf:about="http://example.org/ontology#I060">
    <rdf:type rdf:resource="http://example.org/ontology#RecurrentUrinaryTractInfection"/>
    <rdfs:label>Mild to Moderate (can worsen if untreated) Recurrent Urinary Tract Infection</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasSymptoms>Repeated episodes of urinary burning, urgency, and discomfort that happen several times over a period of months. Symptoms are similar to previous bladder infections.</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE216">
    <rdf:type rdf:resource="http://example.org/ontology#LungInfiltration"/>
    <rdfs:label>lung infiltration</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R304"/>
    <hasSideEffectDescription>Lung infiltrates refer to abnormal substances or fluids within the lung tissue that can arise from various causes, including infections, pulmonary hemorrhage, drug toxicity, leukemic infiltration, and pulmonary edema, particularly in patients with hematologic malignancies.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasDuration>Not specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I017">
    <rdf:type rdf:resource="http://example.org/ontology#ComplicatedUrinaryTractInfectionCUTI"/>
    <rdfs:label>Moderate to Severe Complicated Urinary Tract Infection (cUTI)</rdfs:label>
