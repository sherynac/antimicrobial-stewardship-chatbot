    <hasReference rdf:resource="http://example.org/ontology#R027"/>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W210">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W210</rdfs:label>
    <hasWarningText>Ciprofloxacin is excreted in human milk; The amount of ciprofloxacin absorbed by the infant is unknown; Due to potential serious adverse reactions to infants nursing from mothers taking ciprofloxacin, a decision should be made whether to discontinue nursing or to discontinue the drug, depending on the importance of the drug to the mother.</hasWarningText>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasWarningHeadline>Nursing Mothers</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#NeuropathyPeripheral">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Neuropathy Peripheral</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE046">
    <rdf:type rdf:resource="http://example.org/ontology#Flatulence"/>
    <rdfs:label>Flatulence</rdfs:label>
    <hasSideEffectDescription>Minor side effect; body releases gas in your digestive system through your anus.</hasSideEffectDescription>
    <hasDuration>Not Specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP165">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP165</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R160"/>
    <hasStewardshipDescription>Complete the full course of medicine even if symptoms improve, to prevent infection from coming back and bacteria from becoming resistant.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R051">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R051</rdfs:label>
    <retrievedFrom>https://www.cuh.nhs.uk/patient-information/phenytoin-drug-information/</retrievedFrom>
    <hasAuthor>Cambridge University Hospitals</hasAuthor>
    <hasReferenceTitle>Phenytoin drug information</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2020</publishedIn>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W021">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W021</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <hasWarningHeadline>Decrease in Potassium Level</hasWarningHeadline>
    <hasWarningText>A high sodium load associated with the use of IVOZFO™ may result in decreased levels of potassium in serum or plasma. A low-sodium diet is recommended during treatment. The substitution of potassium may be necessary in some cases. Serum electrolyte levels and water balance must be monitored regularly during therapy</hasWarningText>
  </rdf:Description>
