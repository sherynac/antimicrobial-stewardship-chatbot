  <rdf:Description rdf:about="http://example.org/ontology#ITN041">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN041</rdfs:label>
    <hasClinicalEffects>None specifically reported.</hasClinicalEffects>
    <hasInteractionDescription>Cefotaxime sodium has been reported to be incompatible with alkaline solutions such as sodium bicarbonate. It is recommended that it should be administered separately from aminoglycosides.</hasInteractionDescription>
    <hasManagementAdvice>Monitor for adverse effects if taken with these medications. Consult doctor or pharmacist.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R014"/>
    <interactsWith rdf:resource="http://example.org/ontology#S019"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W039">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W039</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasWarningHeadline>Cardiac/Fluid Overload</hasWarningHeadline>
    <hasWarningText>Monitor signs and symptoms of edema, particularly in patients with cardiac insufficiency, renal impairment, cirrhosis, hypertension, hyperaldosteronism, hypernatremia or pulmonary edema.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W199">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W199</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasWarningHeadline>Use in Elderely</hasWarningHeadline>
    <hasWarningText>No dosage adjustment is necessary for elderly patients with normal renal function. However, since levofloxacin is excreted by the kidneys and some elderly patients experience age-related reduction in renal function, care should be taken in dose selection and renal function monitoring is recommended. Elderly patients are at increased risk of developing severe tendon disorders including tendon rupture, or prolonged QT interval leading to ventricular arrhythmias when being treated with a fluoroquinolone such as levofloxacin</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W260">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W260</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R160"/>
    <hasWarningHeadline>Current and Past Health Conditions</hasWarningHeadline>
    <hasWarningText>Notify healthcare provider if a patient have current and past health conditions in any of the following: kidnet or liver problems, history of anemia, history of diabetes, electrolyte imbalance, history of low levels of vitamin B, or Glucose-6-phosphate dehydrogenase (G6PD) deficiency</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W221">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W221</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasWarningHeadline>Hepatic Impairment</hasWarningHeadline>
    <hasWarningText>Ciprofloxacin should be used with caution in patients with severe hepatic impairment where peak plasma concentration and serum half life may be increased.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W024">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W024</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <hasWarningHeadline>Breastfeeding</hasWarningHeadline>
    <hasWarningText>It is not fully known if the drug passes into breast milk. Consult a healthcare provider before use.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN056">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN056</rdfs:label>
    <hasInteractionDescription>Cotrimoxazole has been shown to potentiate activity of strongly serum protein-bound drugs like oral hypoglycaemic or anticoagulant.</hasInteractionDescription>
    <hasManagementAdvice>Monitor for enhanced drug effects and adjust doses as needed.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R031"/>
    <interactsWith rdf:resource="http://example.org/ontology#S033"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Rare_Concomitant_use_reports">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Rare/Concomitant use reports</rdfs:label>
  </rdf:Description>
