    <retrievedFrom>https://pubmed.ncbi.nlm.nih.gov/23035315/</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W176">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W176</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R013"/>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasWarningText>The drug is contraindicated in patients who have shown hypersensitivity to any of the tetracyclines.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE574">
    <rdf:type rdf:resource="http://example.org/ontology#Rash"/>
    <rdfs:label>rash</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Common"/>
