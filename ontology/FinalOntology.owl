  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#14_days_of_initiation_of_therapy_and_most_cases_occurred_within_6_days">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
