  <rdf:Description rdf:about="http://example.org/ontology#W038">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W038</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasWarningHeadline>Development of Drug-Resistant Bacteria</hasWarningHeadline>
    <hasWarningText>Prescribing CONTEPO in the absence of a proven or strongly suspected bacterial infection indication is unlikely to provide benefit to the patient and increases the risk of the development of drug resistant bacteria</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W237">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W237</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R128"/>
    <hasWarningHeadline>Use in Elderly</hasWarningHeadline>
    <hasWarningText>Elderly patients are more likely to have decreased renal function, therefore, care should be taken in dose selection and renal function should be monitored.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN164">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN164</rdfs:label>
    <hasClinicalEffects>bacteriostatic drugs interfere with the bactericidal action of penicillin</hasClinicalEffects>
    <hasInteractionDescription>Since bacteriostatic drugs interfere with the bactericidal action of penicillin, it is advisable to avoid giving tetracyclines in conjuction with penicillin</hasInteractionDescription>
    <hasManagementAdvice>avoid giving tetracyclines in conjuction with penicillin</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <interactsWith rdf:resource="http://example.org/ontology#S096"/>
  </rdf:Description>
