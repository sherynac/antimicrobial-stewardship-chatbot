  <rdf:Description rdf:about="http://example.org/ontology#ITN088">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN088</rdfs:label>
    <hasClinicalEffects>Digoxin toxicity which includes nausea, arrhythmias</hasClinicalEffects>
    <hasInteractionDescription>Concomitant use of trimethoprim with digoxin has been shown to increase plasma digoxin levels in a proportion of elderly patients. Serum digoxin levels should be monitored.</hasInteractionDescription>
    <hasManagementAdvice>Monitor serum digoxin. Adjust dose to avoid toxicity.</hasManagementAdvice>
