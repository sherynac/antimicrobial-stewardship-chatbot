    <rdfs:label>R187</rdfs:label>
    <hasAuthor>Goyal, A. et al.</hasAuthor>
    <hasReferenceTitle>Systemic Lupus Erythematosus</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2023</publishedIn>
    <retrievedFrom>https://www.ncbi.nlm.nih.gov/books/NBK535405/</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I048">
    <rdf:type rdf:resource="http://example.org/ontology#UrinaryDisease"/>
    <rdfs:label>Chronic Bacterial Prostatis</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R071"/>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
    <hasSymptoms>Fever, chills, painful and frequent urination or have trouble urinating,</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W168">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W168</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasWarningHeadline>Dangerous Combinations</hasWarningHeadline>
    <hasWarningText>Contraindicated for patients with hypersensitivity to macrolides, a history of QT prolongation, or those taking drugs like cisapride, pimozide, ergot alkaloids, ticagrelor, or ranolazine.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Nausea">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Nausea</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Hypokalemia">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Hypokalemia</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE127">
    <rdf:type rdf:resource="http://example.org/ontology#Palpitations"/>
    <rdfs:label>Palpitations</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasReference rdf:resource="http://example.org/ontology#R059"/>
    <hasSideEffectDescription>feeling like your heart is missing heartbeats, racing or pounding felt in chest, throat or neck.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP153">
    <rdf:type rdf:resource="http://example.org/ontology#FoodAndTiming"/>
    <rdfs:label>SP153</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R128"/>
    <hasStewardshipDescription>May be taken with or without food.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#two_months_after_intake">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>two months after intake</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W018">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W018</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasWarningText>Do not use if the patient has a known allergy to fosfomycin. Serious allergic reactions like difficulty breathing, difficulty swallowing, fever, hives, itchy skin, rash, swelling of your tongue, throat or face</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W109">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W109</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasWarningHeadline>Premature &amp; Newborn Infants</hasWarningHeadline>
    <hasWarningText>Premature babies and newborn babies during the first eight weeks of life should
not be given sulfamethoxazole/trimethoprim, as sulfamethoxazole may interfere
with the serum albumin binding of bilirubin to produce kernicterus.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE104">
    <rdf:type rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Pneumonia</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasSideEffectDescription>difficulty breathing that can cause fever and cough with yellow, green or blood mucus</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN148">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN148</rdfs:label>
    <hasClinicalEffects>Elevated drug levels, QT prolongation, and serious cardiac arrhythmias.</hasClinicalEffects>
    <hasInteractionDescription>Concomitant use with clarithromycin.</hasInteractionDescription>
    <hasManagementAdvice>Contraindicated.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R020"/>
    <interactsWith rdf:resource="http://example.org/ontology#S122"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S048">
    <rdf:type rdf:resource="http://example.org/ontology#Food"/>
    <rdfs:label>Food</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasSubstanceDescription>Meals/Diet</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SinglePneumonia">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Single Pneumonia</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#RespiratoryDisease"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE219">
    <rdf:type rdf:resource="http://example.org/ontology#Vomiting"/>
    <rdfs:label>Vomiting</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R210"/>
    <hasSideEffectDescription>Vomiting is when muscles in your belly, chest, neck and head work together to push whatever’s in your stomach out. This forceful expulsion of your stomach’s contents can be a symptom of many conditions</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W279">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W279</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R166"/>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasWarningText>Cotrimoxazole should not be given to patients with history of sensitivity to it or to
sulphonamide or trimethoprim.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ExfoliativeDermatitis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Exfoliative Dermatitis</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN144">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN144</rdfs:label>
    <hasClinicalEffects>May result in death due to cardiac arrhythmias (QT prolongation, ventricular tachycardia, and Torsades de pointes).</hasClinicalEffects>
    <hasInteractionDescription>Concurrent use with Clarithromycin.</hasInteractionDescription>
    <hasManagementAdvice>Contraindicated.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <interactsWith rdf:resource="http://example.org/ontology#S118"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SymptomsOfBowelInflammation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Symptoms of Bowel Inflammation</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP104">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP104</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasStewardshipDescription>Use for treating tonsillitis, pharyngitis and acute otitis media (ear infection) for patients with hypersensitivity to beta-lactam antibiotics or when such treatment is not suitable for other reasons.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE259">
    <rdf:type rdf:resource="http://example.org/ontology#OralThrush"/>
    <rdfs:label>Oral Thrush</rdfs:label>
    <hasDurationOf>3–5 days</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#During_or_after_treatment"/>
    <hasReference rdf:resource="http://example.org/ontology#R032"/>
    <hasSideEffectDescription>White patches in the mouth or on the tongue; a common fungal overgrowth.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE334">
    <rdf:type rdf:resource="http://example.org/ontology#Neutropenia"/>
    <rdfs:label>neutropenia</rdfs:label>
    <hasDurationOf>Neutropenia</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R011"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R190"/>
    <hasSideEffectDescription>having low levels of neutrophils (a type of white blood cell) in blood</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R225">
