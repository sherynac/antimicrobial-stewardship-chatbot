  <rdf:Description rdf:about="http://example.org/ontology#PeripheralNeuropathy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Peripheral Neuropathy</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W112">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W112</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasWarningHeadline>Pregnancy</hasWarningHeadline>
    <hasWarningText>Sulfonamides may cause kernicterus in babies during the first month of life by displacing bilirubin from plasma albumin. Sulfonamides should therefore be avoided as far as possible during the last month of pregnancy. Trimethoprim may interfere with folic acid metabolism and animal experiments have shown that administration of very high doses of trimethoprim during organ development may give rise to birth defects typical of folic acid antagonism. If a trimethoprim-sulfonamide combination is given during pregnancy, folic acid supplementation may be required. Because trimethoprim and sulfamethoxazole may interfere with folic acid metabolism, DBL Sulfamethoxazole 400 mg and Trimethoprim 80 mg should be used during pregnancy only if the potential benefit justifies the potential risk to the fetus.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#A055">
    <rdf:type rdf:resource="http://example.org/ontology#OralSuspension"/>
    <rdfs:label>Oral Suspension</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#AllergicMyocarditis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Allergic Myocarditis</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S140">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Antacids, Sucralfate, Metal Cations, Multivitamins</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasSubstanceDescription>Antacids containing magnesium or aluminum, as well as sucralfate metal cations such as iron and multivitamin preparations with zinc</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE003">
    <rdf:type rdf:resource="http://example.org/ontology#StomachPain"/>
    <rdfs:label>Stomach Pain</rdfs:label>
    <hasDurationOf>1-3 days</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Early_during_treatment"/>
    <hasReference rdf:resource="http://example.org/ontology#R022"/>
    <hasReference rdf:resource="http://example.org/ontology#R023"/>
    <hasSideEffectDescription>Discomfort or pain in the lower abdomen.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE539">
    <rdf:type rdf:resource="http://example.org/ontology#Drowsiness"/>
    <rdfs:label>Drowsiness</rdfs:label>
    <hasDurationOf>Few hours</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#May_appear_after_dose"/>
    <hasReference rdf:resource="http://example.org/ontology#R163"/>
    <hasReference rdf:resource="http://example.org/ontology#R164"/>
    <hasSideEffectDescription>Feeling sleepy.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#RenalImpairment">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Renal Impairment</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE018">
    <rdf:type rdf:resource="http://example.org/ontology#AbdominalPain"/>
    <rdfs:label>Abdominal Pain</rdfs:label>
    <hasDurationOf>1-2 days</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R024"/>
    <hasSideEffectDescription>Mild stomach cramps or discomfort.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W196">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W196</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasWarningHeadline>QT Interval</hasWarningHeadline>
    <hasWarningText>Levofloxacin should be avoided in patients with known prolongation of the QT interval, patients with uncorrected electrolyte imbalance (e.g., hypokalemia and
hypomagnesemia) patients with cardiac disease (e.g., heart failure, myocardial infarction and bradycardia), and in patients receiving drugs that are known to prolong the QT interval such as Class IA (quinidine, procainamide), or Class III (amiodarone, sotalol) antiarrhythmic agents, tricyclic antidepressants, macrolides and antipsychotics.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN004">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN004</rdfs:label>
    <hasClinicalEffects>Fosfomycin may be less effective at treating infection.</hasClinicalEffects>
    <hasInteractionDescription>Metoclopramide may reduce absorption of fosfomycin.</hasInteractionDescription>
    <hasManagementAdvice>Inform your doctor; avoid taking metoclopramide at the same time as fosfomycin if possible.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R022"/>
    <hasReference rdf:resource="http://example.org/ontology#R023"/>
    <interactsWith rdf:resource="http://example.org/ontology#S004"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R226">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R226</rdfs:label>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <hasReferenceTitle>Agitation</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2024</publishedIn>
    <retrievedFrom>https://my.clevelandclinic.org/health/symptoms/agitation</retrievedFrom>
  </rdf:Description>
