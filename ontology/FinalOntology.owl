    <hasSymptoms>High fever, cough, tiredness, rapid breathing or heart rate, shortness of breath</hasSymptoms>
    <hasReference rdf:resource="http://example.org/ontology#R081"/>
    <hasReference rdf:resource="http://example.org/ontology#R020"/>
    <hasReference rdf:resource="http://example.org/ontology#R003"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#MildToSevere"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP099">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP099</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasStewardshipDescription>Monitor for signs of hepatitis (jaundice, dark urine, tender abdomen) and discontinue immediately if they occur</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE039">
    <rdf:type rdf:resource="http://example.org/ontology#Diarrhea"/>
    <rdfs:label>Diarrhea</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <hasReference rdf:resource="http://example.org/ontology#R076"/>
    <whichIs rdf:resource="http://example.org/ontology#Common"/>
    <hasSideEffectDescription>Effects are usually mild. Loose, watery stools during a bowl movement</hasSideEffectDescription>
    <hasDuration>Not Specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE574">
    <rdf:type rdf:resource="http://example.org/ontology#Rash"/>
    <rdfs:label>rash</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R212"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>can be red, inflamed, bumpy as well as dry, itchy or painful</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Common"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W220">
