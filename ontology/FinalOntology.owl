  <rdf:Description rdf:about="http://example.org/ontology#SE542">
    <rdf:type rdf:resource="http://example.org/ontology#SeriousPulmonaryReaction"/>
    <rdfs:label>Serious Pulmonary Reaction</rdfs:label>
    <hasDurationOf>Weeks to Months</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Rare__usually_with_long-term_use__6__months_"/>
    <hasReference rdf:resource="http://example.org/ontology#R163"/>
    <hasSideEffectDescription>Cough, fever, chest pain, shortness of breath.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Esophagitis">
