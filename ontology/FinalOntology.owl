    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Zidovudine</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasSubstanceDescription>An antiretroviral medication for HIV-infected patients.</hasSubstanceDescription>
