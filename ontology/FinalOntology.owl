  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#PeripheralEdema">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Peripheral Edema</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W164">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W164</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasWarningHeadline>Safety Not Established</hasWarningHeadline>
    <hasWarningText>Use is not advised without carefully weighing benefits against risk, as adverse embryo-fetal development effects cannot be excluded. Clarithromycin is excreted into human breast milk.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R157">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R157</rdfs:label>
    <hasAuthor>Courtney Zeigler reviewed by Laurel Reimann</hasAuthor>
