  <rdf:Description rdf:about="http://example.org/ontology#ITN141">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN141</rdfs:label>
    <hasInteractionDescription>Concomitant use with Clarithromycin.</hasInteractionDescription>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasClinicalEffects>Potentiates anticoagulant effects; risk of serious hemorrhage and significant elevations in INR and prothrombin time.</hasClinicalEffects>
    <interactsWith rdf:resource="http://example.org/ontology#S115"/>
    <hasManagementAdvice>Frequently monitor prothrombin time and International Normalized Ratio (INR).</hasManagementAdvice>
  </rdf:Description>
