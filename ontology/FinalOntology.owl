    <hasReferenceTitle>Neutropenia</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</publishedIn>
    <retrievedFrom>https://www.mayoclinic.org/symptoms/neutropenia/basics/definition/sym-20050854</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE525">
    <rdf:type rdf:resource="http://example.org/ontology#RustColoredUrine"/>
    <rdfs:label>Rust-colored Urine</rdfs:label>
    <hasDurationOf>While taking medicine</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Appears_soon_after_starting"/>
    <hasReference rdf:resource="http://example.org/ontology#R161"/>
    <hasSideEffectDescription>Urine may look brownish, harmless but normal.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ErythematousRashes">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Erythematous Rashes</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN126">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN126</rdfs:label>
    <hasClinicalEffects>Decreased absorption</hasClinicalEffects>
    <hasInteractionDescription>Carbamazepine decrease the half-life of doxycycline</hasInteractionDescription>
    <hasManagementAdvice>Avoid taking together</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R011"/>
    <interactsWith rdf:resource="http://example.org/ontology#S100"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Vomiting">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Vomiting</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W188">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W188</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasWarningHeadline>Patients treated with Vitamin K antagonists</hasWarningHeadline>
    <hasWarningText>Due to possible increase in coagulation tests (PT/INR) and/or bleeding in patients treated with levofloxacin in combination with a vitamin K antagonist (e.g., warfarin), coagulation tests should be monitored when these drugs are given concomitantly.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP130">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP130</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasStewardshipDescription>Store in cool, dry place.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W062">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W062</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasWarningHeadline>Breastfeeding</hasWarningHeadline>
    <hasWarningText>Azithromycin is secreted into human breast milk. A risk to the newborn/infant cannot be excluded. A decision must be made whether to discontinue breastfeeding or discontinue the drug, taking into account the benefit of breastfeeding to the child and the benefit of therapy to the mother.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Diarrhea">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Diarrhea</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE065">
    <rdf:type rdf:resource="http://example.org/ontology#Headache"/>
    <rdfs:label>Headache</rdfs:label>
    <hasDurationOf>Few hours to a day</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Common__may_happen_during_treatment"/>
    <hasReference rdf:resource="http://example.org/ontology#R027"/>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasSideEffectDescription>Mild to moderate head pain; usually temporary.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP141">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP141</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasStewardshipDescription>Store at temperatures not exceeding 25°C</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE359">
    <rdf:type rdf:resource="http://example.org/ontology#AnaphylactoidPurpura"/>
    <rdfs:label>anaphylactoid purpura</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#frequency_not_reported"/>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R184"/>
    <hasSideEffectDescription>raised, reddish-purple rash, commonly on the legs, buttocks, and feet</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#VaginalItching">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Vaginal Itching</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W044">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W044</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R029"/>
    <hasWarningHeadline>Allergy</hasWarningHeadline>
    <hasWarningText>Do not take this medication if allergic to fosfomycin or any ingredients of the medication.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SystemicLupusErythematosus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Systemic Lupus Erythematosus</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN193">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN193</rdfs:label>
    <hasClinicalEffects>Not Specified</hasClinicalEffects>
    <hasInteractionDescription>Due to the theoretical possibility of ergotism, the concurrent use of azithromycin with ergot derivatives is not recommended</hasInteractionDescription>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <interactsWith rdf:resource="http://example.org/ontology#S123"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP069">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP069</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R032"/>
    <hasStewardshipDescription>Must be reconstituted correctly and administered by a healthcare professional via IV or IM to ensure correct dosage and effectiveness.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Can_appear_during_early_treatment">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Can appear during early treatment</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S066">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>CYP2C8 / CYP2C9 / OCT2 substrate drugs</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasSubstanceDescription>Drugs metabolized/eliminated by these pathways</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE288">
    <rdf:type rdf:resource="http://example.org/ontology#CardiacArrhythmias"/>
    <rdfs:label>Cardiac Arrhythmias</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Associated_with_drug_interactions"/>
    <hasReference rdf:resource="http://example.org/ontology#R020"/>
    <hasSideEffectDescription>QT prolongation, ventricular tachycardia, ventricular fibrillation, and torsades de pointes.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S120">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Calcium Channel Blockers (e.g., Verapamil)</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasSubstanceDescription>Medications used for high blood pressure or heart conditions.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE238">
    <rdf:type rdf:resource="http://example.org/ontology#Arthralgia"/>
    <rdfs:label>Arthralgia</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R314"/>
    <hasSideEffectDescription>Arthritis isn't a single condition but a broad term for many conditions affecting the joints. Arthritis typically is associated with pain that affects the ability to move a joint. It causes swelling and tenderness of one or more joints. The main symptoms are joint pain and stiffness, which can impact daily activities and work.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE481">
    <rdf:type rdf:resource="http://example.org/ontology#Catatonia"/>
    <rdfs:label>Catatonia</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R093"/>
    <hasReference rdf:resource="http://example.org/ontology#R134"/>
    <hasSideEffectDescription>Catatonia is a disorder that disrupts a person’s awareness of the world around them. People with this condition sometimes react very little or not at all to their surroundings, or might behave in ways that are unusual, unexpected or unsafe to themselves or others.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE128">
    <rdf:type rdf:resource="http://example.org/ontology#HotFlush"/>
    <rdfs:label>Hot flush</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasSideEffectDescription>sudden feeling of warmth in the upper body mostly affecting the face, neck and chest</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S056">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Warfarin / Anticoagulants</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasSubstanceDescription>Vitamin K antagonist</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN203">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN203</rdfs:label>
    <hasClinicalEffects>Elevated serum theophylline levels and increased risk of a patient developing CNS or other adverse reactions.</hasClinicalEffects>
    <hasInteractionDescription>Concomitant administration of ciprofloxacin with theophylline decreases the clearance of theophylline</hasInteractionDescription>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <interactsWith rdf:resource="http://example.org/ontology#S088"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I059">
    <rdf:type rdf:resource="http://example.org/ontology#BladderInfection"/>
    <rdfs:label>Mild to Moderate Bladder Infection</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#MildToModerate"/>
    <hasSymptoms>Pain or pressure in the lower abdomen and a burning feeling during urination. The person may need to urinate very often. Urine may appear cloudy and sometimes may have small amounts of blood.</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R307">
