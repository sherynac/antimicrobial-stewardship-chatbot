  <rdf:Description rdf:about="http://example.org/ontology#W236">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W236</rdfs:label>
    <hasWarningText>The safety and efficacy of cefixime in children less than six (6) months old have not been established. The incidence of GI adverse reactions such as diarrhea and loose stools, in children receiving cefixime suspension, was comparable to the incidence seen in adults receiving cefixime tablets.</hasWarningText>
    <hasWarningHeadline>Use in Children</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R128"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R246">
