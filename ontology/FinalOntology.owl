  <rdf:Description rdf:about="http://example.org/ontology#SE517">
    <rdf:type rdf:resource="http://example.org/ontology#LossOfAppetite"/>
    <rdfs:label>Loss of Appetite</rdfs:label>
    <hasDurationOf>Short-term</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#During_therapy"/>
    <hasReference rdf:resource="http://example.org/ontology#R158"/>
    <hasSideEffectDescription>Decreased desire to eat. The patient may feel full quickly or uninterested in food while taking the medicine.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#HaemophagocyticLymphohistiocytosis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Haemophagocytic Lymphohistiocytosis</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
