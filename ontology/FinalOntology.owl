  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE158">
    <rdf:type rdf:resource="http://example.org/ontology#Photosensitivity"/>
    <rdfs:label>Photosensitivity</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <hasReference rdf:resource="http://example.org/ontology#R063"/>
    <hasSideEffectDescription>Skin reacts negatively to sunlight or UV rays that causes an itchy, painful rash</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W181">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W181</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasWarningHeadline>Neuropathy Symptoms</hasWarningHeadline>
    <hasWarningText>Levofloxacin should be discontinued if the patient experiences symptoms of neuropathy including pain, burning, tingling, numbness and/or weakness or other alterations of sensation including light touch, pain, temperature position sense and vibratory sensation in order to prevent the development of an irreversible condition.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Hypersensitivity">
