  <rdf:Description rdf:about="http://example.org/ontology#SE551">
    <rdf:type rdf:resource="http://example.org/ontology#Diarrhea"/>
    <rdfs:label>Diarrhea</rdfs:label>
    <hasDurationOf>Usually short-term; may last a few days</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#May_occur_anytime_during_treatment"/>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasSideEffectDescription>Passing loose or watery stools more often than normal. It may be mild but should be monitored if severe or persistent.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP064">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP064</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasStewardshipDescription>The bottle must be shaken well before taking each dose to ensure the medication is evenly distributed</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I022">
    <rdf:type rdf:resource="http://example.org/ontology#DisseminatedMycobacteriumAviumComplexMACDisease"/>
    <rdfs:label>Disseminated Mycobacterium avium complex (MAC) disease</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <hasReference rdf:resource="http://example.org/ontology#R094"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
    <hasSymptoms>Fever, night sweats, weight loss, fatigue, diarrhea, abdominal pain, anemia and elevated liver alkaline phosphatase levels.</hasSymptoms>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE556">
    <rdf:type rdf:resource="http://example.org/ontology#LupusLikeSyndrome"/>
    <rdfs:label>Lupus-like Syndrome</rdfs:label>
    <hasDurationOf>Nat develop during prolonged therapy; improves after stopping medicine</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Rare_and_usually_associated_with_long-term_use"/>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasSideEffectDescription>A reaction that causes symptoms similar to lupus, such as joint pain, muscle pain, fever, and skin rash. Symptoms usually improve when the medicine is discontinued.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Pharyngitis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Pharyngitis</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#RespiratoryDisease"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN242">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN242</rdfs:label>
    <hasClinicalEffects>Not Specified</hasClinicalEffects>
    <hasInteractionDescription>Not Specified</hasInteractionDescription>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R133"/>
    <interactsWith rdf:resource="http://example.org/ontology#S028"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Rare__can_happen">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Rare, can happen</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W071">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W071</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R014"/>
    <hasWarningHeadline>Breastfeeding</hasWarningHeadline>
    <hasWarningText>No adverse effects have been found on breast-fed infants whose mothers were receiving cefotaxime</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S126">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Zidovudine</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasSubstanceDescription>An antiretroviral medication for HIV-infected patients.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE276">
    <rdf:type rdf:resource="http://example.org/ontology#StomatitisOrGlossitis"/>
    <rdfs:label>Stomatitis / Glossitis</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <hasSideEffectDescription>Inflammation of the mouth or tongue; may include tooth decoloration.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W166">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W166</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasWarningHeadline>Renal and Hepatic Impairment</hasWarningHeadline>
    <hasWarningText>Caution is advised in patients with severe renal insufficiency or impaired hepatic function. Fatal hepatic failure has been reported in some cases.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN256">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN256</rdfs:label>
    <hasClinicalEffects>Increased blood levels may raise the chance of side effects, while decreased urinary levels may reduce the drug's effectiveness in treating urinary infections.</hasClinicalEffects>
    <hasInteractionDescription>Sulfinpyrazone also decreases the excretion of Nitrofurantoin by the kidneys. This changes the normal balance of the drug in the body.</hasInteractionDescription>
    <hasManagementAdvice>Use with caution and only under medical supervision. Report any unusual side effects or persistent infection symptoms.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <interactsWith rdf:resource="http://example.org/ontology#S175"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S138">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Nonsteroidal Anti-inflammatory Drugs (NSAIDs)</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasSubstanceDescription>medications that reduce inflammation, pain and fever.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE069">
    <rdf:type rdf:resource="http://example.org/ontology#Hypophosphatemia"/>
    <rdfs:label>Hypophosphatemia</rdfs:label>
    <hasDurationOf>During treatment</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Common__can_happen_while_on_drug"/>
    <hasReference rdf:resource="http://example.org/ontology#R027"/>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasSideEffectDescription>Low phosphate; may cause weakness or bone/muscle pain; usually mild.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE233">
    <rdf:type rdf:resource="http://example.org/ontology#StevensJohnsonSyndrome"/>
    <rdfs:label>Stevens-Johnson syndrome</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R120"/>
    <hasSideEffectDescription>Stevens-Johnson syndrome (SJS) is a rare, serious disorder of the skin and mucous membranes. It's usually a reaction to medication that starts with flu-like symptoms, followed by a painful rash that spreads and blisters. Then the top layer of affected skin dies, sheds and begins to heal after several days.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE559">
    <rdf:type rdf:resource="http://example.org/ontology#Thrombocytopenia"/>
    <rdfs:label>Thrombocytopenia</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R140"/>
    <hasSideEffectDescription>Thrombocytopenia occurs when your bone marrow doesn’t make enough platelets. Platelets are blood cells that form blood clots to help stop bleeding. People with this condition may bleed a lot and the bleeding may be hard to stop. Thrombocytopenia affects people with certain medical conditions like autoimmune disease or who take certain medications.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE637">
    <rdf:type rdf:resource="http://example.org/ontology#ChestPain"/>
    <rdfs:label>chest pain</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Common"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R216"/>
    <hasSideEffectDescription>pain or discomfort in the area between the neck and belly</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN090">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN090</rdfs:label>
    <hasClinicalEffects>Decreased TCA efficacy</hasClinicalEffects>
    <hasInteractionDescription>The efficacy of tricyclic antidepressants can decrease when co-administered with sulfamethoxazole/trimethoprim.</hasInteractionDescription>
    <hasManagementAdvice>Monitor therapeutic response. Adjust TCA dose if efficacy decreases.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <interactsWith rdf:resource="http://example.org/ontology#S064"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R039">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R039</rdfs:label>
    <hasAuthor>Monthly Index of Medical Specialties</hasAuthor>
    <hasReferenceTitle>Zenith</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</publishedIn>
    <retrievedFrom>https://www.mims.com/philippines/drug/info/zenith/presentation-and-price</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W197">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W197</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R009"/>
    <hasWarningHeadline>QT Interval</hasWarningHeadline>
    <hasWarningText>Elderly patients and women may be more susceptible to drug-associated effects on the QT interval.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Pyelonephritis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Pyelonephritis</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#UrinaryDisease"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN086">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN086</rdfs:label>
    <hasClinicalEffects>Reversible nephrotoxicity</hasClinicalEffects>
    <hasInteractionDescription>Deterioration in renal function in patients with renal transplants. There have been reports of marked but reversible nephrotoxicity with co-&#13;
administration of sulfamethoxazole/trimethoprim and ciclosporin in renal transplant recipients.</hasInteractionDescription>
    <hasManagementAdvice>Avoid combination if possible. Monitor renal function.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <interactsWith rdf:resource="http://example.org/ontology#S060"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S083">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Rifampicin</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <hasSubstanceDescription>Potent enzyme-inducing antibiotic; may reduce effectiveness of concurrent meds.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S137">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Ergot alkaloids (e.g., Ergotamine)</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasSubstanceDescription>Migraine medications.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R107">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R107</rdfs:label>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <hasReferenceTitle>Corticosteroids (Glucocorticoids)</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2024</publishedIn>
    <retrievedFrom>https://my.clevelandclinic.org/health/treatments/corticosteroids-glucocorticoids</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S159">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Furosemide</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R148"/>
    <hasSubstanceDescription>FUROSEMIDE treats high blood pressure. It may also be used to reduce swelling related to heart, kidney, or liver disease. It helps your kidneys remove more fluid and salt from your blood through the urine. It belongs to a group of medications called diuretics.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE364">
    <rdf:type rdf:resource="http://example.org/ontology#JarischHerxheimerReaction"/>
    <rdfs:label>Jarisch-Herxheimer reaction</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasReference rdf:resource="http://example.org/ontology#R201"/>
    <hasSideEffectDescription>new or worsening symptoms within a few hours of starting treatment for syphilis or certain other bacterial infections</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE650">
    <rdf:type rdf:resource="http://example.org/ontology#Tremor"/>
    <rdfs:label>tremor</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R229"/>
    <hasSideEffectDescription>body movement that’s out of your control</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP048">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <rdfs:label>SP048</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <hasStewardshipDescription>Store at temperatures not exceeding 30°C</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R313">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R313</rdfs:label>
    <hasAuthor>Scholastica</hasAuthor>
    <hasReferenceTitle>Drug Reaction with Eosinophilia and Systemic Symptoms Secondary to Ethambutol</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</publishedIn>
    <retrievedFrom>https://bhm.scholasticahq.com/article/144176-drug-reaction-with-eosinophilia-and-systemic-symptoms-secondary-to-ethambutol</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W125">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W125</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <hasWarningHeadline>Penicillin Sensitivity</hasWarningHeadline>
    <hasWarningText>Hypersensitivity to penicillins and to any ingredient in the products. Patients with infectious mononucleosis due to possible development of rash during therapy.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W177">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W177</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R013"/>
    <hasWarningHeadline>Pediatric Use</hasWarningHeadline>
    <hasWarningText>The use of drugs of the tetracycline class during tooth development (last half of pregnancy, infancy and childhood to the age of 8 years) may cause permanent discoloration of the teeth (yellow-gray-brown). This adverse reaction is more common during long term use of the drugs but has been observed following repeated short-term courses. Enamel hypoplasia has also been reported. Tetracycline drugs, therefore, should not be used in this age group unless other drugs are not likely to be effective or as contraindicated.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W266">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W266</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R163"/>
    <hasWarningHeadline>Acute Overdose</hasWarningHeadline>
    <hasWarningText>Incidents of acute overdosage of FURADANTIN have resulted in symptoms such as vomiting. Induction of emesis is recommended. There is no specific antidote, but a high fluid intake should be maintained to promote urinary excretion of the drug. Nitrofurantoin is dialyzable.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R125">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R125</rdfs:label>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <hasReferenceTitle>Agitation</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2024</publishedIn>
    <retrievedFrom>https://my.clevelandclinic.org/health/symptoms/agitation</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN080">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN080</rdfs:label>
    <hasClinicalEffects>Pancytopenia, marrow suppression, increased toxicity</hasClinicalEffects>
    <hasInteractionDescription>Sulfonamides such as sulfamethoxazole may displace methotrexate from protein binding sites and can compete with the renal transport of methotrexate, thereby increasing free methotrexate levels. Cases of pancytopenia have been reported in patients taking the combination of sulfamethoxazole/trimethoprim and methotrexate.</hasInteractionDescription>
    <hasManagementAdvice>Avoid combination. Monitor for increased free methotrexate and marrow suppression.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <interactsWith rdf:resource="http://example.org/ontology#S054"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN115">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN115</rdfs:label>
    <hasClinicalEffects>Increased plasma carbamazepine levels.</hasClinicalEffects>
    <hasInteractionDescription>Concurrent use.</hasInteractionDescription>
    <hasManagementAdvice>Consider blood level monitoring.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <interactsWith rdf:resource="http://example.org/ontology#S089"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE354">
    <rdf:type rdf:resource="http://example.org/ontology#ExfoliativeDermatitis"/>
    <rdfs:label>exfoliative dermatitis</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#uncommon"/>
