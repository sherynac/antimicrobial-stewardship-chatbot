  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP079">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP079</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R016"/>
    <hasStewardshipDescription>Administered orally. May be taken with or without food. Prescribe only for proven or strongly suspected bacterial infections to prevent the development of drug-resistant bacteria.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP020">
    <rdf:type rdf:resource="http://example.org/ontology#TherapeuticUseAndMonitoring"/>
    <rdfs:label>SP020</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <hasStewardshipDescription>Watch for severe diarrhea that may indicate C. difficile infection.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W093">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W093</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasWarningHeadline>Crystalluria &amp; Renal Risk</hasWarningHeadline>
    <hasWarningText>High doses may cause crystalluria, potentially leading to renal failure. Maintain adequate fluid intake.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE215">
    <rdf:type rdf:resource="http://example.org/ontology#Dyspnoea"/>
    <rdfs:label>dyspnoea</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R303"/>
    <hasSideEffectDescription>Dyspnea, or shortness of breath, is the feeling that you can’t get enough air into your lungs. It might feel like your chest is tight, you’re gasping for air or you’re working harder to breathe. Heart and lung conditions are common causes of dyspnea.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Rare__may_appear_after_prolonged_use">
    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Rare; may appear after prolonged use</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE088">
    <rdf:type rdf:resource="http://example.org/ontology#Diarrhea"/>
    <rdfs:label>Diarrhea</rdfs:label>
    <hasDurationOf>Short-term</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Can_occur_within_first_days"/>
    <hasReference rdf:resource="http://example.org/ontology#R029"/>
    <hasReference rdf:resource="http://example.org/ontology#R030"/>
    <hasSideEffectDescription>Mild loose stools; monitor for severe watery or bloody diarrhea.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE594">
    <rdf:type rdf:resource="http://example.org/ontology#Vertigo"/>
    <rdfs:label>vertigo</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Uncommon"/>
