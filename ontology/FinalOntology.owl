    <hasAuthor>Cleveland Clinic</hasAuthor>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2023</publishedIn>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n0e9bfaaca0144c75b7bd81f48c0754bfb27">
    <rdf:first rdf:resource="http://example.org/ontology#Drug"/>
    <rdf:rest rdf:nodeID="n0e9bfaaca0144c75b7bd81f48c0754bfb28"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN006">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN006</rdfs:label>
    <hasClinicalEffects>No effect on drug levels or effectiveness.</hasClinicalEffects>
    <hasReference rdf:resource="http://example.org/ontology#R024"/>
    <interactsWith rdf:resource="http://example.org/ontology#S005"/>
    <hasManagementAdvice>No speicla precautions needed.</hasManagementAdvice>
    <hasInteractionDescription>Cimetidine does not affect Fosfomycin Tromethamine absorption or blood levels.</hasInteractionDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE521">
    <rdf:type rdf:resource="http://example.org/ontology#PeripheralNeuropathy"/>
    <rdfs:label>Peripheral Neuropathy</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R158"/>
    <hasSideEffectDescription>Damage to nerves that may cause numbness, tingling, burning, or weakness in the hands and feet. Risk is higher in patients with kidney problems or long-term use.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Rare__higher_risk_in_kidney_disease"/>
    <hasDuration>May last if not treated early</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W078">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W078</rdfs:label>
    <hasWarningHeadline>Lactation</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R031"/>
    <hasWarningText>Despite the excretion of trimethoprim and sulphamethoxazole into breast milk, the administration of comazole to lactating women represents a negligible risk to the suckling infants. It also should be used with caution in nursing
mothers because it can pass the placenta and is excreted in breast milk and may cause kernicterus.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S067">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Dofetilide</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasSubstanceDescription>Class III antiarrhythmic</hasSubstanceDescription>
  </rdf:Description>
