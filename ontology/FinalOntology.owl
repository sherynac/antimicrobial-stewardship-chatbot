  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE557">
    <rdf:type rdf:resource="http://example.org/ontology#Megaloblastosis"/>
    <rdfs:label>Megaloblastosis</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R317"/>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>Megaloblastosis is a cytomorphological diagnostic sign for megaloblastic anaemia, which is a morphological and functional erythropoiesis abnormality. At all stages of maturity, megaloblasts have various cytomorphological traits that distinguish them from normal erythroid precursor cells (i.e., normoblasts).</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  </rdf:Description>
