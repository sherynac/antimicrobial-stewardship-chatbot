    <rdf:type rdf:resource="http://example.org/ontology#JarischHerxheimerReaction"/>
    <rdfs:label>Jarisch-Herxheimer reaction</rdfs:label>
    <hasSideEffectDescription>new or worsening symptoms within a few hours of starting treatment for syphilis or certain other bacterial infections</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R201"/>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasReference rdf:resource="http://example.org/ontology#R077"/>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  </rdf:Description>
