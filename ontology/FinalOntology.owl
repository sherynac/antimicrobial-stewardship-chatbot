  <rdf:Description rdf:about="http://example.org/ontology#W150">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W150</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R012"/>
    <hasWarningHeadline>Risk of Severe Diarrhea (C. difficile Infection)</hasWarningHeadline>
    <hasWarningText>Clostridium difficile associated diarrhea (CDAD) has been reported with use of nearly all antibacterial agents, including Doxycycline, and may range in severity from mild diarrhea to fatal colitis.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN014">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN014</rdfs:label>
    <hasClinicalEffects>Increased risk of hypokalemia (weakness, irregular heartbeat).</hasClinicalEffects>
    <hasInteractionDescription>Fosfomycin may lower potassium levels, and furosemide can also reduce potassium.</hasInteractionDescription>
    <hasManagementAdvice>Monitor potassium levels regularly.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <interactsWith rdf:resource="http://example.org/ontology#S012"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP175">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP175</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasStewardshipDescription>The medicine should be taken exactly as prescribed by the doctor. Adults should take 50–100 mg every 6 hours with meals, and children should take the prescribed dose based on body weight. Taking it with food helps improve absorption and reduces stomach upset. Do not skip doses and complete the full course even if symptoms improve early.</hasStewardshipDescription>
  </rdf:Description>
