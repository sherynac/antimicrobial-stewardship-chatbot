    <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    <rdfs:label>Can occur during treatment</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN200">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN200</rdfs:label>
    <hasClinicalEffects>Overall absorption of Ciprofloxacin is not substantially affected</hasClinicalEffects>
    <hasInteractionDescription>When Ciprofloxacin is given concomitantly with food, there is a delay in the absorption of the drug, resulting in peak concentrations that occur closer to 2 hours after dosing rather than 1 hour.</hasInteractionDescription>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <interactsWith rdf:resource="http://example.org/ontology#S048"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE661">
    <rdf:type rdf:resource="http://example.org/ontology#Gastritis"/>
    <rdfs:label>gastritis</rdfs:label>
    <hasDurationOf>Not Specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R240"/>
    <hasSideEffectDescription>inflammation in the soft mucous lining of your stomach</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN117">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
