    <hasWarningHeadline>Not for Children &lt;12</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R020"/>
    <hasWarningText>Indicated for adults and children 12 years and older. It is not recommended for children younger than 12 years; they should use the paediatric suspension instead.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN262">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN262</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R166"/>
