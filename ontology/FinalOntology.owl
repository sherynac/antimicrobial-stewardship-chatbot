  <rdf:Description rdf:about="http://example.org/ontology#ITN026">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN026</rdfs:label>
    <interactsWith rdf:resource="http://example.org/ontology#S020"/>
    <hasClinicalEffects>Reduced antibiotic efficacy.</hasClinicalEffects>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasInteractionDescription>Calcium can bind to the drug and reduce its effectiveness.</hasInteractionDescription>
    <hasManagementAdvice>Take calcium supplements at least 2 hours before or after the dose.</hasManagementAdvice>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN200">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN200</rdfs:label>
    <hasClinicalEffects>Overall absorption of Ciprofloxacin is not substantially affected</hasClinicalEffects>
    <hasInteractionDescription>When Ciprofloxacin is given concomitantly with food, there is a delay in the absorption of the drug, resulting in peak concentrations that occur closer to 2 hours after dosing rather than 1 hour.</hasInteractionDescription>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <interactsWith rdf:resource="http://example.org/ontology#S048"/>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE194">
    <rdf:type rdf:resource="http://example.org/ontology#Hyperkalaemia"/>
    <rdfs:label>hyperkalaemia</rdfs:label>
    <hasSideEffectDescription>Hyperkalemia is a condition in which you have high potassium levels in your blood. You may not have any symptoms, or they may be easy to dismiss. Severe symptoms may cause muscle weakness or affect your heart.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasDuration>Not specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R289"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
  </rdf:Description>
