    <hasSubstanceDescription>Treats occasional diarrhea</hasSubstanceDescription>
    <hasReference rdf:resource="http://example.org/ontology#R048"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN075">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN075</rdfs:label>
    <hasClinicalEffects>Inhibits renal tubular secretion, increasing drug levels</hasClinicalEffects>
    <hasInteractionDescription>Concurrent use with aminopenicillins</hasInteractionDescription>
    <hasManagementAdvice>Carefully monitor clinical status during co-administration</hasManagementAdvice>
    <interactsWith rdf:resource="http://example.org/ontology#S049"/>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R160">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R160</rdfs:label>
