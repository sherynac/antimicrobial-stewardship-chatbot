    <hasDuration>Not Specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R247"/>
    <hasSideEffectDescription>If your blood test showed high (elevated) levels of liver enzymes, you could have a medical condition. Elevated liver enzymes may also be temporary.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN113">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN113</rdfs:label>
    <interactsWith rdf:resource="http://example.org/ontology#S087"/>
    <hasInteractionDescription>Inhibits clarithromycin metabolism.</hasInteractionDescription>
    <hasManagementAdvice>Monitor for increased side effects.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <hasClinicalEffects>Elevated plasma levels and prolonged half-life.</hasClinicalEffects>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE508">
    <rdf:type rdf:resource="http://example.org/ontology#Thrombocytopenia"/>
    <rdfs:label>Thrombocytopenia</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R140"/>
    <hasReference rdf:resource="http://example.org/ontology#R133"/>
    <hasDuration>Not Specified</hasDuration>
    <hasSideEffectDescription>low blood platelet count</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP088">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP088</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <hasStewardshipDescription>Usual duration of treatment is 5 to 10 days depending on severity. Ensure zidovudine and Klaryth doses are separated as advised to maintain efficacy.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Tinnitus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Tinnitus</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W109">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W109</rdfs:label>
    <hasWarningHeadline>Premature &amp; Newborn Infants</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasWarningText>Premature babies and newborn babies during the first eight weeks of life should
not be given sulfamethoxazole/trimethoprim, as sulfamethoxazole may interfere
with the serum albumin binding of bilirubin to produce kernicterus.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S153">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Macrolide antibiotics</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R109"/>
    <hasSubstanceDescription>Macrolides are a class of antibiotics that treat a wide range of bacterial infections, including walking pneumonia, whooping cough and strep throat. Commonly prescribed macrolides include azithromycin, clarithromycin, erythromycin, and fidaxomicin.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN146">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN146</rdfs:label>
    <hasClinicalEffects>Risk of hypotension and acute kidney injury, particularly in elderly patients.</hasClinicalEffects>
    <hasManagementAdvice>Use with caution</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasInteractionDescription>Concomitant administration of drugs metabolized by CYP3A4.</hasInteractionDescription>
    <interactsWith rdf:resource="http://example.org/ontology#S120"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R033">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R033</rdfs:label>
    <retrievedFrom>https://www.ncbi.nlm.nih.gov/books/NBK574530/</retrievedFrom>
    <hasAuthor>National Library of Medicine</hasAuthor>
    <hasReferenceTitle>Toxic Epidermal Necrolysis</hasReferenceTitle>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2023</publishedIn>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE215">
    <rdf:type rdf:resource="http://example.org/ontology#Dyspnoea"/>
    <rdfs:label>dyspnoea</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R303"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasDuration>Not specified</hasDuration>
    <hasSideEffectDescription>Dyspnea, or shortness of breath, is the feeling that you can’t get enough air into your lungs. It might feel like your chest is tight, you’re gasping for air or you’re working harder to breathe. Heart and lung conditions are common causes of dyspnea.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE234">
    <rdf:type rdf:resource="http://example.org/ontology#ToxicEpidermalNecrolysis"/>
    <rdfs:label>toxic epidermal necrolysis</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R121"/>
    <hasSideEffectDescription>Toxic epidermal necrolysis (TEN) is a life-threatening skin condition. It causes peeling and blistering skin over much of the body, including the mouth, eyes, and genitals. TEN is the most severe form of Stevens-Johnson syndrome.</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasDuration>Not specified</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN029">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN029</rdfs:label>
    <interactsWith rdf:resource="http://example.org/ontology#S023"/>
    <hasReference rdf:resource="http://example.org/ontology#R030"/>
    <hasReference rdf:resource="http://example.org/ontology#R029"/>
    <hasClinicalEffects>May reduce effectiveness or increase side effects.</hasClinicalEffects>
    <hasManagementAdvice>Adjust dosing or monitor for interactions; consult doctor.</hasManagementAdvice>
    <hasInteractionDescription>Taking other antibiotics or medications at the same time may affect how fosfomycin works.</hasInteractionDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R236">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R236</rdfs:label>
    <hasReferenceTitle>Cardiac Arrest</hasReferenceTitle>
    <hasAuthor>Cleveland Clinic</hasAuthor>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</publishedIn>
    <retrievedFrom>https://my.clevelandclinic.org/health/diseases/21736-cardiac-arrest</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R183">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R183</rdfs:label>
    <hasAuthor>Mayo Clinic</hasAuthor>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2025</publishedIn>
    <hasReferenceTitle>Anaphylaxis</hasReferenceTitle>
    <retrievedFrom>https://www.mayoclinic.org/diseases-conditions/anaphylaxis/symptoms-causes/syc-20351468</retrievedFrom>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN267">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN267</rdfs:label>
    <hasClinicalEffects>Not Specified</hasClinicalEffects>
    <hasReference rdf:resource="http://example.org/ontology#R166"/>
    <hasInteractionDescription>Trimethoprim may increase serum concentrations of some drugs, including phenytoin, digoxin, procainamide, rosiglitazone, and repaglinidine, potentiating their effect. This may be due to competitive inhibition of renal excretion, decreased metabolism, or both.</hasInteractionDescription>
    <interactsWith rdf:resource="http://example.org/ontology#S186"/>
    <hasManagementAdvice>Not Specified</hasManagementAdvice>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE072">
    <rdf:type rdf:resource="http://example.org/ontology#Anemia"/>
    <rdfs:label>Anemia</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Rare__hardly_happens"/>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasDuration>Rare</hasDuration>
    <hasSideEffectDescription>Low red blood cells; may cause fatigue, weakness, or shortness of breath.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I038">
    <rdf:type rdf:resource="http://example.org/ontology#Bronchopneumonia"/>
    <rdfs:label>Mild to severe Bronchopneumonia</rdfs:label>
    <hasSymptoms>fever, cough, shortness of breath, chest pain, rapid breathing, sweating, chills, headaches, muscle aches, pleurisy, fatigue, confusion or delirium</hasSymptoms>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasReference rdf:resource="http://example.org/ontology#R083"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#MildToSevere"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W282">
    <rdf:type rdf:resource="http://example.org/ontology#PregnancyAndLactation"/>
    <rdfs:label>W282</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R166"/>
    <hasWarningText>No adverse effects have been seen in breast-fed infants whose mothers were
taking cotrimoxazole, and the last available guidance from the American
Academy of Pediatrics considered that it was therefore usually compatible with
breast feeding.</hasWarningText>
    <hasWarningHeadline>Breastfeeding and Infants</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN105">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN105</rdfs:label>
    <hasInteractionDescription>Penicillins (concomitant).</hasInteractionDescription>
    <hasManagementAdvice>Carefully monitor patients receiving both medications.</hasManagementAdvice>
    <interactsWith rdf:resource="http://example.org/ontology#S079"/>
    <hasClinicalEffects>Reduced clearance by inhibiting renal tubular secretion.</hasClinicalEffects>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#UpperUrinaryTractInfection">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#UrinaryDisease"/>
    <rdfs:label>Upper Urinary Tract Infection</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Tonsillitis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#RespiratoryDisease"/>
    <rdfs:label>Tonsillitis</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP160">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP160</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R158"/>
    <hasStewardshipDescription>Always finish the full prescribed course of nitrofurantoin, even if you start feeling better. Stopping early can allow bacteria to survive, potentially causing the infection to come back and increasing the chance of resistance.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE603">
    <rdf:type rdf:resource="http://example.org/ontology#VentricularTachycardia"/>
    <rdfs:label>ventricular tachycardia</rdfs:label>
    <hasSideEffectDescription>fast, abnormal heart rhythm (arrhythmia) that comes from atypical electrical signals in your heart’s lower chambers</hasSideEffectDescription>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasReference rdf:resource="http://example.org/ontology#R238"/>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I056">
    <rdf:type rdf:resource="http://example.org/ontology#UncomplicatedGonorrhea"/>
    <rdfs:label>Uncomplicated Gonorrhea</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R128"/>
    <hasReference rdf:resource="http://example.org/ontology#R032"/>
    <hasReference rdf:resource="http://example.org/ontology#R129"/>
    <hasReference rdf:resource="http://example.org/ontology#R136"/>
    <hasReference rdf:resource="http://example.org/ontology#R014"/>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <hasSymptoms>Often, gonorrhea doesn’t cause symptoms, especially in women.</hasSymptoms>
    <hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE195">
    <rdf:type rdf:resource="http://example.org/ontology#Hyponatraemia"/>
    <rdfs:label>hyponatraemia</rdfs:label>
    <hasDuration>Not specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R290"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasSideEffectDescription>Hyponatremia is when the amount of sodium in your blood is too low. Common causes include heart, liver, kidney and brain diseases, hormone issues and medications.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE062">
    <rdf:type rdf:resource="http://example.org/ontology#Nausea"/>
    <rdfs:label>Nausea</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Common__may_happen_during_or_shortly_after_infusion"/>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasReference rdf:resource="http://example.org/ontology#R027"/>
    <hasSideEffectDescription>Feeling of wanting to vomit; usually mild and goes away on its own.</hasSideEffectDescription>
    <hasDuration>Few hours</hasDuration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W008">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W008</rdfs:label>
    <hasWarningText>Dose selection for an elderly patient should be cautious, usually starting at the low end of the dosing range, reflecting the greater frequency of decreased hepatic, renal, or cardiac function, and of concomitant disease or other drug therapy.</hasWarningText>
    <hasReference rdf:resource="http://example.org/ontology#R023"/>
    <hasWarningHeadline>Geriatric Use</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#treats">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/ontology#Brand"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Indication"/>
    <rdfs:label>treats</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S069">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Allopurinol</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R016"/>
    <hasSubstanceDescription>Gout medication</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S025">
    <rdf:type rdf:resource="http://example.org/ontology#Food"/>
    <rdfs:label>Caffeine</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R030"/>
    <hasReference rdf:resource="http://example.org/ontology#R029"/>
    <hasSubstanceDescription>Can sometimes worsen side effects like dizziness or jitteriness.</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN089">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN089</rdfs:label>
    <hasManagementAdvice>Monitor serum potassium. Avoid in high-risk patients.</hasManagementAdvice>
    <interactsWith rdf:resource="http://example.org/ontology#S063"/>
    <hasInteractionDescription>Due to the potassium sparing effects of sulfamethoxazole/trimethoprim, caution should be used when other agents that increase serum potassium, such as angiotensin converting enzyme inhibitors, angiotensin receptor blockers, potassium sparing diuretics and prednisolone, are co-administered. In the literature, two cases of hyperkalaemia in elderly patients have been reported after concomitant intake of sulfamethoxazole/trimethoprim and an angiotensin converting enzyme inhibitor.</hasInteractionDescription>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasClinicalEffects>Hyperkalemia</hasClinicalEffects>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE147">
    <rdf:type rdf:resource="http://example.org/ontology#Dyspepsia"/>
    <rdfs:label>Dyspepsia</rdfs:label>
    <hasSideEffectDescription>Pain or discomfort in the upper abdomen</hasSideEffectDescription>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I012">
    <rdf:type rdf:resource="http://example.org/ontology#Pharyngitis"/>
    <rdfs:label>Pharyngitis</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasReference rdf:resource="http://example.org/ontology#R128"/>
    <hasReference rdf:resource="http://example.org/ontology#R127"/>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasReference rdf:resource="http://example.org/ontology#R032"/>
    <hasReference rdf:resource="http://example.org/ontology#R129"/>
    <hasReference rdf:resource="http://example.org/ontology#R047"/>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
    <hasReference rdf:resource="http://example.org/ontology#R019"/>
    <hasReference rdf:resource="http://example.org/ontology#R020"/>
    <hasReference rdf:resource="http://example.org/ontology#R055"/>
    <hasReference rdf:resource="http://example.org/ontology#R003"/>
    <hasSymptoms>Sore throat, fever, headache, joint pain and muscle aches, skin rashes, swollen lymph nodes (glands) in the neck</hasSymptoms>
    <hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Pancreatitis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Pancreatitis</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Epistaxis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Epistaxis</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE667">
    <rdf:type rdf:resource="http://example.org/ontology#PseudomembranousOrCDifficileColitis"/>
    <rdfs:label>pseudomembranous / C. difficile colitis</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R246"/>
    <hasReference rdf:resource="http://example.org/ontology#R008"/>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Uncommon"/>
    <hasSideEffectDescription>an inflammatory process that occurs when your colon lining is being injured.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN131">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN131</rdfs:label>
    <hasClinicalEffects>Sample Effects</hasClinicalEffects>
    <hasInteractionDescription>Sample Description</hasInteractionDescription>
    <interactsWith rdf:resource="http://example.org/ontology#S001"/>
    <hasManagementAdvice>Sample Advice</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R001"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W094">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W094</rdfs:label>
    <hasWarningHeadline>Hemodialysis</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
    <hasWarningText>Can be removed from circulation by hemodialysis.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP068">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP068</rdfs:label>
    <hasStewardshipDescription>Complete the full 7-day potency period as prescribed; any remaining reconstituted liquid should be discarded after 7 days</hasStewardshipDescription>
    <hasReference rdf:resource="http://example.org/ontology#R015"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W047">
    <rdf:type rdf:resource="http://example.org/ontology#PatientCondition"/>
    <rdfs:label>W047</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R029"/>
    <hasWarningText>Reduced kidney function may affect dosing and effectiveness of this medication, and whether any special monitoring is needed.</hasWarningText>
    <hasWarningHeadline>Kidney Function</hasWarningHeadline>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R013">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R013</rdfs:label>
    <retrievedFrom>https://www.mims.com/philippines/drug/info/dynadoxy</retrievedFrom>
    <publishedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2026</publishedIn>
    <hasReferenceTitle>Dynadoxy</hasReferenceTitle>
    <hasAuthor>Monthly Index of Medical Specialties</hasAuthor>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP175">
    <rdf:type rdf:resource="http://example.org/ontology#AdministrationAndAdherence"/>
    <rdfs:label>SP175</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasStewardshipDescription>The medicine should be taken exactly as prescribed by the doctor. Adults should take 50–100 mg every 6 hours with meals, and children should take the prescribed dose based on body weight. Taking it with food helps improve absorption and reduces stomach upset. Do not skip doses and complete the full course even if symptoms improve early.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE301">
    <rdf:type rdf:resource="http://example.org/ontology#Nausea"/>
    <rdfs:label>Nausea</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <whichIs rdf:resource="http://example.org/ontology#Occasionally_reported"/>
    <hasDuration>Short-term</hasDuration>
    <hasSideEffectDescription>Feeling of sickness or queasiness.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE303">
    <rdf:type rdf:resource="http://example.org/ontology#UnexplainedWeakness"/>
    <rdfs:label>Unexplained Weakness</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Rare"/>
    <hasDuration>Short-term</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R054"/>
    <hasSideEffectDescription>Feeling unusually tired or weak.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#I023">
    <rdf:type rdf:resource="http://example.org/ontology#AcutePyelonephritis"/>
    <rdfs:label>Severe Acute Pyelonephritis</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasReference rdf:resource="http://example.org/ontology#R026"/>
    <hasReference rdf:resource="http://example.org/ontology#R027"/>
    <hasSeverityType rdf:resource="http://example.org/ontology#Severe"/>
