    <hasPresentation rdf:resource="http://example.org/ontology#A048"/>
    <hasPresentation rdf:resource="http://example.org/ontology#A049"/>
    <hasReference rdf:resource="http://example.org/ontology#R133"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE289">
    <rdf:type rdf:resource="http://example.org/ontology#Rhabdomyolysis"/>
    <rdfs:label>Rhabdomyolysis</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Rare_Concomitant_use_reports"/>
    <hasReference rdf:resource="http://example.org/ontology#R020"/>
    <hasSideEffectDescription>Muscle tissue breakdown (rhabdomyolysis) has been reported when taken with statins, fibrates, colchicine, or allopurinol</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN112">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN112</rdfs:label>
    <hasClinicalEffects>Decreased concentrations of zidovudine.</hasClinicalEffects>
    <hasInteractionDescription>Concomitant use.</hasInteractionDescription>
    <hasManagementAdvice>Separate doses by 1 to 2 hours.</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <interactsWith rdf:resource="http://example.org/ontology#S086"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE239">
    <rdf:type rdf:resource="http://example.org/ontology#Myalgia"/>
    <rdfs:label>myalgia</rdfs:label>
    <hasDurationOf>Not specified</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasReference rdf:resource="http://example.org/ontology#R252"/>
    <hasSideEffectDescription>Myalgia is the medical term for muscle pain, which has many causes. Many of them are easy to treat at home. But myalgia can also be a symptom of disease, especially when it’s widespread and long-lasting.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#S015">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:label>Cisapride</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R105"/>
    <hasSubstanceDescription>Cisapride is used to treat symptoms of nighttime heartburn in people who have not responded to other treatments.</hasSubstanceDescription>
  </rdf:Description>
