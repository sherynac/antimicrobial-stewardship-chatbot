  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#MeningitisAseptic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SideEffect"/>
    <rdfs:label>Meningitis Aseptic</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W252">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W252</rdfs:label>
    <hasWarningHeadline>Renal Impairement</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R158"/>
    <hasWarningText>Should not be taken if the patient has renal impairment (including anuria, oliguria, eGFR &lt;45 mL/min or CrCl &lt;60 mL, or clinically significant elevated serum creatinine); history of cholestatic jaundice or hepatic dysfunction associated with previous nitrofurantoin use.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W016">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <rdfs:label>W016</rdfs:label>
    <hasWarningText>Similar effects noted on regular doses. Adverse events experienced in higher than recommended dose were similar effects noted on regular doses. The typical symptoms of an overdose include reversible loss of hearing, severe nausea, vomiting and diarrhea.</hasWarningText>
    <hasWarningHeadline>Taking higher than recommended dose</hasWarningHeadline>
    <hasReference rdf:resource="http://example.org/ontology#R037"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#LobarPneumonia">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#RespiratoryDisease"/>
    <rdfs:label>Lobar Pneumonia</rdfs:label>
  </rdf:Description>
