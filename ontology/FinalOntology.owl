    <rdf:type rdf:resource="http://example.org/ontology#RespiratoryTractInfection"/>
    <rdfs:label>Respiratory Tract Infection</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R039"/>
    <hasReference rdf:resource="http://example.org/ontology#R096"/>
    <hasReference rdf:resource="http://example.org/ontology#R038"/>
    <hasReference rdf:resource="http://example.org/ontology#R018"/>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasReference rdf:resource="http://example.org/ontology#R091"/>
    <hasReference rdf:resource="http://example.org/ontology#R166"/>
    <hasReference rdf:resource="http://example.org/ontology#R095"/>
    <hasReference rdf:resource="http://example.org/ontology#R031"/>
    <hasSymptoms>a cough that may bring up mucus (phlegm), sneezing a stuffy or runny nose, a sore throat, headaches, muscle aches, breathlessness, tight chest or wheezing, a high temperature, and feeling generally unwell</hasSymptoms>
    <hasSeverityType rdf:resource="http://example.org/ontology#NotSpecified"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#R204">
    <rdf:type rdf:resource="http://example.org/ontology#Reference"/>
    <rdfs:label>R204</rdfs:label>
