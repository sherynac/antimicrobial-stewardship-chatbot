    <hasDurationOf>During treatment</hasDurationOf>
    <hasPattern rdf:resource="http://example.org/ontology#Common__usually_mild"/>
    <hasReference rdf:resource="http://example.org/ontology#R027"/>
    <hasReference rdf:resource="http://example.org/ontology#R028"/>
    <hasSideEffectDescription>Liver enzymes increase; usually no symptoms and reversible after stopping drug.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN070">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <rdfs:label>ITN070</rdfs:label>
    <hasClinicalEffects>Reduced clearance by inhibiting renal tubular secretion</hasClinicalEffects>
    <hasInteractionDescription>Penicillins may decrease renal clearance</hasInteractionDescription>
    <hasManagementAdvice>Carefully monitor patients receiving both concomitantly</hasManagementAdvice>
    <hasReference rdf:resource="http://example.org/ontology#R017"/>
    <interactsWith rdf:resource="http://example.org/ontology#S044"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN243">
