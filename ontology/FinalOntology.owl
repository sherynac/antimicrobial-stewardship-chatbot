    <hasReference rdf:resource="http://example.org/ontology#R143"/>
    <hasDuration>Not Specified</hasDuration>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
    <hasSideEffectDescription>Is a vein inflammation that happens in connection with one or more blood clots. This usually happens in your legs but can affect any vein in your body. While it isn't usually dangerous on its own, it's an important indicator of clotting problems that can lead to life-threatening conditions like pulmonary embolism.</hasSideEffectDescription>
  </rdf:Description>
