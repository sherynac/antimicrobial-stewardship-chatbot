  <rdf:Description rdf:about="http://example.org/ontology#W268">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <rdfs:label>W268</rdfs:label>
    <hasReference rdf:resource="http://example.org/ontology#R165"/>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasWarningText>Do not use Nitrofurantoin  if the patient has a known allergy to this medicine. Taking it again may cause serious allergic reactions such as skin rash, swelling, breathing difficulty, or other harmful effects.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE233">
    <rdf:type rdf:resource="http://example.org/ontology#StevensJohnsonSyndrome"/>
    <rdfs:label>Stevens-Johnson syndrome</rdfs:label>
    <whichIs rdf:resource="http://example.org/ontology#Very_rare"/>
    <hasDuration>Not specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R120"/>
    <hasReference rdf:resource="http://example.org/ontology#R035"/>
    <hasSideEffectDescription>Stevens-Johnson syndrome (SJS) is a rare, serious disorder of the skin and mucous membranes. It's usually a reaction to medication that starts with flu-like symptoms, followed by a painful rash that spreads and blisters. Then the top layer of affected skin dies, sheds and begins to heal after several days.</hasSideEffectDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE447">
    <rdf:type rdf:resource="http://example.org/ontology#Restlessness"/>
    <rdfs:label>Restlessness</rdfs:label>
    <hasDuration>Not Specified</hasDuration>
    <hasReference rdf:resource="http://example.org/ontology#R115"/>
    <hasReference rdf:resource="http://example.org/ontology#R092"/>
    <hasSideEffectDescription>pacing, constant movements of the legs, inability to sit or stand still, rocking from foot to foot, feeling tense or uncomfortable, feeling anxious</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Not_Specified"/>
  </rdf:Description>
