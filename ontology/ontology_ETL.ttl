:SP052 :hasStewardshipDescription "Azithromycin is not intended to treat suitable severe infections where fast high blood concentrations of antibiotic have to be achieved," .

:SP053 :hasReference :R014 .
:SP053 :hasStewardshipDescription "Store at temperatures not exceeding 30°C" .

:SP054 :hasStewardshipDescription "Store at temperatures not exceeding 30°C" .
:SP054 :hasReference :R014 .

