:SE134 :hasSideEffectDescription "This can lead to leukocytosis, which means the patient has a high white blood cell count than normal; Neutrophilia leukocytosis is caused by a high number of neutrophils (the most plentiful type of white blood cell, which helps resolve infections and heal damaged tissues).; Monocytosis is caused by a high number of monocytes (white blood cells that boost your immune responses).; Eosinophilia refers to high levels of eosinophils (white blood cells that play a role in fighting infections and inflammation). Eosinophilia is common and is often related to allergies, parasitic infections or autoimmune disorders; Basophilia, the rarest form of leukocytosis, is characterized by an increased number of basophils (white blood cells that play a role in fighting parasitic infections, preventing blood clotting and responding to allergic reactions)." .
:SE134 :hasDurationOf "Not Specified" .
:SE134 :hasReference :R075 .

:SE135 :hasPattern :Not_specified .
:SE135 :hasDurationOf "Not specified" .
:SE135 :hasReference :R034 .
:SE135 :hasSideEffectDescription "Stevens-Johnson syndrome (SJS) is a rare, serious disorder of the skin and mucous membranes. It's usually a reaction to medication that starts with flu-like symptoms, followed by a painful rash that spreads and blisters. Then the top layer of affected skin dies, sheds and begins to heal after several days." .

:SE136 :hasSideEffectDescription "Toxic epidermal necrolysis (TEN) is potentially life-threatening acute mucocutaneous Syndrome. It usually occurs because of inappropriate immune reactions to certain drugs." .
:SE136 :hasReference :R033 .
:SE136 :hasPattern :Not_specified .
:SE136 :hasDurationOf "Not specified" .

:SE137 :hasSideEffectDescription "Stevens-Johnson syndrome (SJS) is a rare, serious disorder of the skin and mucous membranes. It's usually a reaction to medication that starts with flu-like symptoms, followed by a painful rash that spreads and blisters. Then the top layer of affected skin dies, sheds and begins to heal after several days." .
:SE137 :hasPattern :Not_specified .
:SE137 :hasDurationOf "Not specified" .
:SE137 :hasReference :R034 .

:SE138 :hasReference :R033 .
:SE138 :hasSideEffectDescription "Toxic epidermal necrolysis (TEN) is potentially life-threatening acute mucocutaneous Syndrome. It usually occurs because of inappropriate immune reactions to certain drugs." .
:SE138 :hasDurationOf "Not specified" .
:SE138 :hasPattern :Not_specified .

:SE139 :hasPattern :Most_frequent .
:SE139 :hasReference :R038 .
:SE139 :hasSideEffectDescription "Mild disease in the gastrointestinal tract" .
:SE139 :hasDurationOf "Not Specified" .

:SE141 :hasReference :R064 .
:SE141 :hasReference :R038 .
:SE141 :hasSideEffectDescription "Swelling in the tissue under your skin, commonly seen in the lips, eyelids, tongue, genitals, hands or feet; yellowing of skin and whites of the eyes" .
:SE141 :hasPattern :Happens_during_multiple-dose_regimen .
:SE141 :hasDurationOf "Not Specified" .

:SE142 :hasReference :R038 .
:SE142 :hasReference :R056 .
:SE142 :hasDurationOf "Not Specified" .
:SE142 :hasPattern :Happens_during_multiple-dose_regimen .
:SE142 :hasSideEffectDescription "Sensation of having to vomit or having the urge to vomit." .

:SE143 :hasPattern :Happens_during_multiple-dose_regimen .
:SE143 :hasDurationOf "Not Specified" .
:SE143 :hasReference :R057 .
:SE143 :hasReference :R038 .
:SE143 :hasSideEffectDescription "Forceful ejection stomach contents through the mouth." .

:SE144 :hasDurationOf "Not Specified" .
:SE144 :hasSideEffectDescription "Loose, watery stool during a bowl movement" .
:SE144 :hasReference :R038 .
:SE144 :hasReference :R076 .
:SE144 :hasPattern :Happens_during_multiple-dose_regimen .

:SE145 :hasReference :R038 .
:SE145 :hasSideEffectDescription "Pain felt anywhere between the chest and groin." .
:SE145 :hasDurationOf "Not Specified" .
:SE145 :hasPattern :Happens_during_multiple-dose_regimen .
:SE145 :hasReference :R058 .

:SE146 :hasDurationOf "Not Specified" .
:SE146 :hasSideEffectDescription "Feeling like your heart is missing heartbeats, racing or pounding felt in chest, throat or neck; Pain felt between neck and belly" .
:SE146 :hasPattern :Not_Specified .
:SE146 :hasReference :R059 .
:SE146 :hasReference :R038 .

:SE147 :hasReference :R038 .
:SE147 :hasSideEffectDescription "Pain or discomfort in the upper abdomen" .
:SE147 :hasPattern :Not_Specified .
:SE147 :hasDurationOf "Not Specified" .

:SE148 :hasReference :R038 .
:SE148 :hasDurationOf "Not Specified" .
:SE148 :hasSideEffectDescription "Body releases gas in your digestive system through your anus." .
:SE148 :hasPattern :Not_Specified .

:SE149 :hasPattern :Not_Specified .
:SE149 :hasSideEffectDescription "Black, tarry stool caused by internal bleeding" .
:SE149 :hasReference :R038 .
:SE149 :hasReference :R060 .
:SE149 :hasDurationOf "Not Specified" .

:SE151 :hasDurationOf "Not Specified" .
:SE151 :hasSideEffectDescription "Inflammation of the vagina" .
:SE151 :hasReference :R038 .
:SE151 :hasPattern :Not_Specified .

:SE152 :hasSideEffectDescription "Inflammation of one or both kidneys, which can leak protein into urine and impair the body's ability to absorb water and lead to tissue swelling" .
:SE152 :hasDurationOf "Not Specified" .
:SE152 :hasReference :R061 .
:SE152 :hasPattern :Not_Specified .
:SE152 :hasReference :R038 .

:SE154 :hasSideEffectDescription "false sensation of motion such as spinning or swaying" .
:SE154 :hasPattern :Not_Specified .
:SE154 :hasReference :R038 .
:SE154 :hasDurationOf "Not Specified" .

:SE155 :hasDurationOf "Not Specified" .
:SE155 :hasSideEffectDescription "feeling tired and wanting to fall asleep" .
:SE155 :hasPattern :Not_Specified .
:SE155 :hasReference :R038 .

:SE156 :hasReference :R062 .
:SE156 :hasSideEffectDescription "feeling of weariness, tiredness, or lack of energy" .
:SE156 :hasDurationOf "Not Specified" .
:SE156 :hasPattern :Not_Specified .
:SE156 :hasReference :R038 .

:SE157 :hasDurationOf "Not Specified" .
:SE157 :hasPattern :Not_Specified .
:SE157 :hasReference :R038 .
:SE157 :hasSideEffectDescription "red, bumpy, often itchy skin" .

:SE158 :hasReference :R063 .
:SE158 :hasDurationOf "Not Specified" .
:SE158 :hasPattern :Not_Specified .
:SE158 :hasReference :R038 .
:SE158 :hasSideEffectDescription "Skin reacts negatively to sunlight or UV rays that causes an itchy, painful rash" .

:SE159 :hasSideEffectDescription "A general skin reaction" .
:SE159 :hasDurationOf "Not Specified" .
:SE159 :hasReference :R015 .
:SE159 :hasPattern :Common .

:SE160 :hasDurationOf "Not Specified" .
:SE160 :hasSideEffectDescription "Gastrointestinal disturbance" .
:SE160 :hasPattern :Common .
:SE160 :hasReference :R015 .

:SE161 :hasDurationOf "Not Specified" .
:SE161 :hasSideEffectDescription "Gastrointestinal disturbance" .
:SE161 :hasReference :R015 .
:SE161 :hasPattern :Common .

:SE162 :hasDurationOf "Not Specified" .
:SE162 :hasPattern :Uncommon .
:SE162 :hasSideEffectDescription "Gastrointestinal disturbance" .
:SE162 :hasReference :R015 .

:SE163 :hasPattern :Uncommon .
:SE163 :hasSideEffectDescription "A skin reaction (hives)" .
:SE163 :hasReference :R015 .
:SE163 :hasDurationOf "Not Specified" .

:SE164 :hasDurationOf "Not Specified" .
:SE164 :hasSideEffectDescription "Itching" .
:SE164 :hasPattern :Uncommon .
:SE164 :hasReference :R015 .

:SE165 :hasPattern :Not_specifically_classified_by_frequency__but_reported_in_children .
:SE165 :hasDurationOf "Reversible (can usually be removed by brushing)" .
:SE165 :hasReference :R015 .
:SE165 :hasSideEffectDescription "Affects Amoxil 100 mg/mL oral drops and Amoxil Forte oral suspension; can often be prevented by good oral hygiene" .

:SE166 :hasSideEffectDescription "A general skin reaction" .
:SE166 :hasPattern :Common .
:SE166 :hasReference :R015 .
:SE166 :hasDurationOf "Not Specified" .

:SE167 :hasPattern :Common .
:SE167 :hasDurationOf "Not Specified" .
:SE167 :hasSideEffectDescription "Gastrointestinal disturbance" .
:SE167 :hasReference :R015 .

:SE168 :hasSideEffectDescription "Gastrointestinal disturbance" .
:SE168 :hasPattern :Common .
:SE168 :hasReference :R015 .
