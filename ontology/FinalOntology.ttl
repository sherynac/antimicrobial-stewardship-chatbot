:Brand a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality 1 ;
            owl:onClass :PresentationOrPacking ;
            owl:onProperty :hasPresentation ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality 1 ;
            owl:onClass :Indication ;
            owl:onProperty :treats ] ;
    owl:disjointWith :Antibiotic,
        :Indication,
        :Interaction,
        :Pattern,
        :Severity,
        :SideEffect,
        :Warning .

:PregnancyAndLactation a owl:Class ;
    rdfs:subClassOf :Warning ;
    owl:disjointWith :AgeRestriction,
        :Contraindication,
        :Overdosage,
        :PatientCondition .

