:W001 a :PatientCondition ;
    rdfs:label "W001" ;
    :hasReference :R037 ;
    :hasWarningHeadline "Pneumonia" ;
    :hasWarningText "Not recommended for people with pneumonia who cannot take medicine by mouth. This includes those who are very sick, need to stay in the hospital, have serious infections, are older or frail, or have serious health problems that weaken the immune system." .

:W002 a :PatientCondition ;
    rdfs:label "W002" ;
    :hasReference :R037 ;
    :hasWarningHeadline "Syphilis" ;
    :hasWarningText "Azithromycin, at the recommended dose, should not be relied upon to treat syphilis. Antimicrobial agents used in high doses for short periods of time to treat non-gonococcal urethritis may mask or delay the symptoms of incubating syphilis. All patients with sexually-transmitted urethritis or cervicitis should have a serologic test for syphilis and appropriate cultures for gonorrhea performed at the time of diagnosis. Appropriate antimicrobial therapy and follow-up tests for these diseases should be initiated if infection is confirmed." .

:W003 a :Contraindication ;
    rdfs:label "W003" ;
    :hasReference :R022,
        :R023 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Monurol should not be used in patients with known allergy to fosfomyxin or any of its ingredients." .

:W004 a :PatientCondition ;
    rdfs:label "W004" ;
    :hasReference :R023 ;
    :hasWarningHeadline "Clostridium difficile-associated diarrhea (CDAD)" ;
    :hasWarningText "Clostridium difficile associated diarrhea (CDAD) has been reported with use of nearly all antibacterial agents, including MONUROL, and may range in severity from mild diarrhea to fatal colitis." .

:W005 a :PregnancyAndLactation ;
    rdfs:label "W005" ;
    :hasReference :R023 ;
    :hasWarningHeadline "Pregnancy" ;
    :hasWarningText "During pregnancy, Monurol should be used only when prescribed." .

:W006 a :PregnancyAndLactation ;
    rdfs:label "W006" ;
    :hasReference :R023 ;
    :hasWarningHeadline "Breastfeeding" ;
    :hasWarningText "It is unknown if this drug passes into breast milk. Consult the doctor before breastfeeding." .

:W007 a :AgeRestriction ;
    rdfs:label "W007" ;
    :hasReference :R023 ;
    :hasWarningHeadline "Pediatric Use" ;
    :hasWarningText "Safety and effectiveness in children under 12 years old have not been established." .

:W008 a :AgeRestriction ;
    rdfs:label "W008" ;
    :hasReference :R023 ;
    :hasWarningHeadline "Geriatric Use" ;
    :hasWarningText "Dose selection for an elderly patient should be cautious, usually starting at the low end of the dosing range, reflecting the greater frequency of decreased hepatic, renal, or cardiac function, and of concomitant disease or other drug therapy." .

:W009 a :Contraindication ;
    rdfs:label "W009" ;
    :hasReference :R024 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Do not take Fosfomycin Tromethamine if you have a known allergy to it or any ingredient in the medicine." .

:W010 a :PatientCondition ;
    rdfs:label "W010" ;
    :hasReference :R024 ;
    :hasWarningHeadline "Clostridium difficile-associated diarrhea (CDAD)" ;
    :hasWarningText "Clostridium difficile associated diarrhea (CDAD) has been reported with use of nearly all antibacterial agents, including Fosfomycin Tromethamine, and may range in severity from mild diarrhea to fatal colitis. Treatment with antibacterial agents alters the normal flora of the colon leading to overgrowth of C. difficile." .

:W011 a :PregnancyAndLactation ;
    rdfs:label "W011" ;
    :hasReference :R024 ;
    :hasWarningHeadline "Pregnancy" ;
    :hasWarningText "There are, however, no adequate and well-controlled studies in pregnant women. Because animal reproduction studies are not always predictive of human response, this drug should be used during pregnancy only if clearly needed." .

:W012 a :PregnancyAndLactation ;
    rdfs:label "W012" ;
    :hasReference :R024 ;
    :hasWarningHeadline "Breastfeeding" ;
    :hasWarningText "It is unknown if Fosfomycin Tromethamine passes into breast milk. Talk to your doctor before using while nursing." .

:W013 a :AgeRestriction ;
    rdfs:label "W013" ;
    :hasReference :R024 ;
    :hasWarningHeadline "Pediatric Use" ;
    :hasWarningText "The safety and effectiveness of Fosfomycin Tromethamine in children under 12 years have not been established in adequate and well-controlled studies." .

:W014 a :AgeRestriction ;
    rdfs:label "W014" ;
    :hasReference :R024 ;
    :hasWarningHeadline "Geriatric Use" ;
    :hasWarningText "Older adults may have reduced kidney, liver, or heart function. Use Fosfomycin Tromethamine carefully and follow dosing instructions." .

:W015 a :PatientCondition ;
    rdfs:label "W015" ;
    :hasReference :R024 ;
    :hasWarningHeadline "Single-dose Use" ;
    :hasWarningText "Do not use more than one single dose of Fosfomycin Tromethamine to treat a single episode of acute cystitis. Repeated daily doses of Fosfomycin Tromethamine did not improve the clinical success or microbiological eradication rates compared to single dose therapy, but did increase the incidence of adverse events." .

:W016 a :AgeRestriction ;
    rdfs:label "W016" ;
    :hasReference :R037 ;
    :hasWarningHeadline "Taking higher than recommended dose" ;
    :hasWarningText "Similar effects noted on regular doses. Adverse events experienced in higher than recommended dose were similar effects noted on regular doses. The typical symptoms of an overdose include reversible loss of hearing, severe nausea, vomiting and diarrhea." .

:W017 a :Contraindication ;
    rdfs:label "W017" ;
    :hasReference :R037 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Azithromycin is contraindicated in patients with known hypersensitivity to azithromycin, erythromycin, any macrolide or ketolide antibiotic." .

:W018 a :Contraindication ;
    rdfs:label "W018" ;
    :hasReference :R026 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Do not use if the patient has a known allergy to fosfomycin. Serious allergic reactions like difficulty breathing, difficulty swallowing, fever, hives, itchy skin, rash, swelling of your tongue, throat or face" .

:W019 a :PatientCondition ;
    rdfs:label "W019" ;
    :hasReference :R026 ;
    :hasWarningHeadline "Clostridioides difficile-Associated Diarrhea (CDAD)" ;
    :hasWarningText "Antibiotic use may cause abdominal pain or tenderness, fever, severe diarrhea due to C. difficile." .

:W020 a :PatientCondition ;
    rdfs:label "W020" ;
    :hasReference :R026 ;
    :hasWarningHeadline "Sodium Content" ;
    :hasWarningText "Before receiving IVOZFO, notify the doctor if the patient have any of the following health conditions: heart problems, high blood pressure, hyperaldosteronism which is a condition where you have too much of a hormone called aldosterone, cirrhosis (scar tissue) of the liver, kidney problems, high levels of sodium in the blood, or fluid in your lungs. IVOZFO contains sodium that could make these conditions worse." .

:W021 a :PatientCondition ;
    rdfs:label "W021" ;
    :hasReference :R026 ;
    :hasWarningHeadline "Decrease in Potassium Level" ;
    :hasWarningText "A high sodium load associated with the use of IVOZFO™ may result in decreased levels of potassium in serum or plasma. A low-sodium diet is recommended during treatment. The substitution of potassium may be necessary in some cases. Serum electrolyte levels and water balance must be monitored regularly during therapy" .

:W022 a :PatientCondition ;
    rdfs:label "W022" ;
    :hasReference :R026 ;
    :hasWarningHeadline "Kidney Impairment" ;
    :hasWarningText "Dose adjustment may be needed in patients with reduced kidney function. Monitor kidney status during therapy." .

:W023 a :PregnancyAndLactation ;
    rdfs:label "W023" ;
    :hasReference :R026 ;
    :hasWarningHeadline "Pregnancy" ;
    :hasWarningText "Use during pregnancy only if clearly needed and prescribed by a doctor." .

:W024 a :PregnancyAndLactation ;
    rdfs:label "W024" ;
    :hasReference :R026 ;
    :hasWarningHeadline "Breastfeeding" ;
    :hasWarningText "It is not fully known if the drug passes into breast milk. Consult a healthcare provider before use." .

:W025 a :AgeRestriction ;
    rdfs:label "W025" ;
    :hasReference :R026 ;
    :hasWarningHeadline "Pediatric Use" ;
    :hasWarningText "Safety and effectiveness in children should be confirmed before use. Follow proper dosing guidelines." .

:W026 a :AgeRestriction ;
    rdfs:label "W026" ;
    :hasReference :R026 ;
    :hasWarningHeadline "Geriatric Use" ;
    :hasWarningText "In patients with impaired renal function, the elimination half-life is increased proportionally to the degree of renal insufficiency. Patients with creatinine clearance values of 40 mL/min or less require dose adjustments" .

:W027 a :PatientCondition ;
    rdfs:label "W027" ;
    :hasReference :R037 ;
    :hasWarningHeadline "Impaired hepatic functions" ;
    :hasWarningText "Due to limited data in subjects with Glomerular Filtration Rate < 10 mL/min, caution should be exercised when taking azithrymycin for these patients" .

:W029 a :PatientCondition ;
    rdfs:label "W029" ;
    :hasReference :R037 ;
    :hasWarningHeadline "Cardiac Risk" ;
    :hasWarningText "Prolonged cardiac repolarization and QT interval, imparting a risk of developing cardiac arrhythmia and torsades de pointes, have been seen in treatment with other macrolides. A similar effect with azithromycin cannot be completely ruled out in patients at increased risk for prolonged cardiac repolarization." .

:W030 a :PregnancyAndLactation ;
    rdfs:label "W030" ;
    :hasReference :R037 ;
    :hasWarningHeadline "Pregnancy" ;
    :hasWarningText "Pregnancy Category B: In the animal studies, no evidence of harm to the fetus due to azithromycin was found. There are, however, no adequate and well-controlled studies in pregnant women. Because animal reproduction studies are not always predictive of human response, azithromycin should be used during pregnancy only if clearly needed." .

:W031 a :PregnancyAndLactation ;
    rdfs:label "W031" ;
    :hasReference :R037 ;
    :hasWarningHeadline "Breastfeeding" ;
    :hasWarningText "It is not known whether azithromycin is excreted in human milk. Caution should be exercised when azithromycin is administered to a nursing woman." .

:W032 a :Contraindication ;
    rdfs:label "W032" ;
    :hasReference :R028 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Reactions such as rash, urticaria and anaphylaxis were reported with the use of CONTEPO. Before initiating therapy with CONTEPO, it is important to inquire about previous hypersensitivity reactions to oral or parenteral fosfomycin. If an allergic reaction occurs, discontinue CONTEPO immediately." .

:W033 a :PatientCondition ;
    rdfs:label "W033" ;
    :hasReference :R028 ;
    :hasWarningHeadline "Serum Electrolyte Abnormalities" ;
    :hasWarningText "The high sodium load associated with the use of CONTEPO may result in changes in serum electrolytes, such as increased levels of sodium and decreased levels of potassium, calcium and phosphorus. A low-sodium diet is recommended during CONTEPO treatment. Monitor serum electrolyte levels and fluid status during CONTEPO treatment" .

:W034 a :PatientCondition ;
    rdfs:label "W034" ;
    :hasReference :R028 ;
    :hasWarningHeadline "QT Prolongation" ;
    :hasWarningText "The risk of QT prolongation may increase in patients with electrolyte abnormalities (such as hypokalemia and hypocalcemia), patients with conditions that have potential to cause electrolyte imbalance (such as renal impairment), or patients taking other drugs affecting electrolyte balance or QT prolongation. Avoid CONTEPO in patients with known QT prolongation or ventricular arrhythmias, including a history of torsade de pointes." .

:W035 a :PatientCondition ;
    rdfs:label "W035" ;
    :hasReference :R028 ;
    :hasWarningHeadline "Increased Transaminase Levels" ;
    :hasWarningText "Increase in alanine aminotransferase (ALT) and aspartate aminotransferase (AST) were reported in the clinical trial. Monitor hepatic enzymes during CONTEPO treatment." .

:W036 a :PatientCondition ;
    rdfs:label "W036" ;
    :hasReference :R028 ;
    :hasWarningHeadline "Neutropenia including Agranulocytosis" ;
    :hasWarningText "Neutropenia, including agranulocytosis, has occurred in patients receiving IV fosfomycin treatment. Monitor complete blood count during CONTEPO therapy. If such reactions occur, discontinue CONTEPO and institute appropriate treatment" .

:W037 a :PatientCondition ;
    rdfs:label "W037" ;
    :hasReference :R028 ;
    :hasWarningHeadline "Clostridioides difficile-Associated Diarrhea (CDAD)" ;
    :hasWarningText "This has been reported with nearly all systemic antibacterial agents, including CONTEPO. Evaluate patients if diarrhea occurs." .

:W038 a :PatientCondition ;
    rdfs:label "W038" ;
    :hasReference :R028 ;
    :hasWarningHeadline "Development of Drug-Resistant Bacteria" ;
    :hasWarningText "Prescribing CONTEPO in the absence of a proven or strongly suspected bacterial infection indication is unlikely to provide benefit to the patient and increases the risk of the development of drug resistant bacteria" .

:W039 a :PatientCondition ;
    rdfs:label "W039" ;
    :hasReference :R028 ;
    :hasWarningHeadline "Cardiac/Fluid Overload" ;
    :hasWarningText "Monitor signs and symptoms of edema, particularly in patients with cardiac insufficiency, renal impairment, cirrhosis, hypertension, hyperaldosteronism, hypernatremia or pulmonary edema." .

:W040 a :PregnancyAndLactation ;
    rdfs:label "W040" ;
    :hasReference :R028 ;
    :hasWarningHeadline "Pregnancy Use" ;
    :hasWarningText "Available data from observational studies and pharmacovigilance reports with fosfomycin use in pregnant women are insufficient to identify a drug-associated risk of major birth defects, miscarriage, or adverse maternal or fetal outcomes. Fosfomycin crosses the placental barrier. There are no animal data that meet current standards for nonclinical developmental toxicity studies. However, some reproductive toxicity data are available from published literature. Intravenous or intraperitoneal fosfomycin-sodium did not cause malformations in rabbits or rats, respectively, but showed evidence of fetotoxicity (see Data). The clinical relevance of these animal data is uncertain." .

:W041 a :PregnancyAndLactation ;
    rdfs:label "W041" ;
    :hasReference :R028 ;
    :hasWarningHeadline "Breastfeeding" ;
    :hasWarningText "Breastfeeding not recommended during treatment and for 24 hours after last dose." .

:W042 a :AgeRestriction ;
    rdfs:label "W042" ;
    :hasReference :R028 ;
    :hasWarningHeadline "Pediatric Use" ;
    :hasWarningText "Safety and effectiveness of CONTEPO in patients less than 18 years of age has not been established." .

:W043 a :AgeRestriction ;
    rdfs:label "W043" ;
    :hasReference :R028 ;
    :hasWarningHeadline "Geriatric Use" ;
    :hasWarningText "Elderly patients are more likely to have decreased cardiac and renal function, care should be taken in dose selection, and electrolytes, fluid status, and renal function should be monitored. Dosage adjustment in elderly patients should take into account renal function" .

:W044 a :Contraindication ;
    rdfs:label "W044" ;
    :hasReference :R029 ;
    :hasWarningHeadline "Allergy" ;
    :hasWarningText "Do not take this medication if allergic to fosfomycin or any ingredients of the medication." .

:W045 a :PatientCondition ;
    rdfs:label "W045" ;
    :hasReference :R029 ;
    :hasWarningHeadline "Antibiotic-Associated Colitis" ;
    :hasWarningText "May cause persistent or severe blood or watery diarrhea with or without fever and abdominal pain" .

:W046 a :PatientCondition ;
    rdfs:label "W046" ;
    :hasReference :R029 ;
    :hasWarningHeadline "Dizziness" ;
    :hasWarningText "Fosfomycin may cause dizziness, affecting ability to drive or operate machinery." .

:W047 a :PatientCondition ;
    rdfs:label "W047" ;
    :hasReference :R029 ;
    :hasWarningHeadline "Kidney Function" ;
    :hasWarningText "Reduced kidney function may affect dosing and effectiveness of this medication, and whether any special monitoring is needed." .

:W048 a :PregnancyAndLactation ;
    rdfs:label "W048" ;
    :hasReference :R029 ;
    :hasWarningHeadline "Pregnancy" ;
    :hasWarningText "Fosfomycin crosses the placenta and may affect a developing baby if it is taken during pregnancy. This medication should not be used during pregnancy unless the benefits outweigh the risks." .

:W049 a :PregnancyAndLactation ;
    rdfs:label "W049" ;
    :hasReference :R029 ;
    :hasWarningHeadline "Breastfeeding" ;
    :hasWarningText "May pass into breast milk. If you are breast-feeding and are taking fosfomycin, it may affect your baby." .

:W050 a :PatientCondition ;
    rdfs:label "W050" ;
    :hasReference :R029,
        :R030 ;
    :hasWarningHeadline "Overgrowth of Organisms" ;
    :hasWarningText "Prolonged or repeated use may lead to fungal or resistant bacterial overgrowth." .

:W051 a :PatientCondition ;
    rdfs:label "W051" ;
    :hasReference :R029 ;
    :hasWarningHeadline "Sucrose Content" ;
    :hasWarningText "It contains sucrose. It is not recommended if the patient have hereditary problems of fructose intolerance." .

:W052 a :AgeRestriction ;
    rdfs:label "W052" ;
    :hasReference :R038 ;
    :hasWarningHeadline "Children more than 45 kg" ;
    :hasWarningText "Tablets can only be administered to children weighing more than 45 kg." .

:W053 a :AgeRestriction ;
    rdfs:label "W053" ;
    :hasReference :R039 ;
    :hasWarningHeadline "Taking higher than recommended dose" ;
    :hasWarningText "Adverse effects experienced at doses higher than recommended are similar to those seen at normal doses. Symptoms of a macrolide antibiotic overdose typically include reversible hearing loss, severe nausea, vomiting, and diarrhea. In case of an overdose, administration of medicinal charcoal is recommended, along with general symptomatic treatment and supportive measures as needed." .

:W054 a :AgeRestriction ;
    rdfs:label "W054" ;
    :hasReference :R038 ;
    :hasWarningHeadline "Taking higher than recommended dose" ;
    :hasWarningText "Do not exceed the recommended doses. In case of overdosage consult your physician immediately." .

:W055 a :AgeRestriction ;
    rdfs:label "W055" ;
    :hasReference :R038 ;
    :hasWarningHeadline "Taking higher than recommended dose" ;
    :hasWarningText "Do not exceed the recommended doses. In case of overdosage consult your physician immediately." .

:W056 a :Contraindication ;
    rdfs:label "W056" ;
    :hasReference :R039 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Hypersensitivity to the active substance, erythromycin, any macrolide or ketolide antibiotic, or to any of the excipients." .

:W057 a :Contraindication ;
    rdfs:label "W057" ;
    :hasReference :R038 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Do not take if you have hypersensitivity to the azithromycin, or any macrolide antibiotics." .

:W058 a :Contraindication ;
    rdfs:label "W058" ;
    :hasReference :R038 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Do not take if you have hypersensitivity to the azithromycin, or any macrolide antibiotics." .

:W059 a :Contraindication ;
    rdfs:label "W059" ;
    :hasReference :R038 ;
    :hasWarningHeadline "Co-administration" ;
    :hasWarningText "Do not take with ergot derivatives" .

:W060 a :Contraindication ;
    rdfs:label "W060" ;
    :hasReference :R038 ;
    :hasWarningHeadline "Co-administration" ;
    :hasWarningText "Do not take with ergot derivatives" .

:W061 a :PregnancyAndLactation ;
    rdfs:label "W061" ;
    :hasReference :R039 ;
    :hasWarningHeadline "Pregnancy" ;
    :hasWarningText "The safety of azithromycin has not been confirmed with regard to the use of the active substance during pregnancy. Therefore, azithromycin should only be used during pregnancy if the benefit outweighs the risk." .

:W062 a :PregnancyAndLactation ;
    rdfs:label "W062" ;
    :hasReference :R039 ;
    :hasWarningHeadline "Breastfeeding" ;
    :hasWarningText "Azithromycin is secreted into human breast milk. A risk to the newborn/infant cannot be excluded. A decision must be made whether to discontinue breastfeeding or discontinue the drug, taking into account the benefit of breastfeeding to the child and the benefit of therapy to the mother." .

:W063 a :PatientCondition ;
    rdfs:label "W063" ;
    :hasReference :R039 ;
    :hasWarningHeadline "Fertility" ;
    :hasWarningText "Animal studies have shown reduced pregnancy rate upon the administration of azithromycin. The clinical relevance for humans is unknown." .

:W064 a :PregnancyAndLactation ;
    rdfs:label "W064" ;
    :hasReference :R038 ;
    :hasWarningHeadline "Pregnancy" ;
    :hasWarningText "Should only be used during pregnancy if it is clearly indicated. Caution should be taken when administered to a pregnant woman." .

:W065 a :PregnancyAndLactation ;
    rdfs:label "W065" ;
    :hasReference :R038 ;
    :hasWarningHeadline "Pregnancy" ;
    :hasWarningText "Should only be used during pregnancy if it is clearly indicated. Caution should be taken when administered to a pregnant woman." .

:W066 a :PregnancyAndLactation ;
    rdfs:label "W066" ;
    :hasReference :R038 ;
    :hasWarningHeadline "Breastfeeding" ;
    :hasWarningText "Unknown if Azithromycin is excreted in breast milk. Caution should be taken when administered to a nursing woman." .

:W067 a :PregnancyAndLactation ;
    rdfs:label "W067" ;
    :hasReference :R038 ;
    :hasWarningHeadline "Breastfeeding" ;
    :hasWarningText "Unknown if Azithromycin is excreted in breast milk. Caution should be taken when administered to a nursing woman." .

:W068 a :PatientCondition ;
    rdfs:label "W068" ;
    :hasReference :R039 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Taking can cause rare serious allergic reactions (including angioneurotic oedema, anaphylaxis, which have been rarely fatal) and dermatologic reactions, such as acute generalised exanthematous pustulosis (AGEP), Stevens-Johnson syndrome, toxic epidermal necrolysis (rarely fatal), and drug reaction with eosinophilia and systemic symptoms (DRESS), have been reported. Some reactions have required prolonged observation and treatment. If any of these hypersensitivity reactions occur, discontinue azithromycin immediately and institute appropriate emergency therapy." .

:W069 a :PatientCondition ;
    rdfs:label "W069" ;
    :hasReference :R039 ;
    :hasWarningHeadline "Hepatotoxicity" ;
    :hasWarningText "Use with caution for patients with significant hepatic (liver) disease as cases of fulminant hepatitis leading to life-threatening liver failure have been reported with azithromycin. In case of signs and symptoms of liver dysfunction, such as rapid developing asthenia associated with jaundice, dark urine, bleeding tendency or hepatic encephalopathy. Azithromycin administration should be stopped if liver dysfunction has emerged." .

:W070 a :PregnancyAndLactation ;
    rdfs:label "W070" ;
    :hasReference :R014 ;
    :hasWarningHeadline "Breastfeeding" ;
    :hasWarningText "No adverse effects have been found on breast-fed infants whose mothers were receiving cefotaxime" .

:W071 a :PregnancyAndLactation ;
    rdfs:label "W071" ;
    :hasReference :R014 ;
    :hasWarningHeadline "Breastfeeding" ;
    :hasWarningText "No adverse effects have been found on breast-fed infants whose mothers were receiving cefotaxime" .

:W072 a :Contraindication ;
    rdfs:label "W072" ;
    :hasReference :R039 ;
    :hasWarningHeadline "Co-administration" ;
    :hasWarningText "Due to theoretical possibility of ergotism, azithromycin and ergot derivatives should not be co-administered." .

:W073 a :AgeRestriction ;
    rdfs:label "W073" ;
    :hasReference :R039 ;
    :hasWarningHeadline "Pediatric Use" ;
    :hasWarningText "Safety and efficacy for the prevention or treatment of Mycobacterium avium complex in children have not been established." .

:W074 a :Contraindication ;
    rdfs:label "W074" ;
    :hasReference :R031 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText """Comazole is contraindicated in patients with marked liver parenchymal damage. It is also contraindicated in patients with severe renal insufficiency when repeated determinations of the plasma concentration cannot be made. Except in rare circumstances Comazole should not be given to patient with serious haematological disorders. The combination has occasionally been administered to patients receiving cytotoxic agents for the treatment of leukemias, without evidence of any adverse effect on the bone marrow or peripheral blood. Comazole should not be administered to patients with a history of hypersensitivity to sulphonamides or trimethoprim. Comazole is contraindicated in G6PD (Glucose-6-phosphate dehydrogenase
deficiency). Treatment must be immediately discontinued on the appearance of a skin rash or any element of blood count reduced.""" .

:W075 a :PatientCondition ;
    rdfs:label "W075" ;
    :hasReference :R039 ;
    :hasWarningHeadline "Neurological and pyschiatric disorders" ;
    :hasWarningText "Azithromycin should be used with caution in patients with neurological and psychiartric disorders." .

:W076 a :AgeRestriction ;
    rdfs:label "W076" ;
    :hasReference :R031 ;
    :hasWarningHeadline "Pediatric Use" ;
    :hasWarningText "Comazole should not be given to premature and newborn infants during the first week of life." .

:W077 a :PregnancyAndLactation ;
    rdfs:label "W077" ;
    :hasReference :R031 ;
    :hasWarningHeadline "Pregnancy" ;
    :hasWarningText "Comazole is contraindicated during pregnancy. If pregnancy cannot be excluded, possible risks should be balanced against the expected therapeutic effect. Comazole should not be given during pregnancy especially in late pregnancy because of risk of kernicterus." .

:W078 a :PregnancyAndLactation ;
    rdfs:label "W078" ;
    :hasReference :R031 ;
    :hasWarningHeadline "Lactation" ;
    :hasWarningText """Despite the excretion of trimethoprim and sulphamethoxazole into breast milk, the administration of comazole to lactating women represents a negligible risk to the suckling infants. It also should be used with caution in nursing
mothers because it can pass the placenta and is excreted in breast milk and may cause kernicterus.""" .

:W079 a :AgeRestriction ;
    rdfs:label "W079" ;
    :hasReference :R031 ;
    :hasWarningHeadline "Pediatric Use" ;
    :hasWarningText "Comazole should not be given to premature and newborn infants during the first week of life." .

:W080 a :PregnancyAndLactation ;
    rdfs:label "W080" ;
    :hasReference :R031 ;
    :hasWarningHeadline "Pregnancy" ;
    :hasWarningText "Comazole is contraindicated during pregnancy. If pregnancy cannot be excluded, possible risks should be balanced against the expected therapeutic effect. Comazole should not be given during pregnancy especially in late pregnancy because of risk of kernicterus." .

:W081 a :PregnancyAndLactation ;
    rdfs:label "W081" ;
    :hasReference :R031 ;
    :hasWarningHeadline "Breastfeeding" ;
    :hasWarningText """Despite the excretion of trimethoprim and sulphamethoxazole into breast milk, the administration of comazole to lactating women represents a negligible risk to the suckling infants. It also should be used with caution in nursing
mothers because it can pass the placenta and is excreted in breast milk and may cause kernicterus.""" .

:W082 a :Contraindication ;
    rdfs:label "W082" ;
    :hasReference :R031 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText """Comazole is contraindicated in patients with marked liver parenchymal damage. It is also contraindicated in patients with severe renal insufficiency when repeated determinations of the plasma concentration cannot be made. Except in rare circumstances Comazole should not be given to patient with serious haematological disorders. The combination has occasionally been administered to patients receiving cytotoxic agents for the treatment of leukemias, without evidence of any adverse effect on the bone marrow or peripheral blood. Comazole should not be administered to patients with a history of hypersensitivity to sulphonamides or trimethoprim. Comazole is contraindicated in G6PD (Glucose-6-phosphate dehydrogenase
deficiency). Treatment must be immediately discontinued on the appearance of a skin rash or any element of blood count reduced.""" .

:W083 a :Contraindication ;
    rdfs:label "W083" ;
    :hasReference :R032 ;
    :hasWarningHeadline "Hypersensitivity to Cephalosporins" ;
    :hasWarningText """Cefumax should be used with care in patients with hypersensitivity to penicillin.
In the clinical and laboratory tests, cross-allergenicity between penicillin and cephalosporin was ascertained although there were rare cases of patients who have demonstrated allergic reactions to both of these 2 drugs.
Some cases of anaphylactic shock were reported especially following the parenteral administration.
During pregnancy and children <3 months, cefumax should be used in cases of absolute necessity and under direct medical control.""" .

:W084 a :Contraindication ;
    rdfs:label "W084" ;
    :hasReference :R032 ;
    :hasWarningHeadline "Clostridium difficile-Associated Diarrhea (CDAD)" ;
    :hasWarningText """Clostridium difficile-associated diarrhea (CDAD) has been reported with use nearly all antibacterial agents, including cefuroxime axetil, and may range in severity from mild diarrhea to fatal colitis. Treatment with antibacterial agents alters the normal flora of the colon leading to overgrowth of C. difficile.
Clostridium difficile produces toxins A and B which contribute to the development of CDAD. Hypertoxin producing strains of C. difficile cause increased morbidity and mortality, as these infections can be refractory to antimicrobial therapy and may require colectomy. Clostridium difficile must be considered in all patients who present with diarrhea following antibiotic use. Careful medical history is necessary since CDAD has been reported to occur over 2 months after the administration of antibacterial agents.
If CDAD is suspected or confirmed, ongoing antibiotic use not directed against C. difficile may need to be discontinued. Appropriate fluid and electrolyte management, protein supplementation, antibiotic treatment of C. difficile and surgical evaluation should be instituted as clinically indicated.""" .

:W085 a :Contraindication ;
    rdfs:label "W085" ;
    :hasReference :R015 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Should not be given to patients with a history of hypersensitivity to β-lactam antibiotics (e.g., penicillins, cephalosporins)." .

:W086 a :PatientCondition ;
    rdfs:label "W086" ;
    :hasReference :R015 ;
    :hasWarningHeadline "Infectious Mononucleosis" ;
    :hasWarningText "Should be avoided if infectious mononucleosis is suspected due to risk of morbilliform rash." .

:W087 a :PatientCondition ;
    rdfs:label "W087" ;
    :hasReference :R015 ;
    :hasWarningHeadline "Pseudomembranous Colitis" ;
    :hasWarningText "Antibiotic use may cause mild to life-threatening pseudomembranous colitis. Discontinue if prolonged or significant diarrhea or abdominal cramps occur." .

:W088 a :PatientCondition ;
    rdfs:label "W088" ;
    :hasReference :R015 ;
    :hasWarningHeadline "Renal Impairment" ;
    :hasWarningText "Dosage adjustment required in patients with renal impairment." .

:W089 a :PatientCondition ;
    rdfs:label "W089" ;
    :hasReference :R015 ;
    :hasWarningHeadline "Concurrent Anticoagulant Use" ;
    :hasWarningText "May prolong prothrombin time (INR). Monitor INR and adjust anticoagulant dose if prescribed concurrently." .

:W090 a :PregnancyAndLactation ;
    rdfs:label "W090" ;
    :hasReference :R015 ;
    :hasWarningHeadline "Pregnancy" ;
    :hasWarningText "The safety of use in human pregnancy has not been established by well-controlled studies in pregnant women. May be used in pregnancy when the potential benefits outweigh the potential risks associated with treatment." .

:W091 a :PregnancyAndLactation ;
    rdfs:label "W091" ;
    :hasReference :R015 ;
    :hasWarningHeadline "Lactation" ;
    :hasWarningText "May be used during lactation except for risk of sensitization from trace amounts in breast milk." .

:W092 a :AgeRestriction ;
    rdfs:label "W092" ;
    :hasReference :R015 ;
    :hasWarningHeadline "Gastrointestinal Effects" ;
    :hasWarningText "May cause nausea, vomiting, diarrhea, and electrolyte imbalance. Treat symptomatically." .

:W093 a :AgeRestriction ;
    rdfs:label "W093" ;
    :hasReference :R015 ;
    :hasWarningHeadline "Crystalluria & Renal Risk" ;
    :hasWarningText "High doses may cause crystalluria, potentially leading to renal failure. Maintain adequate fluid intake." .

:W094 a :AgeRestriction ;
    rdfs:label "W094" ;
    :hasReference :R015 ;
    :hasWarningHeadline "Hemodialysis" ;
    :hasWarningText "Can be removed from circulation by hemodialysis." .

:W095 a :PatientCondition ;
    rdfs:label "W095" ;
    :hasReference :R015 ;
    :hasWarningHeadline "Phenylketonuria" ;
    :hasWarningText "Contains aspartame (source of phenylalanine). Use with caution in patients with phenylketonuria." .

:W096 a :PatientCondition ;
    rdfs:label "W096" ;
    :hasReference :R015 ;
    :hasWarningHeadline "Sugar Intolerance" ;
    :hasWarningText "May contain sorbitol. Caution in patients with sugar intolerance." .

:W097 a :PatientCondition ;
    rdfs:label "W097" ;
    :hasReference :R015 ;
    :hasWarningHeadline "Newborn Jaundice Risk" ;
    :hasWarningText "Contains sodium benzoate which is a mild irritant to the skin, eyes and mucus membrane. It may increase risk of jaundice in newborn babies" .

:W098 a :AgeRestriction ;
    rdfs:label "W098" ;
    :hasReference :R015 ;
    :hasWarningHeadline "Newborns & Infants" ;
    :hasWarningText "Use with caution in newborns due to risk of jaundice from sodium benzoate." .

:W099 a :PatientCondition ;
    rdfs:label "W099" ;
    :hasReference :R039 ;
    :hasWarningHeadline "Renal Impairment" ;
    :hasWarningText "33% increase in systemic exposure in severe renal impairment (GFR <10 mL/min)" .

:W100 a :PatientCondition ;
    rdfs:label "W100" ;
    :hasReference :R039 ;
    :hasWarningHeadline "Cardiovascular events" ;
    :hasWarningText "Use with caution in patients with ongoing proarrthymic conditions (especially women and elderly patients) such as: congenital or documented QT prolongation; patients currently receiving treatment with other substances that prolong QT interval, such as antiarrythmics of classes IA (quinidine and procainamide) and class III (dofelitide, amiodarone, and sotalol), cisparide and terfenadine; antipsychotic agents such as pimozide; antidepressants such as citalopram; fluoroquinolones such as moxiflaxin and levoflaxin; patients with electrolyte disturbance, particularly in cases of hypokalaemia and hypomagnesaemia; patients with bradycardia, cardiac arrhythmia or severe cardiac insufficiency." .

:W101 a :PatientCondition ;
    rdfs:label "W101" ;
    :hasReference :R039 ;
    :hasWarningHeadline "Myasthenia gravis" ;
    :hasWarningText "Exacerbations of the symptoms of myasthenia gravis and new onset of myasthenia syndrome have been reported in patients receiving azithromycin therapy" .

:W102 a :AgeRestriction ;
    rdfs:label "W102" ;
    :hasReference :R039 ;
    :hasWarningHeadline "Infantile hypertrophic pyloric stenosis (IHPS)" ;
    :hasWarningText "Following the use of azithromycin in neonates (treatment up to 42 days of life), infantile hypertrophic pyloric stenosis (IHPS) has been reported. Parents and caregiviers should contact physician if vomiting/irritability occurs." .

:W103 a :AgeRestriction ;
    rdfs:label "W103" ;
    :hasReference :R031 ;
    :hasWarningHeadline "Gastronintestinal Effects" ;
    :hasWarningText "Nausea, vomiting, dizziness and confusion are likely symptoms of overdosage." .

:W107 a :PatientCondition ;
    rdfs:label "W107" ;
    :hasReference :R035 ;
    :hasWarningHeadline "Severe Hepatic, Hematologic, and Renal Impairment" ;
    :hasWarningText """Sulfamethoxazole/trimethoprim is contraindicated in patients with a history of drug-induced immune thrombocytopenia with use of trimethoprim and/or sulfonamides and in patients showing marked hepatic damage, blood dyscrasias
or with severe renal insufficiency, where repeated measurements of the plasma concentrations cannot be performed.""" .

:W108 a :Contraindication ;
    rdfs:label "W108" ;
    :hasReference :R035 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "It should not be given to patients with known hypersensitivity to trimethoprim or sulfonamides or with documented megaloblastic anaemia secondary to folate deficiency." .

:W109 a :AgeRestriction ;
    rdfs:label "W109" ;
    :hasReference :R035 ;
    :hasWarningHeadline "Premature & Newborn Infants" ;
    :hasWarningText """Premature babies and newborn babies during the first eight weeks of life should
not be given sulfamethoxazole/trimethoprim, as sulfamethoxazole may interfere
with the serum albumin binding of bilirubin to produce kernicterus.""" .

:W110 a :Contraindication ;
    rdfs:label "W110" ;
    :hasReference :R035 ;
    :hasWarningHeadline "Streptococcal Pharyngitis Treatment" ;
    :hasWarningText "Treatment of streptococcal pharyngitis." .

:W111 a :Contraindication ;
    rdfs:label "W111" ;
    :hasReference :R035 ;
    :hasWarningHeadline "Concomitant Dofetilide Use" ;
    :hasWarningText "Concomitant administration with dofetilide." .

:W112 a :PregnancyAndLactation ;
    rdfs:label "W112" ;
    :hasReference :R035 ;
    :hasWarningHeadline "Pregnancy" ;
    :hasWarningText "Sulfonamides may cause kernicterus in babies during the first month of life by displacing bilirubin from plasma albumin. Sulfonamides should therefore be avoided as far as possible during the last month of pregnancy. Trimethoprim may interfere with folic acid metabolism and animal experiments have shown that administration of very high doses of trimethoprim during organ development may give rise to birth defects typical of folic acid antagonism. If a trimethoprim-sulfonamide combination is given during pregnancy, folic acid supplementation may be required. Because trimethoprim and sulfamethoxazole may interfere with folic acid metabolism, DBL Sulfamethoxazole 400 mg and Trimethoprim 80 mg should be used during pregnancy only if the potential benefit justifies the potential risk to the fetus." .

:W113 a :PregnancyAndLactation ;
    rdfs:label "W113" ;
    :hasReference :R035 ;
    :hasWarningHeadline "Breastfeeding" ;
    :hasWarningText "Although the quantity of sulfamethoxazole/trimethoprim ingested by a breast-fed infant is small, caution should be exercised when DBL Sulfamethoxazole 400 mg and Trimethoprim 80 mg is administered to a nursing woman, especially when breastfeeding jaundiced, ill, stressed, or premature infants because of the potential risk of bilirubin displacement and kernicterus, and it is recommended that the age of the infant be considered and the possible risks be balanced against the expected therapeutic effect." .

:W114 a :AgeRestriction ;
    rdfs:label "W114" ;
    :hasReference :R035 ;
    :hasWarningHeadline "Gastrointestinal, Neurologic, and Hematologic Effects" ;
    :hasWarningText "Include anorexia, colic, nausea, vomiting, dizziness, headache, drowsiness, and unconsciousness. Pyrexia, haematuria, and crystalluria may be noted. Blood dyscrasias and jaundice are potential late manifestations of overdosage. Signs of acute overdosage with trimethoprim include nausea, vomiting, dizziness, headache, mental depression, confusion, and bone marrow depression." .

:W115 a :Contraindication ;
    rdfs:label "W115" ;
    :hasReference :R035 ;
    :hasWarningHeadline "Fatal Reactions" ;
    :hasWarningText "Fatalities associated with the administration of sulphonamides and trimethoprim, either alone or in combination, although rare, have occurred due to severe reactions, including Stevens-Johnson syndrome, toxic epidermal necrolysis, fulminant hepatic necrosis, agranulocytosis, aplastic anaemia, other blood dyscrasias, acute and delayed lung injury, hypersensitivity of the respiratory tract, circulatory shock and other reactions." .

:W116 a :PregnancyAndLactation ;
    rdfs:label "W116" ;
    :hasReference :R017 ;
    :hasWarningHeadline "Safe in Pregnancy; Caution in Nursing" ;
    :hasWarningText "Administered to pregnant women without evidence of fetal harm; use with caution in breastfeeding mothers because it is distributed into milk and may sensitize infants." .

:W117 a :AgeRestriction ;
    rdfs:label "W117" ;
    :hasReference :R017 ;
    :hasWarningHeadline "Neonates and Infants < 3 Months" ;
    :hasWarningText "Specifically dosed at 20-30 mg/kg body weight/day in divided doses every 12 hours." .

:W119 a :AgeRestriction ;
    rdfs:label "W119" ;
    :hasReference :R017 ;
    :hasWarningHeadline "Low Toxicity Symptoms" ;
    :hasWarningText "May cause nausea, vomiting, diarrhea, crystalluria, and allergic manifestations. Symptomatic treatment is required for almost all patients. Problems are unlikely if adequate fluid intake and urinary output are maintained; however crystalluria and hemorrhagic cystitis are possible." .

:W120 a :Contraindication ;
    rdfs:label "W120" ;
    :hasReference :R017 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Hypersensitivity to penicillins and to any ingredient in the products. Patients with infectious mononucleosis due to possible development of rash during therapy." .

:W121 a :PregnancyAndLactation ;
    rdfs:label "W121" ;
    :hasReference :R017 ;
    :hasWarningHeadline "Safe for Mother; Monitor Baby" ;
    :hasWarningText "Administered to pregnant women without evidence of fetal harm; use with caution in breastfeeding mothers because it is distributed into milk and may sensitize infants." .

:W122 a :AgeRestriction ;
    rdfs:label "W122" ;
    :hasReference :R017 ;
    :hasWarningHeadline "Infants > 3 Months & Children < 40 kg" ;
    :hasWarningText "Dosed at 25-50 mg/kg body weight/day in divided doses every 8 or 12 hours." .

:W124 a :AgeRestriction ;
    rdfs:label "W124" ;
    :hasReference :R017 ;
    :hasWarningHeadline "Toxicity Management" ;
    :hasWarningText "May cause nausea, vomiting, diarrhea, crystalluria, and allergic manifestations. Symptomatic treatment is required for almost all patients. Problems are unlikely if adequate fluid intake and urinary output are maintained; however crystalluria and hemorrhagic cystitis are possible." .

:W125 a :Contraindication ;
    rdfs:label "W125" ;
    :hasReference :R017 ;
    :hasWarningHeadline "Penicillin Sensitivity" ;
    :hasWarningText "Hypersensitivity to penicillins and to any ingredient in the products. Patients with infectious mononucleosis due to possible development of rash during therapy." .

:W126 a :PregnancyAndLactation ;
    rdfs:label "W126" ;
    :hasReference :R016 ;
    :hasWarningHeadline "Pregnancy Category B" ;
    :hasWarningText "Safety not definitely established, but used for UTIs without evidence of fetal harm. Distributed into human milk and may lead to sensitization of the infant; use with caution when breastfeeding" .

:W127 a :AgeRestriction ;
    rdfs:label "W127" ;
    :hasReference :R016 ;
    :hasWarningHeadline "Neonates, Infants, and Elderly" ;
    :hasWarningText "Neonates and young infants have incompletely developed renal function, delaying drug elimination. Elderly patients should have doses selected with care due to likely decreased renal function" .

:W128 a :PatientCondition ;
    rdfs:label "W128" ;
    :hasReference :R016 ;
    :hasWarningHeadline "Renal and Hypersensitivity Precautions" ;
    :hasWarningText "Dose adjustment required based on the degree of renal impairment. Long-term use may result in the overgrowth of non-susceptible organisms, including fungi" .

:W129 a :AgeRestriction ;
    rdfs:label "W129" ;
    :hasReference :R016 ;
    :hasWarningHeadline "Toxicity and Renal Risk" ;
    :hasWarningText "Symptoms include allergic reactions, nausea, vomiting, and diarrhea. High doses may cause crystalluria, potentially leading to renal failure, which is generally reversible upon cessation" .

:W130 a :Contraindication ;
    rdfs:label "W130" ;
    :hasReference :R016 ;
    :hasWarningHeadline "Hypersensitivity and Mononucleosis" ;
    :hasWarningText "Prohibited for patients with a known hypersensitivity to penicillins or cephalosporins. Forbidden for patients with infectious mononucleosis due to the high risk of a maculopapular rash" .

:W131 a :Contraindication ;
    rdfs:label "W131" ;
    :hasReference :R047 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Cefuroxime (as Axetil) products are contraindicated in patients with known allergy to the cephalosporin group of antibiotics." .

:W132 a :PatientCondition ;
    rdfs:label "W132" ;
    :hasReference :R047 ;
    :hasWarningHeadline "Renal Impairment" ;
    :hasWarningText "Because cefuroxime is eliminated primarily by the kidney, a dosage interval adjustment is required for patients whose creatinine clearance is 30 mL/min" .

:W133 a :AgeRestriction ;
    rdfs:label "W133" ;
    :hasReference :R047 ;
    :hasWarningHeadline "Cerebral Irritation" ;
    :hasWarningText "Overdosage of cephalosporins can cause cerebral irritation leading to convulsions or encephalopathy. Serum levels of cefuroxime can be reduced by hemodialysis and peritoneal dialysis." .

:W134 a :Contraindication ;
    rdfs:label "W134" ;
    :hasReference :R047 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Strictly prohibited for patients with a history of hypersensitivity to penicillins or any ingredient in the product." .

:W135 a :PregnancyAndLactation ;
    rdfs:label "W135" ;
    :hasReference :R047 ;
    :hasWarningHeadline "Safe for Mother; Monitor Baby" ;
    :hasWarningText "No evidence of fetal harm; distributed into breast milk." .

:W136 a :AgeRestriction ;
    rdfs:label "W136" ;
    :hasReference :R047 ;
    :hasWarningHeadline "Infants > 3 Months & Children < 40 kg" ;
    :hasWarningText "Dosed at 25-50 mg/kg/day in divided doses every 8 or 12 hours." .

:W137 a :PatientCondition ;
    rdfs:label "W137" ;
    :hasReference :R047 ;
    :hasWarningHeadline "Precautions for Chronic Illness" ;
    :hasWarningText "Caution in renal failure, lymphatic leukemia, and mononucleosis (rash risk)." .

:W138 a :PregnancyAndLactation ;
    rdfs:label "W138" ;
    :hasReference :R018 ;
    :hasWarningHeadline "Embryotoxicity & Milk Distribution" ;
    :hasWarningText "Should not be used in pregnant women unless no alternative is appropriate; high doses are associated with embryotoxicity in animals. Detected in breast milk; exercise caution when nursing." .

:W139 a :AgeRestriction ;
    rdfs:label "W139" ;
    :hasReference :R018 ;
    :hasWarningHeadline "Elderly Risk" ;
    :hasWarningText "Elderly patients are at higher risk for colchicine toxicity." .

:W140 a :PatientCondition ;
    rdfs:label "W140" ;
    :hasReference :R018 ;
    :hasWarningHeadline "Renal/Hepatic Impairment & Colitis" ;
    :hasWarningText "Use with caution and consider dose reductions in severe renal or hepatic impairment. Consider a diagnosis of pseudomembranous colitis in patients who develop diarrhea." .

:W141 a :AgeRestriction ;
    rdfs:label "W141" ;
    :hasReference :R018 ;
    :hasWarningHeadline "Gastrointestinal Symptoms & Supportive Care" ;
    :hasWarningText "Overdose causes abdominal pain, vomiting, nausea, and diarrhea. Treat with prompt elimination of unabsorbed drug and supportive measures." .

:W142 a :Contraindication ;
    rdfs:label "W142" ;
    :hasReference :R018 ;
    :hasWarningHeadline "Hypersensitivity & Drug Blocks" ;
    :hasWarningText "Prohibited for patients with known hypersensitivity to macrolides. Concurrent use with astemizole, cisapride, or terfenadine is strictly forbidden." .

:W143 a :Contraindication ;
    rdfs:label "W143" ;
    :hasReference :R011 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Hypersensitivity to any of the tetracyclines." .

:W144 a :PregnancyAndLactation ;
    rdfs:label "W144" ;
    :hasReference :R011 ;
    :hasWarningHeadline "Lactation" ;
    :hasWarningText "Tetracyclines are excreted in breast milk. A dosage of 2g/day for 3 days has achieved a milk plasma ratio of 0.6 to 0.8." .

:W145 a :PregnancyAndLactation ;
    rdfs:label "W145" ;
    :hasReference :R011 ;
    :hasWarningHeadline "Pregnancy" ;
    :hasWarningText "Category D. do not use tetracycline during pregnancy. Tetracyclines readily cross the placenta, are found in fetal tissues and can have toxic effects on the developing fetus (retardation of skeletal development). Evidence of embryotoxicity has also been noted in animals treated early in pregnancy." .

:W146 a :AgeRestriction ;
    rdfs:label "W146" ;
    :hasReference :R011 ;
    :hasWarningHeadline "Pediatric Use" ;
    :hasWarningText "Do not use in children aged 8 years and below because of the effect of tetracyclines in teeth (permanent discoloration and possibly enamel hypoplasia) and bone." .

:W147 a :Contraindication ;
    rdfs:label "W147" ;
    :hasReference :R012 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "This drug is contraindicated in persons who have shown hypersensitivity to any of the tetracyclines." .

:W148 a :AgeRestriction ;
    rdfs:label "W148" ;
    :hasReference :R012 ;
    :hasWarningHeadline "Pediatric Use" ;
    :hasWarningText "The use of drugs of the tetracycline class during tooth development (last half of pregnancy, infancy and childhood to the age of 8 years) may cause permanent discoloration of the teeth (yellow-gray-brown)." .

:W149 a :AgeRestriction ;
    rdfs:label "W149" ;
    :hasReference :R012 ;
    :hasWarningHeadline "Pediatric Use" ;
    :hasWarningText "Use doxycycline in pediatric patients 8 years of age or less only when the potential benefits are expected to outweigh the risks in severe or life-threatening conditions (e.g., anthrax, Rocky Mountain spotted fever), particularly when there are no alternative therapies." .

:W150 a :PatientCondition ;
    rdfs:label "W150" ;
    :hasReference :R012 ;
    :hasWarningHeadline "Risk of Severe Diarrhea (C. difficile Infection)" ;
    :hasWarningText "Clostridium difficile associated diarrhea (CDAD) has been reported with use of nearly all antibacterial agents, including Doxycycline, and may range in severity from mild diarrhea to fatal colitis." .

:W151 a :PatientCondition ;
    rdfs:label "W151" ;
    :hasReference :R012 ;
    :hasWarningHeadline "Skin Reactions" ;
    :hasWarningText "Severe skin reactions, such as exfoliative dermatitis, erythema multiforme, Steven-Johnson syndrome, toxic epidermal necrolysis, and drug reaction with eosinophilia and systemic symptoms (DRESS) have been reported in patients receiving doxycycline." .

:W152 a :AgeRestriction ;
    rdfs:label "W152" ;
    :hasReference :R019 ;
    :hasWarningHeadline "Gastrointestinal and Mental Effects" ;
    :hasWarningText "Symptoms include abdominal pain, nausea, vomiting, and diarrhea. High doses (8g) may cause altered mental status and paranoid behavior." .

:W153 a :Contraindication ;
    rdfs:label "W153" ;
    :hasReference :R019 ;
    :hasWarningHeadline "Allergic Reactions and Dangerous Combinations" ;
    :hasWarningText "Contraindicated for patients with known hypersensitivity to macrolides or history of cholestatic jaundice/hepatic dysfunction." .

:W154 a :PregnancyAndLactation ;
    rdfs:label "W154" ;
    :hasReference :R020 ;
    :hasWarningHeadline "Safety Not Established" ;
    :hasWarningText "Use is not advised without carefully weighing benefits against risk, as adverse embryo-fetal development effects cannot be excluded. The safety of Clarithromycin for using breast-feeding of infants has not been established. Clarithromycin is excreted into human breast milk." .

:W155 a :AgeRestriction ;
    rdfs:label "W155" ;
    :hasReference :R020 ;
    :hasWarningHeadline "Not for Children <12" ;
    :hasWarningText "Indicated for adults and children 12 years and older. It is not recommended for children younger than 12 years; they should use the paediatric suspension instead." .

:W156 a :PatientCondition ;
    rdfs:label "W156" ;
    :hasReference :R020 ;
    :hasWarningHeadline "Renal and Hepatic Impairment" ;
    :hasWarningText "Caution is advised in patients with severe renal insufficiency or impaired hepatic function. Fatal hepatic failure has been reported in some cases." .

:W157 a :AgeRestriction ;
    rdfs:label "W157" ;
    :hasReference :R020 ;
    :hasWarningHeadline "Gastrointestinal and Mental Effects" ;
    :hasWarningText "Large amounts produce GI symptoms. A patient ingesting 8 grams showed altered mental status, paranoid behaviour, hypokalemia, and hypoxemia." .

:W158 a :Contraindication ;
    rdfs:label "W158" ;
    :hasReference :R020 ;
    :hasWarningHeadline "Dangerous Combinations" ;
    :hasWarningText "Contraindicated for patients with hypersensitivity to macrolides, a history of QT prolongation, ventricular cardiac arrhythmia, or those taking drugs like oral midazolam, astemizole, cisapride, pimozide, terfenadine, ergot alkaloids, ticagrelor, or ranolazine." .

:W159 a :PregnancyAndLactation ;
    rdfs:label "W159" ;
    :hasReference :R054 ;
    :hasWarningHeadline "Pregnancy" ;
    :hasWarningText "Embryotoxicity has also been noted in animals treated early in pregnancy." .

:W160 a :AgeRestriction ;
    rdfs:label "W160" ;
    :hasReference :R054 ;
    :hasWarningHeadline "Lactation" ;
    :hasWarningText "Tetracyclines are excreted in breast milk. A dosage of 2g/day for 3 days has achieved a milk plasma ratio of 0.6 to 0.8." .

:W161 a :PatientCondition ;
    rdfs:label "W161" ;
    :hasReference :R054 ;
    :hasWarningHeadline "Pediatric Use" ;
    :hasWarningText "Do not use in children aged 8 years and below because of the effect of tetracyclines in teeth (permanent discoloration and possibly enamel hypoplasia) and bone." .

:W162 a :AgeRestriction ;
    rdfs:label "W162" ;
    :hasReference :R054 ;
    :hasWarningHeadline "Gastrointestinal and Mental Effects" ;
    :hasWarningText "Symptoms include abdominal pain, nausea, vomiting, and diarrhea. High doses (8g) may cause altered mental status and paranoid behavior." .

:W163 a :Contraindication ;
    rdfs:label "W163" ;
    :hasReference :R054 ;
    :hasWarningHeadline "Allergic Reactions and Dangerous Combinations" ;
    :hasWarningText "Contraindicated for patients with known hypersensitivity to macrolides or history of drug-induced hepatic dysfunction. Also contraindicated with drugs like cisapride, simvastatin, or lovastatin." .

:W164 a :PregnancyAndLactation ;
    rdfs:label "W164" ;
    :hasReference :R054 ;
    :hasWarningHeadline "Safety Not Established" ;
    :hasWarningText "Use is not advised without carefully weighing benefits against risk, as adverse embryo-fetal development effects cannot be excluded. Clarithromycin is excreted into human breast milk." .

:W165 a :AgeRestriction ;
    rdfs:label "W165" ;
    :hasReference :R054 ;
    :hasWarningHeadline "Not for Children <12" ;
    :hasWarningText "Indicated for adults and children 12 years and older. It is not recommended for children younger than 12 years; they should use the paediatric suspension instead." .

:W166 a :PatientCondition ;
    rdfs:label "W166" ;
    :hasReference :R054 ;
    :hasWarningHeadline "Renal and Hepatic Impairment" ;
    :hasWarningText "Caution is advised in patients with severe renal insufficiency or impaired hepatic function. Fatal hepatic failure has been reported in some cases." .

:W167 a :AgeRestriction ;
    rdfs:label "W167" ;
    :hasReference :R054 ;
    :hasWarningHeadline "Gastrointestinal and Mental Effects" ;
    :hasWarningText "Large amounts produce GI symptoms. A patient ingesting 8 grams showed altered mental status, paranoid behaviour, hypokalemia, and hypoxemia." .

:W168 a :Contraindication ;
    rdfs:label "W168" ;
    :hasReference :R054 ;
    :hasWarningHeadline "Dangerous Combinations" ;
    :hasWarningText "Contraindicated for patients with hypersensitivity to macrolides, a history of QT prolongation, or those taking drugs like cisapride, pimozide, ergot alkaloids, ticagrelor, or ranolazine." .

:W169 a :PatientCondition ;
    rdfs:label "W169" ;
    :hasReference :R039 ;
    :hasWarningHeadline "Cross Resistance" ;
    :hasWarningText "Not recommended for infections caused by erythromycin-resistant Gram-positive bacteria or MRSA (Methicillin-resistant Staphylococcus aureus). Consider local resistance patterns before use." .

:W170 a :PatientCondition ;
    rdfs:label "W170" ;
    :hasReference :R038 ;
    :hasWarningHeadline "Arrythmia Risk" ;
    :hasWarningText "May cause QT prolongation leading to Torsade de Pointes. Use with caution in at-risk patients." .

:W171 a :PatientCondition ;
    rdfs:label "W171" ;
    :hasReference :R012 ;
    :hasWarningHeadline "Intracranial Hypertension (Pseudotumor Cerebri)" ;
    :hasWarningText "Intracranial hypertension (IH, pseudotumor cerebri) has been assciated with the use of tetracyclines including Doxycycline. Clinical manifestations of IH include headache, blurred vision, diplopia, and vision loss; papilledema can be found on fundoscopy. Women of childbearing age who are overweight or have history of IH are at greater risk for developing tetracycline associated IH." .

:W172 a :PregnancyAndLactation ;
    rdfs:label "W172" ;
    :hasReference :R012 ;
    :hasWarningHeadline "Tetracycline Use in Pregnancy" ;
    :hasWarningText "If any tetracycline is used during pregnancy or if the patient becomes pregnant while taking this drug, the patient should be apprised of the potential hazard to the fetus." .

:W173 a :PatientCondition ;
    rdfs:label "W173" ;
    :hasReference :R012 ;
    :hasWarningHeadline "Photosensitivity" ;
    :hasWarningText "Photosensitivity manifested by an exaggerated sunburn has been observed in some individuals taking tetracyclines. Patients apt to be exposed to direct sunlight or ultraviolet light should be advised that this reaction can occur with tetracycline drugs, and treatment should be discontinued at the first evidence of skin erythema." .

:W174 a :AgeRestriction ;
    rdfs:label "W174" ;
    :hasReference :R012 ;
    :hasWarningHeadline "Overdose Treatment Guidance" ;
    :hasWarningText "In case of overdosage, discontinue medication, treat symptomatically and institute supportive measures. Dialysis does not alter serum half-life and thus would not be of benefit in treating cases of overdosage." .

:W175 a :AgeRestriction ;
    rdfs:label "W175" ;
    :hasReference :R013 ;
    :hasWarningHeadline "Overdose Treatment Guidance" ;
    :hasWarningText "In case of overdosage, discontinue medication. Treat symptomatically and institute supportive measures. Dialysis does not alter serum half-life and thus would not be of benefit in treating cases of overdosage." .

:W176 a :Contraindication ;
    rdfs:label "W176" ;
    :hasReference :R013 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "The drug is contraindicated in patients who have shown hypersensitivity to any of the tetracyclines." .

:W177 a :AgeRestriction ;
    rdfs:label "W177" ;
    :hasReference :R013 ;
    :hasWarningHeadline "Pediatric Use" ;
    :hasWarningText "The use of drugs of the tetracycline class during tooth development (last half of pregnancy, infancy and childhood to the age of 8 years) may cause permanent discoloration of the teeth (yellow-gray-brown). This adverse reaction is more common during long term use of the drugs but has been observed following repeated short-term courses. Enamel hypoplasia has also been reported. Tetracycline drugs, therefore, should not be used in this age group unless other drugs are not likely to be effective or as contraindicated." .

:W178 a :PatientCondition ;
    rdfs:label "W178" ;
    :hasReference :R008 ;
    :hasWarningHeadline "Maintained Hydration" ;
    :hasWarningText "Although levofloxacin is more soluble than other quinolones, adequate hydration of patients receiving levofloxacin should be maintained to prevent the formation of highly concentrated urine." .

:W179 a :PatientCondition ;
    rdfs:label "W179" ;
    :hasReference :R008 ;
    :hasWarningHeadline "Caution to People with CNS disorder" ;
    :hasWarningText "As with other quinolones, levofloxacin should be used with caution in patients with a known or suspected central nervous system (CNS) disorder that may predispose them to seizures or lower the seizure threshold (e.g., severe cerebral arteriosclerosis, epilepsy) or in the presence of other risk factors that may predispose them to seizures or lower the seizure threshold (e.g., certain drug therapy, renal dysfunction)." .

:W180 a :PatientCondition ;
    rdfs:label "W180" ;
    :hasReference :R008 ;
    :hasWarningHeadline "Pain, Inflamation or Rupture of a tendon" ;
    :hasWarningText "Levofloxacin should be discontinued if the patient experiences pain, inflammation or rupture of a tendon. Patients should rest and refrain from exercise until the diagnosis of tendonitis or tendon rupture has been confidently excluded. Tendon rupture can occur during or after therapy with quinolones, including levofloxacin." .

:W181 a :PatientCondition ;
    rdfs:label "W181" ;
    :hasReference :R008 ;
    :hasWarningHeadline "Neuropathy Symptoms" ;
    :hasWarningText "Levofloxacin should be discontinued if the patient experiences symptoms of neuropathy including pain, burning, tingling, numbness and/or weakness or other alterations of sensation including light touch, pain, temperature position sense and vibratory sensation in order to prevent the development of an irreversible condition." .

:W182 a :PatientCondition ;
    rdfs:label "W182" ;
    :hasReference :R008 ;
    :hasWarningHeadline "QT interval" ;
    :hasWarningText "Levofloxacin should be avoided in patients with known prolongation of the QT interval, patients with uncorrected hypokalemia and patients receiving class IA (quinidine, procainamide) or class III (amiodarone, sotalol) antiarrhythmic agents. Elderly patients may be more susceptible to drug-associated effects on the QT interval." .

:W183 a :PatientCondition ;
    rdfs:label "W183" ;
    :hasReference :R008 ;
    :hasWarningHeadline "Abscence of Suspected Bacterial Infection" ;
    :hasWarningText "Prescribing levofloxacin in the absence of a proven or strongly suspected bacterial infection or a prophylactic indication is unlikely to provide benefit to the patient and increases the risk of the development of drug-resistant bacteria." .

:W184 a :Contraindication ;
    rdfs:label "W184" ;
    :hasReference :R008 ;
    :hasWarningHeadline "Multivalent  Cations" ;
    :hasWarningText "No fluoroquinolone should be co-administered with any solution containing multivalent cations, e.g., magnesium, through the same intravenous." .

:W185 a :PatientCondition ;
    rdfs:label "W185" ;
    :hasReference :R008 ;
    :hasWarningHeadline "Patients predisposed to seizures" ;
    :hasWarningText "Quinolones, should be used with extreme caution in patients predisposed to seizures, such as patients with pre-existing central nervous system lesions, concomitant treatment with fenbufen and similar non-steroidal anti-inflammatory drugs or with drugs which lower the cerebral seizure threshold, such as theophylline. Patients with G-6-phosphate dehydrogenase deficiency: Patients with latent or actual defects in glucose-6-phosphate dehydrogenase activity may be prone to hemolytic reactions when treated with quinolone antibacterial agents, and so levofloxacin should be used with caution." .

:W186 a :PatientCondition ;
    rdfs:label "W186" ;
    :hasReference :R008 ;
    :hasWarningHeadline "Patients with renal impairment" ;
    :hasWarningText "Since Levofloxacin is excreted mainly by the kidneys, the dose of Levofloxacin should be adjusted in patients with renal impairment." .

:W187 a :PatientCondition ;
    rdfs:label "W187" ;
    :hasReference :R008 ;
    :hasWarningHeadline "Prevention of photosensitisation" ;
    :hasWarningText """Although photosensitisation is very rare with levofloxacin,
it is recommended that patients should not expose themselves unnecessarily to strong sunlight or to artificial UV rays (e.g., sunray lamp, solarium), in order to prevent
photosensitisation.""" .

:W188 a :PatientCondition ;
    rdfs:label "W188" ;
    :hasReference :R008 ;
    :hasWarningHeadline "Patients treated with Vitamin K antagonists" ;
    :hasWarningText "Due to possible increase in coagulation tests (PT/INR) and/or bleeding in patients treated with levofloxacin in combination with a vitamin K antagonist (e.g., warfarin), coagulation tests should be monitored when these drugs are given concomitantly." .

:W189 a :PatientCondition ;
    rdfs:label "W189" ;
    :hasReference :R008 ;
    :hasWarningHeadline "Psychotic reactions" ;
    :hasWarningText "Caution is recommended if levofloxacin is to be used in psychotic patients or in patients with history of psychiatric disease." .

:W190 a :PatientCondition ;
    rdfs:label "W190" ;
    :hasReference :R008 ;
    :hasWarningHeadline "QT interval prolongation" ;
    :hasWarningText "Caution should be taken when using fluoroquinolones, including levofloxacin, in patients with known risk factors for prolongation of the QT interval such as, for example: congenital long QT syndrome; concomitant use of drugs that are known to prolong the QT interval (e.g., Class IA and III antiarrhythmics, tricyclic antidepressants, macrolides); uncorrected electrolyte imbalance (e.g., hypokalemia, hypomagnesemia); elderly: cardiac disease (e.g.. heart failure, myocardial infarction, bradycardia)." .

:W191 a :PregnancyAndLactation ;
    rdfs:label "W191" ;
    :hasReference :R008 ;
    :hasWarningHeadline "Renal insufficiency" ;
    :hasWarningText "Levofloxacin should be administered with caution in the presence of renal insufficiency. Careful clinical observation and appropriate laboratory studies should be performed prior to and during therapy since elimination of levofloxacin may be reduced. In patients with impaired renal function (creatinine clearance<50 mL/min), adjustment of dose regimen is necessary to avoid the accumulation of levofloxacin due to decreased clearance." .

:W192 a :PregnancyAndLactation ;
    rdfs:label "W192" ;
    :hasReference :R008 ;
    :hasWarningHeadline "Use in Pregnancy" ;
    :hasWarningText "Levofloxacin should be used during pregnancy only if the potential benefit justifies the potential risk to the fetus." .

:W193 a :PregnancyAndLactation ;
    rdfs:label "W193" ;
    :hasReference :R008 ;
    :hasWarningHeadline "Use in Pregnancy" ;
    :hasWarningText "Levofloxacin should be used during pregnancy only if the potential benefit justifies the potential risk to the fetus." .

:W194 a :PregnancyAndLactation ;
    rdfs:label "W194" ;
    :hasReference :R008 ;
    :hasWarningHeadline "Use in Lactation" ;
    :hasWarningText "Based upon data from ofloxacin, it can be presumed that levofloxacin will be excreted in human milk. Because of the potential for serious adverse reactions from levofloxacin in nursing infants, nursing should not be undertaken by mothers who must use levofloxacin." .

:W195 a :PregnancyAndLactation ;
    rdfs:label "W195" ;
    :hasReference :R008 ;
    :hasWarningHeadline "Use in Lactation" ;
    :hasWarningText "Based upon data from ofloxacin, it can be presumed that levofloxacin will be excreted in human milk. Because of the potential for serious adverse reactions from levofloxacin in nursing infants, nursing should not be undertaken by mothers who must use levofloxacin." .

:W196 a :PatientCondition ;
    rdfs:label "W196" ;
    :hasReference :R009 ;
    :hasWarningHeadline "QT Interval" ;
    :hasWarningText """Levofloxacin should be avoided in patients with known prolongation of the QT interval, patients with uncorrected electrolyte imbalance (e.g., hypokalemia and
hypomagnesemia) patients with cardiac disease (e.g., heart failure, myocardial infarction and bradycardia), and in patients receiving drugs that are known to prolong the QT interval such as Class IA (quinidine, procainamide), or Class III (amiodarone, sotalol) antiarrhythmic agents, tricyclic antidepressants, macrolides and antipsychotics.""" .

:W197 a :AgeRestriction ;
    rdfs:label "W197" ;
    :hasReference :R009 ;
    :hasWarningHeadline "QT Interval" ;
    :hasWarningText "Elderly patients and women may be more susceptible to drug-associated effects on the QT interval." .

:W198 a :AgeRestriction ;
    rdfs:label "W198" ;
    :hasReference :R009 ;
    :hasWarningHeadline "Use in children" ;
    :hasWarningText "Quinolones, including levofloxacin, cause arthropathy and osteochondrosis in juvenile animals of several species. Levofloxacin is indicated in pediatric patients ≥6 months old, for inhalational anthrax (post- exposure) and for the treatment of plague, including pneumonic and septicemic plague due to Yersinia pestis and prophylaxis for plague. The risk-benefit assessment indicates that administration of levofloxacin to pediatric patients is appropriate. Safety and effectiveness in pediatric patients <6 months old have not been established." .

:W199 a :AgeRestriction ;
    rdfs:label "W199" ;
    :hasReference :R009 ;
    :hasWarningHeadline "Use in Elderely" ;
    :hasWarningText "No dosage adjustment is necessary for elderly patients with normal renal function. However, since levofloxacin is excreted by the kidneys and some elderly patients experience age-related reduction in renal function, care should be taken in dose selection and renal function monitoring is recommended. Elderly patients are at increased risk of developing severe tendon disorders including tendon rupture, or prolonged QT interval leading to ventricular arrhythmias when being treated with a fluoroquinolone such as levofloxacin" .

:W200 a :PregnancyAndLactation ;
    rdfs:label "W200" ;
    :hasReference :R009 ;
    :hasWarningHeadline "Pregnancy" ;
    :hasWarningText "The drug should not be used in pregnant women unless the potential benefits justify the potential risks to the fetus" .

:W201 a :PregnancyAndLactation ;
    rdfs:label "W201" ;
    :hasReference :R009 ;
    :hasWarningHeadline "Pregnancy" ;
    :hasWarningText "The drug should not be used in pregnant women unless the potential benefits justify the potential risks to the fetus" .

:W202 a :PregnancyAndLactation ;
    rdfs:label "W202" ;
    :hasReference :R009 ;
    :hasWarningHeadline "Lactation" ;
    :hasWarningText "Levofloxacin has not been measured in human milk. However, based on the ofloxacin data, it can be presumed that levofloxacin will be excreted in human milk. Therefore, a decision should be made whether to discontinue breastfeeding or to discontinue the drug, taking into account the importance of the drug to the mother as well as the possible serious adverse effects to the infant." .

:W203 a :PregnancyAndLactation ;
    rdfs:label "W203" ;
    :hasReference :R009 ;
    :hasWarningHeadline "Lactation" ;
    :hasWarningText "Levofloxacin has not been measured in human milk. However, based on the ofloxacin data, it can be presumed that levofloxacin will be excreted in human milk. Therefore, a decision should be made whether to discontinue breastfeeding or to discontinue the drug, taking into account the importance of the drug to the mother as well as the possible serious adverse effects to the infant." .

:W204 a :AgeRestriction ;
    rdfs:label "W204" ;
    :hasReference :R010 ;
    :hasWarningHeadline "QT Interval" ;
    :hasWarningText "Elderly patients may be more susceptible to drug-associated effects on the QT interval. Therefore, precaution should be taken when using levofloxacin with concomitant drugs that can result in prolongation of the QT interval (e.g. class IA or class III antiarrhythmic) or in patients with risk factors for Torsades de pointes (e.g. known QT prolongation, uncorrected hypokalemia)." .

:W205 a :Contraindication ;
    rdfs:label "W205" ;
    :hasReference :R091 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Ciprofloxacin must not be used in cases of hypersensitivity to Ciproflaxin or other quinolone chemotherapeutics" .

:W206 a :AgeRestriction ;
    rdfs:label "W206" ;
    :hasReference :R091 ;
    :hasWarningHeadline "Children and Adolescents" ;
    :hasWarningText "Ciprofloxacin must not be administered to children and adolescents, since there is no experience on the drug's safety in these patient groups; On the basis of animal studies, it is not entirely improbable that the drug could cause damage to articular cartilage in the immature organism." .

:W207 a :PregnancyAndLactation ;
    rdfs:label "W207" ;
    :hasReference :R091 ;
    :hasWarningHeadline "Pregnant Women and Nursing Mothers" ;
    :hasWarningText "Ciprofloxacin must not be administered to pregnant women or nursing mothers, since there is no experience on the drug's safety in these patient groups; On the basis of animal studies, it is not entirely improbable that the drug could cause damage to articular cartilage in the immature organism; Animal studies have also not yet yielded any evidence of teratogenic effects (malformations)" .

:W208 a :Contraindication ;
    rdfs:label "W208" ;
    :hasReference :R092 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Patients must not take when they have hypersensitivity to ciprofloxacin and other quinolone antibiotics" .

:W209 a :Contraindication ;
    rdfs:label "W209" ;
    :hasReference :R092 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Patients must not take when they have hypersensitivity to ciprofloxacin and other quinolone antibiotics" .

:W210 a :PregnancyAndLactation ;
    rdfs:label "W210" ;
    :hasReference :R092 ;
    :hasWarningHeadline "Nursing Mothers" ;
    :hasWarningText "Ciprofloxacin is excreted in human milk; The amount of ciprofloxacin absorbed by the infant is unknown; Due to potential serious adverse reactions to infants nursing from mothers taking ciprofloxacin, a decision should be made whether to discontinue nursing or to discontinue the drug, depending on the importance of the drug to the mother." .

:W211 a :PregnancyAndLactation ;
    rdfs:label "W211" ;
    :hasReference :R092 ;
    :hasWarningHeadline "Nursing Mothers" ;
    :hasWarningText "Ciprofloxacin is excreted in human milk; The amount of ciprofloxacin absorbed by the infant is unknown; Due to potential serious adverse reactions to infants nursing from mothers taking ciprofloxacin, a decision should be made whether to discontinue nursing or to discontinue the drug, depending on the importance of the drug to the mother." .

:W212 a :AgeRestriction ;
    rdfs:label "W212" ;
    :hasReference :R092 ;
    :hasWarningHeadline "Acute Overdosage" ;
    :hasWarningText "In the event of acute overdosage, reversible renal toxicity has been reported in some cases; Make sure to monitor renal (kidney) function and administer magnesium- or calcium-containing antacids which reduce absorption of ciprofloxacin." .

:W213 a :AgeRestriction ;
    rdfs:label "W213" ;
    :hasReference :R092 ;
    :hasWarningHeadline "Acute Overdosage" ;
    :hasWarningText "In the event of acute overdosage, reversible renal toxicity has been reported in some cases; Make sure to monitor renal (kidney) function and administer magnesium- or calcium-containing antacids which reduce absorption of ciprofloxacin." .

:W214 a :PatientCondition ;
    rdfs:label "W214" ;
    :hasReference :R093 ;
    :hasWarningHeadline "Tendon pain, inflammation, rupture" ;
    :hasWarningText "If tendon pain, inflammation or rupture occurs, treatment with ciprofloxacin should be discontinued" .

:W215 a :AgeRestriction ;
    rdfs:label "W215" ;
    :hasReference :R093 ;
    :hasWarningHeadline "Children and Adolescents" ;
    :hasWarningText "Do not take ciprofloxacin if you are a child or an adolescent. Ciprofloxacin was reported to cause arthralgia and degenerative changes in joints that bear weight in young animals." .

:W216 a :PregnancyAndLactation ;
    rdfs:label "W216" ;
    :hasReference :R093 ;
    :hasWarningHeadline "Pregnant and Nursing Mothers" ;
    :hasWarningText "Use it with caution if you are pregnant or a lactating mother.; Ciprofloxacin is excreted in breast milk; Ciprofloxacin was reported to cause arthralgia and degenerative changes in joints that bear weight in young animals." .

:W217 a :PatientCondition ;
    rdfs:label "W217" ;
    :hasReference :R093 ;
    :hasWarningHeadline "Epileptic, history of Central Nervous System (CNS) disorders, myastenia gravis and glucose-6-phosphate dehydrogenase deficiency" ;
    :hasWarningText "Caution should be taken when giving ciprofloxacin to epileptic patients and to those with history of Central Nervous System (CNS) disorders, myasthenia gravis and glucose-6-phosphate dehydrogenase deficiency.; Ciprofloxacin may exacerbate or unmask symptoms of myasthenia gravis." .

:W218 a :PatientCondition ;
    rdfs:label "W218" ;
    :hasReference :R091 ;
    :hasWarningHeadline "Epileptic, history of Central Nervous System (CNS) disorders" ;
    :hasWarningText "In epileptics and in patients who have suffered from previous CNS disorders (e.g. lowered convulsion threshold, previous history of convulsion, reduced cerebral blood flow, altered brain structure or stroke), Ciprofloxacin should only be used where the benefits of treatment exceed the risks, since these patients are endangered because of possible central nervous side effects." .

:W219 a :PatientCondition ;
    rdfs:label "W219" ;
    :hasReference :R093 ;
    :hasWarningHeadline "Patients with alkaline urine" ;
    :hasWarningText "The risk of crystalluria is high in patients with alkaline urine" .

:W220 a :PatientCondition ;
    rdfs:label "W220" ;
    :hasReference :R093 ;
    :hasWarningHeadline "Renal Impairment" ;
    :hasWarningText "Ciprofloxacin should be used with caution in patients with impaired renal function" .

:W221 a :PatientCondition ;
    rdfs:label "W221" ;
    :hasReference :R093 ;
    :hasWarningHeadline "Hepatic Impairment" ;
    :hasWarningText "Ciprofloxacin should be used with caution in patients with severe hepatic impairment where peak plasma concentration and serum half life may be increased." .

:W222 a :AgeRestriction ;
    rdfs:label "W222" ;
    :hasReference :R093 ;
    :hasWarningHeadline "Elderly" ;
    :hasWarningText "Dose of ciprofloxacin should be reduced in the elderly as increased bioavailability and reduced renal clearance were seen probably due to absorption or first pass elimination" .

:W223 a :AgeRestriction ;
    rdfs:label "W223" ;
    :hasReference :R093 ;
    :hasWarningHeadline "Elderly Laboratory Results" ;
    :hasWarningText "In elderly patients treated with ciprofloxacin or urinary tract infeactions, a false postiive reaction for urinary glucose (pseudoglycosuria) has been reported." .

:W224 a :Contraindication ;
    rdfs:label "W224" ;
    :hasReference :R133 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Should not be used if patient has a history of allergy or hypersensitivity to cephalosporins" .

:W225 a :Contraindication ;
    rdfs:label "W225" ;
    :hasReference :R133 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Should not be used if patient has a history of allergy or hypersensitivity to cephalosporins" .

:W226 a :Contraindication ;
    rdfs:label "W226" ;
    :hasReference :R127 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Hypersensitivity to cefixime or other cephalosporins." .

:W227 a :Contraindication ;
    rdfs:label "W227" ;
    :hasReference :R127 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Hypersensitivity to penicillins." .

:W228 a :Contraindication ;
    rdfs:label "W228" ;
    :hasReference :R127 ;
    :hasWarningHeadline "Allergy" ;
    :hasWarningText "History of allergy." .

:W229 a :AgeRestriction ;
    rdfs:label "W229" ;
    :hasReference :R127 ;
    :hasWarningHeadline "Avoidance" ;
    :hasWarningText "Avoid prolonged use." .

:W230 a :Contraindication ;
    rdfs:label "W230" ;
    :hasReference :R127 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Hypersensitivity to cefixime or other cephalosporins." .

:W231 a :Contraindication ;
    rdfs:label "W231" ;
    :hasReference :R127 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Hypersensitivity to penicillins." .

:W232 a :Contraindication ;
    rdfs:label "W232" ;
    :hasReference :R127 ;
    :hasWarningHeadline "Allergy" ;
    :hasWarningText "History of allergy." .

:W233 a :AgeRestriction ;
    rdfs:label "W233" ;
    :hasReference :R127 ;
    :hasWarningHeadline "Avoidance" ;
    :hasWarningText "Avoid prolonged use." .

:W234 a :Contraindication ;
    rdfs:label "W234" ;
    :hasReference :R128 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Careful inquiry should be made prior to cefixime therapy to determine whether the patient has had previous hypersensitivity reactions to cephalosporins, penicillins or other drugs." .

:W235 a :PatientCondition ;
    rdfs:label "W235" ;
    :hasReference :R128 ;
    :hasWarningHeadline "Hemolytic Anemia" ;
    :hasWarningText "Cefixime should not be used in patients with a history of cephalosporin-associated hemolytic anemia since the recurrence of hemolysis is much more severe." .

:W236 a :AgeRestriction ;
    rdfs:label "W236" ;
    :hasReference :R128 ;
    :hasWarningHeadline "Use in Children" ;
    :hasWarningText "The safety and efficacy of cefixime in children less than six (6) months old have not been established. The incidence of GI adverse reactions such as diarrhea and loose stools, in children receiving cefixime suspension, was comparable to the incidence seen in adults receiving cefixime tablets." .

:W237 a :AgeRestriction ;
    rdfs:label "W237" ;
    :hasReference :R128 ;
    :hasWarningHeadline "Use in Elderly" ;
    :hasWarningText "Elderly patients are more likely to have decreased renal function, therefore, care should be taken in dose selection and renal function should be monitored." .

:W238 a :Contraindication ;
    rdfs:label "W238" ;
    :hasReference :R128 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Hypersensitivity to other cephalosporins or penicillins." .

:W239 a :PatientCondition ;
    rdfs:label "W239" ;
    :hasReference :R128 ;
    :hasWarningHeadline "Colitis" ;
    :hasWarningText "As with other broad-spectrum antibiotics, cefixime should be given with caution in individuals with a history of colitis" .

:W240 a :PatientCondition ;
    rdfs:label "W240" ;
    :hasReference :R129 ;
    :hasWarningHeadline "Gastrointestinal Malabsorption" ;
    :hasWarningText "The safety and efficacy of cefixime have not been established in patients with gastrointestinal malabsorption." .

:W241 a :PatientCondition ;
    rdfs:label "W241" ;
    :hasReference :R129 ;
    :hasWarningHeadline "Antibotic Resistance" ;
    :hasWarningText "Prescribing cefixime in the absence of a proven or strongly suspected bacterial infection or a prophylactic indication is unlikely to provide benefit to the patient and increases the risk of antibiotic resistance." .

:W242 a :PatientCondition ;
    rdfs:label "W242" ;
    :hasReference :R129 ;
    :hasWarningHeadline "Overgrowth of non-susceptible" ;
    :hasWarningText "As with other antibacterial drugs, long term or repeated use may result in overgrowth of non- susceptible organisms, including fungi." .

:W243 a :PregnancyAndLactation ;
    rdfs:label "W243" ;
    :hasReference :R129 ;
    :hasWarningHeadline "Pregnancy" ;
    :hasWarningText "Reproduction studies performed in mice and rats up to 400 times the human dose have not revealed evidence of harm to the fetus. There are no adequate and well-controlled studies in pregnant women, and the drug should be used during pregnancy only when clearly needed." .

:W244 a :PregnancyAndLactation ;
    rdfs:label "W244" ;
    :hasReference :R129 ;
    :hasWarningHeadline "Lactation" ;
    :hasWarningText "It is not known whether cefixime is excreted in human milk. Consideration should be given to discontinuing breastfeeding temporarily during treatment with cefixime." .

:W245 a :Contraindication ;
    rdfs:label "W245" ;
    :hasReference :R133 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Should not be given to Penicillin-allergic patients" .

:W246 a :Contraindication ;
    rdfs:label "W246" ;
    :hasReference :R133 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Should not be given to Penicillin-allergic patients" .

:W247 a :Contraindication ;
    rdfs:label "W247" ;
    :hasReference :R133 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Should not be given to patient with history of allergy and hypersensitivity to cephalosporins" .

:W249 a :PatientCondition ;
    rdfs:label "W249" ;
    :hasReference :R157 ;
    :hasWarningHeadline "Kidney Disease Warning" ;
    :hasWarningText "Should not be used if kidneys are not workingas well as they should be. If there is a concern about the health of the kidneys, the healthcare provider may do tests to determine if the kidneys are working well enough to take this medicine." .

:W250 a :PregnancyAndLactation ;
    rdfs:label "W250" ;
    :hasReference :R158 ;
    :hasWarningHeadline "Late Pregnancy Warning" ;
    :hasWarningText "Avoid use near delivery (38-42 weeks gestation, during labour and delivery, or when the onset of labour is imminent)" .

:W251 a :AgeRestriction ;
    rdfs:label "W251" ;
    :hasReference :R157 ;
    :hasWarningHeadline "Infants Under 1 Month" ;
    :hasWarningText "Should not be used in babies under 1 month of age." .

:W252 a :Contraindication ;
    rdfs:label "W252" ;
    :hasReference :R158 ;
    :hasWarningHeadline "Renal Impairement" ;
    :hasWarningText "Should not be taken if the patient has renal impairment (including anuria, oliguria, eGFR <45 mL/min or CrCl <60 mL, or clinically significant elevated serum creatinine); history of cholestatic jaundice or hepatic dysfunction associated with previous nitrofurantoin use." .

:W253 a :AgeRestriction ;
    rdfs:label "W253" ;
    :hasReference :R158 ;
    :hasWarningHeadline "Overdose Risk" ;
    :hasWarningText "May cause gastric irritation, nausea, and vomiting. Induce emesis or perform gastric lavage. Haemodialysis may be performed. Maintain high fluid intake to promote urinary excretion." .

:W254 a :Contraindication ;
    rdfs:label "W254" ;
    :hasReference :R157 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Do not use if you are allergic to nitrofurantoin or any of its ingredients. May cause serious allergic reactions like swelling, rash, itching, trouble breathing, or dizziness. Seek medical help immediately if these occur." .

:W255 a :Contraindication ;
    rdfs:label "W255" ;
    :hasReference :R160 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "May cause allergic reactions, which can be serious. Stop using nitrofurantoin and get help right away if any of the following symptoms of a serious allergic reaction: Breathing problems or wheezing, racing heart, fever or general ill feeling, swollen lymph nodes, swelling of the face, lips, mouth, tongue, or throat, trouble swallowing or throat tightness, itching, skin rash, or pale red bumps on the skin called hives, nausea or vomiting, or dizziness, feeling lightheaded , or fainting" .

:W256 a :PatientCondition ;
    rdfs:label "W256" ;
    :hasReference :R160 ;
    :hasWarningHeadline "Kidney Problems" ;
    :hasWarningText "Avoid Macrobid if your kidneys are not working well; poor kidney function can make the medicine less effective and increase side effects." .

:W257 a :PregnancyAndLactation ;
    rdfs:label "W257" ;
    :hasReference :R161 ;
    :hasWarningHeadline "Late Pregnancy Use" ;
    :hasWarningText "Do not take Macrobid in the last 2-4 weeks of pregnancy." .

:W258 a :AgeRestriction ;
    rdfs:label "W258" ;
    :hasReference :R161 ;
    :hasWarningHeadline "Newborn Use" ;
    :hasWarningText "Macrobid should not be used in babies under 1 month old." .

:W259 a :AgeRestriction ;
    rdfs:label "W259" ;
    :hasReference :R160 ;
    :hasWarningHeadline "Over Use" ;
    :hasWarningText "Taking too much can cause severe nausea, vomiting, stomach pain, or other serious health problems; seek medical help immediately." .

:W260 a :PatientCondition ;
    rdfs:label "W260" ;
    :hasReference :R160 ;
    :hasWarningHeadline "Current and Past Health Conditions" ;
    :hasWarningText "Notify healthcare provider if a patient have current and past health conditions in any of the following: kidnet or liver problems, history of anemia, history of diabetes, electrolyte imbalance, history of low levels of vitamin B, or Glucose-6-phosphate dehydrogenase (G6PD) deficiency" .

:W261 a :PatientCondition ;
    rdfs:label "W261" ;
    :hasReference :R163,
        :R164 ;
    :hasWarningHeadline "G6PD Deficiency" ;
    :hasWarningText "People with G6PD deficiency are at risk for hemolytic anemia from furadantin exposure" .

:W262 a :PregnancyAndLactation ;
    rdfs:label "W262" ;
    :hasReference :R163 ;
    :hasWarningHeadline "Do not use near term or in infants under 1 month" ;
    :hasWarningText "pregnant patients at term (38 weeks to 42 weeks gestation), during labor and delivery, or when the onset of labor is imminent and in pediatric patients younger than 1 month of age because of the possibility of hemolytic anemia due to immature erythrocyte enzyme systems (glutathione instability)" .

:W263 a :AgeRestriction ;
    rdfs:label "W263" ;
    :hasReference :R163 ;
    :hasWarningHeadline "Pediatric Restriction" ;
    :hasWarningText "Children under 1 month should not take this drug." .

:W264 a :PatientCondition ;
    rdfs:label "W264" ;
    :hasReference :R163 ;
    :hasWarningHeadline "Renal Impairment" ;
    :hasWarningText "patients who have anuria, oliguria, or significant impairment of renal function (creatinine clearance under 60 mL per minute or clinically significant elevated serum creatinine) due to an increased risk of toxicity resulting from impaired excretion of the drug" .

:W265 a :PatientCondition ;
    rdfs:label "W265" ;
    :hasReference :R164 ;
    :hasWarningHeadline "History of Liver Problems" ;
    :hasWarningText "Notify healthcare provider if patient developed liver problems before due to furadantin (nitrofurantoin oral suspension) intake" .

:W266 a :AgeRestriction ;
    rdfs:label "W266" ;
    :hasReference :R163 ;
    :hasWarningHeadline "Acute Overdose" ;
    :hasWarningText "Incidents of acute overdosage of FURADANTIN have resulted in symptoms such as vomiting. Induction of emesis is recommended. There is no specific antidote, but a high fluid intake should be maintained to promote urinary excretion of the drug. Nitrofurantoin is dialyzable." .

:W267 a :Contraindication ;
    rdfs:label "W267" ;
    :hasReference :R164 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Allergic to Furadantin (nitrofurantoin oral suspension); any part of Furadantin (nitrofurantoin oral suspension); or any other drugs, foods, or substances." .

:W268 a :Contraindication ;
    rdfs:label "W268" ;
    :hasReference :R165 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText "Do not use Nitrofurantoin  if the patient has a known allergy to this medicine. Taking it again may cause serious allergic reactions such as skin rash, swelling, breathing difficulty, or other harmful effects." .

:W269 a :Contraindication ;
    rdfs:label "W269" ;
    :hasReference :R165 ;
    :hasWarningHeadline "Anuria or Oliguria" ;
    :hasWarningText "This medicine should not be used in patients who are not producing urine (anuria) or producing very little urine (oliguria). Because the drug is removed through the urine, it will not work properly and may build up in the body, increasing the risk of side effects." .

:W270 a :Contraindication ;
    rdfs:label "W270" ;
    :hasReference :R165 ;
    :hasWarningHeadline "Hepatitis" ;
    :hasWarningText "Patients with hepatitis should not use this medicine." .

:W271 a :PregnancyAndLactation ;
    rdfs:label "W271" ;
    :hasReference :R165 ;
    :hasWarningHeadline "Pregnancy at Term" ;
    :hasWarningText "Nitrofurantoin should not be used during pregnancy (labor and delivery)." .

:W272 a :PregnancyAndLactation ;
    rdfs:label "W272" ;
    :hasReference :R165 ;
    :hasWarningHeadline "Lactation" ;
    :hasWarningText "Nitrofurantoin passes into breastmilk in very small amounts. Caution should be used when giving this medicine to breastfeeding mothers, and the infant should be observed for any unusual symptoms." .

:W273 a :AgeRestriction ;
    rdfs:label "W273" ;
    :hasReference :R165 ;
    :hasWarningHeadline "Infants Under 1 Month" ;
    :hasWarningText "This medicine should not be given to infants younger than 1 month old." .

:W274 a :PatientCondition ;
    rdfs:label "W274" ;
    :hasReference :R165 ;
    :hasWarningHeadline "Elderly" ;
    :hasWarningText "Elderly patients using this medicine for a long time should have their liver and lung function checked regularly. Older adults may be more sensitive to possible side effects affecting the lungs of liver." .

:W275 a :PatientCondition ;
    rdfs:label "W275" ;
    :hasReference :R165 ;
    :hasWarningHeadline "Pre-Existing Pulmonary, Hepatic, Neurological, or Allergic Disorders" ;
    :hasWarningText "Patients who already have lung, liver, nerve, or allergic conditions should use this medicine with caution. These existing problems may increase the risk of serious side effects." .

:W276 a :PatientCondition ;
    rdfs:label "W276" ;
    :hasReference :R165 ;
    :hasWarningHeadline "Risk of Peripheral Neuropathy" ;
    :hasWarningText "Withdraw if signs of peripheral neuropathy occur." .

:W277 a :AgeRestriction ;
    rdfs:label "W277" ;
    :hasReference :R165 ;
    :hasWarningHeadline "Excess Intake" ;
    :hasWarningText "Taking more than the prescribed dose may increase the risk of side effects such as nausea, vomiting, or other harmful reactions. Immediate medical attention is needed in case of suspected overdose." .

:W278 a :Contraindication ;
    rdfs:label "W278" ;
    :hasReference :R166 ;
    :hasWarningHeadline "Sulfite-Related Allergic and Anaphylactic Reactions" ;
    :hasWarningText """Sodium metabisulfite contains a sulfite that may cause allergic type reactions,
including anaphylactic symptoms and life threatening or less severe asthmatic
episode in certain susceptible persons.""" .

:W279 a :Contraindication ;
    rdfs:label "W279" ;
    :hasReference :R166 ;
    :hasWarningHeadline "Hypersensitivity" ;
    :hasWarningText """Cotrimoxazole should not be given to patients with history of sensitivity to it or to
sulphonamide or trimethoprim.""" .

:W280 a :Contraindication ;
    rdfs:label "W280" ;
    :hasReference :R166 ;
    :hasWarningHeadline "Foliate Deficiency" ;
    :hasWarningText """Cotrimoxazole should not be given to patients with actual or possible folate
deficiency.""" .

:W281 a :AgeRestriction ;
    rdfs:label "W281" ;
    :hasReference :R166 ;
    :hasWarningHeadline "Infants" ;
    :hasWarningText """No adverse effects have been seen in breast-fed infants whose mothers were
taking cotrimoxazole, and the last available guidance from the American
Academy of Pediatrics considered that it was therefore usually compatible with
breast feeding.""" .

:W282 a :PregnancyAndLactation ;
    rdfs:label "W282" ;
    :hasReference :R166 ;
    :hasWarningHeadline "Breastfeeding and Infants" ;
    :hasWarningText """No adverse effects have been seen in breast-fed infants whose mothers were
taking cotrimoxazole, and the last available guidance from the American
Academy of Pediatrics considered that it was therefore usually compatible with
breast feeding.""" .

