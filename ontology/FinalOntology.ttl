:SP057 a :Storage ;
    rdfs:label "SP057" ;
    :hasReference :R031 ;
    :hasStewardshipDescription "Store at temperatures below 30C, in a tight, light resistant container, protect from light." .

:SP058 a :Storage ;
    rdfs:label "SP058" ;
    :hasReference :R031 ;
    :hasStewardshipDescription "Store at temperatures below 30C, in a tight, light resistant container, protect from light." .

:SP059 a :AdministrationAndAdherence ;
    rdfs:label "SP059" ;
    :hasReference :R015 ;
    :hasStewardshipDescription "Administered orally as a solid dosage form. General medical practice for antibiotics involves taking the medication for the full prescribed duration even if symptoms improve." .

:SP060 a :Storage ;
    rdfs:label "SP060" ;
    :hasReference :R015 ;
    :hasStewardshipDescription "Store the capsules in a dry place at temperatures not exceeding 25°C" .

:SP061 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP061" ;
    :hasReference :R015 ;
    :hasStewardshipDescription "Monitor for common side effects such as skin rash, nausea, and diarrhea. If taking anticoagulants, prothrombin time or INR should be carefully monitored when starting or stopping treatment." .

:SP062 a :AdministrationAndAdherence ;
    rdfs:label "SP062" ;
    :hasReference :R015 ;
    :hasStewardshipDescription "Ensure doses are taken at regular intervals as prescribed to maintain effective blood levels." .

:SP063 a :AdministrationAndAdherence ;
    rdfs:label "SP063" ;
    :hasReference :R015 ;
    :hasStewardshipDescription "Reconstitution is required before use: 1. Loosen powder by shaking. 2. Add water up to 2/3 of the mark on the label. 3. Shake well for 1 minute, then let stand for 1 minute. 4. Add water exactly to the mark and shake well for 30 seconds" .

:SP064 a :AdministrationAndAdherence ;
    rdfs:label "SP064" ;
    :hasReference :R015 ;
    :hasStewardshipDescription "The bottle must be shaken well before taking each dose to ensure the medication is evenly distributed" .

:SP065 a :Storage ;
    rdfs:label "SP065" ;
    :hasReference :R015 ;
    :hasStewardshipDescription "Before the water is added, the powder should be stored in a dry place at temperatures not exceeding 25°C" .

:SP066 a :Storage ;
    rdfs:label "SP066" ;
    :hasReference :R015 ;
    :hasStewardshipDescription "Once water is added (reconstituted), the drops must be stored at refrigerated temperatures (between 2-8°C). The medicine will retain its potency for 7 days under these conditions" .

:SP067 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP067" ;
    :hasReference :R015 ;
    :hasStewardshipDescription "Monitor for superficial tooth discoloration, a side effect specific to the liquid forms; this can often be prevented by maintaining good oral hygiene" .

:SP068 a :AdministrationAndAdherence ;
    rdfs:label "SP068" ;
    :hasReference :R015 ;
    :hasStewardshipDescription "Complete the full 7-day potency period as prescribed; any remaining reconstituted liquid should be discarded after 7 days" .

:SP069 a :AdministrationAndAdherence ;
    rdfs:label "SP069" ;
    :hasReference :R032 ;
    :hasStewardshipDescription "Must be reconstituted correctly and administered by a healthcare professional via IV or IM to ensure correct dosage and effectiveness." .

:SP070 a :AdministrationAndAdherence ;
    rdfs:label "SP070" ;
    :hasReference :R032 ;
    :hasStewardshipDescription "Must be taken orally at prescribed intervals, completing the full course to fully treat infection and prevent resistance." .

:SP071 a :AdministrationAndAdherence ;
    rdfs:label "SP071" ;
    :hasReference :R017 ;
    :hasStewardshipDescription "Administer via dropper. Can be taken with or without food; taking with meals can reduce Gastrointestinal discomfort." .

:SP072 a :AdministrationAndAdherence ;
    rdfs:label "SP072" ;
    :hasReference :R017 ;
    :hasStewardshipDescription "Doses should be given every 8 or 12 hours for neonates/infants < 3 months." .

:SP073 a :Storage ;
    rdfs:label "SP073" ;
    :hasReference :R017 ;
    :hasStewardshipDescription "Store in a dry place at temperatures not exceeding 30°C and protect from light." .

:SP074 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP074" ;
    :hasReference :R017 ;
    :hasStewardshipDescription "Monitor for allergic manifestations and maintain adequate fluid intake to prevent crystalluria." .

:SP075 a :AdministrationAndAdherence ;
    rdfs:label "SP075" ;
    :hasReference :R017 ;
    :hasStewardshipDescription "Administer as a liquid suspension (typically 5 mL per dose). Can be taken w/ meals for better absorption & to reduce Gastrointestinal discomfort." .

:SP076 a :AdministrationAndAdherence ;
    rdfs:label "SP076" ;
    :hasReference :R017 ;
    :hasStewardshipDescription "Usual duration is 5 to 14 days; must complete the course as prescribed." .

:SP077 a :Storage ;
    rdfs:label "SP077" ;
    :hasReference :R017 ;
    :hasStewardshipDescription "Store powder and reconstituted suspension in a dry place below 30°C; protect from light." .

:SP078 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP078" ;
    :hasReference :R017 ;
    :hasStewardshipDescription "Monitor for superinfections during prolonged use and observe for renal output in overdose cases." .

:SP079 a :AdministrationAndAdherence ;
    rdfs:label "SP079" ;
    :hasReference :R016 ;
    :hasStewardshipDescription "Administered orally. May be taken with or without food. Prescribe only for proven or strongly suspected bacterial infections to prevent the development of drug-resistant bacteria." .

:SP080 a :AdministrationAndAdherence ;
    rdfs:label "SP080" ;
    :hasReference :R016 ;
    :hasStewardshipDescription "Usual duration is 5 to 14 days. Continue treatment for at least 48 to 72 hours after becoming asymptomatic. Take for at least 10 days for β-hemolytic streptococcal infections to prevent rheumatic fever." .

:SP081 a :Storage ;
    rdfs:label "SP081" ;
    :hasReference :R016 ;
    :hasStewardshipDescription "Store in a dry place at temperatures not exceeding 30°C. Protect from light to ensure optimal shelf-life." .

:SP082 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP082" ;
    :hasReference :R016 ;
    :hasStewardshipDescription "Maintain adequate fluid intake and urinary output to reduce the possibility of crystalluria. Periodic assessment of renal, hepatic, and hematopoietic functions is recommended during prolonged therapy." .

:SP083 a :AdministrationAndAdherence ;
    rdfs:label "SP083" ;
    :hasReference :R047 ;
    :hasStewardshipDescription "Liquid Suspension: Typically administered as $5\\text{ mL}$ per dose. Can be taken with meals to improve absorption and reduce GI discomfort." .

:SP084 a :AdministrationAndAdherence ;
    rdfs:label "SP084" ;
    :hasReference :R047 ;
    :hasStewardshipDescription "Full Course: Complete the entire prescribed course, even if symptoms improve, to prevent bacterial resistance." .

:SP085 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP085" ;
    :hasReference :R047 ;
    :hasStewardshipDescription "Allergic Reactions: Watch for rashes, itching, or swelling (anaphylaxis)." .

:SP086 a :Storage ;
    rdfs:label "SP086" ;
    :hasReference :R047 ;
    :hasStewardshipDescription "Store at temperatures not exceeding 25°C. Protect from moisture and light" .

:SP087 a :FoodAndTiming ;
    rdfs:label "SP087" ;
    :hasReference :R018 ;
    :hasStewardshipDescription "Reconstitution: For 250mg/5mL 35mL, add 25mL water; for 70mL, add 51mL water. Shake well before each use. May be taken with or without food." .

:SP088 a :AdministrationAndAdherence ;
    rdfs:label "SP088" ;
    :hasReference :R018 ;
    :hasStewardshipDescription "Usual duration of treatment is 5 to 10 days depending on severity. Ensure zidovudine and Klaryth doses are separated as advised to maintain efficacy." .

:SP089 a :Storage ;
    rdfs:label "SP089" ;
    :hasReference :R018 ;
    :hasStewardshipDescription "Store powder and reconstituted suspension at temperatures not exceeding 30°C. Reconstituted suspension is stable for 14 days. Do not refrigerate." .

:SP090 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP090" ;
    :hasReference :R018 ;
    :hasStewardshipDescription "Monitor for the development of diarrhea, which may indicate pseudomembranous colitis. Regularly check blood levels for theophylline, digoxin, or carbamazepine if used concurrently." .

:SP091 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP091" ;
    :hasReference :R018 ;
    :hasStewardshipDescription "Only prescribe Klaryth for proven or strongly suspected bacterial infections to reduce the risk of drug-resistant bacteria developing." .

:SP092 a :AdministrationAndAdherence ;
    rdfs:label "SP092" ;
    :hasReference :R019 ;
    :hasStewardshipDescription "Preparation: Add half the water and shake vigorously; then add the remaining water and shake again. Shake well before each use. Can be taken with milk." .

:SP093 a :AdministrationAndAdherence ;
    rdfs:label "SP093" ;
    :hasReference :R019 ;
    :hasStewardshipDescription "Dosage: The usual recommended daily dosage for children is 15 mg/kg/day divided every 12 hours for 10 days." .

:SP094 a :Storage ;
    rdfs:label "SP094" ;
    :hasReference :R019 ;
    :hasStewardshipDescription "Store reconstituted suspension at 15°C to 25°C and use within 14 days. Do not refrigerate. Protect from moisture and keep tightly closed." .

:SP095 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP095" ;
    :hasReference :R019 ;
    :hasStewardshipDescription "If used with other ototoxic drugs (like aminoglycosides), monitor vestibular and auditory function" .

:SP096 a :AdministrationAndAdherence ;
    rdfs:label "SP096" ;
    :hasReference :R019 ;
    :hasStewardshipDescription "Tablets should be swallowed whole and can be taken with or without food. Take every 12 hours as prescribed." .

:SP097 a :AdministrationAndAdherence ;
    rdfs:label "SP097" ;
    :hasReference :R019 ;
    :hasStewardshipDescription "For respiratory infections, the usual duration is 7-14 days. Dosage for renal impairment (CrCl <30 mL/min) should be reduced by half." .

:SP098 a :Storage ;
    rdfs:label "SP098" ;
    :hasReference :R019 ;
    :hasStewardshipDescription "Store at temperatures not exceeding 30°C and protect from light." .

:SP099 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP099" ;
    :hasReference :R019 ;
    :hasStewardshipDescription "Monitor for signs of hepatitis (jaundice, dark urine, tender abdomen) and discontinue immediately if they occur" .

:SP100 a :AdministrationAndAdherence ;
    rdfs:label "SP100" ;
    :hasReference :R020 ;
    :hasStewardshipDescription "The usual dose is 250 mg twice daily, though this may be increased to 500 mg twice daily for severe infections." .

:SP101 a :AdministrationAndAdherence ;
    rdfs:label "SP101" ;
    :hasReference :R020 ;
    :hasStewardshipDescription "Treatment usually lasts 6 to 14 days. For patients with renal impairment (CrCl <30 mL/min), the dose should be halved and not continue beyond 14 days." .

:SP102 a :Storage ;
    rdfs:label "SP102" ;
    :hasReference :R020 ;
    :hasStewardshipDescription "Store at temperatures not exceeding 30°C. The shelf life is 36 months." .

:SP103 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP103" ;
    :hasReference :R020 ;
    :hasStewardshipDescription "Monitor for signs of hepatic failure, especially in those with pre-existing liver disease. Also, monitor for the development of drug-resistant organisms during H. pylori therapy." .

:SP104 a :AdministrationAndAdherence ;
    rdfs:label "SP104" ;
    :hasReference :R039 ;
    :hasStewardshipDescription "Use for treating tonsillitis, pharyngitis and acute otitis media (ear infection) for patients with hypersensitivity to beta-lactam antibiotics or when such treatment is not suitable for other reasons." .

:SP105 a :AdministrationAndAdherence ;
    rdfs:label "SP105" ;
    :hasReference :R054 ;
    :hasStewardshipDescription "Oral administration: The usual dose is 250 mg twice daily, though this may be increased to 500 mg twice daily for severe infections." .

:SP106 a :AdministrationAndAdherence ;
    rdfs:label "SP106" ;
    :hasReference :R054 ;
    :hasStewardshipDescription "Dosage & Duration: Treatment usually lasts 6 to 14 days. For patients with renal impairment ($CrCl < 30$ mL/min), the dose should be halved and not continue beyond 14 days." .

:SP107 a :Storage ;
    rdfs:label "SP107" ;
    :hasReference :R054 ;
    :hasStewardshipDescription "Store at temperatures not exceeding 30°C." .

:SP108 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP108" ;
    :hasReference :R054 ;
    :hasStewardshipDescription "Patient Safety: Monitor for signs of hepatic failure, especially in those with pre-existing liver disease. Also, monitor for the development of drug-resistant organisms during H. pylori therapy." .

:SP109 a :AdministrationAndAdherence ;
    rdfs:label "SP109" ;
    :hasReference :R054 ;
    :hasStewardshipDescription "Use for treating tonsillitis, pharyngitis and acute otitis media (ear infection) for patients with hypersensitivity to beta-lactam antibiotics or when such treatment is not suitable for other reasons." .

:SP110 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP110" ;
    :hasReference :R054 ;
    :hasStewardshipDescription "Monitor for symptoms such as tender abdomen and discontinue treatment immediately if they occur." .

:SP111 a :Storage ;
    rdfs:label "SP111" ;
    :hasReference :R011 ;
    :hasStewardshipDescription "Store at temperatures not exceeding 30°C" .

