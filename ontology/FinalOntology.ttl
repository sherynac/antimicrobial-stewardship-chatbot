:I017 a :ComplicatedUrinaryTractInfectionCUTI ;
    rdfs:label "Moderate to Severe Complicated Urinary Tract Infection (cUTI)" ;
    :hasReference :R026,
        :R027,
        :R028 ;
    :hasSeverityType :ModerateToSevere ;
    :hasSymptoms "Painful urination, frequent urination, fever, lower abdominal pain, cloudy or foul-smelling urine." .

:I020 a :UncomplicatedUrinaryTractInfectionUTI ;
    rdfs:label "Mild to Severe Uncomplicated Urinary Tract Infection (UTI)" ;
    :hasReference :R009,
        :R264 ;
    :hasSeverityType :MildToSevere ;
    :hasSymptoms "urinary frequency, urgency, dysuria, and suprapubic discomfort." .

:I021 a :AcuteUncomplicatedUrinaryTractInfectionUTI ;
    rdfs:label "Acute Uncomplicated Urinary Tract Infection (UTI)" ;
    :hasReference :R092,
        :R165 ;
    :hasSeverityType :NotSpecified ;
    :hasSymptoms "Strong and frequent urge to urinate, burning or painful feeling when urinating, urine may look cloudy, dark, or have a strong bad smell; Some people may feel mild lower belly pain or discomfort." .

:I022 a :DisseminatedMycobacteriumAviumComplexMACDisease ;
    rdfs:label "Disseminated Mycobacterium avium complex (MAC) disease" ;
    :hasReference :R019,
        :R038,
        :R094 ;
    :hasSeverityType :NotSpecified ;
    :hasSymptoms "Fever, night sweats, weight loss, fatigue, diarrhea, abdominal pain, anemia and elevated liver alkaline phosphatase levels." .

:I023 a :AcutePyelonephritis ;
    rdfs:label "Severe Acute Pyelonephritis" ;
    :hasReference :R026,
        :R027,
        :R028 ;
    :hasSeverityType :Severe ;
    :hasSymptoms "High fever, flank or back pain, chills, nausea, vomiting, painful urination" .

:I027 a :ChronicBronchitis ;
    rdfs:label "Chronic Bronchitis" ;
    :hasReference :R018,
        :R020 ;
    :hasSeverityType :NotSpecified .

:I032 a :UpperUrinaryTractInfection ;
    rdfs:label "Upper Urinary Tract Infection" ;
    :hasReference :R031 ;
    :hasSeverityType :NotSpecified ;
    :hasSymptoms "pain in the lower back or side, fever or chills, nausea or vomiting, brain fog or overall restlessness and bloody urine" .

:I033 a :LowerUrinaryTractInfection ;
    rdfs:label "Lower Urinary Tract Infection" ;
    :hasReference :R031,
        :R266 ;
    :hasSeverityType :NotSpecified ;
    :hasSymptoms "more frequent urination, pain, burning, or other discomfort during urination, a sudden urge to urinate (even if you just went), feeling unable to empty the bladder fully, urine that’s cloudy or slightly colored with blood, urine that smells more pungent than usual, and abdominal or pelvic pain" .

:I038 a :Bronchopneumonia ;
    rdfs:label "Mild to severe Bronchopneumonia" ;
    :hasReference :R015,
        :R083 ;
    :hasSeverityType :MildToSevere ;
    :hasSymptoms "fever, cough, shortness of breath, chest pain, rapid breathing, sweating, chills, headaches, muscle aches, pleurisy, fatigue, confusion or delirium" .

:I042 a :Bronchiectasis ;
    rdfs:label "Bronchiectasis" ;
    :hasReference :R003,
        :R088,
        :R128 ;
    :hasSeverityType :NotSpecified ;
    :hasSymptoms "cough with lots of mucus and pus, repeated colds, bad-smelling mucus, shortness of breath, wheezing, coughing up blood" .

:I047 a :UrinaryDisease ;
    rdfs:label "Mild to Severe Chronic Bacterial Prostatis" ;
    :hasReference :R009,
        :R071 ;
    :hasSeverityType :MildToSevere ;
    :hasSymptoms "Fever, chills, painful and frequent urination or have trouble urinating," .

:I048 a :UrinaryDisease ;
    rdfs:label "Chronic Bacterial Prostatis" ;
    :hasReference :R008,
        :R071,
        :R092 ;
    :hasSeverityType :NotSpecified ;
    :hasSymptoms "Fever, chills, painful and frequent urination or have trouble urinating," .

:I058 a :RecurrentUrinaryTractInfection ;
    rdfs:label "Mild Recurrent Urinary Tract Infection" ;
    :hasReference :R159,
        :R161,
        :R162 ;
    :hasSeverityType :Mild ;
    :hasSymptoms "Repeated bladder infections, urgency to urinate, discomfort in lower abdomen." .

:I065 a :ComplicatedUrinaryTractInfectionCUTI ;
    rdfs:label "Mild to Severe Complicated Urinary Tract Infection (cUTI)" ;
    :hasReference :R009,
        :R271 ;
    :hasSeverityType :MildToSevere ;
    :hasSymptoms "fever or chills, pain in the lower back or side, and overall malaise" .

