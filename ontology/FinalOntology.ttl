    rdfs:label "Nausea" ;
    :hasDurationOf "Few hours to days" ;
    :hasPattern :Usually_appears_at_the_start_of_treatment__may_lessen_with_food ;
    :hasReference :R160 ;
    :hasSideEffectDescription "Feeling sick to your stomach or throwing up." .

