    :hasReference :R092,
        :R099 ;
    :hasSeverityType :NotSpecified ;
    :hasSymptoms "Fever and chills, heavy sweats, chest pain, cough, or shortness of breath, confusion or dizziness, nausea, vomiting, or stomach pains, headache or body aches, and extreme tiredness" .

:I051 a :LegionnairesDisease ;
    rdfs:label "Legionnaire's disease" ;
    :hasReference :R093,
        :R101 ;
    :hasSeverityType :NotSpecified ;
    :hasSymptoms "symptoms similar to pneumonia, cough, fever, headaches, muscle aches, shortness of breath" .

:I052 a :QFever ;
    rdfs:label "Mild to Severe Q Fever" ;
    :hasReference :R093,
        :R102 ;
    :hasSeverityType :MildToSevere ;
    :hasSymptoms "fever, fatigue, headache, malaise, myalgia, chills or sweats, cough, nausea, vomiting, diarrhea" .

:I053 a :Tuberculosis ;
    rdfs:label "Tuberculosis" ;
    :hasReference :R093,
        :R103 ;
    :hasSeverityType :NotSpecified ;
    :hasSymptoms "A bad cough that lasts 3 weeks or longer, pain in the chest, coughing up blood or sputum (phlegm) from deep inside the lungs" .

:I054 a :SecondaryInfectionsInChronicRespiratoryDiseases ;
    rdfs:label "Secondary infections in chronic respiratory diseases" ;
    :hasReference :R129 ;
    :hasSeverityType :NotSpecified ;
    :hasSymptoms "cough, increased sputum production, or dyspnea" .

:I059 a :BladderInfection ;
    rdfs:label "Mild to Moderate Bladder Infection" ;
    :hasReference :R165 ;
    :hasSeverityType :MildToModerate ;
    :hasSymptoms "Pain or pressure in the lower abdomen and a burning feeling during urination. The person may need to urinate very often. Urine may appear cloudy and sometimes may have small amounts of blood." .

:I060 a :RecurrentUrinaryTractInfection ;
    rdfs:label "Mild to Moderate (can worsen if untreated) Recurrent Urinary Tract Infection" ;
    :hasReference :R165 ;
    :hasSymptoms "Repeated episodes of urinary burning, urgency, and discomfort that happen several times over a period of months. Symptoms are similar to previous bladder infections." .

:I061 a :GenitalInfections ;
    rdfs:label "Genital Infections" ;
    :hasReference :R166,
        :R269 ;
    :hasSeverityType :NotSpecified ;
    :hasSymptoms "Burning or itching, discharge or odor, pain around the pelvis, burning and pain when passing urine or with bowel movements, having to go to the bathroom often, and sores, bumps or blisters on genital, anus or mouth" .

:I063 a :ComplicatedUrinaryTractInfectionCUTI ;
    rdfs:label "Complicated Urinary Tract Infection (cUTI)" ;
    :hasReference :R008,
        :R271 ;
    :hasSeverityType :NotSpecified ;
    :hasSymptoms "fever or chills, pain in the lower back or side, and overall malaise" .

:I064 a :AcutePyelonephritis ;
    rdfs:label "Acute Pyelonephritis" ;
    :hasReference :R008,
        :R272 ;
    :hasSeverityType :NotSpecified ;
    :hasSymptoms "fever, chills, pain in your lower back or side, pain when you pee (urinate), bloody or, cloudy pee (hematuria or pyuria) that might smell bad, urgent or frequent need to pee" .

:ITN004 a :Interaction ;
    rdfs:label "ITN004" ;
    :hasClinicalEffects "Fosfomycin may be less effective at treating infection." ;
    :hasInteractionDescription "Metoclopramide may reduce absorption of fosfomycin." ;
    :hasManagementAdvice "Inform your doctor; avoid taking metoclopramide at the same time as fosfomycin if possible." ;
    :hasReference :R022,
        :R023 ;
    :interactsWith :S004 .

:ITN005 a :Interaction ;
    rdfs:label "ITN005" ;
    :hasClinicalEffects "Lower blood and urine levels of fosfomycin." ;
    :hasInteractionDescription "Metoclopramide may lower the absorption of Fosfomycin Tromethamine by speeding up digestion." ;
    :hasManagementAdvice "Avoid using together with Fosfomycin if possible. If needed, monitor for treatment effectiveness." ;
    :hasReference :R024 ;
    :interactsWith :S004 .

:ITN006 a :Interaction ;
    rdfs:label "ITN006" ;
    :hasClinicalEffects "No effect on drug levels or effectiveness." ;
    :hasInteractionDescription "Cimetidine does not affect Fosfomycin Tromethamine absorption or blood levels." ;
    :hasManagementAdvice "No speicla precautions needed." ;
    :hasReference :R024 ;
    :interactsWith :S005 .

:ITN007 a :Interaction ;
    rdfs:label "ITN007" ;
    :hasClinicalEffects "None specifically reported for Fosfomycin Tromethamine." ;
    :hasInteractionDescription "No known interaction with beer; alcohol may affect general health while taking antibiotics." ;
    :hasManagementAdvice "Consume alcohol moderately; avoid excessie drinking while ill or in antibiotics." ;
    :hasReference :R024 ;
    :interactsWith :S006 .

:ITN008 a :Interaction ;
    rdfs:label "ITN008" ;
    :hasClinicalEffects "None specifically reported." ;
    :hasInteractionDescription "No known interaction with wine; alcohol may affect general health while taking antibiotics." ;
    :hasManagementAdvice "Consume alcohol moderately; avoid excessie drinking while ill or in antibiotics." ;
    :hasReference :R024 ;
    :interactsWith :S007 .

:ITN009 a :Interaction ;
    rdfs:label "ITN009" ;
    :hasClinicalEffects "None specifically reported." ;
    :hasInteractionDescription "No known interaction with whiskey; alcohol may affect general health while taking antibiotics." ;
    :hasManagementAdvice "Consume alcohol moderately; avoid excessie drinking while ill or in antibiotics." ;
    :hasReference :R024 ;
    :interactsWith :S008 .

:ITN010 a :Interaction ;
    rdfs:label "ITN010" ;
    :hasClinicalEffects "Lower peak blood level but same total amount excreted in urine." ;
    :hasInteractionDescription "A high-fat meal may slow the absorption of Fosfomycin Tromethamine." ;
    :hasManagementAdvice "Can be taken with or without food." ;
    :hasReference :R024 ;
    :interactsWith :S009 .

:ITN011 a :Interaction ;
    rdfs:label "ITN011" ;
    :hasClinicalEffects "Reduced antibiotic effectiveness." ;
    :hasInteractionDescription "Metoclopramide may lower fosfomycin levels in the body by affecting how it is distributed." ;
    :hasManagementAdvice "Avoid combined use with Fosfomycin if possible. Monitor treatment response." ;
    :hasReference :R026 ;
    :interactsWith :S004 .

:ITN012 a :Interaction ;
    rdfs:label "ITN012" ;
    :hasClinicalEffects "Higher risk of kidney damage." ;
    :hasInteractionDescription "Using fosfomycin with gentamicin may increase stress on the kidneys." ;
    :hasManagementAdvice "Monitor kidney function closely." ;
    :hasReference :R026 ;
    :interactsWith :S010 .

:ITN013 a :Interaction ;
    rdfs:label "ITN013" ;
    :hasClinicalEffects "Increased creatinine or kidney impairment." ;
    :hasInteractionDescription "Combining fosfomycin with vancomycin may increase the risk of kidney problems." ;
    :hasManagementAdvice "Use with caution and monitor renal function." ;
    :hasReference :R026 ;
    :interactsWith :S011 .

:ITN014 a :Interaction ;
    rdfs:label "ITN014" ;
    :hasClinicalEffects "Increased risk of hypokalemia (weakness, irregular heartbeat)." ;
    :hasInteractionDescription "Fosfomycin may lower potassium levels, and furosemide can also reduce potassium." ;
    :hasManagementAdvice "Monitor potassium levels regularly." ;
    :hasReference :R026 ;
    :interactsWith :S012 .

:ITN015 a :Interaction ;
    rdfs:label "ITN015" ;
    :hasClinicalEffects "Fluid retention, high blood pressure, worsening heart failure." ;
    :hasInteractionDescription "Fosfomycin contains sodium, and additional sodium from IV fluids may increase total sodium load." ;
    :hasManagementAdvice "Monitor sodium levels and fluid status." ;
    :hasReference :R026 ;
    :interactsWith :S013 .

:ITN016 a :Interaction ;
    rdfs:label "ITN016" ;
    :hasClinicalEffects "Increased discomfort or nausea." ;
    :hasInteractionDescription "Alcohol does not directly interact, but it may worsen side effects like dizziness or stomach upset." ;
    :hasManagementAdvice "Limit or avoid alcohol during therapy." ;
    :hasReference :R026 ;
    :interactsWith :S006 .

:ITN017 a :Interaction ;
    rdfs:label "ITN017" ;
    :hasClinicalEffects "Increased discomfort or nausea." ;
    :hasInteractionDescription "Alcohol does not directly interact, but it may worsen side effects like dizziness or stomach upset." ;
    :hasManagementAdvice "Limit or avoid alcohol during therapy." ;
    :hasReference :R026 ;
    :interactsWith :S007 .

:ITN018 a :Interaction ;
    rdfs:label "ITN018" ;
    :hasClinicalEffects "Increased discomfort or nausea." ;
    :hasInteractionDescription "Alcohol does not directly interact, but it may worsen side effects like dizziness or stomach upset." ;
    :hasManagementAdvice "Limit or avoid alcohol during therapy." ;
    :hasReference :R026 ;
    :interactsWith :S008 .

:ITN019 a :Interaction ;
    rdfs:label "ITN019" ;
    :hasClinicalEffects "None specifically reported." ;
    :hasInteractionDescription "Antacids containing aluminum or magnesium salts can reduce the rate, but not the extent, of its absorption" ;
    :hasManagementAdvice "Azithromycin should be given at least 1 before or 2 hours after the antacid" ;
    :hasReference :R037 ;
    :interactsWith :S003 .

:ITN020 a :Interaction ;
    rdfs:label "ITN020" ;
    :hasClinicalEffects "None specifically reported." ;
    :hasInteractionDescription "Azithromycin has little or no effect on hepatic cytochrome P450 enzymes, so may or may not interact with astemizole." ;
    :hasManagementAdvice "Monitor for adverse effects if taken with these medications. Consult doctor or pharmacist." ;
    :hasReference :R037 ;
    :interactsWith :S014 .

:ITN021 a :Interaction ;
    rdfs:label "ITN021" ;
    :hasClinicalEffects "None specifically reported." ;
    :hasInteractionDescription "Azithromycin has little or no effect on hepatic cytochrome P450 enzymes, so may or may not interact with cisapride." ;
    :hasManagementAdvice "Monitor for adverse effects if taken with these medications. Consult doctor or pharmacist." ;
    :hasReference :R037 ;
    :interactsWith :S015 .

:ITN022 a :Interaction ;
    rdfs:label "ITN022" ;
    :hasClinicalEffects "None specifically reported." ;
    :hasInteractionDescription "Azithromycin has little or no effect on hepatic cytochrome P450 enzymes, so may or may not interact with terfenadine." ;
    :hasManagementAdvice "Monitor for adverse effects if taken with these medications. Consult doctor or pharmacist." ;
    :hasReference :R037 ;
    :interactsWith :S016 .

:ITN023 a :Interaction ;
    rdfs:label "ITN023" ;
    :hasClinicalEffects "Increased stomach upset, dizziness, or liver strain." ;
    :hasInteractionDescription "Alcohol may increase risk of side effects like nausea, vomiting, or liver problems." ;
    :hasManagementAdvice "Avoid alcohol while taking Contepo." ;
    :hasReference :R027,
        :R028 ;
    :interactsWith :S017 .

:ITN024 a :Interaction ;
    rdfs:label "ITN024" ;
    :hasClinicalEffects "Prolonged bleeding or easy bruising." ;
    :hasInteractionDescription "May increase risk of bleeding when used together." ;
    :hasManagementAdvice "Monitor INR/blood clotting; adjust warfarin dose if necessary." ;
    :hasReference :R027,
        :R028 ;
    :interactsWith :S018 .

:ITN025 a :Interaction ;
    rdfs:label "ITN025" ;
    :hasClinicalEffects "Kidney injury or electrolyte imbalance." ;
    :hasInteractionDescription "Using with other nephrotoxic antibiotics increases risk of kidney damage." ;
    :hasManagementAdvice "Monitor kidney funcation; avoid combination if possible." ;
    :hasReference :R027,
        :R028 ;
    :interactsWith :S019 .

:ITN026 a :Interaction ;
    rdfs:label "ITN026" ;
    :hasClinicalEffects "Reduced antibiotic efficacy." ;
    :hasInteractionDescription "Calcium can bind to the drug and reduce its effectiveness." ;
    :hasManagementAdvice "Take calcium supplements at least 2 hours before or after the dose." ;
    :hasReference :R028 ;
    :interactsWith :S020 .

:ITN027 a :Interaction ;
    rdfs:label "ITN027" ;
    :hasClinicalEffects "Reduced drug effectiveness." ;
    :hasInteractionDescription "Dairy products can interfere with absorption." ;
    :hasManagementAdvice "Take the drug 2 hours before of after consuming dairy." ;
    :hasReference :R028 ;
    :interactsWith :S021 .

:ITN028 a :Interaction ;
    rdfs:label "ITN028" ;
    :hasClinicalEffects "Reduced antibiotic effectiveness." ;
    :hasInteractionDescription "Antacids may reduce absorption of the drug." ;
    :hasManagementAdvice "Take antacids 2 hours before or after the dose." ;
    :hasReference :R028 ;
    :interactsWith :S022 .

:ITN029 a :Interaction ;
    rdfs:label "ITN029" ;
    :hasClinicalEffects "May reduce effectiveness or increase side effects." ;
    :hasInteractionDescription "Taking other antibiotics or medications at the same time may affect how fosfomycin works." ;
    :hasManagementAdvice "Adjust dosing or monitor for interactions; consult doctor." ;
    :hasReference :R029,
        :R030 ;
    :interactsWith :S023 .

:ITN030 a :Interaction ;
