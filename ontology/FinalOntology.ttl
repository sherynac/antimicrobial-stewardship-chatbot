    rdfs:label "has side effect" ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Brand :PresentationOrPacking :Antibiotic ) ] ;
    rdfs:inverseOf :sideEffectOf ;
    rdfs:range :SideEffect ;
    owl:propertyChainAxiom ( :hasBrandName :hasPresentation :hasSideEffect ) .

:hasWarning a owl:ObjectProperty ;
