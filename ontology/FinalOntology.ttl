    rdfs:label "insomnia" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Common ;
    :hasReference :R008,
        :R202 ;
    :hasSideEffectDescription "experience disruptions in how you feel or function because you aren’t sleeping well or sleeping enough." .

