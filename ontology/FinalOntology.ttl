:hasAdministrationAndAdherenceRule a owl:ObjectProperty ;
    rdfs:label "has administration & adherence rule" ;
    rdfs:domain :Brand ;
    rdfs:range :AdministrationAndAdherence .

:hasDrugClass a owl:DatatypeProperty ;
    rdfs:label "has drug class" ;
    rdfs:domain :Antibiotic ;
    rdfs:range xsd:string .

:hasDurationOf a owl:DatatypeProperty ;
    rdfs:label "lasts for" ;
    rdfs:domain :SideEffect ;
    rdfs:range xsd:string .

:hasFoodAndTimingRule a owl:ObjectProperty ;
    rdfs:label "has food and timing rule" ;
    rdfs:domain :Brand ;
    rdfs:range :FoodAndTiming .

:hasInteractionDescription a owl:DatatypeProperty ;
    rdfs:label "has interaction description" ;
    rdfs:domain :Interaction ;
    rdfs:range xsd:string .

:hasManagementAdvice a owl:DatatypeProperty ;
    rdfs:label "has management advice" ;
    rdfs:domain :Interaction ;
    rdfs:range xsd:string .

:hasPattern a owl:ObjectProperty ;
    rdfs:label "which is" ;
    rdfs:domain :SideEffect ;
    rdfs:range :Pattern .

:hasReference a owl:ObjectProperty ;
    rdfs:label "has reference" ;
    rdfs:domain [ owl:unionOf ( :Antibiotic :Brand :Indication :Warning :SideEffect :Interaction :StewardshipPrinciple :Pattern :Substance ) ] ;
    rdfs:range :Reference .

:hasSideEffectDescription a owl:DatatypeProperty ;
    rdfs:label "is described as" ;
    rdfs:domain :SideEffect ;
    rdfs:range xsd:string .

:hasStewardshipDescription a owl:DatatypeProperty ;
    rdfs:label "has stewardship description" ;
    rdfs:domain :StewardshipPrinciple ;
    rdfs:range xsd:string .

:hasStorageRule a owl:ObjectProperty ;
    rdfs:label "has storage rule" ;
    rdfs:domain :Brand ;
    rdfs:range :Storage .

:hasTherapeuticUseAndMonitoringRule a owl:ObjectProperty ;
    rdfs:label "has therapeutic use & monitoring rule" ;
    rdfs:domain :Brand ;
    rdfs:range :TherapeuticUseAndMonitoring .

:hasWarningText a owl:DatatypeProperty ;
    rdfs:label "has warning text" ;
    rdfs:domain :Warning ;
    rdfs:range xsd:string .

:isPresentationOf a owl:ObjectProperty ;
    rdfs:domain :PresentationOrPacking ;
    rdfs:range :Brand ;
    owl:inverseOf :hasPresentation .

:managedAs a owl:ObjectProperty ;
    rdfs:label "managed as" ;
    rdfs:domain :Brand ;
    rdfs:range :StewardshipPrinciple .

:warningOf a owl:ObjectProperty ;
    rdfs:domain :Warning ;
    rdfs:range :Brand ;
    owl:inverseOf :hasWarning .

:14_days_of_initiation_of_therapy_and_most_cases_occurred_within_6_days a :Pattern ;
