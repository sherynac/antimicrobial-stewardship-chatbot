:SP119 a :FoodAndTiming ;
    rdfs:label "SP119" ;
    :hasReference :R009 ;
    :hasStewardshipDescription "May be taken with or without food" .

:SP120 a :AdministrationAndAdherence ;
    rdfs:label "SP120" ;
    :hasReference :R009 ;
    :hasStewardshipDescription "Take at least 2 hr before or 2 hr after antacids containing Ca/Mg/Al, after sucralfate or metal cations (eg, Fe), multivit prep w/ Zn, or didanosine." .

:SP121 a :Storage ;
    rdfs:label "SP121" ;
    :hasReference :A010 ;
    :hasStewardshipDescription "Store at temperatures not exceeding 30°C" .

:SP122 a :FoodAndTiming ;
    rdfs:label "SP122" ;
    :hasReference :R010 ;
    :hasStewardshipDescription "May be taken with or without food: May be taken during or between meals. Swallow whole, do not chew" .

:SP123 a :AdministrationAndAdherence ;
    rdfs:label "SP123" ;
    :hasReference :R010 ;
    :hasStewardshipDescription "Dosage is according to doctor's instructions only" .

:SP124 a :FoodAndTiming ;
    rdfs:label "SP124" ;
    :hasReference :R038 ;
    :hasStewardshipDescription "Azithromycin should be taken at least one hour before or two hours after administration of food and antacid preparations" .

:SP125 a :FoodAndTiming ;
    rdfs:label "SP125" ;
    :hasReference :R091 ;
    :hasStewardshipDescription "May be taken with or without food; Preferably taken 2hrs after meals" .

