:Drug a owl:Class ;
    rdfs:subClassOf :Substance ;
    owl:disjointWith :Beverage,
        :Food .

:SideEffect a owl:Class ;
    owl:disjointWith :Indication,
        :Pattern,
        :Severity .

:Interaction a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality 1 ;
            owl:onClass :Substance ;
            owl:onProperty :interactsWith ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty :hasClinicalEffects ] ;
    owl:disjointWith :Indication,
        :Pattern,
        :Severity,
        :SideEffect,
        :Warning .

:Reference a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty :hasReferenceTitle ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty :hasAuthor ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty :publishedIn ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty :retrievedFrom ] ;
    owl:disjointWith :Antibiotic,
        :Brand,
        :Indication,
        :Interaction,
        :Pattern,
        :PresentationOrPacking,
        :Severity,
        :SideEffect,
        :StewardshipPrinciple,
        :Warning .

