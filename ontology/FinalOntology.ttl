:ITN034 a :Interaction ;
    rdfs:label "ITN034" ;
    :hasClinicalEffects "None specifically reported." ;
    :hasInteractionDescription "Probenecid reduces the renal clearance of cefatoxime, resulting in higher and prolonged plasma concentrations of cefotaxime and its desacetyl metabolite." ;
    :hasManagementAdvice "Monitor for adverse effects if taken with these medications. Consult doctor or pharmacist." ;
    :hasReference :R014 ;
    :interactsWith :S028 .

:ITN035 a :Interaction ;
    rdfs:label "ITN035" ;
    :hasClinicalEffects "None specifically reported." ;
    :hasInteractionDescription "The total body clearance of cefotaxime has been reduced in patients with normal and reduced renal function by mezlocillin." ;
    :hasManagementAdvice "Monitor for adverse effects if taken with these medications. Consult doctor or pharmacist." ;
    :hasReference :R014 ;
    :interactsWith :S029 .

:ITN036 a :Interaction ;
    rdfs:label "ITN036" ;
    :hasClinicalEffects "None specifically reported." ;
    :hasInteractionDescription "The total body clearance of cefotaxime has been reduced in patients with normal and reduced renal function by ureidopenicillins azlocillin." ;
    :hasManagementAdvice "Monitor for adverse effects if taken with these medications. Consult doctor or pharmacist." ;
    :hasReference :R014 ;
    :interactsWith :S030 .

:ITN037 a :Interaction ;
