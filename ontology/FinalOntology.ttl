:SE547 a :Nausea ;
    rdfs:label "Nausea" ;
    :hasDurationOf "Short-term; may last a few hours to a few days" ;
    :hasPattern :Commonly_appears_early_in_treatment__especially_if_taken_without_food ;
    :hasReference :R165 ;
    :hasSideEffectDescription "A feeling of sickness in the stomach that may make the patient feel like vomiting. It may improve when the medicine is taken with meals." .

:SE548 a :Emesis ;
    rdfs:label "Emesis" ;
    :hasDurationOf "Short-term; may occur occasionally during treatment" ;
    :hasPattern :May_occur_after_taking_a_dose__especially_if_stomach_upset_happens ;
    :hasReference :R165 ;
    :hasSideEffectDescription "Throwing up stomach contents. It may be mild or moderate and often happens together with nausea." .

:SE549 a :Anorexia ;
    rdfs:label "Anorexia" ;
    :hasDurationOf "May last during the period of treatment" ;
    :hasPattern :Can_develop_gradually_while_taking_the_medicine ;
    :hasReference :R165 ;
    :hasSideEffectDescription "Reduced desire to eat or feeling full quickly. The patient may eat less than usual because of stomach discomfort." .

:SE550 a :AbdominalPain ;
    rdfs:label "Abdominal Pain" ;
    :hasDurationOf "Usually temporary; may last several hours to days" ;
    :hasPattern :Can_appear_during_early_treatment ;
    :hasReference :R165 ;
    :hasSideEffectDescription "Pain or discomfort in the stomach or lower belly area. It may feel like cramping, pressure, or aching." .

:SE551 a :Diarrhea ;
    rdfs:label "Diarrhea" ;
    :hasDurationOf "Usually short-term; may last a few days" ;
    :hasPattern :May_occur_anytime_during_treatment ;
    :hasReference :R165 ;
    :hasSideEffectDescription "Passing loose or watery stools more often than normal. It may be mild but should be monitored if severe or persistent." .

:SE552 a :PulmonaryHypersensitivityReaction ;
    rdfs:label "Pulmonary Hypersensitivity Reaction" ;
    :hasDurationOf "Can occur suddenly and may become serious if not treated" ;
    :hasPattern :May_appear_during_therapy__especially_with_prolonged_use ;
    :hasReference :R165 ;
    :hasSideEffectDescription "An allergic-type reaction affecting the lungs. Symptoms may include cough, chest pain, fever, or difficulty breathing. Immediate medical attention is needed." .

:SE553 a :PeripheralNeuropathy ;
    rdfs:label "Peripheral Neuropathy" ;
    :hasDurationOf "May develop gradually and can be long-lasting or permanent if not stopped early" ;
    :hasPattern :More_likely_with_prolonged_use_or_in_high-risk_patients ;
    :hasReference :R165 ;
    :hasSideEffectDescription "Nerve damage that causes numbness, tingling, burning sensation, or weakness in the hands and feet. Treatment should be stopped if symptoms appear." .

:SE554 a :ExfoliativeDermatitis ;
    rdfs:label "Exfoliative Dermatitis" ;
    :hasDurationOf "Duration varies; may last until medicine is stopped" ;
    :hasPattern :Rare_but_serious_reaction_during_treatment ;
    :hasReference :R165 ;
    :hasSideEffectDescription "Severe skin reaction where the skin becomes red, irritated, and may peel off. Medical attention is required immediately." .

:SE555 a :ErythemaMultiforme ;
    rdfs:label "Erythema Multiforme" ;
    :hasDurationOf "Duration varies; may resolve after stopping the drug" ;
    :hasPattern :Rare_skin_reaction_during_use ;
    :hasReference :R165 ;
    :hasSideEffectDescription "A skin condition causing red patches, spots, or blister-like lesions on the skin. It may be mild or severe." .

:SE556 a :LupusLikeSyndrome ;
    rdfs:label "Lupus-like Syndrome" ;
    :hasDurationOf "Nat develop during prolonged therapy; improves after stopping medicine" ;
    :hasPattern :Rare_and_usually_associated_with_long-term_use ;
    :hasReference :R165 ;
    :hasSideEffectDescription "A reaction that causes symptoms similar to lupus, such as joint pain, muscle pain, fever, and skin rash. Symptoms usually improve when the medicine is discontinued." .

:SE557 a :Megaloblastosis ;
    rdfs:label "Megaloblastosis" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Not_Specified ;
    :hasReference :R317 ;
    :hasSideEffectDescription "Megaloblastosis is a cytomorphological diagnostic sign for megaloblastic anaemia, which is a morphological and functional erythropoiesis abnormality. At all stages of maturity, megaloblasts have various cytomorphological traits that distinguish them from normal erythroid precursor cells (i.e., normoblasts)." .

:SE558 a :Leukopenia ;
    rdfs:label "Leukopenia" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Not_Specified ;
    :hasReference :R276 ;
    :hasSideEffectDescription "Leukopenia (low white blood cell count) happens when you have a lower-than-normal number of white blood cells. Specifically, you have fewer neutrophils than normal. Neutrophils are white blood cells that act as your immune system’s first line of defense. Without enough white blood cells, you’re more vulnerable to developing infections." .

:SE559 a :Thrombocytopenia ;
    rdfs:label "Thrombocytopenia" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Not_Specified ;
    :hasReference :R140 ;
    :hasSideEffectDescription "Thrombocytopenia occurs when your bone marrow doesn’t make enough platelets. Platelets are blood cells that form blood clots to help stop bleeding. People with this condition may bleed a lot and the bleeding may be hard to stop. Thrombocytopenia affects people with certain medical conditions like autoimmune disease or who take certain medications." .

:SE560 a :SkinRash ;
    rdfs:label "Skin Rash" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Not_Specified ;
    :hasReference :R116 ;
    :hasSideEffectDescription "Skin rashes can be red, inflamed, bumpy as well as dry, itchy or painful. The main cause is dermatitis, which is when your skin reacts to allergens or irritants. Bacteria, viruses, allergens and conditions including eczema, hives, and psoriasis can be the source of skin rashes." .

:SE561 a :RecurrentFever ;
    rdfs:label "Recurrent Fever" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Not_Specified ;
    :hasReference :R318 ;
    :hasSideEffectDescription "SAIDs (systemic autoinflammatory diseases) are a group of disorders that cause recurring fevers. They most commonly affect children. Formerly known as “periodic fever syndromes,” most of these conditions are hereditary and result from a genetic variant." .

:SE562 a :Neutropenia ;
    rdfs:label "Neutropenia" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Not_Specified ;
    :hasReference :R139 ;
    :hasSideEffectDescription "Neutropenia involves having lower-than-normal levels of neutrophils (a type of white blood cell) in your blood." .

:SE563 a :LiverEnzymeElevation ;
    rdfs:label "Liver enzyme Values" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Not_Specified ;
    :hasReference :R247 ;
    :hasSideEffectDescription "If your blood test showed high (elevated) levels of liver enzymes, you could have a medical condition. Elevated liver enzymes may also be temporary." .

