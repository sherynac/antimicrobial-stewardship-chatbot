:SP001 a :AdministrationAndAdherence ;
    rdfs:label "SP001" ;
    :hasReference :R022,
        :R023 ;
    :hasStewardshipDescription "Use Monurol only for confirmed uncomplicated urinary tract infections in adult women. Do not use for kidney infections or perinephric abscess." .

:SP002 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP002" ;
    :hasReference :R022,
        :R023 ;
    :hasStewardshipDescription "Avoid unnecessary use to prevent deveopment of antibiotic-resistant bacteria." .

:SP003 a :AdministrationAndAdherence ;
    rdfs:label "SP003" ;
    :hasReference :R022,
        :R023 ;
    :hasStewardshipDescription "Take the full single-dose as instructed. Do not repeat the dose unless prescribed by a doctor." .

:SP004 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP004" ;
    :hasReference :R022,
        :R023 ;
    :hasStewardshipDescription "Contact your doctor if symptoms do not improve within 2-3 days. Watch for severe diarrhea, allergic reactions, or worsening urinary symptoms." .

:SP005 a :AdministrationAndAdherence ;
    rdfs:label "SP005" ;
    :hasReference :R022,
        :R023 ;
    :hasStewardshipDescription "Do not use in children under 12 years old." .

:SP006 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP006" ;
    :hasReference :R022,
        :R023 ;
    :hasStewardshipDescription "Pregnant or breastfeeding women should consult their doctor before taking Monurol." .

:SP007 a :AdministrationAndAdherence ;
    rdfs:label "SP007" ;
    :hasReference :R024 ;
    :hasStewardshipDescription "Fosfomycin Tromethamine  should be used only for uncomplicated urinary tract infections caused by E.coli or Enterococcus faecalis. Do not use for pyelonephritis or other infections." .

:SP008 a :AdministrationAndAdherence ;
    rdfs:label "SP008" ;
    :hasReference :R024 ;
    :hasStewardshipDescription "Only a single oral dose is recommended. Repeating daily doses does not improve effectiveness and increases side effects." .

:SP009 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP009" ;
    :hasReference :R024 ;
    :hasStewardshipDescription "Obtain urine culture before treatment to ensure the bacteria are susceptible." .

:SP010 a :AdministrationAndAdherence ;
    rdfs:label "SP010" ;
    :hasReference :R024 ;
    :hasStewardshipDescription "Patients should take the full dose as instructed and dissolve the powder in water before drinking." .

:SP011 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP011" ;
    :hasReference :R024 ;
    :hasStewardshipDescription "Monitor symptoms; if they do not improve within 2-3 days or if they return, contact a healthcare provider for further evaluation" .

:SP012 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP012" ;
    :hasReference :R024 ;
    :hasStewardshipDescription "Monitor for diarrhea or water or bloody stools after antibiotic use, which could indicate C. difficile infection." .

:SP013 a :Storage ;
    rdfs:label "SP013" ;
    :hasReference :R037 ;
    :hasStewardshipDescription "Store at temperatures not exceeding 30°C" .

:SP014 a :AdministrationAndAdherence ;
    rdfs:label "SP014" ;
    :hasReference :R026 ;
    :hasStewardshipDescription "Use IV fosfomycin only for confirmed or strongly suspected bacterial infections. It should not be used for viral infections." .

:SP015 a :AdministrationAndAdherence ;
    rdfs:label "SP015" ;
    :hasReference :R026 ;
    :hasStewardshipDescription "Reserve IV fosfomycin for serious infections or resistant bacteriawhen other antibiotics are not effective." .

:SP016 a :AdministrationAndAdherence ;
    rdfs:label "SP016" ;
    :hasReference :R026 ;
    :hasStewardshipDescription "Adjust dose based on kidney function to avoid toxicity." .

:SP017 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP017" ;
    :hasReference :R026 ;
    :hasStewardshipDescription "Monitor kidney function during treatment, especially in patients with renal impairment." .

:SP018 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP018" ;
    :hasReference :R026 ;
    :hasStewardshipDescription "Check electrolyte levels (especially potassium) during prolonged therapy." .

:SP019 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP019" ;
    :hasReference :R026 ;
    :hasStewardshipDescription "Monitor sodium levels in patients with heart failure, hypertension, or fluid retention." .

:SP020 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP020" ;
    :hasReference :R026 ;
    :hasStewardshipDescription "Watch for severe diarrhea that may indicate C. difficile infection." .

:SP021 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP021" ;
    :hasReference :R026 ;
    :hasStewardshipDescription "Observe for signs of allergic reactions during and after infusion." .

:SP022 a :AdministrationAndAdherence ;
    rdfs:label "SP022" ;
    :hasReference :R026 ;
    :hasStewardshipDescription "Complete the full prescribed duration even if symptoms improve early." .

:SP023 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP023" ;
    :hasReference :R026 ;
    :hasStewardshipDescription "Use proper infection control practices in hospital settings to prevent the spread of resistant bacteria." .

:SP024 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP024" ;
    :hasReference :R026 ;
    :hasStewardshipDescription "Avoid unnecessary combination with other nephrotoxic drugs unless clearly needed." .

:SP025 a :AdministrationAndAdherence ;
    rdfs:label "SP025" ;
    :hasReference :R027,
        :R028 ;
    :hasStewardshipDescription "Only use Contepo when prescribed by a healthcare professional for a confirmed infection. Avoid using for viral infections like colds or flu." .

:SP026 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP026" ;
    :hasReference :R027,
        :R028 ;
    :hasStewardshipDescription "Take infection control measures such as hand hygiene and avoiding contact with sick individuals to prevent the spread of infection." .

:SP027 a :AdministrationAndAdherence ;
    rdfs:label "SP027" ;
    :hasReference :R027,
        :R028 ;
    :hasStewardshipDescription "Complete the full course of Contepo even if you feel better to prevent bacterial resistance. Do not skip doses." .

:SP028 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP028" ;
    :hasReference :R027,
        :R028 ;
    :hasStewardshipDescription "Report any severe side effects or unusual symptoms to your healthcare provider. Kidney and liver function may need monitorng during treatment." .

:SP029 a :FoodAndTiming ;
    rdfs:label "SP029" ;
    :hasReference :R037 ;
    :hasStewardshipDescription "May be taken with meals to reduce gastrointestinal discomfort" .

:SP030 a :AdministrationAndAdherence ;
    rdfs:label "SP030" ;
    :hasReference :R029,
        :R030 ;
    :hasStewardshipDescription "Only use for prescribed bacterial infections (uncomplicated UTIs). Avoid for viral infections." .

:SP031 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP031" ;
    :hasReference :R029,
        :R030 ;
    :hasStewardshipDescription "Practice good hygiene to reduce infection spread; drink enough fluids." .

:SP032 a :AdministrationAndAdherence ;
    rdfs:label "SP032" ;
    :hasReference :R029,
        :R030 ;
    :hasStewardshipDescription "Take the full single-dose treatment exactly as prescribed, even if symptoms improve quickly." .

:SP033 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP033" ;
    :hasReference :R029,
        :R030 ;
    :hasStewardshipDescription "Contact your doctor if severe side effects occur. Kidney function may require monitoring." .

:SP034 a :AdministrationAndAdherence ;
    rdfs:label "SP034" ;
    :hasReference :R038 ;
    :hasStewardshipDescription "For people with advanced HIV infection, to prevent a serious illness called Mycobacterium avium complex (MAC) disease, it can be taken by itself or together with another drug called rifabutin (at the recommended dose)" .

:SP035 a :AdministrationAndAdherence ;
    rdfs:label "SP035" ;
    :hasReference :R038 ;
    :hasStewardshipDescription "For people with advanced HIV infection, to treat a serious illness called Mycobacterium avium complex (MAC) disease, it is taken with another drug called ethambutol (at the recommended dose)" .

:SP036 a :FoodAndTiming ;
    rdfs:label "SP036" ;
    :hasReference :R037 ;
    :hasStewardshipDescription "May be taken with or without meals" .

:SP037 a :AdministrationAndAdherence ;
    rdfs:label "SP037" ;
    :hasReference :R039 ;
    :hasStewardshipDescription "Should be swallowed whole with liquid as a single daily dose. Do not chew or crush when taking." .

