    :hasReference :R014 ;
    :hasSideEffectDescription "Includes skin rashes, urticaria, eosinophilia, fever, reactions resembling serum sickness,, and anaphylaxis." .

:SE100 a :HypersensitivityReactions ;
    rdfs:label "Hypersensitivity Reactions" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Not_Specified ;
    :hasReference :R014 ;
    :hasSideEffectDescription "Includes skin rashes, urticaria, eosinophilia, fever, reactions resembling serum sickness,, and anaphylaxis." .

:SE101 a :Arrhythmias ;
    rdfs:label "Arrhythmias" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Not_Specified ;
    :hasReference :R014 ;
    :hasSideEffectDescription "Arrhythmias have been associated with rapid bolus administration through a central venous catheter." .

:SE102 a :Candidiasis ;
    rdfs:label "Candidiasis" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Uncommon ;
    :hasReference :R039,
        :R065 ;
    :hasSideEffectDescription "Yeast infection caused by Candida albicans that commonly affects mouth, skin and vagina" .

:SE104 a :SideEffect ;
    rdfs:label "Pneumonia" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Uncommon ;
    :hasReference :R039 ;
    :hasSideEffectDescription "difficulty breathing that can cause fever and cough with yellow, green or blood mucus" .

:SE105 a :FungalInfections ;
    rdfs:label "Fungal Infections" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Uncommon ;
    :hasReference :R039,
        :R066 ;
    :hasSideEffectDescription "condition caused by fungus; usually affect skin, hair nails or mucous membranes" .

:SE107 a :SideEffect ;
    rdfs:label "Pharyngitis" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Uncommon ;
    :hasReference :R039,
        :R055 ;
    :hasSideEffectDescription "scratchy or burning feeling in the back of your throat; it may hurt to swallow or talk" .

:SE108 a :Gastroenteritis ;
    rdfs:label "Gastroenteritis" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Uncommon ;
    :hasReference :R039,
        :R067 ;
    :hasSideEffectDescription "inflammation of the lining of the stomach and intestines; vomiting and diarrhea" .

:SE110 a :Rhinitis ;
    rdfs:label "Rhinitis" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Uncommon ;
    :hasReference :R039 ;
    :hasSideEffectDescription "nasal congestion, runny nose, sneezing, itching" .

:SE111 a :OralCandidiasis ;
    rdfs:label "Oral candidiasis" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Uncommon ;
    :hasReference :R039,
        :R065 ;
    :hasSideEffectDescription "Infection that affections your mouth, throat, tongue or esophagus; Causes raised, white sores to develop, along with mouth pain, irritation and redness" .

:SE112 a :Leukopenia ;
    rdfs:label "Leukopenia" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Uncommon ;
    :hasReference :R039 ;
    :hasSideEffectDescription "lower-than-normal number of white blood cells" .

:SE114 a :Eosinophilia ;
    rdfs:label "Eosinophilia" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Uncommon ;
    :hasReference :R039,
        :R068 ;
    :hasSideEffectDescription "unusually high number of eosinophils (type of white blood cell) in blood; High number of eosinophils crowd at specific areas of the body, causing medical conditions linked to inflammation that can affecti multiple areas of the body." .

:SE115 a :Angioedema ;
    rdfs:label "Angioedema" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Uncommon ;
    :hasReference :R039,
        :R064 ;
    :hasSideEffectDescription "swelling in the tissue under your skin, commonly seen in the lips, eyelids, tongue, genitals, hands or feet" .

:SE119 a :Insomnia ;
    rdfs:label "Insomnia" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Uncommon ;
    :hasReference :R039 ;
    :hasSideEffectDescription "difficulty falling asleep or staying asleep" .

:SE120 a :Agitation ;
    rdfs:label "Agitation" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Rare ;
    :hasReference :R039 ;
    :hasSideEffectDescription "state of severe restlessness or inner tension" .

:SE121 a :Headache ;
    rdfs:label "Headache" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Common ;
    :hasReference :R039 ;
    :hasSideEffectDescription "Discomfort in the head or face" .

:SE123 a :Somnolence ;
    rdfs:label "Somnolence" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Uncommon ;
    :hasReference :R039 ;
    :hasSideEffectDescription "feeling tired and wanting to fall asleep" .

:SE124 a :Dysgeusia ;
    rdfs:label "Dysgeusia" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Uncommon ;
    :hasReference :R039,
        :R070 ;
    :hasSideEffectDescription "all foods taste metallic, sweet, sour or bitter" .

:SE126 a :Vertigo ;
    rdfs:label "Vertigo" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Uncommon ;
    :hasReference :R039 ;
    :hasSideEffectDescription "false sensation of motion such as spinning or swaying" .

:SE127 a :Palpitations ;
    rdfs:label "Palpitations" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Uncommon ;
    :hasReference :R039,
        :R059 ;
    :hasSideEffectDescription "feeling like your heart is missing heartbeats, racing or pounding felt in chest, throat or neck." .

:SE128 a :HotFlush ;
    rdfs:label "Hot flush" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Uncommon ;
    :hasReference :R039 ;
    :hasSideEffectDescription "sudden feeling of warmth in the upper body mostly affecting the face, neck and chest" .

:SE129 a :Diarrhea ;
    rdfs:label "Diarrhea" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Very_Common ;
    :hasReference :R039 ;
    :hasSideEffectDescription "Loose, watery stools." .

:SE130 a :Vomiting ;
    rdfs:label "Vomiting" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Common ;
    :hasReference :R039,
        :R057 ;
    :hasSideEffectDescription "Effects are usually mild. Forceful ejection stomach contents through the mouth." .

:SE131 a :AbdominalPain ;
    rdfs:label "Abdominal Pain" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Common ;
    :hasReference :R039,
        :R058 ;
    :hasSideEffectDescription "pain felt anywhere between the chest and groin." .

:SE132 a :Nausea ;
    rdfs:label "Nausea" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Common ;
    :hasReference :R039,
        :R056 ;
    :hasSideEffectDescription "Effects are usually mild. Sensation of having to vomit or having the urge to vomit." .

:SE133 a :DecreasedLymphocyteCountAndBloodBicarbonate ;
    rdfs:label "Decreased lymphocyte count and blood bicarbonate" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Common ;
    :hasReference :R039,
        :R073,
        :R074 ;
    :hasSideEffectDescription "Low lymphocyte count can increase chances of getting sick; Low level of blood bicarbonate can cause metabolic acidosis or too much acid in the body." .

:SE134 a :IncreasedEosinophilCountBasophilsMonocytesAndNeutrophils ;
    rdfs:label "Increased Eosinophil count, basophils, monocytes and neutrophils" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Common ;
    :hasReference :R039,
        :R075 ;
    :hasSideEffectDescription "This can lead to leukocytosis, which means the patient has a high white blood cell count than normal; Neutrophilia leukocytosis is caused by a high number of neutrophils (the most plentiful type of white blood cell, which helps resolve infections and heal damaged tissues).; Monocytosis is caused by a high number of monocytes (white blood cells that boost your immune responses).; Eosinophilia refers to high levels of eosinophils (white blood cells that play a role in fighting infections and inflammation). Eosinophilia is common and is often related to allergies, parasitic infections or autoimmune disorders; Basophilia, the rarest form of leukocytosis, is characterized by an increased number of basophils (white blood cells that play a role in fighting parasitic infections, preventing blood clotting and responding to allergic reactions)." .

:SE135 a :StevensJohnsonSyndrome ;
    rdfs:label "Stevens-Johnson Syndrome" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Not_specified ;
    :hasReference :R034 ;
    :hasSideEffectDescription "Stevens-Johnson syndrome (SJS) is a rare, serious disorder of the skin and mucous membranes. It's usually a reaction to medication that starts with flu-like symptoms, followed by a painful rash that spreads and blisters. Then the top layer of affected skin dies, sheds and begins to heal after several days." .

:SE136 a :ToxicEpidermalNecrolysis ;
    rdfs:label "Toxic epidermal necrolysis" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Not_specified ;
    :hasReference :R033 ;
    :hasSideEffectDescription "Toxic epidermal necrolysis (TEN) is potentially life-threatening acute mucocutaneous Syndrome. It usually occurs because of inappropriate immune reactions to certain drugs." .

:SE137 a :StevensJohnsonSyndrome ;
    rdfs:label "Stevens-Johnson Syndrome" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Not_specified ;
    :hasReference :R034 ;
    :hasSideEffectDescription "Stevens-Johnson syndrome (SJS) is a rare, serious disorder of the skin and mucous membranes. It's usually a reaction to medication that starts with flu-like symptoms, followed by a painful rash that spreads and blisters. Then the top layer of affected skin dies, sheds and begins to heal after several days." .

:SE138 a :ToxicEpidermalNecrolysis ;
    rdfs:label "Toxic epidermal necrolysis" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Not_specified ;
    :hasReference :R033 ;
    :hasSideEffectDescription "Toxic epidermal necrolysis (TEN) is potentially life-threatening acute mucocutaneous Syndrome. It usually occurs because of inappropriate immune reactions to certain drugs." .

:SE139 a :GastrointestinalDisturbances ;
    rdfs:label "Gastrointestinal disturbances" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Most_frequent ;
    :hasReference :R038 ;
    :hasSideEffectDescription "Mild disease in the gastrointestinal tract" .

:SE141 a :AngioedemaAndCholestaticJaundice ;
    rdfs:label "Angioedema and cholestatic jaundice" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Happens_during_multiple-dose_regimen ;
    :hasReference :R038,
        :R064 ;
    :hasSideEffectDescription "Swelling in the tissue under your skin, commonly seen in the lips, eyelids, tongue, genitals, hands or feet; yellowing of skin and whites of the eyes" .

:SE142 a :Nausea ;
    rdfs:label "Nausea" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Happens_during_multiple-dose_regimen ;
    :hasReference :R038,
        :R056 ;
    :hasSideEffectDescription "Sensation of having to vomit or having the urge to vomit." .

:SE143 a :Vomiting ;
    rdfs:label "Vomiting" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Happens_during_multiple-dose_regimen ;
    :hasReference :R038,
        :R057 ;
    :hasSideEffectDescription "Forceful ejection stomach contents through the mouth." .

:SE144 a :Diarrhea ;
    rdfs:label "Diarrhea" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Happens_during_multiple-dose_regimen ;
    :hasReference :R038,
        :R076 ;
    :hasSideEffectDescription "Loose, watery stool during a bowl movement" .

:SE145 a :AbdominalPain ;
    rdfs:label "Abdominal Pain" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Happens_during_multiple-dose_regimen ;
    :hasReference :R038,
        :R058 ;
    :hasSideEffectDescription "Pain felt anywhere between the chest and groin." .

:SE146 a :PalpitationsAndChestPain ;
    rdfs:label "Palpitations and chest pain" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Not_Specified ;
    :hasReference :R038,
        :R059 ;
    :hasSideEffectDescription "Feeling like your heart is missing heartbeats, racing or pounding felt in chest, throat or neck; Pain felt between neck and belly" .

:SE147 a :Dyspepsia ;
    rdfs:label "Dyspepsia" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Not_Specified ;
    :hasReference :R038 ;
    :hasSideEffectDescription "Pain or discomfort in the upper abdomen" .

:SE148 a :Flatulence ;
    rdfs:label "Flatulence" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Not_Specified ;
    :hasReference :R038 ;
    :hasSideEffectDescription "Body releases gas in your digestive system through your anus." .

:SE149 a :Melena ;
    rdfs:label "Melena" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Not_Specified ;
    :hasReference :R038,
        :R060 ;
    :hasSideEffectDescription "Black, tarry stool caused by internal bleeding" .

:SE151 a :Vaginitis ;
    rdfs:label "Vaginitis" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Not_Specified ;
    :hasReference :R038 ;
    :hasSideEffectDescription "Inflammation of the vagina" .

:SE152 a :Nephritis ;
    rdfs:label "Nephritis" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Not_Specified ;
    :hasReference :R038,
        :R061 ;
    :hasSideEffectDescription "Inflammation of one or both kidneys, which can leak protein into urine and impair the body's ability to absorb water and lead to tissue swelling" .

:SE154 a :Vertigo ;
    rdfs:label "Vertigo" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Not_Specified ;
    :hasReference :R038 ;
    :hasSideEffectDescription "false sensation of motion such as spinning or swaying" .

:SE155 a :Somnolence ;
    rdfs:label "Somnolence" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Not_Specified ;
    :hasReference :R038 ;
    :hasSideEffectDescription "feeling tired and wanting to fall asleep" .

:SE156 a :Fatigue ;
    rdfs:label "Fatigue" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Not_Specified ;
    :hasReference :R038,
        :R062 ;
    :hasSideEffectDescription "feeling of weariness, tiredness, or lack of energy" .

:SE157 a :Rash ;
    rdfs:label "Rash" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Not_Specified ;
    :hasReference :R038 ;
    :hasSideEffectDescription "red, bumpy, often itchy skin" .

:SE158 a :Photosensitivity ;
    rdfs:label "Photosensitivity" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Not_Specified ;
    :hasReference :R038,
        :R063 ;
    :hasSideEffectDescription "Skin reacts negatively to sunlight or UV rays that causes an itchy, painful rash" .

:SE159 a :SkinRash ;
    rdfs:label "Skin Rash" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Common ;
    :hasReference :R015 ;
    :hasSideEffectDescription "A general skin reaction" .

:SE160 a :Diarrhea ;
    rdfs:label "Diarrhea" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Common ;
    :hasReference :R015 ;
    :hasSideEffectDescription "Gastrointestinal disturbance" .

:SE161 a :Nausea ;
    rdfs:label "Nausea" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Common ;
    :hasReference :R015 ;
    :hasSideEffectDescription "Gastrointestinal disturbance" .

:SE162 a :Vomiting ;
    rdfs:label "Vomiting" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Uncommon ;
    :hasReference :R015 ;
    :hasSideEffectDescription "Gastrointestinal disturbance" .

:SE163 a :Urticaria ;
    rdfs:label "Urticaria" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Uncommon ;
    :hasReference :R015 ;
    :hasSideEffectDescription "A skin reaction (hives)" .

:SE164 a :Pruritus ;
    rdfs:label "Pruritus" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Uncommon ;
    :hasReference :R015 ;
    :hasSideEffectDescription "Itching" .

:SE165 a :SuperficialToothDiscoloration ;
    rdfs:label "Superficial Tooth Discoloration" ;
    :hasDurationOf "Reversible (can usually be removed by brushing)" ;
    :hasPattern :Not_specifically_classified_by_frequency__but_reported_in_children ;
    :hasReference :R015 ;
    :hasSideEffectDescription "Affects Amoxil 100 mg/mL oral drops and Amoxil Forte oral suspension; can often be prevented by good oral hygiene" .

:SE166 a :SkinRash ;
    rdfs:label "Skin Rash" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Common ;
    :hasReference :R015 ;
    :hasSideEffectDescription "A general skin reaction" .

:SE167 a :Diarrhea ;
    rdfs:label "Diarrhea" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Common ;
    :hasReference :R015 ;
    :hasSideEffectDescription "Gastrointestinal disturbance" .

:SE168 a :Nausea ;
    rdfs:label "Nausea" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Common ;
    :hasReference :R015 ;
    :hasSideEffectDescription "Gastrointestinal disturbance" .

:SE169 a :Vomiting ;
    rdfs:label "Vomiting" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Uncommon ;
    :hasReference :R015 ;
    :hasSideEffectDescription "Gastrointestinal disturbance" .

:SE170 a :Urticaria ;
    rdfs:label "Urticaria" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Uncommon ;
    :hasReference :R015 ;
    :hasSideEffectDescription "A skin reaction (hives)" .

:SE171 a :Pruritus ;
    rdfs:label "Pruritus" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Uncommon ;
    :hasReference :R015 ;
    :hasSideEffectDescription "Itching" .

:SE172 a :OvergrowthFungalOrCDifficile ;
    rdfs:label "Overgrowth fungal / C. difficile" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Common___1_100_to__1_10_ ;
    :hasReference :R035,
        :R072 ;
    :hasSideEffectDescription "Clostridioides difficile is a bacterium that causes an infection of the colon, the longest part of the large intestine. Symptoms can range from diarrhea to life-threatening damage to the colon. The bacterium is often called C. difficile or C. diff." .

:SE173 a :Leukopenia ;
    rdfs:label "Leukopenia" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R276 ;
    :hasSideEffectDescription "Leukopenia (low white blood cell count) happens when you have a lower-than-normal number of white blood cells. Specifically, you have fewer neutrophils than normal. Neutrophils are white blood cells that act as your immune system’s first line of defense. Without enough white blood cells, you’re more vulnerable to developing infections." .

:SE174 a :Neutropenia ;
    rdfs:label "Neutropenia" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R139 ;
    :hasSideEffectDescription "Neutropenia involves having lower-than-normal levels of neutrophils (a type of white blood cell) in your blood." .

:SE175 a :Thrombocytopenia ;
    rdfs:label "Thrombocytopenia" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R140 ;
    :hasSideEffectDescription "Thrombocytopenia occurs when your bone marrow doesn’t make enough platelets. Platelets are blood cells that form blood clots to help stop bleeding. People with this condition may bleed a lot and the bleeding may be hard to stop. Thrombocytopenia affects people with certain medical conditions like autoimmune disease or who take certain medications." .

:SE176 a :Agranulocytosis ;
    rdfs:label "Agranulocytosis" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R277 ;
    :hasSideEffectDescription "Agranulocytosis refers to having severely low neutrophil levels. Neutrophils are a type of white blood cell. They fight germs that make you sick. Untreated agranulocytosis can lead to life-threatening infections." .

:SE177 a :MegaloblasticAnaemia ;
    rdfs:label "Megaloblastic anaemia" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R278 ;
    :hasSideEffectDescription "Megaloblastic anemia is a form of macrocytic anemia, a blood disorder that happens when your bone marrow produces stem cells that make abnormally large red blood cells. Megaloblastic anemia is a type of vitamin deficiency anemia that happens when you don’t get enough vitamin B12 and/or vitamin B9 (folate)." .

:SE178 a :AplasticAnaemia ;
    rdfs:label "Aplastic anaemia" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R279 ;
    :hasSideEffectDescription "Aplastic anemia is a rare but serious blood disorder. It happens when something damages your bone marrow so it can’t make enough new blood cells and platelets. Left untreated, aplastic anemia is a life-threatening condition." .

:SE179 a :HaemolyticAnaemia ;
    rdfs:label "haemolytic anaemia" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R280 ;
    :hasSideEffectDescription "Hemolytic anemia is a blood disorder that typically happens when your red blood cells break down or die faster than your body can replace them with new blood cells. People may develop hemolytic anemia by inheriting genetic conditions that cause anemia, certain infections and certain medications." .

:SE180 a :Methaemoglobinaemia ;
    rdfs:label "methaemoglobinaemia" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R281 ;
    :hasSideEffectDescription "Methemoglobinemia (MetHb) is a rare blood disorder that affects how red blood cells deliver oxygen throughout your body. Not everyone has symptoms, but nearly all people with this condition have skin, nails or lips that are a distinctive shade of blue or purple." .

:SE181 a :Eosinophilia ;
    rdfs:label "eosinophilia" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R068 ;
    :hasSideEffectDescription "Eosinophilia happens when your body produces an unusually high number of eosinophils. Eosinophils are one of several white blood cells that support your immune system." .

:SE182 a :Purpura ;
    rdfs:label "purpura" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R185 ;
    :hasSideEffectDescription "Purpura causes red, purple or brown blood spots on your skin. It happens when small blood vessels leak blood under your skin’s surface." .

:SE183 a :HaemolysisInG6PDDeficiency ;
    rdfs:label "haemolysis in certain susceptible G-6-PD deficient patients" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R282 ;
    :hasSideEffectDescription "Hemolysis is the medical term used to describe the destruction of red blood cells. Your body is constantly destroying old or damaged red blood cells and replacing them with new ones." .

:SE184 a :SerumSickness ;
    rdfs:label "Serum sickness" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R186 ;
    :hasSideEffectDescription "Serum sickness is an allergic reaction to certain proteins in medicines. Symptoms may include hives, swelling, fever, rash and joint pain." .

:SE185 a :AnaphylacticReaction ;
    rdfs:label "anaphylactic reaction" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R283 ;
    :hasSideEffectDescription "Anaphylaxis is when you have a severe allergic reaction. Most commonly, it happens after you eat certain foods or get stung by an insect. Going into anaphylactic shock can be life-threatening." .

:SE186 a :AllergicMyocarditis ;
    rdfs:label "allergic myocarditis" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R284 ;
    :hasSideEffectDescription "Myocarditis is inflammation of the heart muscle, or myocardium. This inflammation weakens your heart muscle, making it harder for your heart to pump. This can be caused by viral infections or inflammatory conditions." .

:SE187 a :HypersensitivityVasculitisHenochSchonleinPurpura ;
    rdfs:label "hypersensitivity vasculitis resembling Henoch-Schönlein purpura" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R285 ;
    :hasSideEffectDescription "Henoch-Schonlein purpura causes the small blood vessels in the skin, joints, intestines and kidneys to become inflamed and bleed. The most noticeable symptom of this form of vasculitis is a rash that often appears on the legs and feet. Henoch-Schonlein purpura also can cause belly pain and aching joints. Rarely, the condition may cause serious kidney damage." .

:SE188 a :PeriarteritisNodosa ;
    rdfs:label "periarteritis nodosa" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R286 ;
    :hasSideEffectDescription "Polyarteritis nodosa or PAN is a rare condition of inflamed blood vessels that hurt your organs. You can have symptoms in many parts of your body at one time." .

:SE189 a :SystemicLupusErythematosus ;
    rdfs:label "systemic lupus erythematosus" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R187 ;
    :hasSideEffectDescription "Systemic lupus erythematosus (SLE) is a systemic autoimmune disease with multisystem involvement and is associated with significant morbidity and mortality. Genetic, immunological, endocrine, and environmental factors influence the loss of immunological tolerance against self-antigens leading to the formation of pathogenic autoantibodies that cause tissue damage through multiple mechanisms." .

:SE190 a :HaemophagocyticLymphohistiocytosis ;
    rdfs:label "haemophagocytic lymphohistiocytosis" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R287 ;
    :hasSideEffectDescription "Hemophagocytic lymphohistiocytosis is a rare and often life-threatening condition if left untreated. HLH causes your immune system to attack your body instead of a foreign invader like a virus. The condition is either acquired or genetic and there’s no way to prevent it." .

:SE191 a :SevereHypersensitivityWithPneumocystisJiroveciiPneumonia ;
    rdfs:label "Severe hypersensitivity reactions associated with Pneumocystis jirovecii pneumonia" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R288 ;
    :hasSideEffectDescription "Pneumocystis carinii pneumonia (PCP), now referred to as Pneumocystis jirovecii pneumonia, is a fungal infection that most commonly affects the immunocompromised and, in some cases, can be severely life-threatening. Typically, patients at risk are those with underlying disease states that alter host immunity, such as cancer, human immunodeficiency virus, transplant recipients, or those taking immunosuppressive therapies and medications. Patients presenting with PCP may show signs of fever, cough, dyspnea, and, in severe cases, respiratory failure." .

:SE192 a :Thrombocytopenia ;
    rdfs:label "thrombocytopenia" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R140 ;
    :hasSideEffectDescription "Thrombocytopenia occurs when your bone marrow doesn’t make enough platelets. Platelets are blood cells that form blood clots to help stop bleeding. People with this condition may bleed a lot and the bleeding may be hard to stop. Thrombocytopenia affects people with certain medical conditions like autoimmune disease or who take certain medications." .

:SE193 a :IncreasedHepaticEnzymes ;
    rdfs:label "Increased Hepatic Enzymes" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R247 ;
    :hasSideEffectDescription "If your blood test showed high (elevated) levels of liver enzymes, you could have a medical condition. Elevated liver enzymes may also be temporary." .

:SE194 a :Hyperkalaemia ;
    rdfs:label "hyperkalaemia" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R289 ;
    :hasSideEffectDescription "Hyperkalemia is a condition in which you have high potassium levels in your blood. You may not have any symptoms, or they may be easy to dismiss. Severe symptoms may cause muscle weakness or affect your heart." .

:SE195 a :Hyponatraemia ;
    rdfs:label "hyponatraemia" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R290 ;
    :hasSideEffectDescription "Hyponatremia is when the amount of sodium in your blood is too low. Common causes include heart, liver, kidney and brain diseases, hormone issues and medications." .

:SE196 a :Rhabdomyolysis ;
    rdfs:label "rhabdomyolysis" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R291 ;
    :hasSideEffectDescription "Rhabdomyolysis is a rare muscle injury where your muscles break down. This is a life-threatening condition that can happen after an injury or excessive exercise without rest." .

:SE197 a :Hyperkalaemia ;
    rdfs:label "Hyperkalaemia" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_common ;
    :hasReference :R035,
        :R289 ;
    :hasSideEffectDescription "Hyperkalemia is a condition in which you have high potassium levels in your blood. You may not have any symptoms, or they may be easy to dismiss. Severe symptoms may cause muscle weakness or affect your heart." .

:SE198 a :Hypoglycaemia ;
    rdfs:label "Hypoglycaemia" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R292 ;
    :hasSideEffectDescription "Hypoglycemia (low blood sugar) is common in people who have diabetes. But it can also sometimes affect people without diabetes." .

:SE199 a :Hyponatraemia ;
    rdfs:label "hyponatraemia" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R290 ;
    :hasSideEffectDescription "Hyponatremia is when the amount of sodium in your blood is too low. Common causes include heart, liver, kidney and brain diseases, hormone issues and medications." .

:SE200 a :DecreasedAppetite ;
    rdfs:label "decreased appetite" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R293 ;
    :hasSideEffectDescription "A loss of appetite is a symptom that can have many causes. This occurs when you don’t feel hungry. The medical term for a loss of appetite is anorexia. This is different from the eating disorder anorexia nervosa." .

:SE201 a :MetabolicAcidosis ;
    rdfs:label "metabolic acidosis" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R294 ;
    :hasSideEffectDescription "Metabolic acidosis is a condition in which acids build up in your body. Causes include untreated diabetes, the loss of bicarbonate in your body and kidney conditions. Symptoms include an accelerated heartbeat, confusion and fatigue." .

:SE202 a :Depression ;
    rdfs:label "Depression" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R295 ;
    :hasSideEffectDescription "Depression is a common mental health condition that causes a persistent feeling of sadness and changes in how you think, sleep, eat and act." .

:SE203 a :Hallucinations ;
    rdfs:label "Hallucinations" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R126 ;
    :hasSideEffectDescription "Hallucinations are false perceptions of sensory experiences. Some hallucinations are normal, such as those caused by falling asleep or waking up. But others may be a sign of a more serious condition like schizophrenia or dementia." .

:SE204 a :PsychoticDisorder ;
    rdfs:label "Psychotic disorder" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Not_known ;
    :hasReference :R035,
        :R296 ;
    :hasSideEffectDescription "Psychosis is the term for a collection of symptoms that happen when a person has trouble telling the difference between what’s real and what’s not. This disconnection from reality can happen for several reasons, including many different mental and physical conditions." .

:SE205 a :Headache ;
    rdfs:label "Headache" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R203 ;
    :hasSideEffectDescription "Headaches are a very common condition that most people will experience many times during their lives. The main symptom of a headache is pain in your head or face." .

:SE206 a :MeningitisAseptic ;
    rdfs:label "Meningitis aseptic" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R297 ;
    :hasSideEffectDescription "Aseptic meningitis is an inflammatory condition of the meninges characterized by cerebrospinal fluid pleocytosis and negative bacterial cultures. Although generally considered a benign illness, it encompasses a wide range of etiologies and clinical manifestations, which vary depending on the underlying cause and the patient's immune status." .

:SE207 a :Seizure ;
    rdfs:label "seizure" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R144 ;
    :hasSideEffectDescription "A seizure is abnormal electrical activity in your brain. It causes changes in awareness and muscle control. It also causes symptoms that affect your behavior and senses. Seizures can affect anyone at any age and there are a lot of possible causes, from an underlying medical condition to an injury or illness." .

:SE208 a :NeuropathyPeripheral ;
    rdfs:label "neuropathy peripheral" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R298 ;
    :hasSideEffectDescription "Peripheral neuropathy refers to any condition that affects the nerves outside your brain or spinal cord. This can happen for several reasons, from trauma to infections to inherited conditions." .

:SE209 a :Ataxia ;
    rdfs:label "ataxia" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R299 ;
    :hasSideEffectDescription "Ataxia is when you have problems coordinating how your muscles work, leading to awkward, unwieldy or clumsy movements. It’s a possible symptom with a wide range of conditions or circumstances, or it can happen as a stand-alone condition." .

:SE210 a :Dizziness ;
    rdfs:label "dizziness" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R300 ;
    :hasSideEffectDescription "Dizziness is a common issue. If you have dizziness, you may feel woozy and disoriented. You may feel as if you’re about to lose your balance. Many things may make you dizzy, such as anxiety or a reaction to medication. But dizziness may be a symptom of an underlying medical issue." .

:SE211 a :Vertigo ;
    rdfs:label "Vertigo" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R231 ;
    :hasSideEffectDescription "Vertigo causes dizziness and makes you feel like you’re spinning when you’re not. It most commonly occurs when there’s an issue with your inner ear. But you can also develop it if you have a condition affecting your brain, like a tumor or stroke." .

:SE212 a :Tinnitus ;
    rdfs:label "tinnitus" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R135 ;
    :hasSideEffectDescription "Tinnitus fills your ears with sounds no one else hears. It’s a common issue affecting more than 50 million people in the United States. Tinnitus can be severe, affecting people’s daily lives. Tinnitus isn’t a disease. It’s a symptom of several medical conditions." .

:SE213 a :Uveitis ;
    rdfs:label "Uveitis" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R301 ;
    :hasSideEffectDescription "Uveitis is a condition where you have inflammation of the uvea, which includes the iris, ciliary body and choroid. It’s common, and vision loss is one of the possible complications (especially when uveitis is severe or goes untreated)." .

:SE214 a :Cough ;
    rdfs:label "Cough" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R302 ;
    :hasSideEffectDescription "A cough is a forceful push of air that your body uses to clear irritants, mucus and germs out of your airways. Common causes include allergies, asthma, infections (like colds), chronic lung conditions and acid reflux." .

:SE215 a :Dyspnoea ;
    rdfs:label "dyspnoea" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R303 ;
    :hasSideEffectDescription "Dyspnea, or shortness of breath, is the feeling that you can’t get enough air into your lungs. It might feel like your chest is tight, you’re gasping for air or you’re working harder to breathe. Heart and lung conditions are common causes of dyspnea." .

:SE216 a :LungInfiltration ;
    rdfs:label "lung infiltration" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R304 ;
    :hasSideEffectDescription "Lung infiltrates refer to abnormal substances or fluids within the lung tissue that can arise from various causes, including infections, pulmonary hemorrhage, drug toxicity, leukemic infiltration, and pulmonary edema, particularly in patients with hematologic malignancies." .

:SE217 a :Nausea ;
    rdfs:label "Nausea" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Common ;
    :hasReference :R035,
        :R204 ;
    :hasSideEffectDescription "Nausea can make it feel like your stomach is ready to do somersaults, sending whatever’s inside right back up and out." .

:SE218 a :Diarrhea ;
    rdfs:label "Diarrhea" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Common ;
    :hasReference :R035,
        :R207 ;
    :hasSideEffectDescription "Diarrhea means having a loose, watery stool during a bowel movement. It’s common in both children and adults and usually goes away on its own within a few days." .

:SE219 a :Vomiting ;
    rdfs:label "Vomiting" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Uncommon ;
    :hasReference :R035,
        :R210 ;
    :hasSideEffectDescription "Vomiting is when muscles in your belly, chest, neck and head work together to push whatever’s in your stomach out. This forceful expulsion of your stomach’s contents can be a symptom of many conditions" .

:SE220 a :Glossitis ;
    rdfs:label "Glossitis" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R245 ;
    :hasSideEffectDescription "Glossitis is inflammation that makes your tongue swollen, smooth or red. Allergic reactions, infections and dry mouth may cause it." .

:SE221 a :Stomatitis ;
    rdfs:label "stomatitis" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R241 ;
    :hasSideEffectDescription "Stomatitis (oral mucositis) is inflammation in the tissue lining your mouth or lips. The most common types are cold sores and canker sores. Causes include infections, injuries, allergic reactions and cancer treatment side effects." .

:SE222 a :Pancreatitis ;
    rdfs:label "pancreatitis" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R242 ;
    :hasSideEffectDescription "Pancreatitis is inflammation in your pancreas. It’s usually temporary (acute) but can also be a life-long (chronic) condition. The most common symptom is abdominal pain. The most common causes are alcohol use and gallstones." .

:SE223 a :JaundiceCholestatic ;
    rdfs:label "Jaundice cholestatic" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R305 ;
    :hasSideEffectDescription "Cholestatic jaundice results from impaired bile flow, accumulating bile components, such as bilirubin, in the bloodstream. This condition can be classified as intrahepatic, caused by issues within the liver, or extrahepatic, resulting from obstructions outside the liver. Common clinical manifestations include jaundice, pruritus, fatigue, malabsorption of fats and fat-soluble vitamins, and the appearance of skin lesions such as xanthomas." .

:SE224 a :HepaticNecrosis ;
    rdfs:label "hepatic necrosis" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R306 ;
    :hasSideEffectDescription "The clinical course of acute hepatic necrosis resembles an acute, toxic injury to the liver with sudden and precipitous onset, marked elevations in serum aminotransferase levels, and early signs of hepatic (or other organ) dysfunction or failure despite minimal or no jaundice. Rapid recovery after withdrawal of the agent is also typical. Other organ failure, such as lung, kidney or bone marrow, may also be present and may overshadow the hepatic injury. Acute hepatic necrosis is typically caused by a direct hepatotoxin and is usually dose dependent and “expected”, rather than idiosyncratic." .

:SE225 a :TransaminasesIncreased ;
    rdfs:label "Transaminases increased" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R307 ;
    :hasSideEffectDescription "Transaminitis is one result you might see on a standard blood test. It means you have high levels of certain liver enzymes in your blood. Enzymes called transaminases release from liver cells when something injures those cells. Alcohol, medications, viruses and metabolic diseases are among the possible causes of liver damage and transaminitis." .

:SE226 a :BloodBilirubinIncreased ;
    rdfs:label "blood bilirubin increased" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R308 ;
    :hasSideEffectDescription "Higher than usual levels of bilirubin may mean different types of liver or bile duct problems. Sometimes, higher bilirubin levels may be caused by an increased rate of destruction of red blood cells." .

:SE227 a :Rash ;
    rdfs:label "Rash" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Common ;
    :hasReference :R035,
        :R116 ;
    :hasSideEffectDescription "Skin rashes can be red, inflamed, bumpy as well as dry, itchy or painful. The main cause is dermatitis, which is when your skin reacts to allergens or irritants. Bacteria, viruses, allergens and conditions including eczema, hives, and psoriasis can be the source of skin rashes." .

:SE228 a :PhotosensitivityReaction ;
    rdfs:label "Photosensitivity reaction" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R063 ;
    :hasSideEffectDescription "Photosensitivity is when your skin reacts negatively to sunlight or UV rays. It causes an itchy, painful rash. Unlike a sunburn, symptoms can appear within minutes." .

:SE229 a :DermatitisExfoliative ;
    rdfs:label "dermatitis exfoliative" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R309 ;
    :hasSideEffectDescription "Exfoliative dermatitis is a serious skin condition that causes extreme shedding of the top layers of your skin. It may cover most of your body and lead to so much skin damage that your body can’t keep warm. Dehydration is also a risk due to your skin losing its ability to hold onto moisture." .

:SE230 a :Angioedema ;
    rdfs:label "angioedema" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R064 ;
    :hasSideEffectDescription "Angioedema is swelling in the tissue under your skin. It’s most common in your lips, eyelids, tongue, genitals, hands and feet. Causes include allergies, medication side effects, vibrations, inherited gene changes and some health conditions." .

:SE231 a :FixedDrugEruption ;
    rdfs:label "fixed drug eruption" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R310 ;
    :hasSideEffectDescription "The term fixed drug eruption (FDE) describes the development of one or more annular or oval erythematous patches as a result of systemic exposure to a drug. A vesicle or bulla may or may not occur at the center of  patch and these reactions normally resolve with hyperpigmentation and may recur at the same site with reexposure to the drug. Repeated exposure to the offending drug may also cause new lesions to develop in addition to lighting up the older hyperpigmented lesions. Lesions can occur anywhere on the body (ie, face, tongue, hands, feet, torso, extremities, and genitalia) but genitalia and oral muscosa are often favored." .

:SE232 a :ErythemaMultiforme ;
    rdfs:label "erythema multiforme" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R119 ;
    :hasSideEffectDescription "Erythema multiforme is your body’s reaction to an illness, infection or medicine. This condition affects your skin and causes a painful, itchy rash that looks like a bulls-eye or a target." .

:SE233 a :StevensJohnsonSyndrome ;
    rdfs:label "Stevens-Johnson syndrome" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R120 ;
    :hasSideEffectDescription "Stevens-Johnson syndrome (SJS) is a rare, serious disorder of the skin and mucous membranes. It's usually a reaction to medication that starts with flu-like symptoms, followed by a painful rash that spreads and blisters. Then the top layer of affected skin dies, sheds and begins to heal after several days." .

:SE234 a :ToxicEpidermalNecrolysis ;
    rdfs:label "toxic epidermal necrolysis" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R121 ;
    :hasSideEffectDescription "Toxic epidermal necrolysis (TEN) is a life-threatening skin condition. It causes peeling and blistering skin over much of the body, including the mouth, eyes, and genitals. TEN is the most severe form of Stevens-Johnson syndrome." .

:SE235 a :AcuteGeneralisedExanthematousPustulosis ;
    rdfs:label """acute\r
generalised exanthematous pustulosis""" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R311 ;
    :hasSideEffectDescription "Acute generalized exanthematous pustulosis (AGEP) comprises a severe cutaneous adverse reaction marked by the abrupt onset of sterile, nonfollicular pinpoint pustules on an erythematous base. Drug exposure, most frequently systemic antibiotics, is the primary cause, although viral infections and environmental triggers have also been implicated. Genetic predisposition, advanced age, and comorbid immune dysregulation are considered risk factors. AGEP is most often attributed to a type IV hypersensitivity mechanism involving drug-specific T cells, neutrophil activation, and cytokine release, although the pathophysiology remains incompletely characterized." .

:SE236 a :AcuteFebrileNeutrophilicDermatosis ;
    rdfs:label "Acute febrile neutrophilic dermatosis" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Not_known ;
    :hasReference :R035,
        :R312 ;
    :hasSideEffectDescription "Acute febrile neutrophilic dermatosis (AFND), also known as Sweet syndrome or Gomm-Button disease, manifests as erythematous plaques and papules, coupled with constitutional symptoms like fever and malaise." .

:SE237 a :DrugReactionWithEosinophiliaAndSystemicSymptoms ;
    rdfs:label "Drug reaction with eosinophilia and systemic symptoms" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Not_known ;
    :hasReference :R035,
        :R313 ;
    :hasSideEffectDescription "Drug reaction with eosinophilia and systemic symptoms (DRESS) is a T cell mediated, drug-specific immune response associated with end-organ damage." .

:SE238 a :Arthralgia ;
    rdfs:label "Arthralgia" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R314 ;
    :hasSideEffectDescription "Arthritis isn't a single condition but a broad term for many conditions affecting the joints. Arthritis typically is associated with pain that affects the ability to move a joint. It causes swelling and tenderness of one or more joints. The main symptoms are joint pain and stiffness, which can impact daily activities and work." .

:SE239 a :Myalgia ;
    rdfs:label "myalgia" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R252 ;
    :hasSideEffectDescription "Myalgia is the medical term for muscle pain, which has many causes. Many of them are easy to treat at home. But myalgia can also be a symptom of disease, especially when it’s widespread and long-lasting." .

:SE240 a :RenalImpairment ;
    rdfs:label "Renal impairment" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R254 ;
    :hasSideEffectDescription "Kidney failure is a condition in which one or both of your kidneys no longer work on their own. Causes include diabetes, high blood pressure and acute kidney injuries. Symptoms include fatigue, nausea and vomiting, swelling, changes in how often you go to the bathroom and brain fog." .

:SE241 a :TubulointerstitialNephritisAndUveitisSyndrome ;
    rdfs:label "tubulointerstitial nephritis and uveitis syndrome" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R315 ;
    :hasSideEffectDescription "Tubulointerstitial nephritis and uveitis (TINU) syndrome is defined as the occurrence of tubulointerstitial nephritis (TIN) and uveitis in the absence of other systemic diseases." .

:SE242 a :RenalTubularAcidosis ;
    rdfs:label """renal tubular\r
acidosis""" ;
    :hasDurationOf "Not specified" ;
    :hasPattern :Very_rare ;
    :hasReference :R035,
        :R316 ;
    :hasSideEffectDescription "Renal tubular acidosis is when you have too much acid in your blood because of a problem with your kidneys. There are three main types of RTA. Causes may include genetic conditions, autoimmune diseases and certain medications." .

:SE243 a :GastrointestinalDisturbances ;
    rdfs:label "Gastrointestinal disturbances" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Common ;
    :hasReference :R017 ;
    :hasSideEffectDescription "Includes nausea, vomiting, diarrhea, glossitis, and stomatitis." .

:SE244 a :HypersensitivityReactions ;
    rdfs:label "Hypersensitivity Reactions" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Fairly_Frequent ;
    :hasReference :R017 ;
    :hasSideEffectDescription "Erythematous maculopapular rashes, urticaria, or rarely, anaphylaxis." .

:SE245 a :HematologicAndLymphaticSystems ;
    rdfs:label "Hematologic and Lymphatic Systems" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Rare ;
    :hasReference :R017 ;
    :hasSideEffectDescription "Includes anemia, thrombocytopenia, and leukopenia; resolves after stopping therapy." .

:SE246 a :CentralNervousSystemEffects ;
    rdfs:label "Central Nervous System Effects" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Rare ;
    :hasReference :R017 ;
    :hasSideEffectDescription "Reversable hyperactivity, agitation, anxiety, insomnia, confusion, behavioral changes, and/or dizziness." .

:SE247 a :GastrointestinalEffects ;
    rdfs:label "Gastrointestinal Effects" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Common ;
    :hasReference :R017 ;
    :hasSideEffectDescription "Includes nausea, vomiting, enterocolitis, and diarrhea." .

:SE248 a :HypersensitivityReactions ;
    rdfs:label "Hypersensitivity Reactions" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Frequent ;
    :hasReference :R017 ;
    :hasSideEffectDescription "Erythematous maculopapular rashes, urticaria, or rarely, anaphylaxis." .

:SE249 a :HematologicAndLymphaticSystems ;
    rdfs:label "Hematologic and Lymphatic Systems" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Rare ;
    :hasReference :R017 ;
    :hasSideEffectDescription "Includes anemia, thrombocytopenia, and leukopenia; resolves after stopping therapy." .

:SE250 a :Hepatic ;
    rdfs:label "Hepatic" ;
    :hasDurationOf "Not Specified" ;
    :hasPattern :Rare ;
    :hasReference :R017 ;
    :hasSideEffectDescription "Moderate rise in aminotransferase and/or alanine aminotransferase enzymes." .

:SE251 a :InjectionSiteReaction ;
    rdfs:label "Injection Site Reaction" ;
    :hasDurationOf "5 days" ;
    :hasPattern :During_or_immediately_after_administration ;
    :hasReference :R032,
        :R322 ;
    :hasSideEffectDescription "Pain, swelling, or redness at the site where the medicine was injected." .

:SE252 a :Diarrhea ;
    rdfs:label "Diarrhea" ;
    :hasDurationOf "2–3 days" ;
    :hasPattern :During_or_shortly_after_treatment ;
    :hasReference :R032 ;
    :hasSideEffectDescription "Loose or watery stools; usually mild, but should be monitored for severity." .

:SE253 a :NauseaOrVomiting ;
    rdfs:label "Nausea / Vomiting" ;
    :hasDurationOf "1–3 days" ;
    :hasPattern :Early_during_treatment ;
    :hasReference :R032 ;
    :hasSideEffectDescription "Feeling of sickness or upset stomach; often improves if the body adjusts." .

:SE254 a :AbdominalPain ;
    rdfs:label "Abdominal Pain" ;
    :hasDurationOf "1–3 days" ;
    :hasPattern :Early_during_treatment ;
    :hasReference :R032 ;
    :hasSideEffectDescription "General abdominal discomfort or cramping." .

:SE255 a :Headache ;
    rdfs:label "Headache" ;
    :hasDurationOf "1–3 days" ;
    :hasPattern :During_treatment ;
    :hasReference :R032 ;
    :hasSideEffectDescription "Mild to moderate aching in the head." .

:SE256 a :Dizziness ;
    rdfs:label "Dizziness" ;
    :hasDurationOf "1–3 days" ;
    :hasPattern :During_treatment ;
    :hasReference :R032 ;
    :hasSideEffectDescription "Feeling lightheaded, unsteady, or faint." .

:SE257 a :VaginalYeastInfection ;
    rdfs:label "Vaginal Yeast Infection" ;
    :hasDurationOf "3–7 days" ;
    :hasPattern :During_or_after_treatment ;
    :hasReference :R032 ;
    :hasSideEffectDescription "Itching, irritation, or thick white discharge due to changes in bacterial flora." .

:SE258 a :RashOrHives ;
