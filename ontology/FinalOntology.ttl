:I002 a :AcuteBacterialExacerbationsOfCOPD ;
    rdfs:label "Mild to Moderate Acute Bacterial Exacerbations of COPD" ;
    :hasReference :R037,
        :R040 ;
    :hasSeverityType :MildToModerate ;
    :hasSymptoms "increased wheezing, fever without another identified cause, or an increase in heart rate or respiratory rate greater than 20% from baseline." .

:I003 a :AcuteBacterialSinusitis ;
    rdfs:label "Mild to Moderate Acute Bacterial Sinusitis" ;
    :hasReference :R013,
        :R037 ;
    :hasSeverityType :MildToModerate ;
    :hasSymptoms "Colored, thick mucus (from nose or down throat), stuffy, blocked nose, face feels full, pressured, or painful, can't smell things well (or at all), fever" .

:I013 a :NonGonococcalUrethritis ;
    rdfs:label "Non-gonococcal urethritis" ;
    :hasReference :R038,
        :R045 ;
    :hasSeverityType :NotSpecified ;
    :hasSymptoms "Men: Discharge from penis, pain while peeing (dysuria), pain while ejaculating (dysorgasmia or orgasmalgia), itching, irritation and/or tenderness, abdominal pain. Women: Vaginal discharge, pain while peeing, pain during sexual intercourse (dyspareunia), spotting or cramping throughout the month (irregular periods)." .

:I015 a :GenitalUlcerDiseaseForMen ;
    rdfs:label "Genital Ulcer Disease for Men" ;
    :hasReference :R037,
        :R046 ;
    :hasSeverityType :NotSpecified ;
    :hasSymptoms "Burning sensation, fever, itchy genitals,painful urination or sexual intercourse" .

:I019 a :UncomplicatedUrinaryTractInfectionUTI ;
    rdfs:label "Uncomplicated Urinary Tract Infection (UTI)" ;
    :hasReference :R008,
        :R264 ;
    :hasSeverityType :NotSpecified ;
    :hasSymptoms "urinary frequency, urgency, dysuria, and suprapubic discomfort." .

:I024 a :HospitalAcquiredPneumoniaHAP ;
    rdfs:label "Severe Hospital-Acquired Pneumonia (HAP)" ;
    :hasReference :R026 ;
    :hasSeverityType :Severe ;
    :hasSymptoms "Cough, fever, shortness of breath, chest pain, thick mucus" .

:I025 a :VentilatorAssociatedPneumoniaVAP ;
    rdfs:label "Severe Ventilator-Associated Pneumonia (VAP)" ;
    :hasReference :R026 ;
    :hasSeverityType :Severe ;
    :hasSymptoms "Fever, worsening breathing, increased secretions, low oxygen levels" .

:I036 a :SinglePneumonia ;
    rdfs:label "Mild to severe Single pneumonia" ;
    :hasReference :R003,
        :R020,
        :R081 ;
    :hasSeverityType :MildToSevere ;
    :hasSymptoms "High fever, cough, tiredness, rapid breathing or heart rate, shortness of breath" .

:I040 a :LungAbscess ;
    rdfs:label "Lung Abscess" ;
    :hasReference :R003,
        :R086 ;
    :hasSeverityType :NotSpecified ;
    :hasSymptoms "mimic pneumonia, including fever, chills cough, night sweats, and chest pain, with a productive cough developing as a hallmark sign" .

:I043 a :Tracheobronchitis ;
    rdfs:label "Severe Tracheobronchitis" ;
    :hasReference :R012,
        :R089,
        :R320 ;
    :hasSeverityType :Severe ;
    :hasSymptoms "coughing, mild headaches, soreness in the chest, a sore throat, tiredness, mild body aches" .

:I046 a :CommunityAcquiredRespiratoryInfections ;
    rdfs:label "Initial therapy Community Acquired Respiratory Infections" ;
    :hasReference :R020 ;
    :hasSeverityType :InitialTherapy .

