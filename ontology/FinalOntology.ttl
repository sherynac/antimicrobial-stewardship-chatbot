:hasAuthor a owl:DatatypeProperty ;
    rdfs:label "has author" ;
    rdfs:domain :Reference ;
    rdfs:range xsd:string .

:hasClinicalEffects a owl:DatatypeProperty ;
    rdfs:label "has clinical effects" ;
    rdfs:domain :Interaction ;
    rdfs:range xsd:string .

:hasInteraction a owl:ObjectProperty ;
    rdfs:label "has interaction" ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Brand :Antibiotic ) ] ;
    rdfs:range :Interaction ;
    owl:propertyChainAxiom ( :hasBrandName :hasPresentation :hasInteraction ) .

:hasReferenceTitle a owl:DatatypeProperty ;
    rdfs:label "has reference title" ;
    rdfs:domain :Reference ;
    rdfs:range xsd:string .

:hasSeverityType a owl:ObjectProperty ;
    rdfs:label "has severity type" ;
    rdfs:domain :Indication ;
    rdfs:range :Severity .

:hasSubstanceDescription a owl:DatatypeProperty ;
    rdfs:label "has substance description" ;
    rdfs:domain :Substance ;
    rdfs:range xsd:string .

:hasSymptoms a owl:DatatypeProperty ;
    rdfs:label "has symptoms" ;
    rdfs:domain :Indication ;
    rdfs:range xsd:string .

:hasWarningHeadline a owl:DatatypeProperty ;
    rdfs:label "has warning headline" ;
    rdfs:domain :Warning ;
    rdfs:range xsd:string .

:isBrandOf a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "is brand of" ;
    rdfs:domain :Brand ;
    rdfs:range :Antibiotic ;
    owl:inverseOf :hasBrandName .

:isInvolvedIn a owl:ObjectProperty ;
    rdfs:label "is involved in" ;
    rdfs:domain :Substance ;
    rdfs:range :Interaction ;
    owl:inverseOf :interactsWith .

:mild a :Pattern ;
    rdfs:label "mild" .

:publishedIn a owl:DatatypeProperty ;
    rdfs:label "published in" ;
    rdfs:domain :Reference ;
    rdfs:range xsd:integer .

:retrievedFrom a owl:DatatypeProperty ;
    rdfs:label "retrieved from" ;
    rdfs:domain :Reference ;
    rdfs:range xsd:string .

:sideEffectOf a owl:ObjectProperty ;
    rdfs:label "side effect of" ;
    rdfs:domain :SideEffect ;
    rdfs:range :Brand ;
    owl:inverseOf :hasSideEffect .

:treats a owl:ObjectProperty ;
    rdfs:label "treats" ;
    rdfs:domain :Brand ;
    rdfs:range :Indication .

:two_months_after_intake a :Pattern ;
    rdfs:label "two months after intake" .

:two_months_after_the_administration_of_antibacterial_agents_ a :Pattern ;
    rdfs:label "two months after the administration of antibacterial agents." .

:A010 a :PowderForInjection ;
    rdfs:label "Powder for Injection" ;
    :hasInteraction :ITN037,
        :ITN038,
        :ITN039,
        :ITN041 ;
    :hasSideEffect :SE100 ;
    :hasStorageRule :SP054,
        :SP056 ;
    :hasWarning :W071 ;
    :treats :I030,
        :I035,
        :I045,
        :I056 .

:AbilityToDriveOrOperateMachinery a owl:Class ;
    rdfs:label "Ability to Drive or Operate Machinery" ;
    rdfs:subClassOf :SideEffect .

:AbnormalDreaming a owl:Class ;
    rdfs:label "Abnormal Dreaming" ;
    rdfs:subClassOf :SideEffect .

:AbnormalGait a owl:Class ;
    rdfs:label "Abnormal Gait" ;
