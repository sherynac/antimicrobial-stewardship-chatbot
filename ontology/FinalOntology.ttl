:ITN040 a :Interaction ;
    rdfs:label "ITN040" ;
    :hasClinicalEffects "None specifically reported." ;
    :hasInteractionDescription "Cefotaxime sodium has been reported to be incompatible with alkaline solutions such as sodium bicarbonate. It is recommended that it should be administered separately from aminoglycosides." ;
    :hasManagementAdvice "Monitor for adverse effects if taken with these medications. Consult doctor or pharmacist." ;
    :hasReference :R014 ;
    :interactsWith :S019 .

:ITN041 a :Interaction ;
    rdfs:label "ITN041" ;
    :hasClinicalEffects "None specifically reported." ;
