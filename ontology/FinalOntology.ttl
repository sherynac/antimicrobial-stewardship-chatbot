:SP051 a :TherapeuticUseAndMonitoring ;
    rdfs:label "SP051" ;
    :hasReference :R039 ;
    :hasStewardshipDescription "Observation for sign of superinfection with non-susceptible organisms, including fungi." .

:SP052 a :AdministrationAndAdherence ;
    rdfs:label "SP052" ;
    :hasReference :R039 ;
    :hasStewardshipDescription "Azithromycin is not intended to treat suitable severe infections where fast high blood concentrations of antibiotic have to be achieved," .

:SP053 a :Storage ;
