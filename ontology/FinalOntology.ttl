:SP116 a :FoodAndTiming ;
    rdfs:label "SP116" ;
    :hasReference :R008 ;
    :hasStewardshipDescription "May be taken with or without food: May be taken during or between meals. Swallow whole, do not crush." .

:SP117 a :AdministrationAndAdherence ;
    rdfs:label "SP117" ;
    :hasReference :R008 ;
    :hasStewardshipDescription "Take at least 2 hr before or 2 hr after antacids containing Mg/Al, sucralfate, metal cations (eg, Fe), & multivit prep w/ Zn." .

:SP118 a :Storage ;
    rdfs:label "SP118" ;
    :hasReference :R009 ;
