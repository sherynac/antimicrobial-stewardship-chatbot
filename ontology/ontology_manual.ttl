# MANUAL - Classes, Concepts, Subclasses, Object Properties, Data Type Properties, Disjointness Properties, Closed World Enumerations, differentFrom Assertions for Key Instances, OWL Restrictions

##############################################################
# Classes
##############################################################

# Substance
:Substance rdf:type owl:Class .

# Substance concepts
:Drug rdf:type owl:Class ; 
    rdfs:subClassOf :Substance .
:Food rdf:type owl:Class ; 
    rdfs:subClassOf :Substance .
:Beverage rdf:type owl:Class ; 
    rdfs:subClassOf :Substance .

# Reference
:Reference rdf:type owl:Class .

# StewardshipPrinciple
:StewardshipPrinciple rdf:type owl:Class .

# StewardshipPrinciple subclasses
:TherapeuticUseAndMonitoring rdf:type owl:Class ; 
    rdfs:subClassOf :StewardshipPrinciple .
:AdministrationAndAdherence rdf:type owl:Class ; 
    rdfs:subClassOf :StewardshipPrinciple .
:FoodAndTiming rdf:type owl:Class ; 
    rdfs:subClassOf :StewardshipPrinciple .
:Storage rdf:type owl:Class ; 
    rdfs:subClassOf :StewardshipPrinciple .

# PresentationOrPacking
:PresentationOrPacking rdf:type owl:Class .

# PresentationOrPacking subclasses
:Capsule rdf:type owl:Class ;
    rdfs:subClassOf :PresentationOrPacking ;
    rdfs:label "Capsule" .
:Tablet rdf:type owl:Class ;
    rdfs:subClassOf :PresentationOrPacking ;
    rdfs:label "Tablet" .
:IVInjection rdf:type owl:Class ;
    rdfs:subClassOf :PresentationOrPacking ;
    rdfs:label "IV Injection" .
:Syrup rdf:type owl:Class ;
    rdfs:subClassOf :PresentationOrPacking ;
    rdfs:label "Syrup" .
:Suspension rdf:type owl:Class ;
    rdfs:subClassOf :PresentationOrPacking ;
    rdfs:label "Suspension" .
:Ointment rdf:type owl:Class ;
    rdfs:subClassOf :PresentationOrPacking ;
    rdfs:label "Ointment" .

# Brand
:Brand rdf:type owl:Class .

# Antibiotic
:Antibiotic rdf:type owl:Class .

# Interaction
:Interaction rdf:type owl:Class .

# Warning
:Warning rdf:type owl:Class .

# Warning concepts
:PregnancyAndLactation rdf:type owl:Class ; 
