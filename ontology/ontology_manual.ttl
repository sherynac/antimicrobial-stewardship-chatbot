# Severity
:Severity rdf:type owl:Class .

# Severity concepts
:NotSpecified rdf:type owl:Class ;
    rdfs:subClassOf :Severity ;
    rdfs:label "Not specified" .
:MildToModerate rdf:type owl:Class ;
    rdfs:subClassOf :Severity ;
    rdfs:label "Mild to moderate" .
:Mild rdf:type owl:Class ;
    rdfs:subClassOf :Severity ;
    rdfs:label "Mild" .
:MildToSevere rdf:type owl:Class ;
    rdfs:subClassOf :Severity ;
    rdfs:label "Mild to severe" .
:ModerateToSevere rdf:type owl:Class ;
    rdfs:subClassOf :Severity ;
    rdfs:label "Moderate to severe" .
:Severe rdf:type owl:Class ;
    rdfs:subClassOf :Severity ;
    rdfs:label "Severe" .
:InitialTherapy rdf:type owl:Class ;
    rdfs:subClassOf :Severity ;
    rdfs:label "Initial therapy" .

##############################################################
# Object Properties
###############################################################
:hasBrandName rdf:type owl:ObjectProperty ;
    rdfs:domain :Antibiotic ;
    rdfs:range :Brand ;
    rdfs:label "has brand name" ;
    owl:inverseOf :isBrandOf .

:isBrandOf rdf:type owl:ObjectProperty;
    rdf:type owl:FunctionalProperty;
    rdfs:domain :Brand;
    rdfs:range :Antibiotic;
    rdfs:label "is brand of" ;
    owl:inverseOf :hasBrandName .

:hasPresentation rdf:type owl:ObjectProperty ;
    rdfs:domain :Brand ;
    rdfs:range :PresentationOrPacking ;
    rdfs:label "has presentation" .

:isPresentationOf rdf:type owl:ObjectProperty ;
    owl:inverseOf :hasPresentation ;
    rdfs:domain :PresentationOrPacking ;
    rdfs:range :Brand .

:hasSeverityType rdf:type owl:ObjectProperty ;
    rdfs:domain :Indication ;
    rdfs:range :Severity ;
    rdfs:label "has severity type" .

:treats rdf:type owl:ObjectProperty ;
    rdfs:domain :Brand ;
    rdfs:range :Indication ;
    rdfs:label "treats" .

:hasWarning rdf:type owl:ObjectProperty ;
    rdfs:domain :Brand ;
    rdfs:range :Warning ;
    rdfs:label "has warning" .

:warningOf rdf:type owl:ObjectProperty ;
    owl:inverseOf :hasWarning ;
    rdfs:domain :Warning ;
    rdfs:range :Brand .

:hasSideEffect rdf:type owl:ObjectProperty ;
    rdfs:domain :Brand ;
    rdfs:range :SideEffect ;
    rdfs:label "has side effect" ;
    rdfs:inverseOf :sideEffectOf .

:sideEffectOf rdf:type owl:ObjectProperty ;
    rdfs:domain :SideEffect ;
    rdfs:range :Brand ;
    rdfs:label "side effect of";
    owl:inverseOf :hasSideEffect .

:hasInteraction rdf:type owl:ObjectProperty ;
    rdfs:domain :Brand ;
    rdfs:range :Interaction ;
    rdfs:label "has interaction" .

:interactsWith rdf:type owl:ObjectProperty ;
    rdfs:domain :Interaction ;
    rdfs:range :Substance ;
    rdfs:label "interacts with" ;
    owl:inverseOf :isInvolvedIn .

:isInvolvedIn rdf:type owl:ObjectProperty ;
    rdfs:domain :Substance ;
    rdfs:range :Interaction ;
    rdfs:label "is involved in" ;
    owl:inverseOf :interactsWith .

:managedAs rdf:type owl:ObjectProperty ;
    rdfs:domain :Brand ;
    rdfs:range :StewardshipPrinciple;
    rdfs:label "managed as" .

:hasTherapeuticUseAndMonitoringRule rdf:type owl:ObjectProperty ;
    rdfs:domain :Brand ;
    rdfs:range :TherapeuticUseAndMonitoring;
    rdfs:label "has therapeutic use & monitoring rule" .

:hasAdministrationAndAdherenceRule rdf:type owl:ObjectProperty ;
    rdfs:domain :Brand ;
    rdfs:range :AdministrationAndAdherence;
    rdfs:label "has administration & adherence rule" .

:hasFoodAndTimingRule rdf:type owl:ObjectProperty ;
    rdfs:domain :Brand ;
    rdfs:range :FoodAndTiming;
    rdfs:label "has food and timing rule" .

:hasStorageRule rdf:type owl:ObjectProperty ;
    rdfs:domain :Brand ;
    rdfs:range :Storage;
    rdfs:label "has storage rule" .

:hasReference rdf:type owl:ObjectProperty ;
    rdfs:domain [ owl:unionOf (
        :Antibiotic 
        :Brand 
        :Indication 
        :Warning 
        :SideEffect 
        :Interaction 
        :StewardshipPrinciple
        :Pattern
        :Substance
    ) ] ;
    rdfs:range :Reference ;
    rdfs:label "has reference" .


##############################################################
# Data Type Properties
###############################################################
:hasDrugClass rdf:type owl:DatatypeProperty ;
    rdfs:domain :Antibiotic ;
    rdfs:range xsd:string ;
    rdfs:label "has drug class" .

:hasDosage rdf:type owl:DatatypeProperty ;
    rdfs:domain :PresentationOrPacking ;
    rdfs:range xsd:string ;
    rdfs:label "has dosage" .

:hasUnitPrice rdf:type owl:DatatypeProperty ;
    rdfs:domain :PresentationOrPacking ;
    rdfs:range xsd:double ;
    rdfs:label "has unit price" .

:hasWarningHeadline rdf:type owl:DatatypeProperty ;
    rdfs:domain :Warning;
    rdfs:range xsd:string ;
    rdfs:label "has warning headline" .

:hasWarningText rdf:type owl:DatatypeProperty ;
    rdfs:domain :Warning;
    rdfs:range xsd:string ;
    rdfs:label "has warning text" .

:hasSideEffectDescription rdf:type owl:DatatypeProperty ;
    rdfs:domain :SideEffect ;
    rdfs:range xsd:string ;
    rdfs:label "is described as" .

:hasDurationOf rdf:type owl:DatatypeProperty ;
    rdfs:domain :SideEffect ;
    rdfs:range xsd:string ;
    rdfs:label "lasts for" .

:hasPattern rdf:type owl:DatatypeProperty ;
    rdfs:domain :SideEffect ;
    rdfs:range xsd:string ;
    rdfs:label "which is" .

:hasClinicalEffects rdf:type owl:DatatypeProperty ;
    rdfs:domain :Interaction ;
    rdfs:range xsd:string ;
    rdfs:label "has clinical effects" .

:hasManagementAdvice rdf:type owl:DatatypeProperty ;
    rdfs:domain :Interaction ;
    rdfs:range xsd:string;
    rdfs:label "has management advice" .

:hasInteractionDescription rdf:type owl:DatatypeProperty;
    rdfs:domain :Interaction ;
    rdfs:range xsd:string;
    rdfs:label "has interaction description" .
    
:hasSubstanceDescription rdf:type owl:DatatypeProperty ;
    rdfs:domain :Substance ;
    rdfs:range xsd:string ;
    rdfs:label "has substance description" .

:hasStewardshipDescription rdf:type owl:DatatypeProperty ;
    rdfs:domain :StewardshipPrinciple ;
    rdfs:range xsd:string ;
    rdfs:label "has stewardship description" .

:hasSymptoms rdf:type owl:DatatypeProperty ;
    rdfs:domain :Indication;
    rdfs:range xsd:string ;
    rdfs:label "has symptoms" .

:hasReferenceTitle rdf:type owl:DatatypeProperty;
    rdfs:domain :Reference;
    rdfs:range xsd:string;
    rdfs:label "has reference title" .

:hasAuthor rdf:type owl:DatatypeProperty;
    rdfs:domain :Reference;
    rdfs:range xsd:string;
    rdfs:label "has author" .

:publishedIn rdf:type owl:DatatypeProperty;
    rdfs:domain :Reference;
    rdfs:range xsd:integer;
    rdfs:label "published in".

:retrievedFrom rdf:type owl:DatatypeProperty;
    rdfs:domain :Reference;
    rdfs:range xsd:string;
    rdfs:label "retrieved from".

##############################################################
# Disjointness Properties
##############################################################

# Disjoint Substance types
:Drug rdf:type owl:Class ;
    owl:disjointWith :Food, :Beverage .

:Food rdf:type owl:Class ;
    owl:disjointWith :Beverage .

# Disjoint StewardshipPrinciple subclasses
:TherapeuticUseAndMonitoring owl:disjointWith :AdministrationAndAdherence, :FoodAndTiming, :Storage .
:AdministrationAndAdherence owl:disjointWith :FoodAndTiming, :Storage .
:FoodAndTiming owl:disjointWith :Storage .

# Disjoint PresentationOrPacking subclasses
:Capsule owl:disjointWith :Tablet, :IVInjection, :Syrup, :Suspension, :Ointment .
:Tablet owl:disjointWith :IVInjection, :Syrup, :Suspension, :Ointment .
:IVInjection owl:disjointWith :Syrup, :Suspension, :Ointment .
:Syrup owl:disjointWith :Suspension, :Ointment .
:Suspension owl:disjointWith :Ointment .

# Disjoint Warning subclasses
:PregnancyAndLactation owl:disjointWith :AgeRestriction, :PatientCondition, :Overdosage, :Contraindication .
:AgeRestriction owl:disjointWith :PatientCondition, :Overdosage, :Contraindication .
:PatientCondition owl:disjointWith :Overdosage, :Contraindication .
:Overdosage owl:disjointWith :Contraindication .

# Disjoint Indication subclasses
:UrinaryDisease owl:disjointWith :RespiratoryDisease .

# Disjoint Severity concepts
:NotSpecified owl:disjointWith :MildToModerate, :Mild, :MildToSevere, :ModerateToSevere, :Severe, :InitialTherapy .
:MildToModerate owl:disjointWith :Mild, :MildToSevere, :ModerateToSevere, :Severe, :InitialTherapy .
:Mild owl:disjointWith :MildToSevere, :ModerateToSevere, :Severe, :InitialTherapy .
:MildToSevere owl:disjointWith :ModerateToSevere, :Severe, :InitialTherapy .
:ModerateToSevere owl:disjointWith :Severe, :InitialTherapy .
:Severe owl:disjointWith :InitialTherapy .

# Disjoint top-level classes
:Substance owl:disjointWith :Reference, :StewardshipPrinciple, :PresentationOrPacking, :Brand, :Antibiotic, :Interaction, :Warning, :SideEffect, :Pattern, :Indication, :Severity .
:Reference owl:disjointWith :StewardshipPrinciple, :PresentationOrPacking, :Brand, :Antibiotic, :Interaction, :Warning, :SideEffect, :Pattern, :Indication, :Severity .
:StewardshipPrinciple owl:disjointWith :PresentationOrPacking, :Brand, :Antibiotic, :Interaction, :Warning, :SideEffect, :Pattern, :Indication, :Severity .
:PresentationOrPacking owl:disjointWith :Brand, :Antibiotic, :Interaction, :Warning, :SideEffect, :Pattern, :Indication, :Severity .
:Brand owl:disjointWith :Antibiotic, :Interaction, :Warning, :SideEffect, :Pattern, :Indication, :Severity .
:Antibiotic owl:disjointWith :Interaction, :Warning, :SideEffect, :Pattern, :Indication, :Severity .
:Interaction owl:disjointWith :Warning, :SideEffect, :Pattern, :Indication, :Severity .
:Warning owl:disjointWith :SideEffect, :Pattern, :Indication, :Severity .
:SideEffect owl:disjointWith :Pattern, :Indication, :Severity .
:Pattern owl:disjointWith :Indication, :Severity .
:Indication owl:disjointWith :Severity .

##############################################################
# Closed World Enumerations (oneOf)
##############################################################

# Severity as enumeration (closed set)
:Severity rdf:type owl:Class ;
    owl:equivalentClass [
        rdf:type owl:Class ;
        owl:oneOf ( :NotSpecified :MildToModerate :Mild :MildToSevere :ModerateToSevere :Severe :InitialTherapy )
    ] .

# PresentationOrPacking enumeration
:PresentationOrPacking rdf:type owl:Class ;
    owl:equivalentClass [
        rdf:type owl:Class ;
        owl:oneOf ( :Capsule :Tablet :IVInjection :Syrup :Suspension :Ointment )
    ] .

# Substance type enumeration
:Substance rdf:type owl:Class ;
    owl:equivalentClass [
        rdf:type owl:Class ;
        owl:oneOf ( :Drug :Food :Beverage )
    ] .

##############################################################
# differentFrom Assertions for Key Instances
##############################################################

# Stewardship principles are all different from each other
:TherapeuticUseAndMonitoring owl:differentFrom :AdministrationAndAdherence .
:TherapeuticUseAndMonitoring owl:differentFrom :FoodAndTiming .
:TherapeuticUseAndMonitoring owl:differentFrom :Storage .
:AdministrationAndAdherence owl:differentFrom :FoodAndTiming .
:AdministrationAndAdherence owl:differentFrom :Storage .
:FoodAndTiming owl:differentFrom :Storage .

# Presentation forms are all different
:Capsule owl:differentFrom :Tablet .
:Capsule owl:differentFrom :IVInjection .
:Capsule owl:differentFrom :Syrup .
:Capsule owl:differentFrom :Suspension .
:Capsule owl:differentFrom :Ointment .
:Tablet owl:differentFrom :IVInjection .
:Tablet owl:differentFrom :Syrup .
:Tablet owl:differentFrom :Suspension .
:Tablet owl:differentFrom :Ointment .
:IVInjection owl:differentFrom :Syrup .
:IVInjection owl:differentFrom :Suspension .
:IVInjection owl:differentFrom :Ointment .
:Syrup owl:differentFrom :Suspension .
:Syrup owl:differentFrom :Ointment .
:Suspension owl:differentFrom :Ointment .

# Severity levels are all different
:NotSpecified owl:differentFrom :MildToModerate .
:NotSpecified owl:differentFrom :Mild .
:NotSpecified owl:differentFrom :MildToSevere .
:NotSpecified owl:differentFrom :ModerateToSevere .
:NotSpecified owl:differentFrom :Severe .
:NotSpecified owl:differentFrom :InitialTherapy .
:MildToModerate owl:differentFrom :Mild .
:MildToModerate owl:differentFrom :MildToSevere .
:MildToModerate owl:differentFrom :ModerateToSevere .
:MildToModerate owl:differentFrom :Severe .
:MildToModerate owl:differentFrom :InitialTherapy .
:Mild owl:differentFrom :MildToSevere .
:Mild owl:differentFrom :ModerateToSevere .
:Mild owl:differentFrom :Severe .
:Mild owl:differentFrom :InitialTherapy .
:MildToSevere owl:differentFrom :ModerateToSevere .
:MildToSevere owl:differentFrom :Severe .
:MildToSevere owl:differentFrom :InitialTherapy .
:ModerateToSevere owl:differentFrom :Severe .
:ModerateToSevere owl:differentFrom :InitialTherapy .
:Severe owl:differentFrom :InitialTherapy .


##############################################################
# OWL Restrictions (Cardinality and Value Constraints)
##############################################################

# A Brand must have at least one presentation
:Brand rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :hasPresentation ;
    owl:minQualifiedCardinality 1 ;
    owl:onClass :PresentationOrPacking
] .

# A Brand must treat at least one indication
:Brand rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :treats ;
    owl:minQualifiedCardinality 1 ;
    owl:onClass :Indication
] .

# Every indication needs symptoms
:Indication rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :hasSymptoms ;
    owl:minCardinality 1
] .

# An Indication must have exactly one severity type
:Indication rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :hasSeverityType ;
    owl:cardinality 1
] .

# Every interaction needs substance
:Interaction rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :interactsWith ;
    owl:minQualifiedCardinality 1 ;
    owl:onClass :Substance
] .

# An Interaction must have clinical effects description
:Interaction rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :hasClinicalEffects ;
    owl:minCardinality 1
] .

# A PresentationOrPacking must have a dosage value
# :PresentationOrPacking rdfs:subClassOf [
#     rdf:type owl:Restriction ;
#     owl:onProperty :hasDosage ;
#     owl:minCardinality 1
# ] .

# A Warning must have a headline
:Warning rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :hasWarningHeadline ;
    owl:minCardinality 1
] .

# Reference must have a title
:Reference rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :hasReferenceTitle ;
    owl:minCardinality 1
] .

# Reference must have author
:Reference rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :hasAuthor ;
    owl:minCardinality 1
] .

# Reference must have publication year
:Reference rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :publishedIn ;
    owl:minCardinality 1
] .

# Reference must have a url
:Reference rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :retrievedFrom ;
    owl:minCardinality 1
] .

# A Substance must have a description
:Substance rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :hasSubstanceDescription ;
    owl:minCardinality 1
] .