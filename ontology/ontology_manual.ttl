# Pattern  
:Pattern rdf:type owl:Class .

# Indication  
:Indication rdf:type owl:Class .

# Disjointness Properties
:Indication owl:disjointWith :SideEffect .
:SideEffect owl:disjointWith :Indication .

# Indication concepts
:UrinaryDisease rdf:type owl:Class ;
    rdfs:subClassOf :Indication .
:RespiratoryDisease rdf:type owl:Class ;
    rdfs:subClassOf :Indication .

