:ITN270 :hasInteractionDescription "It has been suggested that trimethoprim may potentiate the effects of warfarin." .
:ITN270 :hasClinicalEffects "Not Specified" .
:ITN270 :hasManagementAdvice "Not Specified" .
:ITN270 :hasReference :R166 .
