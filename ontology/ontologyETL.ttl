:ITN049 :interactsWith :S018 .

:ITN050 :hasClinicalEffects "Dose adjustment of azithromycin is not recommended when administered in combination with nelfinavir." .
:ITN050 :hasInteractionDescription "Co-administration with a single oral dose of azithromycin resulted in increased azithromycin serum concetration." .
:ITN050 :hasReference :R038 .
:ITN050 :interactsWith :S037 .
:ITN050 :hasManagementAdvice "Close monitoring for known adverse effects of azithromycin, such as liver enzyme abnormalities and hearing impairment." .

