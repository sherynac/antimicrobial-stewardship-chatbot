:ITN004 :hasReference :R022 .

:ITN005 :interactsWith :S004 .
:ITN005 :hasManagementAdvice "Avoid using together with Fosfomycin if possible. If needed, monitor for treatment effectiveness." .
:ITN005 :hasClinicalEffects "Lower blood and urine levels of fosfomycin." .
:ITN005 :hasReference :R024 .
:ITN005 :hasInteractionDescription "Metoclopramide may lower the absorption of Fosfomycin Tromethamine by speeding up digestion." .

:ITN006 :hasClinicalEffects "No effect on drug levels or effectiveness." .
