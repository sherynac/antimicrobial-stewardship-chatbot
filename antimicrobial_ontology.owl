  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S081">
    <rdf:type rdf:resource="http://example.org/ontology/Substance"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S048">
    <rdf:type rdf:resource="http://example.org/ontology/Substance"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R270">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Bronchitis</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R250">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Joint Pain</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W095">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Contains aspartame (source of phenylalanine). Use with caution in patients with phenylketonuria.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN128">
    <rdf:type rdf:resource="http://example.org/ontology/Interaction"/>
    <ex:interactsWith rdf:resource="http://example.org/ontology/S102"/>
    <ex:hasReference rdf:resource="http://example.org/ontology/R011"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/I038">
    <rdf:type rdf:resource="http://example.org/ontology/Indication"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN215">
    <rdf:type rdf:resource="http://example.org/ontology/Interaction"/>
    <ex:interactsWith rdf:resource="http://example.org/ontology/S028"/>
    <ex:hasReference rdf:resource="http://example.org/ontology/R0133"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W122">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Dosed at 25-50 mg/kg body weight/day in divided doses every 8 or 12 hours.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W166">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Caution is advised in patients with severe renal insufficiency or impaired hepatic function. Fatal hepatic failure has been reported in some cases.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R081">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Pneumonia</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R229">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Tremor</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/I030">
    <rdf:type rdf:resource="http://example.org/ontology/Indication"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R069">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Agitation</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN158">
    <rdf:type rdf:resource="http://example.org/ontology/Interaction"/>
    <ex:interactsWith rdf:resource="http://example.org/ontology/S132"/>
    <ex:hasReference rdf:resource="http://example.org/ontology/R054"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W206">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Ciprofloxacin must not be administered to children and adolescents, since there is no experience on the drug's safety in these patient groups; On the basis of animal studies, it is not entirely improbable that the drug could cause damage to articular cartilage in the immature organism.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN132">
    <rdf:type rdf:resource="http://example.org/ontology/Interaction"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W007">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Safety and effectiveness in children under 12 years old have not been established.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN094">
    <rdf:type rdf:resource="http://example.org/ontology/Interaction"/>
    <ex:interactsWith rdf:resource="http://example.org/ontology/S068"/>
    <ex:hasReference rdf:resource="http://example.org/ontology/R035"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN022">
    <rdf:type rdf:resource="http://example.org/ontology/Interaction"/>
    <ex:interactsWith rdf:resource="http://example.org/ontology/S016"/>
    <ex:hasReference rdf:resource="http://example.org/ontology/R037"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN099">
    <rdf:type rdf:resource="http://example.org/ontology/Interaction"/>
    <ex:interactsWith rdf:resource="http://example.org/ontology/S073"/>
    <ex:hasReference rdf:resource="http://example.org/ontology/R016"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R024">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Fosfomycin Tromethamine Granules for Oral Solution</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S039">
    <rdf:type rdf:resource="http://example.org/ontology/Substance"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/I007">
    <rdf:type rdf:resource="http://example.org/ontology/Indication"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S123">
    <rdf:type rdf:resource="http://example.org/ontology/Substance"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W212">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>In the event of acute overdosage, reversible renal toxicity has been reported in some cases; Make sure to monitor renal (kidney) function and administer magnesium- or calcium-containing antacids which reduce absorption of ciprofloxacin.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S078">
    <rdf:type rdf:resource="http://example.org/ontology/Substance"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/Antibiotic">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/Indication">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R156">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Nitrofurantoin</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/I035">
    <rdf:type rdf:resource="http://example.org/ontology/Indication"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W188">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Due to possible increase in coagulation tests (PT/INR) and/or bleeding in patients treated with levofloxacin in combination with a vitamin K antagonist (e.g., warfarin), coagulation tests should be monitored when these drugs are given concomitantly.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W109">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Premature babies and newborn babies during the first eight weeks of life should
not be given sulfamethoxazole/trimethoprim, as sulfamethoxazole may interfere
with the serum albumin binding of bilirubin to produce kernicterus.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W278">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Sodium metabisulfite contains a sulfite that may cause allergic type reactions,
including anaphylactic symptoms and life threatening or less severe asthmatic
episode in certain susceptible persons.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R130">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Kidney Infection (Pyelonephritis)</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W078">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Despite the excretion of trimethoprim and sulphamethoxazole into breast milk, the administration of comazole to lactating women represents a negligible risk to the suckling infants. It also should be used with caution in nursing
mothers because it can pass the placenta and is excreted in breast milk and may cause kernicterus.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S140">
    <rdf:type rdf:resource="http://example.org/ontology/Substance"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S166">
    <rdf:type rdf:resource="http://example.org/ontology/Substance"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R094">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Disseminated Mycobacterium avium Complex Disease</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R076">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Diarrhea</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R184">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Henoch-Schönlein Purpura: A Case Report and Review of Literature</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W251">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Should not be used in babies under 1 month of age.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R220">
