    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Macrodantin</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W222">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Dose of ciprofloxacin should be reduced in the elderly as increased bioavailability and reduced renal clearance were seen probably due to absorption or first pass elimination</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W020">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Before receiving IVOZFO, notify the doctor if the patient have any of the following health conditions: heart problems, high blood pressure, hyperaldosteronism which is a condition where you have too much of a hormone called aldosterone, cirrhosis (scar tissue) of the liver, kidney problems, high levels of sodium in the blood, or fluid in your lungs. IVOZFO contains sodium that could make these conditions worse. </ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R283">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Anaphylaxis</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S129">
    <rdf:type rdf:resource="http://example.org/ontology/Substance"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R188">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Hemolytic Anemia</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN042">
    <rdf:type rdf:resource="http://example.org/ontology/Interaction"/>
    <ex:interactsWith rdf:resource="http://example.org/ontology/S022"/>
    <ex:hasReference rdf:resource="http://example.org/ontology/R039"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R073">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Lymphopenia</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W260">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Notify healthcare provider if a patient have current and past health conditions in any of the following: kidnet or liver problems, history of anemia, history of diabetes, electrolyte imbalance, history of low levels of vitamin B, or Glucose-6-phosphate dehydrogenase (G6PD) deficiency</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R261">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Acute Sinusitis</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R279">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Aplastic Anemia&#13;</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W133">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Overdosage of cephalosporins can cause cerebral irritation leading to convulsions or encephalopathy. Serum levels of cefuroxime can be reduced by hemodialysis and peritoneal dialysis.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN149">
