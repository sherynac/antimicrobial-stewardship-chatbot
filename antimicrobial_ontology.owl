  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W197">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Elderly patients and women may be more susceptible to drug-associated effects on the QT interval.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W242">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>As with other antibacterial drugs, long term or repeated use may result in overgrowth of non- susceptible organisms, including fungi.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R264">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Uncomplicated Urinary Tract Infections</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W210">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Ciprofloxacin is excreted in human milk; The amount of ciprofloxacin absorbed by the infant is unknown; Due to potential serious adverse reactions to infants nursing from mothers taking ciprofloxacin, a decision should be made whether to discontinue nursing or to discontinue the drug, depending on the importance of the drug to the mother.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W023">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
