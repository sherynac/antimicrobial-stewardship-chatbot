    <rdf:type rdf:resource="http://example.org/ontology/Substance"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W025">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Safety and effectiveness in children should be confirmed before use. Follow proper dosing guidelines.</ex:description>
  </rdf:Description>
