  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W244">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>It is not known whether cefixime is excreted in human milk. Consideration should be given to discontinuing breastfeeding temporarily during treatment with cefixime.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN275">
