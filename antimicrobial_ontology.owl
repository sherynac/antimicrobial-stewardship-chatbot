    <ex:title>Genital Ulcers</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W146">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Do not use in children aged 8 years and below because of the effect of tetracyclines in teeth (permanent discoloration and possibly enamel hypoplasia) and bone.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S069">
