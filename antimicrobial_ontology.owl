    <ex:title>Prothrombin deficiency</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W264">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>patients who have anuria, oliguria, or significant impairment of renal function (creatinine clearance under 60 mL per minute or clinically significant elevated serum creatinine) due to an increased risk of toxicity resulting from impaired excretion of the drug</ex:description>
  </rdf:Description>
