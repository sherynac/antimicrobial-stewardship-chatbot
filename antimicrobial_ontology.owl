  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W163">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Contraindicated for patients with known hypersensitivity to macrolides or history of drug-induced hepatic dysfunction. Also contraindicated with drugs like cisapride, simvastatin, or lovastatin.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN174">
