    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Overdose causes abdominal pain, vomiting, nausea, and diarrhea. Treat with prompt elimination of unabsorbed drug and supportive measures.</ex:description>
  </rdf:Description>
