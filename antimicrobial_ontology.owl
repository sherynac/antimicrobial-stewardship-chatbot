  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W136">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Dosed at 25-50 mg/kg/day in divided doses every 8 or 12 hours.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R053">
