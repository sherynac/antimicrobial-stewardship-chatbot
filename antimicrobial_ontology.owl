  <rdf:Description rdf:about="http://example.org/ontology/W165">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Indicated for adults and children 12 years and older. It is not recommended for children younger than 12 years; they should use the paediatric suspension instead.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W167">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Large amounts produce GI symptoms. A patient ingesting 8 grams showed altered mental status, paranoid behaviour, hypokalemia, and hypoxemia.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W186">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Since Levofloxacin is excreted mainly by the kidneys, the dose of Levofloxacin should be adjusted in patients with renal impairment.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R247">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
