  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W134">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Strictly prohibited for patients with a history of hypersensitivity to penicillins or any ingredient in the product.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R077">
