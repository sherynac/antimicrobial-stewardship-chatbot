    <ex:hasReference rdf:resource="http://example.org/ontology/R013"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W280">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Cotrimoxazole should not be given to patients with actual or possible folate
deficiency.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R296">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Psychosis</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W026">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>In patients with impaired renal function, the elimination half-life is increased proportionally to the degree of renal insufficiency. Patients with creatinine clearance values of 40 mL/min or less require dose adjustments</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S109">
    <rdf:type rdf:resource="http://example.org/ontology/Substance"/>
