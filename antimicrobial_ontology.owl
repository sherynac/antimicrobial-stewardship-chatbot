    <ex:interactsWith rdf:resource="http://example.org/ontology/S094"/>
    <ex:hasReference rdf:resource="http://example.org/ontology/R018"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W211">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Ciprofloxacin is excreted in human milk; The amount of ciprofloxacin absorbed by the infant is unknown; Due to potential serious adverse reactions to infants nursing from mothers taking ciprofloxacin, a decision should be made whether to discontinue nursing or to discontinue the drug, depending on the importance of the drug to the mother.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W277">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Taking more than the prescribed dose may increase the risk of side effects such as nausea, vomiting, or other harmful reactions. Immediate medical attention is needed in case of suspected overdose.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN185">
    <rdf:type rdf:resource="http://example.org/ontology/Interaction"/>
    <ex:interactsWith rdf:resource="http://example.org/ontology/S144"/>
    <ex:hasReference rdf:resource="http://example.org/ontology/R010"/>
  </rdf:Description>
