  <rdf:Description rdf:about="http://example.org/ontology/W173">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Photosensitivity manifested by an exaggerated sunburn has been observed in some individuals taking tetracyclines. Patients apt to be exposed to direct sunlight or ultraviolet light should be advised that this reaction can occur with tetracycline drugs, and treatment should be discontinued at the first evidence of skin erythema.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R195">
