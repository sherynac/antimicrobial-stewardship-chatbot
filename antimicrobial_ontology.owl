  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/I010">
    <rdf:type rdf:resource="http://example.org/ontology/Indication"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W178">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Although levofloxacin is more soluble than other quinolones, adequate hydration of patients receiving levofloxacin should be maintained to prevent the formation of highly concentrated urine.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W249">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Should not be used if kidneys are not workingas well as they should be. If there is a concern about the health of the kidneys, the healthcare provider may do tests to determine if the kidneys are working well enough to take this medicine.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S159">
    <rdf:type rdf:resource="http://example.org/ontology/Substance"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W029">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Prolonged cardiac repolarization and QT interval, imparting a risk of developing cardiac arrhythmia and torsades de pointes, have been seen in treatment with other macrolides. A similar effect with azithromycin cannot be completely ruled out in patients at increased risk for prolonged cardiac repolarization.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W258">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Macrobid should not be used in babies under 1 month old.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R189">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Thrombocytopenia (low platelet count)</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R224">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Hyperkalemia (High Potassium)</ex:title>
  </rdf:Description>
