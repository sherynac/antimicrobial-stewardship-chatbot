    <rdf:type rdf:resource="http://example.org/ontology/Indication"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R110">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Clinical Review of Oral and Maxillofacial Surgery</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R120">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Stevens-Johnson syndrome</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S005">
    <rdf:type rdf:resource="http://example.org/ontology/Substance"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W265">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Notify healthcare provider if patient developed liver problems before due to furadantin (nitrofurantoin oral suspension) intake</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/I054">
    <rdf:type rdf:resource="http://example.org/ontology/Indication"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W140">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Use with caution and consider dose reductions in severe renal or hepatic impairment. Consider a diagnosis of pseudomembranous colitis in patients who develop diarrhea.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R125">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Agitation</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R142">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Pseudomembranous colitis</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W045">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>May cause persistent or severe blood or watery diarrhea with or without fever and abdominal pain</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W204">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Elderly patients may be more susceptible to drug-associated effects on the QT interval. Therefore, precaution should be taken when using levofloxacin with concomitant drugs that can result in prolongation of the QT interval (e.g. class IA or class III antiarrhythmic) or in patients with risk factors for Torsades de pointes (e.g. known QT prolongation, uncorrected hypokalemia).</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R187">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Systemic Lupus Erythematosus</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN178">
    <rdf:type rdf:resource="http://example.org/ontology/Interaction"/>
    <ex:interactsWith rdf:resource="http://example.org/ontology/S101"/>
    <ex:hasReference rdf:resource="http://example.org/ontology/R013"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W191">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Levofloxacin should be administered with caution in the presence of renal insufficiency. Careful clinical observation and appropriate laboratory studies should be performed prior to and during therapy since elimination of levofloxacin may be reduced. In patients with impaired renal function (creatinine clearance&lt;50 mL/min), adjustment of dose regimen is necessary to avoid the accumulation of levofloxacin due to decreased clearance.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN183">
    <rdf:type rdf:resource="http://example.org/ontology/Interaction"/>
    <ex:interactsWith rdf:resource="http://example.org/ontology/S141"/>
    <ex:hasReference rdf:resource="http://example.org/ontology/R009"/>
  </rdf:Description>
