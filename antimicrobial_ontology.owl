  <rdf:Description rdf:about="http://example.org/ontology/W150">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Clostridium difficile associated diarrhea (CDAD) has been reported with use of nearly all antibacterial agents, including Doxycycline, and may range in severity from mild diarrhea to fatal colitis.</ex:description>
  </rdf:Description>
