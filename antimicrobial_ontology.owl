    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>pregnant patients at term (38 weeks to 42 weeks gestation), during labor and delivery, or when the onset of labor is imminent and in pediatric patients younger than 1 month of age because of the possibility of hemolytic anemia due to immature erythrocyte enzyme systems (glutathione instability)</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R091">
