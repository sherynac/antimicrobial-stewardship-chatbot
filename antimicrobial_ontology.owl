    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>People with G6PD deficiency are at risk for hemolytic anemia from furadantin exposure</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN136">
