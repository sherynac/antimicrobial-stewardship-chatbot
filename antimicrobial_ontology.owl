  <rdf:Description rdf:about="http://example.org/ontology/W218">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>In epileptics and in patients who have suffered from previous CNS disorders (e.g. lowered convulsion threshold, previous history of convulsion, reduced cerebral blood flow, altered brain structure or stroke), Ciprofloxacin should only be used where the benefits of treatment exceed the risks, since these patients are endangered because of possible central nervous side effects.</ex:description>
  </rdf:Description>
