    <ex:title>Hypoglycemia</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W027">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Due to limited data in subjects with Glomerular Filtration Rate &lt; 10 mL/min, caution should be exercised when taking azithrymycin for these patients</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN062">
