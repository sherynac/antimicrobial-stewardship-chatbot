    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Contraindicated for patients with known hypersensitivity to macrolides or history of cholestatic jaundice/hepatic dysfunction.</ex:description>
  </rdf:Description>
