    <rdf:type rdf:resource="http://example.org/ontology/Indication"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/I001">
    <rdf:type rdf:resource="http://example.org/ontology/Indication"/>
  </rdf:Description>
