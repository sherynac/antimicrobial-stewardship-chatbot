    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Azithromycin should be used with caution in patients with neurological and psychiartric disorders.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W119">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>May cause nausea, vomiting, diarrhea, crystalluria, and allergic manifestations. Symptomatic treatment is required for almost all patients. Problems are unlikely if adequate fluid intake and urinary output are maintained; however crystalluria and hemorrhagic cystitis are possible.</ex:description>
  </rdf:Description>
