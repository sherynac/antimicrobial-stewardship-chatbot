    <ex:title>Esophageal Ulcer</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W215">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Do not take ciprofloxacin if you are a child or an adolescent. Ciprofloxacin was reported to cause arthralgia and degenerative changes in joints that bear weight in young animals.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R106">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Terfenadine</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W154">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Use is not advised without carefully weighing benefits against risk, as adverse embryo-fetal development effects cannot be excluded. The safety of Clarithromycin for using breast-feeding of infants has not been established. Clarithromycin is excreted into human breast milk.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R138">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Sinus Infection (Sinusitis)</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN272">
    <rdf:type rdf:resource="http://example.org/ontology/Interaction"/>
    <ex:interactsWith rdf:resource="http://example.org/ontology/S191"/>
    <ex:hasReference rdf:resource="http://example.org/ontology/R166"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S070">
    <rdf:type rdf:resource="http://example.org/ontology/Substance"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W096">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>May contain sorbitol. Caution in patients with sugar intolerance.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R277">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Agranulocytosis</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R211">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Indigestion (Dyspepsia)</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN114">
    <rdf:type rdf:resource="http://example.org/ontology/Interaction"/>
    <ex:interactsWith rdf:resource="http://example.org/ontology/S088"/>
    <ex:hasReference rdf:resource="http://example.org/ontology/R018"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W145">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Category D. do not use tetracycline during pregnancy. Tetracyclines readily cross the placenta, are found in fetal tissues and can have toxic effects on the developing fetus (retardation of skeletal development). Evidence of embryotoxicity has also been noted in animals treated early in pregnancy.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W246">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Should not be given to Penicillin-allergic patients</ex:description>
  </rdf:Description>
