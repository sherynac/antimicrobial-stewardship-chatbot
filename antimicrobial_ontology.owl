  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W139">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Elderly patients are at higher risk for colchicine toxicity.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W240">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>The safety and efficacy of cefixime have not been established in patients with gastrointestinal malabsorption.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S117">
    <rdf:type rdf:resource="http://example.org/ontology/Substance"/>
  </rdf:Description>
