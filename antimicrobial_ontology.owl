    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Do not take with ergot derivatives</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W221">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Ciprofloxacin should be used with caution in patients with severe hepatic impairment where peak plasma concentration and serum half life may be increased.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R237">
