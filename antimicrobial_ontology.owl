    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>This drug is contraindicated in persons who have shown hypersensitivity to any of the tetracyclines.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R171">
