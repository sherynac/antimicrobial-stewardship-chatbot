  <rdf:Description rdf:about="http://example.org/ontology/W070">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>No adverse effects have been found on breast-fed infants whose mothers were receiving cefotaxime</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W034">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>The risk of QT prolongation may increase in patients with electrolyte abnormalities (such as hypokalemia and hypocalcemia), patients with conditions that have potential to cause electrolyte imbalance (such as renal impairment), or patients taking other drugs affecting electrolyte balance or QT prolongation. Avoid CONTEPO in patients with known QT prolongation or ventricular arrhythmias, including a history of torsade de pointes.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN021">
    <rdf:type rdf:resource="http://example.org/ontology/Interaction"/>
    <ex:interactsWith rdf:resource="http://example.org/ontology/S015"/>
    <ex:hasReference rdf:resource="http://example.org/ontology/R037"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R185">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Purpura</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R015">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Amoxil/Amoxil Forte</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W143">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Hypersensitivity to any of the tetracyclines.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/I021">
    <rdf:type rdf:resource="http://example.org/ontology/Indication"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/I056">
    <rdf:type rdf:resource="http://example.org/ontology/Indication"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W256">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Avoid Macrobid if your kidneys are not working well; poor kidney function can make the medicine less effective and increase side effects.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R242">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Pancreatitis</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S173">
    <rdf:type rdf:resource="http://example.org/ontology/Substance"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W225">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Should not be used if patient has a history of allergy or hypersensitivity to cephalosporins</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W055">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Do not exceed the recommended doses. In case of overdosage consult your physician immediately.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R127">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Triocef</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W108">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>It should not be given to patients with known hypersensitivity to trimethoprim or sulfonamides or with documented megaloblastic anaemia secondary to folate deficiency.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN050">
    <rdf:type rdf:resource="http://example.org/ontology/Interaction"/>
    <ex:interactsWith rdf:resource="http://example.org/ontology/S037"/>
    <ex:hasReference rdf:resource="http://example.org/ontology/R038"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W195">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Based upon data from ofloxacin, it can be presumed that levofloxacin will be excreted in human milk. Because of the potential for serious adverse reactions from levofloxacin in nursing infants, nursing should not be undertaken by mothers who must use levofloxacin.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/I050">
    <rdf:type rdf:resource="http://example.org/ontology/Indication"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R002">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Glossary of Terms: Antimicrobial Resistance</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R117">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Itchy skin (pruritus)</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W044">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Do not take this medication if allergic to fosfomycin or any ingredients of the medication.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W068">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Taking can cause rare serious allergic reactions (including angioneurotic oedema, anaphylaxis, which have been rarely fatal) and dermatologic reactions, such as acute generalised exanthematous pustulosis (AGEP), Stevens-Johnson syndrome, toxic epidermal necrolysis (rarely fatal), and drug reaction with eosinophilia and systemic symptoms (DRESS), have been reported. Some reactions have required prolonged observation and treatment. If any of these hypersensitivity reactions occur, discontinue azithromycin immediately and institute appropriate emergency therapy.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S133">
    <rdf:type rdf:resource="http://example.org/ontology/Substance"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN218">
    <rdf:type rdf:resource="http://example.org/ontology/Interaction"/>
    <ex:interactsWith rdf:resource="http://example.org/ontology/S158"/>
    <ex:hasReference rdf:resource="http://example.org/ontology/R0133"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S051">
    <rdf:type rdf:resource="http://example.org/ontology/Substance"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S061">
    <rdf:type rdf:resource="http://example.org/ontology/Substance"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W127">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Neonates and young infants have incompletely developed renal function, delaying drug elimination. Elderly patients should have doses selected with care due to likely decreased renal function</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/I012">
    <rdf:type rdf:resource="http://example.org/ontology/Indication"/>
  </rdf:Description>
