  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W263">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Children under 1 month should not take this drug.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W014">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Older adults may have reduced kidney, liver, or heart function. Use Fosfomycin Tromethamine carefully and follow dosing instructions.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN240">
    <rdf:type rdf:resource="http://example.org/ontology/Interaction"/>
