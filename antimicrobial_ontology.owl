  <rdf:Description rdf:about="http://example.org/ontology/R317">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>A diagnostic and therapeutic conflict with masked megaloblastosis</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W148">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>The use of drugs of the tetracycline class during tooth development (last half of pregnancy, infancy and childhood to the age of 8 years) may cause permanent discoloration of the teeth (yellow-gray-brown).</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W135">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>No evidence of fetal harm; distributed into breast milk.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN230">
    <rdf:type rdf:resource="http://example.org/ontology/Interaction"/>
    <ex:interactsWith rdf:resource="http://example.org/ontology/S008"/>
    <ex:hasReference rdf:resource="http://example.org/ontology/R0133"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W063">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Animal studies have shown reduced pregnancy rate upon the administration of azithromycin. The clinical relevance for humans is unknown.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN118">
    <rdf:type rdf:resource="http://example.org/ontology/Interaction"/>
    <ex:interactsWith rdf:resource="http://example.org/ontology/S092"/>
    <ex:hasReference rdf:resource="http://example.org/ontology/R018"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W190">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Caution should be taken when using fluoroquinolones, including levofloxacin, in patients with known risk factors for prolongation of the QT interval such as, for example: congenital long QT syndrome; concomitant use of drugs that are known to prolong the QT interval (e.g., Class IA and III antiarrhythmics, tricyclic antidepressants, macrolides); uncorrected electrolyte imbalance (e.g., hypokalemia, hypomagnesemia); elderly: cardiac disease (e.g.. heart failure, myocardial infarction, bradycardia).</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R290">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Hyponatremia</ex:title>
  </rdf:Description>
