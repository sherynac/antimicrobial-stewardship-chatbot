  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R058">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Abdominal Pain</ex:title>
  </rdf:Description>
