  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W126">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Safety not definitely established, but used for UTIs without evidence of fetal harm. Distributed into human milk and may lead to sensitization of the infant; use with caution when breastfeeding</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S180">
    <rdf:type rdf:resource="http://example.org/ontology/Substance"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W207">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Ciprofloxacin must not be administered to pregnant women or nursing mothers, since there is no experience on the drug's safety in these patient groups; On the basis of animal studies, it is not entirely improbable that the drug could cause damage to articular cartilage in the immature organism; Animal studies have also not yet yielded any evidence of teratogenic effects (malformations)</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W013">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>The safety and effectiveness of Fosfomycin Tromethamine in children under 12 years have not been established in adequate and well-controlled studies.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN059">
    <rdf:type rdf:resource="http://example.org/ontology/Interaction"/>
    <ex:interactsWith rdf:resource="http://example.org/ontology/S036"/>
    <ex:hasReference rdf:resource="http://example.org/ontology/R031"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S157">
    <rdf:type rdf:resource="http://example.org/ontology/Substance"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W004">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Clostridium difficile associated diarrhea (CDAD) has been reported with use of nearly all antibacterial agents, including MONUROL, and may range in severity from mild diarrhea to fatal colitis.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R126">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Hallucinations</ex:title>
  </rdf:Description>
