    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Safety and effectiveness of CONTEPO in patients less than 18 years of age has not been established.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R226">
