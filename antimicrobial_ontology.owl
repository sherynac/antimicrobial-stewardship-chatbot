    <ex:title>Cough</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W183">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Prescribing levofloxacin in the absence of a proven or strongly suspected bacterial infection or a prophylactic indication is unlikely to provide benefit to the patient and increases the risk of the development of drug-resistant bacteria.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN045">
    <rdf:type rdf:resource="http://example.org/ontology/Interaction"/>
    <ex:interactsWith rdf:resource="http://example.org/ontology/S033"/>
