  <rdf:Description rdf:about="http://example.org/ontology/W243">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Reproduction studies performed in mice and rats up to 400 times the human dose have not revealed evidence of harm to the fetus. There are no adequate and well-controlled studies in pregnant women, and the drug should be used during pregnancy only when clearly needed.</ex:description>
  </rdf:Description>
