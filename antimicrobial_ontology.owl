  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/I051">
    <rdf:type rdf:resource="http://example.org/ontology/Indication"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R007">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Monthly Index of Medical Specialties</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W098">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Use with caution in newborns due to risk of jaundice from sodium benzoate.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN147">
    <rdf:type rdf:resource="http://example.org/ontology/Interaction"/>
    <ex:interactsWith rdf:resource="http://example.org/ontology/S121"/>
