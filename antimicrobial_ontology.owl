  <rdf:Description rdf:about="http://example.org/ontology/W254">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Do not use if you are allergic to nitrofurantoin or any of its ingredients. May cause serious allergic reactions like swelling, rash, itching, trouble breathing, or dizziness. Seek medical help immediately if these occur.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S044">
    <rdf:type rdf:resource="http://example.org/ontology/Substance"/>
  </rdf:Description>
