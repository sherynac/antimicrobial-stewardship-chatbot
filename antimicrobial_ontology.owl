    <ex:interactsWith rdf:resource="http://example.org/ontology/S043"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN151">
    <rdf:type rdf:resource="http://example.org/ontology/Interaction"/>
    <ex:interactsWith rdf:resource="http://example.org/ontology/S125"/>
    <ex:hasReference rdf:resource="http://example.org/ontology/R020"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R090">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Epiglottitis</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W198">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Quinolones, including levofloxacin, cause arthropathy and osteochondrosis in juvenile animals of several species. Levofloxacin is indicated in pediatric patients ≥6 months old, for inhalational anthrax (post- exposure) and for the treatment of plague, including pneumonic and septicemic plague due to Yersinia pestis and prophylaxis for plague. The risk-benefit assessment indicates that administration of levofloxacin to pediatric patients is appropriate. Safety and effectiveness in pediatric patients &lt;6 months old have not been established.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R291">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Rhabdomyolysis</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W168">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Contraindicated for patients with hypersensitivity to macrolides, a history of QT prolongation, or those taking drugs like cisapride, pimozide, ergot alkaloids, ticagrelor, or ranolazine.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN146">
    <rdf:type rdf:resource="http://example.org/ontology/Interaction"/>
    <ex:interactsWith rdf:resource="http://example.org/ontology/S120"/>
    <ex:hasReference rdf:resource="http://example.org/ontology/R019"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W067">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Unknown if Azithromycin is excreted in breast milk. Caution should be taken when administered to a nursing woman.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R285">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Henoch-Schonlein purpura</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R172">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Enterocolitis</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R311">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Acute Generalized Exanthematous Pustulosis</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W125">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Hypersensitivity to penicillins and to any ingredient in the products. Patients with infectious mononucleosis due to possible development of rash during therapy.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/ITN216">
    <rdf:type rdf:resource="http://example.org/ontology/Interaction"/>
    <ex:interactsWith rdf:resource="http://example.org/ontology/S028"/>
    <ex:hasReference rdf:resource="http://example.org/ontology/R0133"/>
  </rdf:Description>
