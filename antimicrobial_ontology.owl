  <rdf:Description rdf:about="http://example.org/ontology/W227">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Hypersensitivity to penicillins.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S036">
    <rdf:type rdf:resource="http://example.org/ontology/Substance"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W269">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>This medicine should not be used in patients who are not producing urine (anuria) or producing very little urine (oliguria). Because the drug is removed through the urine, it will not work properly and may build up in the body, increasing the risk of side effects.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S063">
    <rdf:type rdf:resource="http://example.org/ontology/Substance"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R198">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Hyperpigmentation</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W160">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Tetracyclines are excreted in breast milk. A dosage of 2g/day for 3 days has achieved a milk plasma ratio of 0.6 to 0.8.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S182">
    <rdf:type rdf:resource="http://example.org/ontology/Substance"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W270">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Patients with hepatitis should not use this medicine.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/R174">
    <rdf:type rdf:resource="http://example.org/ontology/Reference"/>
    <ex:title>Maculopapular Rash</ex:title>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S141">
    <rdf:type rdf:resource="http://example.org/ontology/Substance"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W281">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>No adverse effects have been seen in breast-fed infants whose mothers were
taking cotrimoxazole, and the last available guidance from the American
Academy of Pediatrics considered that it was therefore usually compatible with
breast feeding.</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/S148">
