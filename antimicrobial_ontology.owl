  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/W130">
    <rdf:type rdf:resource="http://example.org/ontology/Warning"/>
    <ex:description>Prohibited for patients with a known hypersensitivity to penicillins or cephalosporins. Forbidden for patients with infectious mononucleosis due to the high risk of a maculopapular rash</ex:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology/A043">
    <rdf:type rdf:resource="http://example.org/ontology/Antibiotic"/>
    <ex:genericName>Cefixime</ex:genericName>
    <ex:brandName>Triocef</ex:brandName>
