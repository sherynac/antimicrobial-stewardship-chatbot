<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/ontology#"
     xml:base="http://example.org/ontology"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://example.org/sample-ontology"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/ontology#hasBrandName -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#hasBrandName">
        <rdfs:domain rdf:resource="http://example.org/ontology#Antibiotic"/>
        <rdfs:range rdf:resource="http://example.org/ontology#Brand"/>
        <rdfs:label>has brand name</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#hasDrugClass -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#hasDrugClass">
        <rdfs:domain rdf:resource="http://example.org/ontology#Antibiotic"/>
        <rdfs:range rdf:resource="http://example.org/ontology#DrugClass"/>
        <rdfs:label>has drug class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#hasInteraction -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#hasInteraction">
        <rdfs:domain rdf:resource="http://example.org/ontology#Brand"/>
        <rdfs:range rdf:resource="http://example.org/ontology#Interaction"/>
        <rdfs:label>has interaction</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#hasPresentation -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#hasPresentation">
        <rdfs:domain rdf:resource="http://example.org/ontology#Brand"/>
        <rdfs:range rdf:resource="http://example.org/ontology#Presentation_Packing"/>
        <rdfs:label>has presentation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#hasReference -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#hasReference">
        <rdfs:domain rdf:resource="http://example.org/ontology#Antibiotic"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Indication"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Interaction"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#MedicalTerm"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#SideEffect"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#StewardshipPrinciple"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Substance"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Warning"/>
        <rdfs:range rdf:resource="http://example.org/ontology#Reference"/>
        <rdfs:label>has reference</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#hasSideEffect -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#hasSideEffect">
        <rdfs:domain rdf:resource="http://example.org/ontology#Brand"/>
        <rdfs:range rdf:resource="http://example.org/ontology#SideEffect"/>
        <rdfs:label>has side effect</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#hasWarning -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#hasWarning">
        <rdfs:domain rdf:resource="http://example.org/ontology#Brand"/>
        <rdfs:range rdf:resource="http://example.org/ontology#Warning"/>
        <rdfs:label>has warning</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#interactsWith -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#interactsWith">
        <rdfs:domain rdf:resource="http://example.org/ontology#Interaction"/>
        <rdfs:range rdf:resource="http://example.org/ontology#Substance"/>
        <rdfs:label>interacts with</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#lastsFor -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#lastsFor">
        <rdfs:domain rdf:resource="http://example.org/ontology#SideEffect"/>
        <rdfs:range rdf:resource="http://example.org/ontology#Duration"/>
        <rdfs:label>lasts for</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#managedBy -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#managedBy">
        <rdfs:domain rdf:resource="http://example.org/ontology#Brand"/>
        <rdfs:range rdf:resource="http://example.org/ontology#StewardshipPrinciple"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#treats -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#treats">
        <rdfs:domain rdf:resource="http://example.org/ontology#Brand"/>
        <rdfs:range rdf:resource="http://example.org/ontology#Indication"/>
        <rdfs:label>treats</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#whichIs -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#whichIs">
        <rdfs:domain rdf:resource="http://example.org/ontology#SideEffect"/>
        <rdfs:range rdf:resource="http://example.org/ontology#Pattern"/>
        <rdfs:label>which is</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/ontology#hasAuthor -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasAuthor">
        <rdfs:domain rdf:resource="http://example.org/ontology#Reference"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>has author</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasClinicalEffects -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasClinicalEffects">
        <rdfs:domain rdf:resource="http://example.org/ontology#Interaction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>has clinical effects</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasInteractionDescription -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasInteractionDescription">
        <rdfs:domain rdf:resource="http://example.org/ontology#Interaction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>has interaction description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasManagementAdvice -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasManagementAdvice">
        <rdfs:domain rdf:resource="http://example.org/ontology#Interaction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>has management advice</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasReferenceTitle -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasReferenceTitle">
        <rdfs:domain rdf:resource="http://example.org/ontology#Reference"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>has reference title</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasSideEffectDescription -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasSideEffectDescription">
        <rdfs:domain rdf:resource="http://example.org/ontology#SideEffect"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>is described as</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasSideEffectName -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasSideEffectName">
        <rdfs:domain rdf:resource="http://example.org/ontology#SideEffect"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>has side effect name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasStewardshipDescription -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasStewardshipDescription">
        <rdfs:domain rdf:resource="http://example.org/ontology#StewardshipPrinciple"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>has stewardship description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasSubstanceDescription -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasSubstanceDescription">
        <rdfs:domain rdf:resource="http://example.org/ontology#Substance"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>has substance description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasSymptoms -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasSymptoms">
        <rdfs:domain rdf:resource="http://example.org/ontology#Indication"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>has symptoms</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasTermDefinition -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasTermDefinition">
        <rdfs:domain rdf:resource="http://example.org/ontology#MedicalTerm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>has term definition</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasWarningHeadline -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasWarningHeadline">
        <rdfs:domain rdf:resource="http://example.org/ontology#Warning"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>has warning headline</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasWarningText -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasWarningText">
        <rdfs:domain rdf:resource="http://example.org/ontology#Warning"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>has warning text</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#managedBy -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#managedBy"/>
    


    <!-- http://example.org/ontology#publishedIn -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#publishedIn">
        <rdfs:domain rdf:resource="http://example.org/ontology#Reference"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>published in</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#retrievedFrom -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#retrievedFrom">
        <rdfs:domain rdf:resource="http://example.org/ontology#Reference"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>retrieved from</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/ontology#Adherence -->

    <owl:Class rdf:about="http://example.org/ontology#Adherence">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#StewardshipPrinciple"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#AgeRestriction -->

    <owl:Class rdf:about="http://example.org/ontology#AgeRestriction">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#Warning"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#Antibiotic -->

    <owl:Class rdf:about="http://example.org/ontology#Antibiotic"/>
    


    <!-- http://example.org/ontology#Beverage -->

    <owl:Class rdf:about="http://example.org/ontology#Beverage">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#Substance"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#Brand -->

    <owl:Class rdf:about="http://example.org/ontology#Brand"/>
    


    <!-- http://example.org/ontology#Contraindication -->

    <owl:Class rdf:about="http://example.org/ontology#Contraindication">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#Warning"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#Drug -->

    <owl:Class rdf:about="http://example.org/ontology#Drug">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#Substance"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#DrugClass -->

    <owl:Class rdf:about="http://example.org/ontology#DrugClass"/>
    


    <!-- http://example.org/ontology#Duration -->

    <owl:Class rdf:about="http://example.org/ontology#Duration"/>
    


    <!-- http://example.org/ontology#Food -->

    <owl:Class rdf:about="http://example.org/ontology#Food">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#Substance"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#Indication -->

    <owl:Class rdf:about="http://example.org/ontology#Indication"/>
    


    <!-- http://example.org/ontology#Interaction -->

    <owl:Class rdf:about="http://example.org/ontology#Interaction"/>
    


    <!-- http://example.org/ontology#MedicalTerm -->

    <owl:Class rdf:about="http://example.org/ontology#MedicalTerm"/>
    


    <!-- http://example.org/ontology#MildRespiratoryDisease -->

    <owl:Class rdf:about="http://example.org/ontology#MildRespiratoryDisease">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#RespiratoryDisease"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#Monitoring -->

    <owl:Class rdf:about="http://example.org/ontology#Monitoring">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#StewardshipPrinciple"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#Overdosage -->

    <owl:Class rdf:about="http://example.org/ontology#Overdosage">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#Warning"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#PatientCondition -->

    <owl:Class rdf:about="http://example.org/ontology#PatientCondition">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#Warning"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#Pattern -->

    <owl:Class rdf:about="http://example.org/ontology#Pattern"/>
    


    <!-- http://example.org/ontology#PregnancyAndLactation -->

    <owl:Class rdf:about="http://example.org/ontology#PregnancyAndLactation">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#Warning"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#Presentation_Packing -->

    <owl:Class rdf:about="http://example.org/ontology#Presentation_Packing"/>
    


    <!-- http://example.org/ontology#Prevention -->

    <owl:Class rdf:about="http://example.org/ontology#Prevention">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#StewardshipPrinciple"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#ProperUse -->

    <owl:Class rdf:about="http://example.org/ontology#ProperUse">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#StewardshipPrinciple"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#Reference -->

    <owl:Class rdf:about="http://example.org/ontology#Reference"/>
    


    <!-- http://example.org/ontology#RespiratoryDisease -->

    <owl:Class rdf:about="http://example.org/ontology#RespiratoryDisease">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#Indication"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#SideEffect -->

    <owl:Class rdf:about="http://example.org/ontology#SideEffect"/>
    


    <!-- http://example.org/ontology#StewardshipPrinciple -->

    <owl:Class rdf:about="http://example.org/ontology#StewardshipPrinciple"/>
    


    <!-- http://example.org/ontology#Storage -->

    <owl:Class rdf:about="http://example.org/ontology#Storage">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#StewardshipPrinciple"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#Substance -->

    <owl:Class rdf:about="http://example.org/ontology#Substance"/>
    


    <!-- http://example.org/ontology#UrinaryDisease -->

    <owl:Class rdf:about="http://example.org/ontology#UrinaryDisease">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#Indication"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#Warning -->

    <owl:Class rdf:about="http://example.org/ontology#Warning"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/ontology#AntibioticResistance -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#AntibioticResistance">
        <rdf:type rdf:resource="http://example.org/ontology#MedicalTerm"/>
        <hasReference rdf:resource="http://example.org/ontology#R002"/>
        <hasTermDefinition>microorganisms such as bacteria, fungi, viruses and parasites change when exposed to antimicrobial drugs such as antibiotics (= antibacterials), antifungals, antivirals, antimalarials and anthelmintics. As a result, the medicines become ineffective.</hasTermDefinition>
    </owl:NamedIndividual>
    


    <!-- http://example.org/ontology#AntimicrobialStewardship -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#AntimicrobialStewardship">
        <rdf:type rdf:resource="http://example.org/ontology#MedicalTerm"/>
        <hasReference rdf:resource="http://example.org/ontology#R003"/>
        <hasTermDefinition>coordinated interventions designed to promote, improve, monitor, and evaluate the judicious use of antimicrobials so as to preserve their future effectiveness and to promote and protect human and animal health. </hasTermDefinition>
    </owl:NamedIndividual>
    


    <!-- http://example.org/ontology#AtypicalPneumonia -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#AtypicalPneumonia">
        <rdf:type rdf:resource="http://example.org/ontology#MildRespiratoryDisease"/>
        <hasSymptoms>Sore throat, extreme tiredness, chest pain, low-grade fever, mild chills, cough, sneezing, headache</hasSymptoms>
    </owl:NamedIndividual>
    


    <!-- http://example.org/ontology#Beer -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#Beer">
        <rdf:type rdf:resource="http://example.org/ontology#Beverage"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/ontology#Capsule -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#Capsule">
        <rdf:type rdf:resource="http://example.org/ontology#Presentation_Packing"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/ontology#Ceimetidine -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#Ceimetidine">
        <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/ontology#Common -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#Common">
        <rdf:type rdf:resource="http://example.org/ontology#Pattern"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/ontology#DairyProducts -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#DairyProducts">
        <rdf:type rdf:resource="http://example.org/ontology#Food"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/ontology#Doxin -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#Doxin">
        <rdf:type rdf:resource="http://example.org/ontology#Brand"/>
        <hasInteraction rdf:resource="http://example.org/ontology#ITN121"/>
        <hasInteraction rdf:resource="http://example.org/ontology#ITN122"/>
        <hasPresentation rdf:resource="http://example.org/ontology#Capsule"/>
        <hasReference rdf:resource="http://example.org/ontology#R011"/>
        <hasSideEffect rdf:resource="http://example.org/ontology#SE310"/>
        <hasSideEffect rdf:resource="http://example.org/ontology#SE312"/>
        <hasSideEffect rdf:resource="http://example.org/ontology#SE313"/>
        <hasWarning rdf:resource="http://example.org/ontology#W143"/>
        <hasWarning rdf:resource="http://example.org/ontology#W145"/>
        <hasWarning rdf:resource="http://example.org/ontology#W146"/>
        <managedBy rdf:resource="http://example.org/ontology#SP000"/>
        <managedBy rdf:resource="http://example.org/ontology#SP001"/>
        <managedBy rdf:resource="http://example.org/ontology#SP082"/>
        <managedBy rdf:resource="http://example.org/ontology#SP111"/>
        <treats rdf:resource="http://example.org/ontology#AtypicalPneumonia"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/ontology#Doxyclen -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#Doxyclen">
        <rdf:type rdf:resource="http://example.org/ontology#Brand"/>
        <hasInteraction rdf:resource="http://example.org/ontology#ITN165"/>
        <hasPresentation rdf:resource="http://example.org/ontology#Capsule"/>
        <hasReference rdf:resource="http://example.org/ontology#R012"/>
        <hasSideEffect rdf:resource="http://example.org/ontology#SE338"/>
        <hasWarning rdf:resource="http://example.org/ontology#W151"/>
        <hasWarning rdf:resource="http://example.org/ontology#W172"/>
        <managedBy rdf:resource="http://example.org/ontology#SP112"/>
        <managedBy rdf:resource="http://example.org/ontology#SP113"/>
        <treats rdf:resource="http://example.org/ontology#AtypicalPneumonia"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/ontology#Doxycycline -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#Doxycycline">
        <rdf:type rdf:resource="http://example.org/ontology#Antibiotic"/>
        <hasBrandName rdf:resource="http://example.org/ontology#Doxin"/>
        <hasBrandName rdf:resource="http://example.org/ontology#Doxyclen"/>
        <hasBrandName rdf:resource="http://example.org/ontology#Dynadoxy"/>
        <hasDrugClass rdf:resource="http://example.org/ontology#Tetracyclines"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/ontology#Dynadoxy -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#Dynadoxy">
        <rdf:type rdf:resource="http://example.org/ontology#Brand"/>
        <hasInteraction rdf:resource="http://example.org/ontology#ITN174"/>
        <hasPresentation rdf:resource="http://example.org/ontology#Capsule"/>
        <hasReference rdf:resource="http://example.org/ontology#R013"/>
        <hasSideEffect rdf:resource="http://example.org/ontology#SE371"/>
        <hasWarning rdf:resource="http://example.org/ontology#W175"/>
        <treats rdf:resource="http://example.org/ontology#SinusInfection"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/ontology#ITN121 -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#ITN121">
        <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
        <interactsWith rdf:resource="http://example.org/ontology#anticoagulant"/>
        <hasClinicalEffects>tetracyclines depress plasma prothrombin activity</hasClinicalEffects>
        <hasInteractionDescription>Because tetracyclines depress plasma prothrombin activity, patients who are on anticoagulant therapy may require reduction of their anticoagulant dosage.</hasInteractionDescription>
        <hasManagementAdvice>reduction of anticoagulant dosage</hasManagementAdvice>
    </owl:NamedIndividual>
    


    <!-- http://example.org/ontology#ITN122 -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#ITN122">
        <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
        <interactsWith rdf:resource="http://example.org/ontology#penicillin"/>
        <hasClinicalEffects>bacteriostatic drugs interfere with the bactericidal action of penicillin</hasClinicalEffects>
        <hasInteractionDescription>Since bacteriostatic drugs interfere with the bactericidal action of penicillin, it is advisable to avoid giving tetracyclines in conjuction with penicillin</hasInteractionDescription>
        <hasManagementAdvice>avoid giving tetracyclines in conjuction with penicillin</hasManagementAdvice>
    </owl:NamedIndividual>
    


