    <!-- http://example.org/ontology#SP001 -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#SP001">
        <rdf:type rdf:resource="http://example.org/ontology#Adherence"/>
        <hasStewardshipDescription>Take at least 2 hr before or 2 hr after antacids containing Mg/Al, sucralfate, metal cations (eg, Fe), &amp; multivit prep w/ Zn.</hasStewardshipDescription>
    </owl:NamedIndividual>
    


    <!-- http://example.org/ontology#SP082 -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#SP082">
        <rdf:type rdf:resource="http://example.org/ontology#Monitoring"/>
        <hasStewardshipDescription>Maintain adequate fluid intake and urinary output to reduce the possibility of crystalluria. Periodic assessment of renal, hepatic, and hematopoietic functions is recommended during prolonged therapy.</hasStewardshipDescription>
    </owl:NamedIndividual>
    


