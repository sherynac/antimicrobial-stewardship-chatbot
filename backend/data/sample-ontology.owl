  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#anticoagulant">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <hasSubstanceDescription>Anticoagulant therapy</hasSubstanceDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W175">
    <rdf:type rdf:resource="http://example.org/ontology#Overdosage"/>
    <hasWarningHeadline>Overdosage Treatment Guidance</hasWarningHeadline>
    <hasWarningText>In case of overdosage, discontinue medication. Treat symptomatically and institute supportive measures. Dialysis does not alter serum half-life and thus would not be of benefit in treating cases of overdosage.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP111">
    <rdf:type rdf:resource="http://example.org/ontology#Storage"/>
    <hasStewardshipDescription>Store at temperatures not exceeding 30°C</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP082">
    <rdf:type rdf:resource="http://example.org/ontology#Monitoring"/>
    <hasStewardshipDescription>Maintain adequate fluid intake and urinary output to reduce the possibility of crystalluria. Periodic assessment of renal, hepatic, and hematopoietic functions is recommended during prolonged therapy.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Capsule">
    <rdf:type rdf:resource="http://example.org/ontology#Presentation_Packing"/>
    <rdfs:label>Capsule</rdfs:label>
  </rdf:Description>
