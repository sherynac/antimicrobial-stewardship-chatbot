  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W146">
    <rdf:type rdf:resource="http://example.org/ontology#AgeRestriction"/>
    <hasWarningHeadline>Pediatric Use</hasWarningHeadline>
    <hasWarningText>The use of drugs of the tetracycline class during tooth development (last half of pregnancy, infancy and childhood to the age of 8 years) may cause permanent discoloration of the teeth (yellow-gray-brown).</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ITN122">
    <rdf:type rdf:resource="http://example.org/ontology#Interaction"/>
    <interactsWith rdf:resource="http://example.org/ontology#penicillin"/>
    <hasInteractionDescription>Since bacteriostatic drugs interfere with the bactericidal action of penicillin, it is advisable to avoid giving tetracyclines in conjuction with penicillin</hasInteractionDescription>
    <hasClinicalEffects>bacteriostatic drugs interfere with the bactericidal action of penicillin</hasClinicalEffects>
    <hasManagementAdvice>avoid giving tetracyclines in conjuction with penicillin</hasManagementAdvice>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Tetracyclines">
    <rdf:type rdf:resource="http://example.org/ontology#DrugClass"/>
    <rdfs:label>Tetracyclines</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#W143">
    <rdf:type rdf:resource="http://example.org/ontology#Contraindication"/>
    <hasWarningHeadline>Hypersensitivity</hasWarningHeadline>
    <hasWarningText>Hypersensitivity to any of the tetracyclines.</hasWarningText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Presentation_Packing">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SP001">
    <rdf:type rdf:resource="http://example.org/ontology#Adherence"/>
    <hasStewardshipDescription>Take at least 2 hr before or 2 hr after antacids containing Mg/Al, sucralfate, metal cations (eg, Fe), &amp; multivit prep w/ Zn.</hasStewardshipDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SE313">
    <rdf:type rdf:resource="http://example.org/ontology#SideEffect"/>
    <hasSideEffectName>Vomiting</hasSideEffectName>
    <hasSideEffectDescription>forceful ejection of some or all of the contents of the stomach through the mouth</hasSideEffectDescription>
    <whichIs rdf:resource="http://example.org/ontology#Common"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasInteraction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/ontology#Brand"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Interaction"/>
