<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns="http://example.org/ontology#"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://example.org/reasoning-sample">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n8151bb09e5e34cb0914c793b5219e1fab1">
    <rdf:first rdf:resource="http://example.org/ontology#belongsToClass"/>
    <rdf:rest rdf:nodeID="n8151bb09e5e34cb0914c793b5219e1fab2"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasSideEffect">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:range rdf:resource="http://example.org/ontology#SideEffect"/>
    <owl:propertyChainAxiom rdf:nodeID="n8151bb09e5e34cb0914c793b5219e1fab1"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n8151bb09e5e34cb0914c793b5219e1fab2">
    <rdf:first rdf:resource="http://example.org/ontology#hasSideEffect"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Drug">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Diarrhea">
    <rdf:type rdf:resource="http://example.org/ontology#SideEffect"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Tetracyclines">
    <rdf:type rdf:resource="http://example.org/ontology#DrugClass"/>
    <hasSideEffect rdf:resource="http://example.org/ontology#Diarrhea"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Doxycycline">
    <rdf:type rdf:resource="http://example.org/ontology#Drug"/>
    <belongsToClass rdf:resource="http://example.org/ontology#Tetracyclines"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#belongsToClass">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/ontology#Drug"/>
    <rdfs:range rdf:resource="http://example.org/ontology#DrugClass"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#SideEffect">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#DrugClass">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
</rdf:RDF>
