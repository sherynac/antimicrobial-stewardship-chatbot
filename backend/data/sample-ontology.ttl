@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/ontology#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/sample-ontology> rdf:type owl:Ontology .

###############################################################
# Classes
###############################################################

# Reference
:Reference rdf:type owl:Class .

# Antibiotic
:Antibiotic rdf:type owl:Class .
:Brand rdf:type owl:Class .

# Presentation
:PresentationPacking rdf:type owl:Class .
:Capsule rdf:type owl:Class ;
    rdfs:subClassOf :PresentationPacking .
:FilmCoatedTablet rdf:type owl:Class ;
    rdfs:subClassOf :PresentationPacking .
:IVInfusion rdf:type owl:Class ;
    rdfs:subClassOf :PresentationPacking .

# Indication
:Indication rdf:type owl:Class .
:RespiratoryDisease rdf:type owl:Class;
    rdfs:subClassOf :Indication .
:UrinaryDisease rdf:type owl:Class ;
    rdfs:subClassOf :Indication .
:UrinaryTractInfection rdf:type owl:Class;
    rdfs:subClassOf :UrinaryDisease .
:AtypicalPneumonia rdf:type owl:Class;
    rdfs:subClassOf :RespiratoryDisease .
:SinusInfection rdf:type owl:Class;
    rdfs:subClassOf :RespiratoryDisease .
:GenitourinaryTractInfection rdf:type owl:Class;
    rdfs:subClassOf :UrinaryDisease .

# Severity
:Severity rdf:type owl:Class .

# Warning
:Warning rdf:type owl:Class .
:PregnancyAndLactation rdf:type owl:Class ; rdfs:subClassOf :Warning .
:AgeRestriction rdf:type owl:Class ; rdfs:subClassOf :Warning .
:PatientCondition rdf:type owl:Class ; rdfs:subClassOf :Warning .
:Overdosage rdf:type owl:Class ; rdfs:subClassOf :Warning .
:Contraindication rdf:type owl:Class ; rdfs:subClassOf :Warning .

# Side Effect
:SideEffect rdf:type owl:Class .
:Diarrhea rdf:type owl:Class;
    rdfs:subClassOf :SideEffect.
:Nausea rdf:type owl:Class;
    rdfs:subClassOf :SideEffect .
:Vomiting rdf:type owl:Class;
    rdfs:subClassOf :SideEffect.
:Headache rdf:type owl:Class;
    rdfs:subClassOf :SideEffect .
:Pattern rdf:type owl:Class .

# StewardshipPrinciple
:StewardshipPrinciple rdf:type owl:Class .
:ProperUse rdf:type owl:Class ; rdfs:subClassOf :StewardshipPrinciple .
:Adherence rdf:type owl:Class ; rdfs:subClassOf :StewardshipPrinciple .
:Storage rdf:type owl:Class ; rdfs:subClassOf :StewardshipPrinciple .
:Monitoring rdf:type owl:Class ; rdfs:subClassOf :StewardshipPrinciple .
:Prevention rdf:type owl:Class ; rdfs:subClassOf :StewardshipPrinciple .

# Interaction
:Interaction rdf:type owl:Class .
:Substance rdf:type owl:Class .
:Drug rdf:type owl:Class ; rdfs:subClassOf :Substance .
:Food rdf:type owl:Class ; rdfs:subClassOf :Substance .
:Beverage rdf:type owl:Class ; rdfs:subClassOf :Substance .

##############################################################
# Validation and Disjointness Properties
###############################################################

:Antibiotic owl:disjointWith :Brand .
:Brand owl:disjointWith :Indication .
:Brand owl:disjointWith :Warning .
:Brand owl:disjointWith :SideEffect .
:Indication owl:disjointWith :Warning .
:SideEffect owl:disjointWith :Indication .
:Interaction owl:disjointWith :Substance .
:Drug owl:disjointWith :Food, :Beverage .
:Food owl:disjointWith :Beverage .

# Validation rules (every brand needs a presentation)
:Brand rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :hasPresentation ;
    owl:minQualifiedCardinality 1 ;
    owl:onClass :PresentationPacking
] .

# Every indication needs symptoms
:Indication rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :hasSymptoms ;
    owl:minCardinality 1
] .

# Every interaction needs substance
:Interaction rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :interactsWith ;
    owl:minQualifiedCardinality 1 ;
    owl:onClass :Substance
] .

# Severity values are distinct
:Mild owl:differentFrom :Severe .
:Mild owl:differentFrom :NotSpecified .
:Severe owl:differentFrom :NotSpecified .
:Severity owl:oneOf ( :Mild :Severe :NotSpecified ) .

# Pattern values are distinct
:Common owl:differentFrom :Infrequent, :FrequencyNotReported .
:Infrequent owl:differentFrom :FrequencyNotReported .
:Pattern owl:oneOf ( :Common :Infrequent :FrequencyNotReported ) .

##############################################################
# Object Properties
###############################################################
:hasBrandName rdf:type owl:ObjectProperty ;
    rdfs:domain :Antibiotic ;
    rdfs:range :Brand ;
    rdfs:label "has brand name" ;
    owl:inverseOf :isBrandOf .

:isBrandOf rdf:type owl:ObjectProperty;
    rdf:type owl:FunctionalProperty;
    rdfs:domain :Brand;
    rdfs:range :Antibiotic;
    rdfs:label "is brand of" ;
    owl:inverseOf :hasBrandName .

:hasPresentation rdf:type owl:ObjectProperty ;
    rdfs:domain :Brand ;
    rdfs:range :PresentationPacking ;
    rdfs:label "has presentation" .

:isPresentationOf rdf:type owl:ObjectProperty ;
    owl:inverseOf :hasPresentation ;
    rdfs:domain :PresentationPacking ;
    rdfs:range :Brand .

:hasSeverity rdf:type owl:ObjectProperty ;
    rdfs:domain :Indication ;
    rdfs:range :Severity ;
    rdfs:label "has severity" .

:treats rdf:type owl:ObjectProperty ;
    rdfs:domain :Brand ;
    rdfs:range :Indication ;
    rdfs:label "treats" .

:hasWarning rdf:type owl:ObjectProperty ;
    rdfs:domain :Brand ;
    rdfs:range :Warning ;
    rdfs:label "has warning" .

:warningOf rdf:type owl:ObjectProperty ;
    owl:inverseOf :hasWarning ;
    rdfs:domain :Warning ;
    rdfs:range :Brand .

:hasSideEffect rdf:type owl:ObjectProperty ;
    rdfs:domain :Brand ;
    rdfs:range :SideEffect ;
    rdfs:label "has side effect" ;
    rdfs:inverseOf :sideEffectOf .

:sideEffectOf rdf:type owl:ObjectProperty ;
    rdfs:domain :SideEffect ;
    rdfs:range :Brand ;
    rdfs:label "side effect of";
    owl:inverseOf :hasSideEffect .

:whichIs rdf:type owl:ObjectProperty ;
    rdfs:domain :SideEffect ;
    rdfs:range :Pattern ;
    rdfs:label "which is" .

:hasInteraction rdf:type owl:ObjectProperty ;
    rdfs:domain :Brand ;
    rdfs:range :Interaction ;
    rdfs:label "has interaction" .

:interactsWith rdf:type owl:ObjectProperty ;
    rdfs:domain :Interaction ;
    rdfs:range :Substance ;
    rdfs:label "interacts with" .

:isInvolvedIn rdf:type owl:ObjectProperty ;
    rdfs:domain :Substance ;
    rdfs:range :Interaction ;
    owl:inverseOf :interactsWith ;
    rdfs:label "is involved in".

:managedBy rdf:type owl:ObjectProperty ;
    rdfs:domain :Brand ;
    rdfs:range :StewardshipPrinciple;
    rdfs:label "managed by" .

:hasStorageRule rdf:type owl:ObjectProperty ;
    rdfs:domain :Brand ;
    rdfs:range :StewardshipPrinciple;
    rdfs:label "has storage rule" .

:hasReference rdf:type owl:ObjectProperty ;
    rdfs:domain [ owl:unionOf (
        :Antibiotic 
        :Brand 
        :Indication 
        :Warning 
        :SideEffect 
        :Interaction 
        :StewardshipPrinciple
        :Pattern
        :Substance
    ) ] ;
    rdfs:range :Reference ;
    rdfs:label "has reference" .

##############################################################
# Data Type Properties
###############################################################
:hasDrugClass rdf:type owl:DatatypeProperty ;
    rdfs:domain :Antibiotic ;
    rdfs:range xsd:string ;
    rdfs:label "has drug class" .

:hasDosage rdf:type owl:DatatypeProperty ;
    rdfs:domain :PresentationPacking ;
    rdfs:range xsd:string ;
    rdfs:label "has dosage" .

:hasUnitPrice rdf:type owl:DatatypeProperty ;
    rdfs:domain :PresentationPacking ;
    rdfs:range xsd:double ;
    rdfs:label "has unit price" .

:hasSymptoms rdf:type owl:DatatypeProperty ;
    rdfs:domain :Indication;
    rdfs:range xsd:string ;
    rdfs:label "has symptoms" .

:hasWarningHeadline rdf:type owl:DatatypeProperty ;
    rdfs:domain :Warning;
    rdfs:range xsd:string ;
    rdfs:label "has warning headline" .

:hasWarningText rdf:type owl:DatatypeProperty ;
    rdfs:domain :Warning;
    rdfs:range xsd:string ;
    rdfs:label "has warning text" .

:hasSideEffectDescription rdf:type owl:DatatypeProperty ;
    rdfs:domain :SideEffect ;
    rdfs:range xsd:string ;
    rdfs:label "is described as" .

:lastsFor rdf:type owl:DatatypeProperty ;
    rdfs:domain :SideEffect ;
    rdfs:range xsd:string ;
    rdfs:label "lasts for" .

:hasClinicalEffects rdf:type owl:DatatypeProperty ;
    rdfs:domain :Interaction ;
    rdfs:range xsd:string ;
    rdfs:label "has clinical effects" .

:hasManagementAdvice rdf:type owl:DatatypeProperty ;
    rdfs:domain :Interaction ;
    rdfs:range xsd:string;
    rdfs:label "has management advice" .

:hasInteractionDescription rdf:type owl:DatatypeProperty;
    rdfs:domain :Interaction ;
    rdfs:range xsd:string;
    rdfs:label "has interaction description" .
    
:hasSubstanceDescription rdf:type owl:DatatypeProperty ;
    rdfs:domain :Substance ;
    rdfs:range xsd:string ;
    rdfs:label "has substance description" .

:hasStewardshipDescription rdf:type owl:DatatypeProperty ;
    rdfs:domain :StewardshipPrinciple ;
    rdfs:range xsd:string ;
    rdfs:label "has stewardship description" .

:hasReferenceTitle rdf:type owl:DatatypeProperty;
    rdfs:domain :Reference;
    rdfs:range xsd:string;
    rdfs:label "has reference title" .

:hasAuthor rdf:type owl:DatatypeProperty;
    rdfs:domain :Reference;
    rdfs:range xsd:string;
    rdfs:label "has author" .

:publishedIn rdf:type owl:DatatypeProperty;
    rdfs:domain :Reference;
    rdfs:range xsd:integer;
    rdfs:label "published in".

:retrievedFrom rdf:type owl:DatatypeProperty;
    rdfs:domain :Reference;
    rdfs:range xsd:string;
    rdfs:label "retrieved from".

