:ITN001 :hasInteractionDescription "Because tetracyclines depress plasma prothrombin activity, patients who are on anticoagulant therapy may require reduction of their anticoagulant dosage." .
:ITN001 :hasReference :R001 .
:ITN001 :interactsWith :Anticoagulants .

:ITN002 :interactsWith :Anticoagulants .
