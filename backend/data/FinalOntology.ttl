:SE591 :hasReference :R022 .
:SE591 :hasReference :R277 .

:SE592 :hasReference :R022 .
:SE592 :hasPattern :NotSpecified .
:SE592 :hasReference :R189 .
:SE592 :hasSideEffectDescription "Chest pain is discomfort or pain that you feel anywhere along the front of your body between your neck and upper abdomen." .

:SE593 :hasPattern :NotSpecified .
:SE593 :hasReference :R234 .
:SE593 :hasReference :R022 .
:SE593 :hasSideEffectDescription "Mouth ulcers are sores or open lesions in the mouth." .

:SE594 :hasReference :R022 .
:SE594 :hasSideEffectDescription "Anorexia is an eating disorder that causes people to weigh less than is considered healthy for their age and height, usually by excessive weight loss." .
:SE594 :hasPattern :NotSpecified .
:SE594 :hasReference :R132 .

:SE595 :hasPattern :NotSpecified .
:SE595 :hasReference :R278 .
:SE595 :hasSideEffectDescription "The Coombs test looks for antibodies that may stick to your red blood cells and cause red blood cells to die too early." .
:SE595 :hasReference :R022 .

:SE596 :hasPattern :NotSpecified .
:SE596 :hasSideEffectDescription "Hearing loss means hearing disorders make it hard, but not impossible, to hear." .
:SE596 :hasReference :R250 .
:SE596 :hasReference :R022 .

:SE597 :hasSideEffectDescription "Hypersensitivity pneumonitis is inflammation of the lungs due to breathing in dust, fungus, molds, or other substances." .
:SE597 :hasReference :R279 .
:SE597 :hasReference :R022 .
:SE597 :hasPattern :NotSpecified .

:SE598 :hasSideEffectDescription "Glossitis is a problem in which the tongue is swollen and inflammed. This often makes the surface of the tongue appear smooth." .
:SE598 :hasReference :R022 .
:SE598 :hasPattern :NotSpecified .
:SE598 :hasReference :R135 .

:SE599 :hasSideEffectDescription "Arthralgia is an alternative name of joint pain. It can affect one or more joints. Joint pain can be caused by many types of injuries or conditions. It may be linked to arthritis, bursitis, and muscle pain." .
:SE599 :hasReference :R191 .
:SE599 :hasPattern :NotSpecified .
:SE599 :hasReference :R022 .

