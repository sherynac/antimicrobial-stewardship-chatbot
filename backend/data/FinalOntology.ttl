# Severity are all different from each other
:Mild owl:differentFrom :MildToModerate, :Moderate, :NotSpecified, :Severe .
:MildToModerate owl:differentFrom :Mild, :Moderate, :NotSpecified, :Severe .
:Moderate owl:differentFrom :Mild, :MildToModerate, :NotSpecified, :Severe .
:NotSpecified owl:differentFrom :Mild, :MildToModerate, :Moderate, :Severe .
:Severe owl:differentFrom :Mild, :MildToModerate, :Moderate, :NotSpecified .

# End of differentFrom Assertions for Key Instances


##############################################################
# OWL Restrictions (Cardinality and Value Constraints)
##############################################################

# Presentation must have at least one Brand
:Presentation rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :isPresentationOf ;
    owl:minQualifiedCardinality 1 ;
    owl:onClass :Brand
] .

# SideEffect must have at least one source (Brand, Presentation, or Antibiotic)
:SideEffect rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :sideEffectOf ;
    owl:minCardinality 1
] .

# SideEffect must have a description
:SideEffect rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :hasSideEffectDescription ;
    owl:minCardinality 1
] .

# SideEffect must have a duration
:SideEffect rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :hasDurationOf ;
    owl:minCardinality 1
] .

# SideEffect must have a pattern
:SideEffect rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :hasPattern ;
    owl:minQualifiedCardinality 1 ;
    owl:onClass :Pattern
] .

# End of OWL Restrictions (Cardinality and Value Constraints)


