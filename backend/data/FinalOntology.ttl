:SE590 :hasReference :R240 .
:SE590 :hasPattern :NotSpecified .

:SE591 :hasSideEffectDescription "Chills refers to feeling cold after being in a cold environment. The word can also refer to an episode of shivering along with paleness and feeling cold." .
