    rdfs:label "Oral Suspension (60 mL)" .

:OralSuspension70ML rdf:type owl:Class ;
    rdfs:subClassOf :Presentation ;
    rdfs:label "Oral Suspension (70 mL)" .

:PowderForInjection rdf:type owl:Class ;
    rdfs:subClassOf :Presentation ;
    rdfs:label "Powder for Injection" .

:PowderForInjection10ML rdf:type owl:Class ;
    rdfs:subClassOf :Presentation ;
