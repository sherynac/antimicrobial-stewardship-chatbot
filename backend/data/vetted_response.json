{
  "IntentDefinitions": [
    {
      "intent": "GET_ANTIBIOTIC_INFO",
      "description": "Get brands and their presentations for an antibiotic",
      "responses": [
        {
          "responseID": 1,
          "condition": "generic_only",
          "responseText": "{generic} (a {drug_class})is available in the following brands and forms: ",
          "targetNodes": ["generic", "drug_class"]
        },
        {
          "responseID": 2,
          "condition": "brand_only",
          "responseText": "{brand} (generic: {generic}) comes in {presentation}. Other brands include {other_brands}.",
          "targetNodes": ["brand", "generic", "presentation", "other_brands"]
        },
        {
          "responseID": 3,
          "condition": "presentation_only_query",
          "responseText": "{brand} comes in {presentation}.",
          "targetNodes": ["brand", "presentation"]
        },
        {
          "responseID": 4,
          "condition": "both_generic_and_brand",
          "responseText": "{is_brand_of}, {brand} is a brand of {generic}. It comes in {presentation}.",
          "targetNodes" : ["is_brand_of", "brand", "generic", "presentation"]
        }
      ]
    }
  ]
}